+                        </label>
+                        {place.media ? <button type="button" className="button secondary" onClick={() => updatePlace(index, { media: null })}>Remove image</button> : null}
+                      </div>
+                    </article>
+                  );
+                })}
+              </div>
+              <button type="button" className="button secondary full" onClick={addPlace}>+ Add another place</button>
+            </section>
+
+            <section className="mobile-card trade-create-preview trade-create-preview--deck plan-create-preview">
+              <div>
+                <p className="eyebrow">Feed preview</p>
