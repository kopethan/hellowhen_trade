+'use client';
+
+import Link from 'next/link';
+import { useRouter } from 'next/navigation';
+import type { CreatePlanPlaceRequest, CreatePlanRequest, MediaAssetDto, PlanDto, PlanPlaceDto, UpdatePlanPlaceRequest, UpdatePlanRequest } from '@hellowhen/contracts';
+import type { FormEvent } from 'react';
+import { useEffect, useMemo, useState } from 'react';
+import { api } from '../../lib/api';
+import { getFriendlyApiErrorMessage } from '../../lib/webErrors';
+import { useWebAuth } from '../../providers/WebAuthProvider';
+import { PlanDeck } from './PlanDeck';
+import { PlansFeatureGate, PlansInternalBadge } from './PlansFeatureGate';
+import { planMediaSrc } from './plansPresentation';
+
+type PlaceMode = 'local' | 'remote';
+
+type PlaceForm = {
+  id?: string;
+  mode: PlaceMode;
+  date: string;
+  time: string;
+  title: string;
+  locationText: string;
+  note: string;
+  media: MediaAssetDto | null;
+};
+
+type PlanEditorClientProps = {
+  mode: 'create' | 'edit';
+  planId?: string;
+};
+
+function pad(value: number) {
+  return String(value).padStart(2, '0');
+}
+
+function dateInputValue(date: Date) {
+  return `${date.getFullYear()}-${pad(date.getMonth() + 1)}-${pad(date.getDate())}`;
+}
+
+function timeInputValue(date: Date) {
+  return `${pad(date.getHours())}:${pad(date.getMinutes())}`;
+}
+
+function isoFromDateAndTime(date: string, time: string) {
+  return new Date(`${date}T${time || '00:00'}`).toISOString();
+}
+
+function datetimeParts(value?: string | null, fallback?: string) {
+  const date = value ? new Date(value) : fallback ? new Date(fallback) : new Date(Date.now() + 24 * 60 * 60 * 1000);
+  if (Number.isNaN(date.getTime())) {
+    const next = new Date(Date.now() + 24 * 60 * 60 * 1000);
+    return { date: dateInputValue(next), time: '13:00' };
+  }
+  return { date: dateInputValue(date), time: timeInputValue(date) };
+}
+
+function defaultPlace(date = dateInputValue(new Date(Date.now() + 24 * 60 * 60 * 1000)), mode: PlaceMode = 'local'): PlaceForm {
+  return {
+    mode,
+    date,
+    time: '',
+    title: '',
+    locationText: '',
+    note: '',
+    media: null,
+  };
+}
+
+function normalizeUploadedMedia(response: unknown): MediaAssetDto | null {
+  const media = (response as { media?: MediaAssetDto; asset?: MediaAssetDto } | null)?.media ?? (response as { asset?: MediaAssetDto } | null)?.asset ?? null;
+  return media?.id ? media : null;
+}
+
+function placeToForm(place: PlanPlaceDto, plan: PlanDto): PlaceForm {
+  const parts = datetimeParts(place.startsAt, plan.startsAt);
+  const rawMode = ((place as any).mode ?? plan.mode) as string | null | undefined;
+  const mode: PlaceMode = rawMode === 'remote' ? 'remote' : 'local';
+  return {
+    id: place.id,
+    mode,
+    date: parts.date,
+    time: parts.time,
+    title: place.title ?? '',
+    locationText: place.addressPublicText ?? '',
+    note: place.note ?? '',
+    media: place.media?.[0] ?? null,
+  };
+}
+
+function buildPreviewPlan(values: { title: string; description: string; category: string; places: PlaceForm[] }, fallbackPlan?: PlanDto | null): PlanDto {
+  const datedPlaces = values.places.map((place, index) => {
+    const startsAt = place.date && place.time ? isoFromDateAndTime(place.date, place.time) : fallbackPlan?.startsAt ?? new Date().toISOString();
+    return {
+      id: place.id ?? `preview-place-${index}`,
+      planId: fallbackPlan?.id ?? 'preview-plan',
+      order: index,
+      title: place.title.trim() || `Place ${index + 1}`,
+      note: place.note.trim() || null,
+      addressPublicText: place.locationText.trim() || null,
+      startsAt,
+      endsAt: null,
+      createdAt: new Date().toISOString(),
+      updatedAt: new Date().toISOString(),
+      mode: place.mode,
+      media: place.media ? [place.media] : [],
+    } as PlanPlaceDto;
+  });
+  const startsAt = datedPlaces[0]?.startsAt ?? fallbackPlan?.startsAt ?? new Date().toISOString();
+  const endsAt = datedPlaces[datedPlaces.length - 1]?.startsAt ?? startsAt;
+  return {
+    id: fallbackPlan?.id ?? 'preview-plan',
+    ownerId: fallbackPlan?.ownerId ?? 'preview-owner',
+    title: values.title.trim() || 'Plan title',
+    description: values.description.trim() || 'Add a short description so people understand the plan.',
+    category: values.category.trim() || null,
+    tags: fallbackPlan?.tags ?? [],
+    mode: null,
+    locationLabel: null,
+    startsAt,
+    endsAt,
+    maxParticipants: null,
+    joinApprovalMode: 'automatic',
+    status: 'open',
+    createdAt: fallbackPlan?.createdAt ?? new Date().toISOString(),
+    updatedAt: new Date().toISOString(),
+    cancelledAt: null,
+    owner: fallbackPlan?.owner ?? null,
+    places: datedPlaces,
+    media: [],
+    participants: fallbackPlan?.participants ?? [],
+    participantCount: fallbackPlan?.participantCount ?? 0,
+    pendingRequestCount: 0,
+    myParticipantStatus: fallbackPlan?.myParticipantStatus ?? null,
+    canSeePrivatePlaceDetails: fallbackPlan?.canSeePrivatePlaceDetails ?? false,
+  } as PlanDto;
+}
+
+export function PlanEditorClient({ mode, planId }: PlanEditorClientProps) {
+  const router = useRouter();
+  const auth = useWebAuth();
+  const tomorrow = useMemo(() => dateInputValue(new Date(Date.now() + 24 * 60 * 60 * 1000)), []);
+  const [loadedPlan, setLoadedPlan] = useState<PlanDto | null>(null);
+  const [title, setTitle] = useState('');
+  const [description, setDescription] = useState('');
+  const [category, setCategory] = useState('');
+  const [places, setPlaces] = useState<PlaceForm[]>(() => [defaultPlace(tomorrow)]);
+  const [loading, setLoading] = useState(mode === 'edit');
+  const [saving, setSaving] = useState(false);
+  const [uploadingIndex, setUploadingIndex] = useState<number | null>(null);
+  const [message, setMessage] = useState('');
+  const [error, setError] = useState('');
+
+  useEffect(() => {
+    if (mode !== 'edit' || !planId || !auth.hydrated) return;
+    let mounted = true;
+    async function loadPlan() {
+      setLoading(true);
+      setError('');
+      try {
+        if (!auth.isAuthenticated) throw new Error('signed_out_plan_editor');
+        const response = await api.plans.get(planId!);
+        if (!mounted) return;
+        const plan = response.plan;
+        setLoadedPlan(plan);
+        setTitle(plan.title ?? '');
+        setDescription(plan.description ?? '');
+        setCategory(plan.category ?? '');
+        setPlaces((plan.places?.length ? plan.places : []).map((place) => placeToForm(place, plan)));
+      } catch (loadError) {
+        if (!mounted) return;
+        setError(getFriendlyApiErrorMessage(loadError, 'Could not load Plan.'));
+      } finally {
+        if (mounted) setLoading(false);
+      }
+    }
+    void loadPlan();
+    return () => { mounted = false; };
+  }, [auth.hydrated, auth.isAuthenticated, mode, planId]);
+
+  useEffect(() => {
+    if (places.length === 0) setPlaces([defaultPlace(tomorrow)]);
+  }, [places.length, tomorrow]);
+
+  const previewPlan = useMemo(() => buildPreviewPlan({ title, description, category, places }, loadedPlan), [category, description, loadedPlan, places, title]);
+  const canSubmit = auth.hydrated && auth.isAuthenticated && !loading;
+
+  function updatePlace(index: number, patch: Partial<PlaceForm>) {
+    setPlaces((current) => current.map((place, itemIndex) => itemIndex === index ? { ...place, ...patch } : place));
+  }
+
+  function addPlace() {
+    setPlaces((current) => {
+      const previous = current[current.length - 1];
+      return [...current, defaultPlace(previous?.date ?? tomorrow, previous?.mode ?? 'local')];
+    });
+  }
+
+  function movePlace(index: number, direction: -1 | 1) {
+    setPlaces((current) => {
+      const target = index + direction;
+      if (target < 0 || target >= current.length) return current;
+      const next = [...current];
+      const [item] = next.splice(index, 1);
+      if (!item) return current;
+      next.splice(target, 0, item);
+      return next;
+    });
+  }
+
+  function removeUnsavedPlace(index: number) {
+    setPlaces((current) => {
+      const item = current[index];
+      if (!item || item.id || current.length <= 1) return current;
+      return current.filter((_, itemIndex) => itemIndex !== index);
+    });
+  }
+
+  async function uploadPlaceImage(index: number, files: FileList | null) {
+    const file = files?.[0];
+    if (!file) return;
+    setUploadingIndex(index);
+    setError('');
+    setMessage('');
+    try {
+      const formData = new FormData();
+      formData.append('image', file);
+      const response = await api.media.uploadImage(formData);
+      const media = normalizeUploadedMedia(response);
+      if (!media) throw new Error('Upload succeeded but no media was returned.');
+      updatePlace(index, { media });
+      setMessage('Place image uploaded.');
+    } catch (uploadError) {
+      setError(getFriendlyApiErrorMessage(uploadError, 'Could not upload image.'));
+    } finally {
+      setUploadingIndex(null);
+    }
+  }
+
+  function validate() {
+    const cleanTitle = title.trim();
+    const cleanDescription = description.trim();
+    if (cleanTitle.length < 3) return 'Plan title must be at least 3 characters.';
+    if (cleanDescription.length < 10) return 'Plan description must be at least 10 characters.';
+    if (!places.length) return 'Add at least one place.';
+
+    const datetimes: number[] = [];
+    for (const [index, place] of places.entries()) {
+      if (!place.date) return `Choose a date for place ${index + 1}.`;
+      if (!place.time) return `Choose a time for place ${index + 1}.`;
+      if (place.title.trim().length < 3) return `Place ${index + 1} needs a name.`;
+      if (place.locationText.trim().length < 3) return place.mode === 'remote' ? `Place ${index + 1} needs an online link or instruction.` : `Place ${index + 1} needs an address or meeting point.`;
+      const time = new Date(isoFromDateAndTime(place.date, place.time)).getTime();
+      if (!Number.isFinite(time)) return `Place ${index + 1} date/time is invalid.`;
+      datetimes.push(time);
+    }
+
+    for (let index = 1; index < datetimes.length; index += 1) {
+      if ((datetimes[index] ?? 0) < (datetimes[index - 1] ?? 0)) {
+        return `Place ${index + 1} must be at the same time or after place ${index}.`;
+      }
+    }
+    return '';
+  }
+
+  function toPlacePayload(place: PlaceForm, order: number): CreatePlanPlaceRequest | UpdatePlanPlaceRequest {
+    return {
+      title: place.title.trim(),
+      note: place.note.trim() || undefined,
+      addressPublicText: place.locationText.trim() || undefined,
+      startsAt: isoFromDateAndTime(place.date, place.time),
+      order,
+      mode: place.mode,
+      mediaIds: place.media?.id ? [place.media.id] : [],
+    } as CreatePlanPlaceRequest | UpdatePlanPlaceRequest;
+  }
+
+  async function submit(event: FormEvent<HTMLFormElement>) {
+    event.preventDefault();
+    if (!auth.isAuthenticated) {
+      router.push(`/auth?next=${mode === 'edit' && planId ? `/plans/${planId}/edit` : '/plans/new'}`);
+      return;
+    }
+    const validationError = validate();
+    if (validationError) {
+      setError(validationError);
+      return;
+    }
+    setSaving(true);
+    setError('');
+    setMessage('');
+    try {
+      const firstStartsAt = isoFromDateAndTime(places[0]!.date, places[0]!.time);
+      const lastStartsAt = isoFromDateAndTime(places[places.length - 1]!.date, places[places.length - 1]!.time);
+      const basePayload = {
+        title: title.trim(),
+        description: description.trim(),
+        category: category.trim() || undefined,
+        mode: null,
+        locationLabel: null,
+        startsAt: firstStartsAt,
+        endsAt: lastStartsAt,
+        maxParticipants: null,
+        joinApprovalMode: 'automatic',
+        status: 'open',
+      };
+
+      if (mode === 'edit' && planId) {
+        await api.plans.update(planId, basePayload as UpdatePlanRequest);
+        for (const [index, place] of places.entries()) {
+          const payload = toPlacePayload(place, index);
+          if (place.id) await api.plans.updatePlace(planId, place.id, payload as UpdatePlanPlaceRequest);
+          else await api.plans.createPlace(planId, payload as CreatePlanPlaceRequest);
+        }
+        router.replace(`/plans/${planId}`);
+        return;
+      }
+
+      const createPayload: CreatePlanRequest = {
+        ...basePayload,
+        category: category.trim() || undefined,
+        mode: undefined,
+        locationLabel: undefined,
+        maxParticipants: undefined,
+        places: places.map((place, index) => toPlacePayload(place, index) as CreatePlanPlaceRequest),
+      } as CreatePlanRequest;
+      const response = await api.plans.create(createPayload);
+      router.replace(`/plans/${response.plan.id}`);
+    } catch (saveError) {
+      setError(getFriendlyApiErrorMessage(saveError, mode === 'edit' ? 'Could not save Plan.' : 'Could not create Plan.'));
+    } finally {
+      setSaving(false);
+    }
+  }
+
+  return (
+    <PlansFeatureGate>
+      <main className="mobile-page plans-page">
+        <section className="page-intro">
+          <div>
+            <PlansInternalBadge />
+            <h2>{mode === 'edit' ? 'Edit Plan' : 'Create Plan'}</h2>
+            <p>Build a hidden Plan from place cards. Each place can be Local or Remote and has its own date, time, and image.</p>
+          </div>
+          <Link className="button secondary page-intro__action" href={mode === 'edit' && planId ? `/plans/${planId}` : '/plans'}>{mode === 'edit' ? 'Plan' : 'Plans'}</Link>
+        </section>
+
+        {!auth.hydrated || loading ? <section className="mobile-card"><p className="meta">Loading...</p></section> : null}
+        {auth.hydrated && !auth.isAuthenticated ? (
+          <section className="mobile-card mobile-card--soft">
+            <h3>Log in required</h3>
+            <p>Use a demo or internal account to create hidden Plans.</p>
+            <button type="button" className="button primary" onClick={() => router.push(`/auth?next=${mode === 'edit' && planId ? `/plans/${planId}/edit` : '/plans/new'}`)}>Log in</button>
+          </section>
+        ) : null}
+
+        {canSubmit ? (
+          <form className="mobile-list" onSubmit={submit}>
+            <section className="mobile-card plan-form plan-editor__section">
+              <label>
+                <span>Plan title</span>
+                <input value={title} onChange={(event) => setTitle(event.target.value)} minLength={3} maxLength={120} required placeholder="Saturday photo walk" />
+              </label>
+              <label>
+                <span>Description</span>
+                <textarea value={description} onChange={(event) => setDescription(event.target.value)} minLength={10} maxLength={2000} required placeholder="Explain the full plan and who should join." />
+              </label>
+              <label>
+                <span>Category</span>
+                <input value={category} onChange={(event) => setCategory(event.target.value)} maxLength={80} placeholder="Culture, coffee, study, sport..." />
+              </label>
+            </section>
+
+            <section className="mobile-card plan-form plan-editor__section">
+              <div className="plan-editor__section-heading">
+                <div>
+                  <p className="eyebrow">Places</p>
+                  <h3>Build the route</h3>
+                  <p className="meta">Add each stop as a square card. New places copy the previous date, but you control every date and time.</p>
+                </div>
+                <button type="button" className="button secondary" onClick={addPlace}>+ Add place</button>
+              </div>
+
+              <div className="mobile-list">
+                {places.map((place, index) => {
+                  const modeLabel = place.mode === 'remote' ? 'Link or online location' : 'Address or meeting point';
+                  const imageSrc = planMediaSrc(place.media);
+                  return (
+                    <article key={place.id ?? `new-${index}`} className="plan-place-editor-card">
+                      <div className="plan-place-editor-card__top">
+                        <span className="semantic-badge instruction">Place {index + 1}</span>
+                        <div className="cta-row">
+                          <button type="button" className="button secondary" onClick={() => movePlace(index, -1)} disabled={index === 0}>Up</button>
+                          <button type="button" className="button secondary" onClick={() => movePlace(index, 1)} disabled={index === places.length - 1}>Down</button>
+                          {!place.id && places.length > 1 ? <button type="button" className="button secondary" onClick={() => removeUnsavedPlace(index)}>Remove</button> : null}
+                        </div>
+                      </div>
+
+                      <div className="segmented-control" role="group" aria-label={`Place ${index + 1} type`}>
+                        <button type="button" className={place.mode === 'local' ? 'is-active' : ''} onClick={() => updatePlace(index, { mode: 'local' })}>Local</button>
+                        <button type="button" className={place.mode === 'remote' ? 'is-active' : ''} onClick={() => updatePlace(index, { mode: 'remote' })}>Remote</button>
+                      </div>
+
+                      <div className="plan-form__row">
+                        <label>
+                          <span>Date</span>
+                          <input type="date" value={place.date} onChange={(event) => updatePlace(index, { date: event.target.value })} required />
+                        </label>
+                        <label>
+                          <span>Time</span>
+                          <input type="time" value={place.time} onChange={(event) => updatePlace(index, { time: event.target.value })} required />
+                        </label>
+                      </div>
+
+                      <label>
+                        <span>Place name</span>
+                        <input value={place.title} onChange={(event) => updatePlace(index, { title: event.target.value })} required minLength={3} maxLength={120} placeholder={place.mode === 'remote' ? 'Planning call' : 'Coffee near République'} />
+                      </label>
+                      <label>
+                        <span>{modeLabel}</span>
+                        <input value={place.locationText} onChange={(event) => updatePlace(index, { locationText: event.target.value })} required minLength={3} maxLength={160} placeholder={place.mode === 'remote' ? 'Zoom, Meet, Discord, website, or instructions' : 'Search or enter an address'} />
+                      </label>
+                      <label>
+                        <span>Notes / purpose</span>
+                        <textarea value={place.note} onChange={(event) => updatePlace(index, { note: event.target.value })} maxLength={1000} placeholder="What will happen at this stop?" />
+                      </label>
+
+                      <div className="plan-place-image-picker">
+                        <div className="plan-place-image-picker__preview" aria-hidden="true">
+                          {imageSrc ? <img src={imageSrc} alt="" loading="lazy" /> : <span>1 image</span>}
+                        </div>
+                        <label className="image-upload-button">
+                          <input type="file" accept="image/jpeg,image/png,image/webp" onChange={(event) => uploadPlaceImage(index, event.target.files)} disabled={uploadingIndex !== null} />
