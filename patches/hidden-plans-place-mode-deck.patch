+                <p className="meta">Card 1 summarizes the Plan. Each place becomes one square card after it.</p>
+              </div>
+              <div className="trade-create-preview__deck">
+                <PlanDeck plan={previewPlan} preview className="trade-stack-deck--create-preview" />
+              </div>
+            </section>
+
+            {message ? <p className="success-message">{message}</p> : null}
+            {error ? <p className="form-error">{error}</p> : null}
+            <div className="sticky-form-actions">
+              <Link className="button secondary" href={mode === 'edit' && planId ? `/plans/${planId}` : '/plans'}>Cancel</Link>
+              <button className="button primary" type="submit" disabled={saving || uploadingIndex !== null}>{saving ? 'Saving...' : mode === 'edit' ? 'Save Plan' : 'Create hidden Plan'}</button>
+            </div>
+          </form>
+        ) : null}
+      </main>
+    </PlansFeatureGate>
+  );
+}
