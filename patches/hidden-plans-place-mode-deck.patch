diff --git a/apps/web/src/features/plans/PlanDeck.tsx b/apps/web/src/features/plans/PlanDeck.tsx
new file mode 100644
index 0000000..2bc9459
--- /dev/null
+++ b/apps/web/src/features/plans/PlanDeck.tsx
@@ -0,0 +1,102 @@
+'use client';
+
+import { useMemo } from 'react';
+import { useRouter } from 'next/navigation';
+import type { PlanDto, PlanPlaceDto } from '@hellowhen/contracts';
+import { SquareStackDeck, type SquareStackDeckItem } from '../deck/SquareStackDeck';
+import { TradePosterCard } from '../trade/TradePosterCard';
+import { compactPlanLocation, planMediaSrc, planModeLabel, planOwnerName, planRangeLabel, shortPlanDateTime } from './plansPresentation';
+
+type PlanDeckProps = {
+  plan: PlanDto;
+  className?: string;
+  preview?: boolean;
+  onOpen?: () => void;
+};
+
+function cardCountLabel(totalCards: number) {
+  return `01/${String(Math.max(totalCards, 1)).padStart(2, '0')}`;
+}
+
+function summaryChips(plan: PlanDto) {
+  return [
+    `${plan.places?.length ?? 0} place${(plan.places?.length ?? 0) === 1 ? '' : 's'}`,
+    plan.category ?? '',
+  ].filter(Boolean).slice(0, 3);
+}
+
+function placeBadge(place: PlanPlaceDto, index: number, total: number) {
+  return `${shortPlanDateTime(place.startsAt)} · ${String(index + 1).padStart(2, '0')}/${String(Math.max(total, 1)).padStart(2, '0')}`;
+}
+
+function placeSubtitle(place: PlanPlaceDto) {
+  return compactPlanLocation(place.addressPublicText) || place.note || '';
+}
+
+export function buildPlanDeckItems(plan: PlanDto, actionLabel = 'Open'): SquareStackDeckItem[] {
+  const places = [...(plan.places ?? [])].sort((left, right) => {
+    const orderDiff = (left.order ?? 0) - (right.order ?? 0);
+    if (orderDiff !== 0) return orderDiff;
+    return new Date(left.startsAt ?? plan.startsAt).getTime() - new Date(right.startsAt ?? plan.startsAt).getTime();
+  });
+  const totalCards = places.length + 1;
+  const firstPlaceImage = places.find((place) => place.media?.[0])?.media?.[0] ?? null;
+
+  const summary: SquareStackDeckItem = {
+    id: `${plan.id}-summary`,
+    ariaLabel: `${actionLabel} ${plan.title}`,
+    content: (
+      <TradePosterCard
+        id={`${plan.id}-summary`}
+        imageUrl={planMediaSrc(firstPlaceImage)}
+        imageAlt={plan.title}
+        badge={`PLAN · ${cardCountLabel(totalCards)}`}
+        eyebrow={planOwnerName(plan)}
+        title={plan.title}
+        subtitle={plan.description}
+        chips={[planRangeLabel(plan), ...summaryChips(plan)].filter(Boolean).slice(0, 3)}
+        variant="trade"
+      />
+    ),
+  };
+
+  const placeItems = places.map((place, index): SquareStackDeckItem => {
+    const image = place.media?.[0] ?? null;
+    const modeLabel = planModeLabel((place as any).mode ?? plan.mode);
+    return {
+      id: `${plan.id}-place-${place.id ?? index}`,
+      ariaLabel: `${actionLabel} ${plan.title}: ${place.title}`,
+      content: (
+        <TradePosterCard
+          id={`${plan.id}-${place.id ?? index}`}
+          imageUrl={planMediaSrc(image)}
+          imageAlt={place.title}
+          badge={placeBadge(place, index, places.length)}
+          eyebrow={modeLabel || `Place ${index + 1}`}
+          title={plan.title}
+          subtitle={[place.title, placeSubtitle(place)].filter(Boolean).join(' · ')}
+          chips={[modeLabel, place.note ?? ''].filter(Boolean).slice(0, 3)}
+          variant="trade"
+        />
+      ),
+    };
+  });
+
+  return [summary, ...placeItems];
+}
+
+export function PlanDeck({ plan, className, preview = false, onOpen }: PlanDeckProps) {
+  const router = useRouter();
+  const items = useMemo(() => buildPlanDeckItems(plan, preview ? 'Preview' : 'Open'), [plan, preview]);
+  const deckClassName = ['plan-stack-deck', 'trade-stack-deck', preview ? 'trade-stack-deck--preview' : null, className].filter(Boolean).join(' ');
+
+  return (
+    <SquareStackDeck
+      className={deckClassName}
+      items={items}
+      label={plan.title}
+      onOpen={preview ? undefined : onOpen ?? (() => router.push(`/plans/${plan.id}`))}
+      lockScrollWithinDeck={preview}
+    />
+  );
+}
