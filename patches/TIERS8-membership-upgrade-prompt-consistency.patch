diff --git a/apps/web/src/app/globals.css b/apps/web/src/app/globals.css
index df848ef..d41aa98 100644
--- a/apps/web/src/app/globals.css
+++ b/apps/web/src/app/globals.css
@@ -8314,3 +8314,24 @@ html[data-theme="dark"] .onboarding-guide-primary {
   .add-to-agenda-sheet__time-grid, .add-to-agenda-sheet__actions { grid-template-columns: 1fr; }
   .add-to-agenda-sheet__panel { border-radius: 28px 28px 22px 22px; }
 }
+
+/* Shared Membership upgrade prompts. */
+.membership-upgrade-card { display: grid; grid-template-columns: auto minmax(0, 1fr) auto; gap: 13px; align-items: center; border: 1px solid color-mix(in srgb, var(--success-border) 48%, var(--app-border)); border-radius: 26px; background: linear-gradient(135deg, color-mix(in srgb, var(--success-bg) 16%, var(--app-surface)), var(--app-surface)); padding: 16px; box-shadow: var(--app-card-shadow); }
+.membership-upgrade-card--compact { border-radius: 22px; padding: 13px; }
+.membership-upgrade-card--disabled { border-color: color-mix(in srgb, var(--app-border) 74%, transparent); background: color-mix(in srgb, var(--app-surface) 88%, var(--app-surface-soft)); }
+.membership-upgrade-card__icon { display: grid; place-items: center; width: 44px; height: 44px; border: 1px solid color-mix(in srgb, var(--success-border) 40%, var(--app-border)); border-radius: 17px; background: var(--app-surface); color: var(--app-text); box-shadow: var(--app-control-shadow); }
+.membership-upgrade-card--compact .membership-upgrade-card__icon { width: 38px; height: 38px; border-radius: 15px; }
+.membership-upgrade-card--disabled .membership-upgrade-card__icon { border-color: var(--app-border); color: var(--app-text-muted); }
+.membership-upgrade-card__body { display: grid; gap: 5px; min-width: 0; }
+.membership-upgrade-card__body h3, .membership-upgrade-card__body p { margin: 0; }
+.membership-upgrade-card__body h3 { color: var(--app-text); font-size: 16px; font-weight: 950; letter-spacing: -0.015em; }
+.membership-upgrade-card__body p, .membership-upgrade-card__action span { color: var(--app-text-muted); font-size: 12px; font-weight: 850; line-height: 1.45; }
+.membership-upgrade-card__body code { display: block; width: fit-content; max-width: 100%; overflow-x: auto; border: 1px solid var(--app-border); border-radius: 14px; background: var(--app-surface-soft); color: var(--app-text-muted); padding: 8px 10px; font-size: 12px; font-weight: 850; }
+.membership-upgrade-card__action { display: flex; justify-content: flex-end; min-width: max-content; }
+.saved-toggle-upgrade-prompt { display: inline-grid; gap: 6px; }
+.saved-toggle-upgrade-prompt a { color: var(--warning-text); font-weight: 950; text-decoration: underline; text-underline-offset: 2px; }
+@media (max-width: 760px) {
+  .membership-upgrade-card { grid-template-columns: auto minmax(0, 1fr); align-items: start; }
+  .membership-upgrade-card__action { grid-column: 1 / -1; justify-content: flex-start; min-width: 0; }
+  .membership-upgrade-card__action .button { width: 100%; }
+}
diff --git a/apps/web/src/components/MembershipUpgradeCard.tsx b/apps/web/src/components/MembershipUpgradeCard.tsx
new file mode 100644
index 0000000..51a7df2
--- /dev/null
+++ b/apps/web/src/components/MembershipUpgradeCard.tsx
@@ -0,0 +1,49 @@
+'use client';
+
+import Link from 'next/link';
+import { WebIcon, type WebIconName } from './WebIcon';
+
+type MembershipUpgradeCardProps = {
+  badge: string;
+  title: string;
+  body: string;
+  actionLabel: string;
+  comingSoonLabel: string;
+  href?: string;
+  icon?: WebIconName;
+  variant?: 'plus' | 'pro' | 'disabled';
+  compact?: boolean;
+  code?: string;
+};
+
+export function MembershipUpgradeCard({
+  badge,
+  title,
+  body,
+  actionLabel,
+  comingSoonLabel,
+  href = '/account/membership',
+  icon = 'profile',
+  variant = 'plus',
+  compact = false,
+  code,
+}: MembershipUpgradeCardProps) {
+  const canOpenMembership = Boolean(href);
+
+  return (
+    <section className={`membership-upgrade-card membership-upgrade-card--${variant} ${compact ? 'membership-upgrade-card--compact' : ''}`.trim()}>
+      <span className="membership-upgrade-card__icon" aria-hidden="true">
+        <WebIcon name={icon} size={compact ? 18 : 22} decorative />
+      </span>
+      <div className="membership-upgrade-card__body">
+        <span className={`semantic-badge ${variant === 'disabled' ? 'instruction' : 'success'}`}>{badge}</span>
+        <h3>{title}</h3>
+        <p>{body}</p>
+        {code ? <code>{code}</code> : null}
+      </div>
+      <div className="membership-upgrade-card__action">
+        {canOpenMembership ? <Link href={href} className="button primary">{actionLabel}</Link> : <span>{comingSoonLabel}</span>}
+      </div>
+    </section>
+  );
+}
