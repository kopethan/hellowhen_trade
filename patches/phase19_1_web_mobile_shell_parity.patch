+
 * { box-sizing: border-box; }
-body { margin: 0; background: #F8FAFC; }
+html, body { min-height: 100%; }
+body { margin: 0; background: var(--app-bg-muted); color: var(--app-text); }
 a { color: inherit; text-decoration: none; }
-.shell { max-width: 1120px; margin: 0 auto; padding: 24px; }
-.nav { display: flex; align-items: center; justify-content: space-between; gap: 16px; margin-bottom: 24px; }
-.brand { display: flex; align-items: center; gap: 10px; font-weight: 900; }
-.brand-mark { display: inline-grid; place-items: center; width: 36px; height: 36px; border-radius: 999px; background: #14B8A6; color: white; }
-.nav-links { display: flex; flex-wrap: wrap; gap: 12px; color: #475569; font-weight: 800; }
-.card { border: 1px solid #E2E8F0; border-radius: 24px; background: #FFFFFF; padding: 24px; box-shadow: 0 14px 40px rgba(15, 23, 42, 0.06); }
-.hero { display: grid; grid-template-columns: 1.2fr 0.8fr; gap: 18px; }
-.grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 16px; }
-.button { display: inline-flex; align-items: center; justify-content: center; min-height: 42px; border-radius: 14px; border: 1px solid #CBD5E1; padding: 0 14px; font-weight: 900; background: white; }
-.button.primary { background: #111827; border-color: #111827; color: white; }
+p { color: var(--app-text-muted); line-height: 1.55; }
+h1, h2, h3, p { margin-top: 0; }
+h1 { font-size: 30px; line-height: 1.05; letter-spacing: -0.05em; margin-bottom: 0; }
+h2 { font-size: 24px; line-height: 1.1; letter-spacing: -0.04em; margin-bottom: 10px; }
+h3 { font-size: 17px; line-height: 1.2; letter-spacing: -0.02em; margin-bottom: 6px; }
+
+.web-app-viewport { min-height: 100dvh; display: grid; place-items: center; padding: 0; }
+.web-app-shell { position: relative; width: min(100vw, var(--app-shell-width)); height: 100dvh; min-height: 100dvh; overflow: hidden; background: var(--app-bg); box-shadow: var(--app-shadow); }
+.web-top-header { position: fixed; z-index: 20; top: 0; left: 50%; width: min(100vw, var(--app-shell-width)); min-height: var(--app-header-height); display: flex; align-items: flex-end; gap: 12px; padding: calc(12px + env(safe-area-inset-top)) 18px 14px; transform: translateX(-50%); background: color-mix(in srgb, var(--app-bg) 90%, transparent); border-bottom: 1px solid color-mix(in srgb, var(--app-border) 80%, transparent); backdrop-filter: blur(18px); }
+.web-top-header--root { justify-content: space-between; }
+.web-top-header--nested { align-items: center; padding-bottom: 12px; }
+.web-top-header--nested h1 { font-size: 22px; letter-spacing: -0.04em; }
+.web-kicker { margin: 0 0 4px; color: var(--app-text-soft); font-size: 11px; font-weight: 900; letter-spacing: 0.12em; line-height: 1; text-transform: uppercase; }
+.web-back-button { display: inline-grid; place-items: center; flex: 0 0 auto; width: 42px; height: 42px; border: 1px solid var(--app-border); border-radius: 999px; background: var(--app-surface); color: var(--app-text); font-size: 32px; font-weight: 600; line-height: 1; box-shadow: 0 8px 24px rgba(15, 23, 42, 0.08); }
+.web-scroll-area { height: 100%; overflow-y: auto; padding: calc(var(--app-header-height) + 16px) 16px calc(var(--app-tab-height) + 22px + env(safe-area-inset-bottom)); scrollbar-width: none; }
+.web-scroll-area::-webkit-scrollbar { display: none; }
+.web-bottom-tabs { position: fixed; z-index: 30; bottom: 0; left: 50%; width: min(100vw, var(--app-shell-width)); min-height: calc(var(--app-tab-height) + env(safe-area-inset-bottom)); display: grid; grid-template-columns: repeat(4, 1fr); gap: 4px; padding: 8px 10px calc(8px + env(safe-area-inset-bottom)); transform: translateX(-50%); background: color-mix(in srgb, var(--app-bg) 92%, transparent); border-top: 1px solid color-mix(in srgb, var(--app-border) 85%, transparent); backdrop-filter: blur(18px); }
+.web-tab { display: grid; place-items: center; gap: 3px; min-width: 0; border-radius: 18px; color: var(--app-text-muted); font-size: 11px; font-weight: 900; }
