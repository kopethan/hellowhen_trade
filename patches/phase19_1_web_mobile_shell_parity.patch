+import Link from 'next/link';
+import { MobilePage, PageIntro } from '../../components/MobilePage';
+
+const accountItems = [
+  { href: '/account/profile', title: 'Profile', body: 'Display name, handle, bio, and profile photo.' },
+  { href: '/account/wallet', title: 'Wallet', body: 'Available money, pending earnings, and demo top-up.' },
+  { href: '/account/payouts', title: 'Payouts', body: 'Demo payout requests and earnings summary.' },
+  { href: '/account/settings', title: 'Settings', body: 'Appearance, country, preferred currency, and account settings.' },
+  { href: '/account/support', title: 'Support', body: 'Create and follow support requests.' },
+];
+
+export default function AccountPage() {
+  return (
+    <MobilePage>
+      <PageIntro
+        eyebrow="Private"
+        title="Account"
+        body="Your profile, wallet, payouts, settings, and support live here."
+      />
+      <div className="mobile-list">
+        {accountItems.map((item) => (
+          <Link key={item.href} href={item.href} className="mobile-link-card">
+            <span>
+              <strong>{item.title}</strong>
+              <br />
+              {item.body}
+            </span>
+            <span className="mobile-link-card__arrow">›</span>
+          </Link>
+        ))}
+      </div>
+    </MobilePage>
+  );
+}
