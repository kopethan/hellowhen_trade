diff --git a/apps/web/src/app/globals.css b/apps/web/src/app/globals.css
index 4390877..fc7a996 100644
--- a/apps/web/src/app/globals.css
+++ b/apps/web/src/app/globals.css
@@ -4324,3 +4324,67 @@ html[data-theme="dark"] .onboarding-guide-primary {
 .inventory-wizard-card--idea .field-error {
   margin-top: -6px;
 }
+
+/* WIZARD29: web Need/Offer details step cleanup */
+.inventory-wizard-card--details {
+  gap: 13px;
+}
+
+.inventory-details-primary,
+.inventory-details-optional {
+  display: grid;
+  gap: 12px;
+}
+
+.inventory-details-toggle {
+  display: flex;
+  align-items: center;
+  justify-content: space-between;
+  gap: 12px;
+  width: 100%;
+  min-height: 46px;
+  border: 1px solid color-mix(in srgb, var(--app-border) 84%, transparent);
+  border-radius: 18px;
+  background: color-mix(in srgb, var(--app-bg-muted) 72%, transparent);
+  color: var(--app-text);
+  padding: 0 13px;
+  font: inherit;
+  cursor: pointer;
+}
+
+.inventory-details-toggle span {
+  font-size: 13px;
+  font-weight: 950;
+}
+
+.inventory-details-toggle strong {
+  color: var(--app-text-muted);
+  font-size: 11px;
+  font-weight: 950;
+  text-transform: uppercase;
+  letter-spacing: 0.06em;
+}
+
+.inventory-details-toggle[aria-expanded="true"] {
+  border-color: color-mix(in srgb, var(--proposal-border) 50%, var(--app-border));
+  background: color-mix(in srgb, var(--proposal-bg) 18%, var(--app-surface));
+}
+
+.inventory-details-optional {
+  border-top: 1px solid color-mix(in srgb, var(--app-border) 72%, transparent);
+  padding-top: 13px;
+}
+
+.inventory-details-optional textarea {
+  min-height: 104px;
+}
+
+@media (min-width: 620px) {
+  .inventory-details-primary {
+    grid-template-columns: repeat(2, minmax(0, 1fr));
+  }
+
+  .inventory-details-primary__wide {
+    grid-column: 1 / -1;
+  }
+}
