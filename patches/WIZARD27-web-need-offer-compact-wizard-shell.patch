diff --git a/apps/web/src/app/globals.css b/apps/web/src/app/globals.css
index 7bff4e5..32d581a 100644
--- a/apps/web/src/app/globals.css
+++ b/apps/web/src/app/globals.css
@@ -4256,3 +4256,52 @@ html[data-theme="dark"] .onboarding-guide-primary {
 .trade-side-source-trigger small { align-self: start; color: var(--app-text-muted); font-size: 12px; font-weight: 800; line-height: 1.35; }
 .trade-side-choice-card--link:focus-visible,
 .trade-side-source-trigger:focus-visible { outline: 3px solid color-mix(in srgb, var(--proposal-border) 72%, transparent); outline-offset: 3px; }
+
+/* WIZARD27: web Need/Offer compact wizard shell */
+.wizard-shell--inventory-create {
+  width: min(100%, 640px);
+  margin-right: auto;
+  margin-left: auto;
+}
+
+.wizard-shell--inventory-create .wizard-shell__step-intro p {
+  display: none;
+}
+
+.wizard-shell--inventory-create .wizard-shell__footer-wrap {
+  position: static;
+  z-index: auto;
+  bottom: auto;
+  margin: 2px 0 0;
+  padding: 0;
+  background: transparent;
+}
+
+.wizard-shell--inventory-create .wizard-footer {
+  border-radius: 22px;
+}
+
+.inventory-wizard-full-link {
+  white-space: nowrap;
+}
+
+@media (max-width: 520px) {
+  .wizard-shell--inventory-create {
+    width: 100%;
+  }
+
+  .wizard-shell--inventory-create .wizard-shell__footer-wrap {
+    margin-top: 4px;
+  }
+
+  .wizard-shell--inventory-create .wizard-footer {
+    padding: 12px 13px;
+  }
+
+  .inventory-wizard-full-link {
+    min-height: 38px;
+    padding-right: 11px;
+    padding-left: 11px;
+    font-size: 11px;
+  }
+}
