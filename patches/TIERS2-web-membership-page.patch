diff --git a/apps/web/src/features/account/MembershipClient.tsx b/apps/web/src/features/account/MembershipClient.tsx
new file mode 100644
index 0000000..ac95315
--- /dev/null
+++ b/apps/web/src/features/account/MembershipClient.tsx
@@ -0,0 +1,308 @@
+'use client';
+
+import Link from 'next/link';
+import { useEffect, useMemo, useState } from 'react';
+import type { PlusSubscriptionSnapshotResponse } from '@hellowhen/contracts';
+import {
+  ACCOUNT_IDENTITY_METADATA,
+  HANDLE_NAMESPACE_METADATA,
+  MEMBERSHIP_FEATURE_CATALOG,
+  PERSONAL_MEMBERSHIP_TIER_METADATA,
+  normalizePersonalMembershipTier,
+  normalizeSubscriptionStatus,
+  type AccountIdentityMetadata,
+  type MembershipFeatureAvailability,
+  type MembershipFeatureInclusion,
+  type MembershipFeatureKey,
+  type PersonalMembershipTier,
+  type PersonalMembershipTierMetadata,
+  type SubscriptionStatus,
+} from '@hellowhen/shared';
+import { api } from '../../lib/api';
+import { betaFeatures } from '../../lib/betaFeatures';
+import { useWebAuth } from '../../providers/WebAuthProvider';
+import { useWebTranslation } from '../../providers/WebI18nProvider';
+
+const personalCards = [
+  PERSONAL_MEMBERSHIP_TIER_METADATA.free,
+  PERSONAL_MEMBERSHIP_TIER_METADATA.plus,
+  PERSONAL_MEMBERSHIP_TIER_METADATA.pro,
+] as const;
+
+const featureLimit = 5;
+
+type MembershipCardAction = {
+  label: string;
+  href?: string;
+  disabled?: boolean;
+};
+
+function formatStatus(status: SubscriptionStatus) {
+  return status.replaceAll('_', ' ');
+}
+
+function availabilityTone(availability: MembershipFeatureAvailability) {
+  switch (availability) {
+    case 'included':
+      return 'success';
+    case 'limited':
+      return 'instruction';
+    case 'future':
+      return 'info';
+    case 'upgrade':
+    default:
+      return 'warning';
+  }
+}
+
+function featureLabel(key: MembershipFeatureKey) {
+  return MEMBERSHIP_FEATURE_CATALOG[key].shortLabel;
+}
+
+function FeatureList({ features }: { features: readonly MembershipFeatureInclusion[] }) {
+  const visibleFeatures = features.slice(0, featureLimit);
+  const extraCount = Math.max(features.length - visibleFeatures.length, 0);
+
+  return (
+    <ul className="membership-card__features">
+      {visibleFeatures.map((feature) => (
+        <li key={`${feature.key}-${feature.availability}`}>
+          <span className={`semantic-badge ${availabilityTone(feature.availability)}`}>{feature.availability}</span>
+          <span>
+            <strong>{featureLabel(feature.key)}</strong>
+            {feature.note ? <small>{feature.note}</small> : null}
+          </span>
+        </li>
+      ))}
+      {extraCount > 0 ? <li className="membership-card__feature-more">+{extraCount} more</li> : null}
+    </ul>
+  );
+}
+
+function CardAction({ action }: { action: MembershipCardAction }) {
+  if (action.href && !action.disabled) return <Link className="button full" href={action.href}>{action.label}</Link>;
+  return <button className="secondary full" type="button" disabled>{action.label}</button>;
+}
+
+function PersonalTierCard({
+  card,
+  currentTier,
+  currentStatus,
+  action,
+  statusLoaded,
+}: {
+  card: PersonalMembershipTierMetadata;
+  currentTier: PersonalMembershipTier;
+  currentStatus: SubscriptionStatus;
+  action: MembershipCardAction;
+  statusLoaded: boolean;
+}) {
+  const isCurrent = statusLoaded && card.tier === currentTier;
+  const currentIsActive = currentStatus === 'active' || currentStatus === 'trialing';
+  const badgeClass = card.tier === 'plus' ? 'success' : card.tier === 'pro' ? 'professional' : 'neutral';
+
+  return (
+    <article className={`membership-card ${card.featured ? 'is-featured' : ''}`.trim()}>
+      <div className="membership-card__header">
+        <div>
+          <span className={`semantic-badge ${badgeClass}`}>{card.badgeLabel}</span>
+          <h3>{card.displayName}</h3>
+          <p>{card.description}</p>
+        </div>
+        {isCurrent ? (
+          <span className={`semantic-badge ${currentIsActive ? 'success' : 'instruction'}`}>
+            {currentIsActive ? 'Your tier' : formatStatus(currentStatus)}
+          </span>
+        ) : null}
+      </div>
+      <FeatureList features={card.featureInclusions} />
+      <p className="membership-card__boundary">
+        {card.tier === 'free'
+          ? 'Free / Basic keeps core Need + Offer exchanges available.'
+          : card.tier === 'plus'
+            ? 'Plus is for private organization and assistance tools. It does not bypass safety or moderation.'
+            : 'Pro stays a personal membership tier for professional trust and package features.'}
+      </p>
+      <CardAction action={action} />
+    </article>
+  );
+}
+
+function BusinessIdentityCard({ card }: { card: AccountIdentityMetadata }) {
+  const namespace = HANDLE_NAMESPACE_METADATA[card.handleNamespace];
+  const action: MembershipCardAction = betaFeatures.businessAccountsVisible
+    ? { label: 'Open business area', href: '/account/business' }
+    : { label: 'Business identity is not public yet', disabled: true };
+
+  return (
+    <article className="membership-card membership-card--business">
+      <div className="membership-card__header">
+        <div>
+          <span className="semantic-badge business">{card.badgeLabel}</span>
+          <h3>{card.displayName}</h3>
+          <p>{card.description}</p>
+        </div>
+        <span className="semantic-badge info">Separate identity</span>
+      </div>
+      <div className="membership-namespace-grid" aria-label="Handle namespace examples">
+        <div>
+          <span>Personal namespace</span>
+          <strong>{HANDLE_NAMESPACE_METADATA.personal.examplePath}</strong>
+        </div>
+        <div>
+          <span>Organization namespace</span>
+          <strong>{namespace.examplePath}</strong>
+        </div>
+      </div>
+      <FeatureList features={card.featureInclusions} />
+      <p className="membership-card__boundary">
+        Business is not a personal tier. It uses a separate organization namespace so a personal handle like /u/apple does not block an official organization handle like /org/apple later.
+      </p>
+      {namespace.currentLegacyExamplePath ? (
+        <p className="membership-card__legacy-note">Current repo route note: business profiles may still use {namespace.currentLegacyExamplePath} until the future /org namespace is introduced.</p>
+      ) : null}
+      <CardAction action={action} />
+    </article>
+  );
+}
+
+export function MembershipClient() {
+  const auth = useWebAuth();
+  const { t } = useWebTranslation();
+  const [plusSnapshot, setPlusSnapshot] = useState<PlusSubscriptionSnapshotResponse | null>(null);
+  const [loadError, setLoadError] = useState(false);
+
+  useEffect(() => {
+    let mounted = true;
+    async function loadMembershipStatus() {
+      if (!auth.hydrated || !auth.isAuthenticated) {
+        if (mounted) {
+          setPlusSnapshot(null);
+          setLoadError(false);
+        }
+        return;
+      }
+      try {
+        const response = await api.plus.me();
+        if (mounted) {
+          setPlusSnapshot(response);
+          setLoadError(false);
+        }
+      } catch {
+        if (mounted) {
+          setPlusSnapshot(null);
+          setLoadError(true);
+        }
+      }
+    }
+    void loadMembershipStatus();
+    return () => { mounted = false; };
+  }, [auth.hydrated, auth.isAuthenticated]);
+
+  const statusLoaded = Boolean(plusSnapshot);
+  const currentTier = normalizePersonalMembershipTier(plusSnapshot?.state?.subscriptionTier);
+  const currentStatus = normalizeSubscriptionStatus(plusSnapshot?.state?.subscriptionStatus);
+
+  const actions = useMemo<Record<PersonalMembershipTier, MembershipCardAction>>(() => {
+    const loginHref = `/auth?next=${encodeURIComponent('/account/membership')}`;
+    if (!auth.isAuthenticated) {
+      return {
+        free: { label: 'Login or register', href: loginHref },
+        plus: { label: 'Login to view access', href: loginHref },
+        pro: { label: 'Login to view access', href: loginHref },
+      };
+    }
+
+    if (!statusLoaded && !loadError) {
+      return {
+        free: { label: 'Loading status…', disabled: true },
+        plus: { label: 'Loading status…', disabled: true },
+        pro: { label: 'Loading status…', disabled: true },
+      };
+    }
+
+    return {
+      free: { label: statusLoaded && currentTier === 'free' ? 'Current membership' : 'Included by default', disabled: true },
+      plus: { label: statusLoaded && currentTier === 'plus' ? 'Current membership' : 'Checkout not connected', disabled: true },
+      pro: { label: statusLoaded && currentTier === 'pro' ? 'Current membership' : 'Checkout not connected', disabled: true },
+    };
+  }, [auth.isAuthenticated, currentTier, loadError, statusLoaded]);
+
+  return (
+    <div className="membership-page">
+      <div className="page-intro">
+        <div>
+          <p className="eyebrow">Membership</p>
+          <h2>Membership</h2>
+          <p>Compare personal membership tiers and the separate Business / organization identity type.</p>
+        </div>
+        <div className="page-intro__action">
+          <Link href="/account" className="button secondary">Back to account</Link>
+        </div>
+      </div>
+
+      <section className="membership-hero-card">
+        <div className="membership-hero-card__icon" aria-hidden="true">★</div>
+        <div>
+          <span className="semantic-badge instruction">No checkout</span>
+          <h3>Display foundation only</h3>
+          <p>This page shows Free / Basic, Plus, Pro, and Business metadata without Stripe, Apple, Google, or any billing provider.</p>
+        </div>
+      </section>
+
+      {auth.hydrated && !auth.isAuthenticated ? (
+        <section className="mobile-card mobile-card--soft membership-status-card">
+          <span className="semantic-badge instruction">Signed out</span>
+          <h3>Login to compare against your account</h3>
+          <p>You can still read the membership structure here. Login to see which personal tier is attached to your account.</p>
+          <Link className="button primary" href={`/auth?next=${encodeURIComponent('/account/membership')}`}>{t('common.actions.loginOrRegister')}</Link>
+        </section>
+      ) : null}
+
+      {auth.isAuthenticated ? (
+        <section className="mobile-card mobile-card--soft membership-status-card">
+          <span className="semantic-badge info">Account status</span>
+          <h3>{plusSnapshot ? `${PERSONAL_MEMBERSHIP_TIER_METADATA[currentTier].displayName} · ${formatStatus(currentStatus)}` : loadError ? 'Membership status unavailable' : 'Loading membership status…'}</h3>
+          <p>{loadError ? 'Could not load the account membership snapshot. The comparison cards are still available.' : 'Membership status is read-only here. No checkout or billing action is connected.'}</p>
+        </section>
+      ) : null}
+
+      <section className="membership-section">
+        <div className="membership-section__header">
+          <span className="semantic-badge neutral">Personal tiers</span>
+          <div>
+            <h3>Personal membership</h3>
+            <p>Free / Basic, Plus, and Pro belong to the personal user account.</p>
+          </div>
+        </div>
+        <div className="membership-grid membership-grid--personal">
+          {personalCards.map((card) => (
+            <PersonalTierCard
+              key={card.tier}
+              action={actions[card.tier]}
+              card={card}
+              currentStatus={currentStatus}
+              currentTier={currentTier}
+              statusLoaded={statusLoaded}
+            />
+          ))}
+        </div>
+      </section>
+
+      <section className="membership-section membership-section--identity">
+        <div className="membership-section__header">
+          <span className="semantic-badge business">Identity type</span>
+          <div>
+            <h3>Business is separate from personal tiers</h3>
+            <p>Business / organization accounts should not compete with personal handles.</p>
+          </div>
+        </div>
+        <BusinessIdentityCard card={ACCOUNT_IDENTITY_METADATA.business_organization} />
+      </section>
+
+      <section className="notice-box info membership-next-note">
+        <strong>TIERS2 boundary:</strong> this is a web account foundation page only. Payment checkout, public pricing, mobile UI, organization routes, and schema changes are intentionally out of scope.
+      </section>
+    </div>
+  );
+}
