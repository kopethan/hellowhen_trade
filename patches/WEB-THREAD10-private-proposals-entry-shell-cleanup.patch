diff --git a/apps/web/src/app/globals.css b/apps/web/src/app/globals.css
index 7e71500..af46aaa 100644
--- a/apps/web/src/app/globals.css
+++ b/apps/web/src/app/globals.css
@@ -5617,3 +5617,82 @@ html[data-theme="dark"] .onboarding-guide-primary {
     box-shadow: none;
   }
 }
+
+/* WEB-THREAD10: private proposals entry shell cleanup */
+.private-proposals-page--messages-only {
+  padding-bottom: 0;
+}
+
+.private-proposals-page--messages-only .private-proposals-section--clean {
+  display: flex;
+  flex: 1 1 auto;
+  min-height: 0;
+  flex-direction: column;
+  gap: 0;
+  border-bottom: 0;
+  overflow-y: auto;
+  padding: 0 16px 18px;
+  overscroll-behavior: contain;
+}
+
+.private-proposals-page--messages-only .private-proposals-section--clean .proposal-composer {
+  margin-inline: -16px;
+  border-bottom: 1px solid var(--app-divider-strong);
+  background: color-mix(in srgb, var(--app-bg) 98%, transparent);
+  padding: 14px 16px 16px;
+}
+
+.private-proposals-page--messages-only .proposal-attachment-lines {
+  gap: 0;
+  margin: -2px -16px 8px;
+}
+
+.private-proposals-page--messages-only .proposal-attachment-hint {
+  margin: 0 16px;
+  border: 1px dashed var(--app-border-strong);
+  border-radius: 18px;
+  background: var(--app-surface-soft);
+  padding: 11px 12px;
+}
+
+.private-proposals-page--messages-only .private-proposal-row-list {
+  flex: 0 0 auto;
+  margin: 0 -16px;
+}
+
+.private-proposals-page--messages-only .private-proposal-row {
+  min-height: 68px;
+  border-bottom-color: var(--app-divider-strong);
+  background: transparent;
+}
+
+.private-proposals-page--messages-only .private-proposal-row--active {
+  background: color-mix(in srgb, var(--proposal-bg) 26%, transparent);
+}
+
+.private-proposals-page--messages-only .private-proposal-empty-text {
+  margin: 0 -16px;
+  border-bottom: 1px solid var(--app-divider-strong);
+  color: var(--app-text-muted);
+  padding: 18px 16px;
+  text-align: center;
+}
+
+.web-thread-state {
+  align-content: start;
+  gap: 12px;
+  padding: 20px 16px 24px;
+}
+
+.web-thread-state h3 {
+  margin: 0;
+  color: var(--app-text);
+  font-size: 22px;
+  font-weight: 950;
+  letter-spacing: -0.04em;
+  line-height: 1.08;
+}
+
+.web-thread-state .button {
+  justify-self: stretch;
+}
