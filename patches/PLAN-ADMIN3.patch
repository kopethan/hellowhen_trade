+async function adminPlaceReportData(places: Array<{ id: string; planPlaces?: Array<{ id: string }> }>, mediaByPlace = new Map<string, any[]>()) {
+  const reportClient = (prisma as any).report;
+  const counts = new Map<string, number>();
