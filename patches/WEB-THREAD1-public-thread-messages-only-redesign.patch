+.web-thread-header__back, .web-thread-header__menu { display: grid; place-items: center; width: 42px; height: 42px; border: 1px solid transparent; border-radius: 999px; background: transparent; color: var(--app-text); padding: 0; }
+.web-thread-header__back:hover, .web-thread-header__back:focus-visible, .web-thread-header__menu:hover, .web-thread-header__menu:focus-visible { border-color: var(--app-border); background: var(--app-surface-soft); }
+.web-thread-header__menu { justify-self: end; }
+.public-discussion-section--messages-only { display: grid; gap: 0; padding: 0 16px calc(84px + env(safe-area-inset-bottom)); }
+.public-discussion-section--empty { display: grid; gap: 12px; padding: 22px 16px; }
+.public-discussion-section--empty h3 { margin: 0; color: var(--app-text); font-size: 21px; line-height: 1.12; }
+.public-discussion-section--empty p { margin: 0; }
+.public-discussion-empty-text { margin: 26px 0; color: var(--app-text-muted); font-size: 14px; font-weight: 850; text-align: center; }
+.public-discussion-section--messages-only .public-message-date { margin: 14px 0; }
+.public-discussion-section--messages-only .public-message { margin-inline: -16px; padding: 13px 16px; border-bottom: 1px solid var(--app-border-strong); }
+.public-discussion-section--messages-only .public-message__body { font-size: 14px; font-weight: 760; line-height: 1.52; }
+.public-discussion-section--messages-only .public-message__menu { padding-top: 3px; }
+.public-discussion-composer--messages-only { position: sticky; bottom: calc(var(--app-tab-height) + env(safe-area-inset-bottom) + 4px); z-index: 30; grid-template-columns: minmax(0, 1fr) auto; align-items: end; gap: 8px; margin: 10px -16px 0; border: 0; border-top: 1px solid var(--app-border-strong); border-radius: 0; background: color-mix(in srgb, var(--app-bg) 94%, transparent); padding: 10px 16px; box-shadow: none; backdrop-filter: blur(16px); }
+.public-discussion-composer--messages-only textarea { min-height: 44px; max-height: 120px; border-radius: 18px; background: var(--app-surface); }
+.web-thread-options-list, .web-thread-info-page { display: grid; gap: 0; padding: 4px 16px 24px; }
+.web-thread-option-row { display: grid; grid-template-columns: minmax(0, 1fr) auto; align-items: center; gap: 12px; margin-inline: -16px; border: 0; border-bottom: 1px solid var(--app-border-strong); background: transparent; color: var(--app-text); padding: 16px; text-align: left; text-decoration: none; }
+.web-thread-option-row span { display: grid; min-width: 0; gap: 3px; }
+.web-thread-option-row strong { color: var(--app-text); font-size: 15px; font-weight: 950; line-height: 1.22; }
+.web-thread-option-row small { color: var(--app-text-muted); font-size: 12px; font-weight: 760; line-height: 1.36; }
+.web-thread-option-row:hover, .web-thread-option-row:focus-visible { background: var(--app-surface-soft); }
+.web-thread-info-page { gap: 14px; padding-top: 18px; }
+.web-thread-info-page > p { margin: 0; color: var(--app-text); font-size: 15px; font-weight: 760; line-height: 1.55; }
+.web-thread-info-page .report-content-block { display: grid; gap: 12px; }
+.web-thread-guide-list { display: grid; gap: 12px; margin: 0; padding: 0; list-style: none; }
+.web-thread-guide-list li { margin-inline: -16px; border-bottom: 1px solid var(--app-border-strong); color: var(--app-text); padding: 14px 16px; font-size: 14px; font-weight: 800; line-height: 1.45; }
+@media (min-width: 760px) {
+  .public-discussion-page--messages-only { min-height: auto; margin-top: -4px; }
+  .public-discussion-composer--messages-only { bottom: calc(var(--app-tab-height) + env(safe-area-inset-bottom) + 10px); }
+}
+@media (max-width: 420px) {
+  .public-discussion-composer--messages-only { grid-template-columns: minmax(0, 1fr) auto; }
+}
