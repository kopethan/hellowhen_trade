+.public-landing__text-link { color: var(--app-text); font-size: 14px; font-weight: 950; text-decoration: underline; text-decoration-thickness: 2px; text-underline-offset: 5px; }
+.public-landing__poster { display: grid; gap: 16px; border: 1px solid color-mix(in srgb, var(--app-border-strong) 70%, transparent); border-radius: 32px; background: color-mix(in srgb, var(--app-surface) 82%, transparent); padding: 22px; box-shadow: var(--app-card-shadow-strong); backdrop-filter: blur(18px); transform: rotate(1.6deg); }
