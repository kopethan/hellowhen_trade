+.public-landing__checklist { display: grid; gap: 10px; margin: 0; padding: 0; list-style: none; }
+.public-landing__checklist li { position: relative; padding-left: 48px; color: var(--app-text); font-weight: 850; }
+.public-landing__checklist li::before { content: "✓"; position: absolute; left: 18px; top: 50%; transform: translateY(-50%); display: grid; place-items: center; width: 22px; height: 22px; border-radius: 999px; background: var(--success-bg); color: var(--success-text); font-size: 13px; font-weight: 950; }
+.public-landing__chips { display: flex; flex-wrap: wrap; gap: 10px; }
+.public-landing__chips span { display: inline-flex; align-items: center; min-height: 38px; border: 1px solid var(--app-border); border-radius: 999px; background: var(--app-surface-soft); color: var(--app-text); padding: 0 14px; font-weight: 900; }
+.public-landing__final { display: grid; justify-items: center; gap: 12px; border-radius: 34px; background: var(--app-text); color: var(--app-bg); padding: clamp(24px, 4vw, 44px); text-align: center; box-shadow: var(--app-card-shadow-strong); }
+.public-landing__final p { color: color-mix(in srgb, var(--app-bg) 84%, transparent); }
+.public-landing__final .public-landing__eyebrow { background: color-mix(in srgb, var(--app-bg) 12%, transparent); color: var(--app-bg); border-color: color-mix(in srgb, var(--app-bg) 28%, transparent); }
+.public-landing__actions--centered { justify-content: center; }
+
+@media (max-width: 880px) {
+  .public-landing__hero-grid, .public-landing__section--split, .public-landing__cards--three { grid-template-columns: 1fr; }
+  .public-landing__poster { transform: none; }
+}
+
+@media (max-width: 560px) {
+  .public-landing { gap: 16px; }
+  .public-landing__hero, .public-landing__section, .public-landing__final { border-radius: 28px; }
+  .public-landing__nav { align-items: flex-start; }
+  .public-landing__nav-links { flex-direction: column; align-items: stretch; gap: 8px; }
+  .public-landing__nav-links a { min-height: 34px; padding: 0 11px; font-size: 12px; }
+  .public-landing h1 { font-size: 41px; }
+  .public-landing__actions { align-items: stretch; flex-direction: column; }
+  .public-landing__actions .button, .public-landing__text-link { width: 100%; justify-content: center; text-align: center; }
+}
