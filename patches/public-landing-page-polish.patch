+.public-landing__cards--three { grid-template-columns: repeat(3, minmax(0, 1fr)); }
+.public-landing__card, .public-landing__step, .public-landing__checklist li { border: 1px solid color-mix(in srgb, var(--app-border-strong) 70%, transparent); border-radius: 24px; background: color-mix(in srgb, var(--app-surface) 86%, transparent); padding: 18px; }
+.public-landing__card p, .public-landing__step p { font-size: 14px; }
+.public-landing__steps { display: grid; gap: 12px; }
