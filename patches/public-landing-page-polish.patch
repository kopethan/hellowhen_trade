+.public-landing__hero-grid { position: relative; z-index: 1; display: grid; grid-template-columns: minmax(0, 1fr) minmax(280px, 0.7fr); gap: clamp(22px, 5vw, 56px); align-items: center; }
+.public-landing__hero-copy { max-width: 680px; }
+.public-landing__eyebrow { display: inline-flex; align-items: center; width: fit-content; min-height: 28px; border: 1px solid var(--instruction-border); border-radius: 999px; background: color-mix(in srgb, var(--instruction-bg) 88%, var(--app-surface)); color: var(--instruction-text); padding: 0 12px; font-size: 11px; font-weight: 950; letter-spacing: 0.13em; text-transform: uppercase; }
