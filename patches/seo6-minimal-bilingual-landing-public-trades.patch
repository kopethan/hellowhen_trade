-import { PublicLandingPage } from '../features/landing/PublicLandingPage';
+import type { TradeDto } from '@hellowhen/contracts';
+import { PublicLandingPage, type PublicLandingTradePreview } from '../features/landing/PublicLandingPage';
+import { api } from '../lib/api';
 import { publicPageMetadata } from '../lib/seo';
 
+export const dynamic = 'force-dynamic';
+
 export const metadata = publicPageMetadata({ pathname: '/' });
 
-export default function HomePage() {
-  return <PublicLandingPage />;
+type PublicTradesFeedResponse = { trades?: TradeDto[] } | TradeDto[];
+
+function compactJoin(values: Array<string | null | undefined>) {
+  return values.filter((value): value is string => Boolean(value && value.trim())).join(' · ');
+}
+
+function unwrapTrades(response: PublicTradesFeedResponse): TradeDto[] {
+  if (Array.isArray(response)) return response;
+  return Array.isArray(response.trades) ? response.trades : [];
+}
+
+function hasMoneySurface(trade: TradeDto) {
+  return (trade.amountCents ?? 0) > 0
+    || (trade.creditAmount ?? 0) > 0
+    || (trade.payment?.amountCents ?? 0) > 0
+    || (trade.payment?.creditAmount ?? 0) > 0
+    || (trade.escrow?.heldAmountCents ?? 0) > 0
+    || (trade.escrow?.heldCredits ?? 0) > 0;
+}
+
+function toTradePreview(trade: TradeDto): PublicLandingTradePreview {
+  return {
+    id: trade.id,
+    title: trade.title,
+    needTitle: trade.need?.title ?? null,
+    offerTitle: trade.offer?.title ?? null,
+    needMeta: compactJoin([trade.need?.category, trade.need?.timing, trade.need?.locationLabel]),
+    offerMeta: compactJoin([trade.offer?.category, trade.offer?.availability, trade.offer?.locationLabel]),
+    mode: trade.need?.mode ?? trade.offer?.mode ?? null,
+  };
+}
+
+async function loadLandingTradePreviews(): Promise<PublicLandingTradePreview[]> {
+  try {
+    const response = await api.trades.feed({ take: 12 });
+    return unwrapTrades(response as PublicTradesFeedResponse).filter((trade) => !hasMoneySurface(trade)).slice(0, 6).map(toTradePreview);
+  } catch {
+    return [];
+  }
+}
+
+export default async function HomePage() {
+  const tradePreviews = await loadLandingTradePreviews();
+  return <PublicLandingPage tradePreviews={tradePreviews} />;
 }
