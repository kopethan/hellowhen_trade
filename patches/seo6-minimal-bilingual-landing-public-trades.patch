@@ -0,0 +1,38 @@
+'use client';
+
+import type { AppSettings } from '@hellowhen/contracts';
+import { useWebAppSettings } from '../../providers/WebAppSettingsProvider';
+import { useWebTranslation } from '../../providers/WebI18nProvider';
+
+type LandingLanguage = 'en' | 'fr';
+
+const options: Array<{ value: LandingLanguage; label: string }> = [
+  { value: 'en', label: 'EN' },
+  { value: 'fr', label: 'FR' },
+];
+
+export function PublicLandingLanguageToggle() {
+  const { language } = useWebTranslation();
+  const { settings, setSettings } = useWebAppSettings();
+
+  async function chooseLanguage(nextLanguage: LandingLanguage) {
+    const nextSettings: AppSettings = { ...settings, language: nextLanguage };
+    await setSettings(nextSettings, { syncRemote: false });
+  }
+
+  return (
+    <div className="public-landing__language-toggle" aria-label="Choose landing page language">
+      {options.map((option) => (
+        <button
+          key={option.value}
+          type="button"
+          className={language === option.value ? 'is-active' : ''}
+          aria-pressed={language === option.value}
+          onClick={() => { void chooseLanguage(option.value); }}
+        >
+          {option.label}
+        </button>
+      ))}
+    </div>
+  );
+}
