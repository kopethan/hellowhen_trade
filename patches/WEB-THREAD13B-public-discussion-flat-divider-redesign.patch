diff --git a/apps/web/src/app/globals.css b/apps/web/src/app/globals.css
index 6f02960..cfdc607 100644
--- a/apps/web/src/app/globals.css
+++ b/apps/web/src/app/globals.css
@@ -6117,3 +6117,284 @@ html[data-theme="dark"] .onboarding-guide-primary {
     padding: 20px;
   }
 }
+
+/* WEB-THREAD13B: public discussion flat divider redesign */
+.public-discussion-page--flat {
+  position: relative;
+  display: flex;
+  min-height: calc(100dvh - var(--app-header-height) - var(--app-tab-height));
+  flex-direction: column;
+  overflow: visible;
+  border: 0;
+  border-radius: 0;
+  background: transparent;
+  box-shadow: none;
+}
+
+.public-discussion-page--flat > .web-thread-header {
+  position: absolute;
+  z-index: 20;
+  top: 2px;
+  right: 0;
+  left: auto;
+  display: flex;
+  width: auto;
+  min-height: 0;
+  border: 0;
+  background: transparent;
+  padding: 0;
+  pointer-events: none;
+}
+
+.public-discussion-page--flat > .web-thread-header h2,
+.public-discussion-page--flat > .web-thread-header .web-thread-header__back {
+  display: none;
+}
+
+.public-discussion-page--flat > .web-thread-header .web-thread-header__menu {
+  width: 40px;
+  height: 40px;
+  border: 1px solid color-mix(in srgb, var(--app-border) 78%, transparent);
+  background: color-mix(in srgb, var(--app-surface) 78%, transparent);
+  box-shadow: var(--app-control-shadow);
+  pointer-events: auto;
+  backdrop-filter: blur(16px);
+}
+
+.public-discussion-page--flat .public-discussion-section--messages-only {
+  display: flex;
+  min-height: 0;
+  flex: 1 1 auto;
+  flex-direction: column;
+  gap: 0;
+  overflow: visible;
+  border: 0;
+  background: transparent;
+  padding: 4px 0 18px;
+}
+
+.public-discussion-page--flat .public-message-list--thread {
+  display: grid;
+  gap: 0;
+  margin: 0;
+}
+
+.public-discussion-page--flat .public-message-group {
+  display: grid;
+  gap: 0;
+}
+
+.public-discussion-page--flat .public-message-date {
+  display: flex;
+  width: 100%;
+  align-items: center;
+  gap: 12px;
+  justify-self: stretch;
+  margin: 12px 0 10px;
+  border: 0;
+  border-radius: 0;
+  background: transparent;
+  box-shadow: none;
+  color: var(--app-text-muted);
+  padding: 0;
+  font-size: 11px;
+  font-weight: 950;
+  letter-spacing: .12em;
+  line-height: 1;
+  text-transform: uppercase;
+}
+
+.public-discussion-page--flat .public-message-date::before,
+.public-discussion-page--flat .public-message-date::after {
+  content: "";
+  height: 1px;
+  flex: 1 1 auto;
+  background: color-mix(in srgb, var(--app-divider-strong) 78%, transparent);
+}
+
+.public-discussion-page--flat .public-message {
+  display: grid;
+  gap: 10px;
+  margin: 0;
+  border: 0;
+  border-bottom: 1px solid color-mix(in srgb, var(--app-divider-strong) 86%, transparent);
+  border-radius: 0;
+  background: transparent;
+  padding: 14px 0 16px;
+  box-shadow: none;
+}
+
+.public-discussion-page--flat .public-message:hover {
+  border-color: color-mix(in srgb, var(--app-divider-strong) 86%, transparent);
+  background: transparent;
+}
+
+.public-discussion-page--flat .public-message__header {
+  align-items: flex-start;
+  gap: 12px;
+}
+
+.public-discussion-page--flat .public-message__header .user-identity-link {
+  max-width: min(58vw, 320px);
+  padding: 0;
+}
+
+.public-discussion-page--flat .public-message__header .user-identity-link:hover,
+.public-discussion-page--flat .public-message__header .user-identity-link:focus-visible {
+  background: transparent;
+  transform: none;
+}
+
+.public-discussion-page--flat .public-message__meta {
+  gap: 6px;
+  min-width: fit-content;
+  padding-top: 1px;
+  white-space: nowrap;
+}
+
+.public-discussion-page--flat .public-message__body,
+.public-discussion-page--flat .public-message__edited,
+.public-discussion-page--flat .public-message-edit-form,
+.public-discussion-page--flat .public-message__menu {
+  margin-left: 0;
+}
+
+.public-discussion-page--flat .public-message__body {
+  max-width: 72ch;
+  font-size: 15px;
+  font-weight: 760;
+  line-height: 1.55;
+}
+
+.public-discussion-page--flat .public-message__edited {
+  margin-top: -4px;
+  font-size: 11px;
+}
+
+.public-discussion-page--flat .public-message__menu {
+  padding-top: 0;
+}
+
+.public-discussion-page--flat .notice-box {
+  margin: 8px 0 12px;
+}
+
+.public-discussion-page--flat .public-discussion-empty-text {
+  margin: 30px 0;
+  border: 1px dashed var(--app-border-strong);
+  border-radius: 22px;
+  background: color-mix(in srgb, var(--app-surface) 54%, transparent);
+  padding: 18px;
+}
+
+.public-discussion-page--flat .public-discussion-composer--messages-only {
+  position: sticky;
+  z-index: 25;
+  bottom: calc(var(--app-tab-height) + env(safe-area-inset-bottom) + 8px);
+  display: grid;
+  grid-template-columns: minmax(0, 1fr);
+  gap: 10px;
+  margin: auto 0 0;
+  border: 0;
+  border-top: 1px solid color-mix(in srgb, var(--app-divider-strong) 82%, transparent);
+  border-radius: 0;
+  background: color-mix(in srgb, var(--app-bg) 94%, transparent);
+  padding: 12px 0 max(12px, env(safe-area-inset-bottom));
+  box-shadow: none;
+  backdrop-filter: blur(16px);
+}
+
+.public-discussion-page--flat .public-discussion-composer--messages-only textarea {
+  min-height: 48px;
+  max-height: 132px;
+  border-radius: 18px;
+  background: var(--app-surface);
+  padding-top: 13px;
+}
+
+.public-discussion-page--flat .public-discussion-composer--messages-only button {
+  min-height: 46px;
+  border-radius: 16px;
+}
+
+.public-discussion-page--flat .public-discussion-bottom-notice {
+  position: sticky;
+  bottom: calc(var(--app-tab-height) + env(safe-area-inset-bottom) + 8px);
+  margin: auto 0 0;
+  border-width: 1px 0 0;
+  border-radius: 0;
+  background: color-mix(in srgb, var(--app-bg) 94%, transparent);
+  padding: 12px 0 max(12px, env(safe-area-inset-bottom));
+  backdrop-filter: blur(16px);
+}
+
+@media (min-width: 760px) {
+  .public-discussion-page--flat {
+    max-width: 760px;
+    min-height: calc(100dvh - var(--app-header-height) - 74px);
+    margin-right: auto;
+    margin-left: auto;
+    border: 0;
+    border-radius: 0;
+    background: transparent;
+    box-shadow: none;
+  }
+
+  .public-discussion-page--flat > .web-thread-header {
+    top: 0;
+    right: 0;
+  }
+
+  .public-discussion-page--flat > .web-thread-header .web-thread-header__menu {
+    background: color-mix(in srgb, var(--app-surface) 84%, transparent);
+  }
+
+  .public-discussion-page--flat .public-discussion-section--messages-only {
+    padding: 4px 0 22px;
+  }
+
+  .public-discussion-page--flat .public-message-list--thread {
+    margin: 0;
+  }
+
+  .public-discussion-page--flat .public-message-date {
+    margin: 10px 0 12px;
+  }
+
+  .public-discussion-page--flat .public-message {
+    padding: 16px 0 18px;
+  }
+
+  .public-discussion-page--flat .public-message__header .user-identity-link {
+    max-width: 340px;
+  }
+
+  .public-discussion-page--flat .public-message__body {
+    font-size: 15px;
+  }
+
+  .public-discussion-page--flat .public-discussion-composer--messages-only {
+    bottom: 0;
+    grid-template-columns: minmax(0, 1fr) auto;
+    align-items: end;
+    gap: 10px;
+    background: color-mix(in srgb, var(--app-bg-muted) 88%, transparent);
+    padding: 14px 0 0;
+  }
+
+  .public-discussion-page--flat .public-discussion-composer--messages-only textarea {
+    min-height: 48px;
+  }
+
+  .public-discussion-page--flat .public-discussion-composer--messages-only button {
+    min-height: 48px;
+    padding-right: 20px;
+    padding-left: 20px;
+  }
+
+  .public-discussion-page--flat .public-discussion-bottom-notice {
+    bottom: 0;
+    background: color-mix(in srgb, var(--app-bg-muted) 88%, transparent);
+    padding: 14px 0 0;
+  }
+}
