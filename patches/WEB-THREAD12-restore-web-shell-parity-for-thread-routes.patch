diff --git a/apps/web/src/app/globals.css b/apps/web/src/app/globals.css
index f013c7e..2216ffd 100644
--- a/apps/web/src/app/globals.css
+++ b/apps/web/src/app/globals.css
@@ -5698,3 +5698,61 @@ html[data-theme="dark"] .onboarding-guide-primary {
 .web-thread-state .button {
   justify-self: stretch;
 }
+
+/* WEB-THREAD12: restore thread routes to the normal web app shell */
+.public-discussion-page--messages-only,
+.private-proposals-page--messages-only,
+.proposal-conversation-page--messages-only {
+  width: 100%;
+  max-width: none;
+  height: auto;
+  min-height: calc(100dvh - var(--app-header-height) - var(--app-tab-height) - 54px);
+  margin: 0;
+  overflow: hidden;
+  border: 0;
+  border-radius: 0;
+  background: var(--app-bg);
+  box-shadow: none;
+}
+
+.public-discussion-page--messages-only .web-thread-header,
+.private-proposals-page--messages-only .web-thread-header,
+.proposal-conversation-page--messages-only .thread-page-header {
+  background: color-mix(in srgb, var(--app-bg) 96%, transparent);
+}
+
+@media (min-width: 760px) {
+  .public-discussion-page--messages-only,
+  .private-proposals-page--messages-only,
+  .proposal-conversation-page--messages-only {
+    max-width: 760px;
+    min-height: min(760px, calc(100dvh - 178px));
+    margin-right: auto;
+    margin-left: auto;
+    border: 1px solid color-mix(in srgb, var(--app-border) 86%, transparent);
+    border-radius: 28px;
+    background: var(--app-surface);
+    box-shadow: var(--app-card-shadow);
+  }
+
+  .public-discussion-page--messages-only .web-thread-header,
+  .private-proposals-page--messages-only .web-thread-header,
+  .proposal-conversation-page--messages-only .thread-page-header {
+    border-radius: 28px 28px 0 0;
+    background: color-mix(in srgb, var(--app-surface) 94%, transparent);
+  }
+
+  .public-discussion-section--messages-only,
+  .private-proposals-page--messages-only .private-proposals-section--clean,
+  .proposal-conversation-page--messages-only .proposal-thread-message-list {
+    background: color-mix(in srgb, var(--app-surface-soft) 40%, transparent);
+  }
+
+  .public-discussion-composer--messages-only,
+  .proposal-conversation-page--messages-only .thread-bottom-composer,
+  .proposal-conversation-page--messages-only .thread-closed-copy,
+  .public-discussion-bottom-notice {
+    border-radius: 0 0 28px 28px;
+    background: color-mix(in srgb, var(--app-surface) 96%, transparent);
+  }
+}
