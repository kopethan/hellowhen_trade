diff --git a/apps/web/src/app/globals.css b/apps/web/src/app/globals.css
index 98f7fb0..5686db4 100644
--- a/apps/web/src/app/globals.css
+++ b/apps/web/src/app/globals.css
@@ -1020,6 +1020,39 @@ html.trade-tools-open, html.trade-tools-open body { overflow: hidden; }
   }
 }
 
+
+/* NEEDOFFER-WEB2: polish owner inventory cards with the same balanced media/content alignment as starter cards. */
+@media (min-width: 720px) {
+  .inventory-card--owner {
+    grid-template-columns: minmax(180px, 32%) minmax(0, 1fr);
+    min-height: 160px;
+  }
+
+  .inventory-card--owner .inventory-card__media {
+    align-self: stretch;
+    height: 100%;
+    min-height: 100%;
+    aspect-ratio: auto;
+  }
+
+  .inventory-card--owner .inventory-card__body {
+    align-content: start;
+    gap: 8px;
+    padding: 16px 18px;
+  }
+
+  .inventory-card--owner .inventory-card__footer {
+    margin-top: auto;
+  }
+}
+
+@media (min-width: 1024px) {
+  .inventory-card--owner {
+    grid-template-columns: minmax(210px, 32%) minmax(0, 1fr);
+    min-height: 168px;
+  }
+}
+
 /* Phase 19.5: web Account, wallet, payouts, profile photo, and support polish */
 .wallet-page, .support-mobile-page { display: grid; gap: 16px; }
 .wallet-hero-card { display: grid; gap: 16px; border: 0; border-radius: 32px; background: linear-gradient(145deg, color-mix(in srgb, var(--money-bg) 52%, var(--app-surface)), var(--app-surface)); padding: 20px; box-shadow: var(--app-card-shadow-strong); }
