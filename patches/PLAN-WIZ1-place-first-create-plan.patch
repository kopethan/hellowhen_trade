+function truncateGeneratedPlanText(value: string, maxLength: number) {
+  return value.length > maxLength ? `${value.slice(0, Math.max(0, maxLength - 1)).trim()}…` : value;
+}
+
+function planModeText(mode: ReturnType<typeof planModeFromSelectedPlaces>) {
+  if (mode === 'remote') return 'Remote';
+  if (mode === 'hybrid') return 'Mixed';
+  return 'Local';
+}
+
+function buildGeneratedMobilePlanTitle(places: SelectedPlanPlaceState[], startsAt?: string | null) {
+  const names = places.map(generatedSelectedPlaceTitle).filter(Boolean);
+  const firstName = names[0] ?? 'New plan';
+  const secondName = names[1] ?? 'Place 2';
+  if (names.length === 1) return truncateGeneratedPlanText(firstName, 120);
+  if (names.length === 2) return truncateGeneratedPlanText(`${firstName} → ${secondName}`, 120);
+  if (names.length > 2) return truncateGeneratedPlanText(`${firstName} + ${names.length - 1} places`, 120);
+  if (startsAt) return truncateGeneratedPlanText(`Plan for ${new Intl.DateTimeFormat(undefined, { month: 'short', day: 'numeric' }).format(new Date(startsAt))}`, 120);
+  return 'New plan';
+}
+
+function buildGeneratedMobilePlanDescription(places: SelectedPlanPlaceState[], startsAt?: string | null) {
+  const placeCount = places.length;
+  const parts = [
+    `${placeCount} ${placeCount === 1 ? 'place' : 'places'}`,
+    startsAt ? `Starts ${new Intl.DateTimeFormat(undefined, { month: 'short', day: 'numeric', hour: '2-digit', minute: '2-digit' }).format(new Date(startsAt))}` : null,
+    `${planModeText(planModeFromSelectedPlaces(places))} plan`,
+    'Free join',
+  ].filter((part): part is string => Boolean(part));
+  return truncateGeneratedPlanText(parts.join(' · ') || 'Place-first Plan · Free join', 2000);
+}
