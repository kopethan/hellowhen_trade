diff --git a/apps/web/src/app/globals.css b/apps/web/src/app/globals.css
index 5686db4..20d7799 100644
--- a/apps/web/src/app/globals.css
+++ b/apps/web/src/app/globals.css
@@ -3594,3 +3594,102 @@ html[data-theme="dark"] .onboarding-guide-primary {
   .onboarding-guide-body { font-size: 15px; line-height: 1.38; }
   .onboarding-guide-dots { margin-top: 12px; }
 }
+
+/* NEEDOFFER-WEB3: keep starter library cards compact and native-like on mobile web. */
+.inventory-template-card { position: relative; }
+.inventory-template-card.is-disabled { cursor: not-allowed; }
+.inventory-template-card__chevron { display: none; }
+
+@media (max-width: 719px) {
+  .inventory-template-card {
+    cursor: pointer;
+    min-height: 118px;
+  }
+
+  .inventory-template-card:not(.is-disabled):active {
+    transform: translateY(1px);
+  }
+
+  .inventory-template-card:focus-visible {
+    outline: 3px solid color-mix(in srgb, var(--accent-ring) 70%, transparent);
+    outline-offset: 3px;
+  }
+
+  .inventory-template-card__media {
+    align-self: stretch;
+    height: 100%;
+    min-height: 100%;
+    aspect-ratio: auto;
+  }
+
+  .inventory-template-card__body {
+    align-content: center;
+    gap: 5px;
+    padding: 10px 36px 10px 12px;
+  }
+
+  .inventory-template-card__body .status-row {
+    flex-wrap: nowrap;
+    gap: 5px;
+    overflow: hidden;
+  }
+
+  .inventory-template-card__body .status-row .semantic-badge {
+    flex: 0 1 auto;
+    max-width: 100%;
+    overflow: hidden;
+    text-overflow: ellipsis;
+    white-space: nowrap;
+  }
+
+  .inventory-template-card__body h3 {
+    display: -webkit-box;
+    overflow: hidden;
+    -webkit-line-clamp: 2;
+    -webkit-box-orient: vertical;
+  }
+
+  .inventory-template-card__body .meta {
+    display: block;
+    overflow: hidden;
+    text-overflow: ellipsis;
+    white-space: nowrap;
+  }
+
+  .inventory-template-card__button,
+  .inventory-template-card__footer,
+  .inventory-template-card .inventory-card__tags,
+  .inventory-template-card__body > p:not(.meta) {
+    display: none;
+  }
+
+  .inventory-template-card__chevron {
+    position: absolute;
+    top: 50%;
+    right: 12px;
+    display: grid;
+    place-items: center;
+    width: 20px;
+    height: 20px;
+    color: var(--app-text-muted);
+    font-size: 26px;
+    font-weight: 650;
+    line-height: 1;
+    transform: translateY(-50%);
+  }
+}
+
+@media (max-width: 380px) {
+  .inventory-template-card {
+    min-height: 108px;
+  }
+
+  .inventory-template-card__body {
+    gap: 4px;
+    padding: 8px 30px 8px 10px;
+  }
+
+  .inventory-template-card__chevron {
+    right: 9px;
+  }
+}
