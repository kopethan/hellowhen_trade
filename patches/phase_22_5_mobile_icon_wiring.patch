new file mode 100644
index 0000000..46eec86
--- /dev/null
+++ b/apps/mobile/src/components/MobileIcon.tsx
@@ -0,0 +1,82 @@
+import React from 'react';
+import { Feather } from '@expo/vector-icons';
+import type { StyleProp, TextStyle } from 'react-native';
+
+export type MobileIconName =
+  | 'add'
+  | 'back'
+  | 'business'
+  | 'chevron-right'
+  | 'close'
+  | 'dispute'
+  | 'filter'
+  | 'help'
+  | 'image'
+  | 'need'
+  | 'offer'
+  | 'payout'
+  | 'profile'
+  | 'proposal'
+  | 'proposal-accepted'
+  | 'proposal-declined'
+  | 'refresh'
+  | 'search'
+  | 'send'
+  | 'settings'
+  | 'trade'
+  | 'wallet'
+  | 'warning';
+
+type FeatherIconName = React.ComponentProps<typeof Feather>['name'];
+
+const iconMap: Record<MobileIconName, FeatherIconName> = {
+  add: 'plus',
+  back: 'arrow-left',
+  business: 'briefcase',
+  'chevron-right': 'chevron-right',
+  close: 'x',
+  dispute: 'alert-triangle',
+  filter: 'sliders',
+  help: 'help-circle',
+  image: 'image',
+  need: 'arrow-down-circle',
+  offer: 'arrow-up-circle',
+  payout: 'dollar-sign',
+  profile: 'user',
+  proposal: 'message-circle',
+  'proposal-accepted': 'check-circle',
+  'proposal-declined': 'x-circle',
+  refresh: 'refresh-cw',
+  search: 'search',
+  send: 'send',
+  settings: 'settings',
+  trade: 'repeat',
+  wallet: 'credit-card',
+  warning: 'alert-triangle',
+};
+
+type MobileIconProps = {
+  name: MobileIconName;
+  color: string;
+  size?: number;
+  label?: string;
+  decorative?: boolean;
+  style?: StyleProp<TextStyle>;
+};
+
+export function MobileIcon({ name, color, size = 20, label, decorative, style }: MobileIconProps) {
+  const isDecorative = decorative ?? !label;
+
+  return (
+    <Feather
+      accessibilityElementsHidden={isDecorative}
+      accessibilityLabel={!isDecorative ? label : undefined}
+      accessibilityRole={!isDecorative ? 'image' : undefined}
+      color={color}
+      importantForAccessibility={isDecorative ? 'no' : 'auto'}
+      name={iconMap[name]}
+      size={size}
+      style={style}
+    />
+  );
+}
