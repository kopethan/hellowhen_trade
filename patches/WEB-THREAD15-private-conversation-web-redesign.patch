+/* WEB-THREAD15: private conversation web redesign */
+.private-thread-menu {
+  position: relative;
+  justify-self: end;
+}
+
+.private-thread-menu__popover {
+  position: absolute;
+  z-index: 80;
+  top: calc(100% + 10px);
+  right: 0;
+  display: grid;
+  width: min(320px, calc(100vw - 32px));
+  gap: 6px;
+  border: 1px solid color-mix(in srgb, var(--app-border) 86%, transparent);
+  border-radius: 20px;
+  background: color-mix(in srgb, var(--app-surface) 96%, transparent);
+  padding: 8px;
+  box-shadow: var(--app-card-shadow);
+  backdrop-filter: blur(18px);
+}
+
+.private-thread-menu__popover a,
+.private-thread-menu__popover button {
+  display: grid;
+  grid-template-columns: 20px minmax(0, 1fr);
+  align-items: center;
+  gap: 10px;
+  width: 100%;
+  border: 0;
+  border-radius: 15px;
+  background: transparent;
+  color: var(--app-text);
+  padding: 11px 12px;
+  text-align: left;
+  text-decoration: none;
+}
+
+.private-thread-menu__popover a:hover,
+.private-thread-menu__popover a:focus-visible,
+.private-thread-menu__popover button:hover,
+.private-thread-menu__popover button:focus-visible {
+  background: var(--app-surface-soft);
+  outline: none;
+}
+
+.private-thread-menu__popover .danger-text {
+  color: var(--danger-text);
+}
+
+.private-thread-menu__popover span {
+  display: grid;
+  min-width: 0;
+  gap: 2px;
+}
+
+.private-thread-menu__popover strong {
+  overflow: hidden;
+  color: currentColor;
+  font-size: 13px;
+  font-weight: 950;
+  line-height: 1.2;
+  text-overflow: ellipsis;
+  white-space: nowrap;
+}
+
+.private-thread-menu__popover small {
+  overflow: hidden;
+  color: var(--app-text-muted);
+  font-size: 11px;
+  font-weight: 760;
+  line-height: 1.28;
+  text-overflow: ellipsis;
+  white-space: nowrap;
+}
+
+.private-thread-summary-strip {
+  display: grid;
+  flex: 0 0 auto;
+  gap: 10px;
+  margin: 14px 14px 0;
+  border: 1px solid color-mix(in srgb, var(--proposal-border) 34%, var(--app-border));
+  border-radius: 22px;
+  background: color-mix(in srgb, var(--proposal-bg) 16%, var(--app-surface));
+  padding: 12px;
+}
+
+.private-thread-summary-strip__main {
+  display: grid;
+  min-width: 0;
+  gap: 5px;
+}
+
+.private-thread-summary-strip__main .semantic-badge {
+  justify-self: start;
+}
+
+.private-thread-summary-strip__main strong {
+  overflow: hidden;
+  color: var(--app-text);
+  font-size: 16px;
+  font-weight: 950;
+  letter-spacing: -0.025em;
+  line-height: 1.15;
+  text-overflow: ellipsis;
+  white-space: nowrap;
+}
+
+.private-thread-summary-strip__main p,
+.private-thread-summary-strip__empty {
+  margin: 0;
+  color: var(--app-text-muted);
+  font-size: 12px;
+  font-weight: 800;
+  line-height: 1.35;
+}
+
+.private-thread-summary-strip__items {
+  display: flex;
+  flex-wrap: wrap;
+  gap: 6px;
+}
+
+.private-thread-summary-strip__items span {
+  max-width: 100%;
+  overflow: hidden;
+  border: 1px solid color-mix(in srgb, var(--app-border) 76%, transparent);
+  border-radius: 999px;
+  background: color-mix(in srgb, var(--app-surface) 86%, transparent);
+  color: var(--app-text-muted);
+  padding: 5px 9px;
+  font-size: 11px;
+  font-weight: 900;
+  line-height: 1.1;
+  text-overflow: ellipsis;
+  white-space: nowrap;
+}
+
+.private-thread-summary-strip__actions {
+  display: flex;
+  flex-wrap: wrap;
+  gap: 8px;
+}
+
+.private-thread-summary-strip__actions button {
+  min-height: 34px;
+  border-radius: 999px;
+  padding: 0 12px;
+  font-size: 11px;
+}
+
+.proposal-conversation-page--messages-only .proposal-thread-message-list {
+  gap: 10px;
+  padding-top: 12px;
+}
+
+.proposal-conversation-page--messages-only .proposal-conversation-list .message-bubble {
+  max-width: min(68%, 540px);
+  border-color: color-mix(in srgb, var(--app-border) 46%, transparent);
+  border-radius: 19px 19px 19px 8px;
+  background: color-mix(in srgb, var(--app-surface) 96%, transparent);
+  padding: 10px 12px;
+}
+
+.proposal-conversation-page--messages-only .proposal-conversation-list .message-bubble--own {
+  border-color: color-mix(in srgb, var(--proposal-border) 34%, transparent);
+  border-radius: 19px 19px 8px 19px;
+  background: color-mix(in srgb, var(--proposal-bg) 34%, var(--app-surface));
+}
+
+.proposal-conversation-page--messages-only .proposal-conversation-list .message-bubble > p:not(.message-meta):not(.message-deleted) {
+  font-size: 14px;
+  line-height: 1.5;
+}
+
+.proposal-conversation-page--messages-only .thread-bottom-composer {
+  display: grid;
+  grid-template-columns: minmax(0, 1fr) auto;
+  align-items: end;
+  gap: 8px;
+  margin: 10px 14px max(10px, env(safe-area-inset-bottom));
+  border: 1px solid color-mix(in srgb, var(--app-border) 82%, transparent);
+  border-radius: 24px;
+  background: color-mix(in srgb, var(--app-surface) 92%, transparent);
+  padding: 8px;
+  box-shadow: 0 14px 34px rgba(15, 23, 42, 0.065);
+  backdrop-filter: blur(16px);
+}
+
+.proposal-conversation-page--messages-only .thread-bottom-composer:focus-within {
+  border-color: color-mix(in srgb, var(--proposal-border) 42%, var(--app-border-strong));
+  box-shadow: 0 16px 38px rgba(15, 23, 42, 0.085);
+}
+
+.proposal-conversation-page--messages-only .thread-bottom-composer textarea {
+  min-height: 46px;
+  max-height: 144px;
+  border: 0;
+  border-radius: 17px;
+  background: transparent;
+  padding: 13px 14px;
+  box-shadow: none;
+  line-height: 1.45;
+  overflow-y: hidden;
+  resize: none;
+}
+
+.proposal-conversation-page--messages-only .thread-bottom-composer textarea:focus {
+  box-shadow: none;
+}
+
+.proposal-conversation-page--messages-only .thread-bottom-composer button {
+  align-self: end;
+  min-height: 46px;
+  border-radius: 17px;
+}
+
+.proposal-conversation-page--messages-only .thread-bottom-composer .field-error {
+  grid-column: 1 / -1;
+}
+
+@media (min-width: 760px) {
+  .proposal-conversation-page--messages-only {
+    display: grid;
+    grid-template-rows: auto minmax(0, auto);
+    max-width: 760px;
+    min-height: auto;
+    overflow: visible;
+    border: 0;
+    border-radius: 0;
+    background: transparent;
+    box-shadow: none;
+  }
+
+  .proposal-conversation-page--messages-only .thread-page-header {
+    grid-template-columns: 44px minmax(0, 1fr) 44px;
+    min-height: 70px;
+    border: 0;
+    border-radius: 0;
+    background: transparent;
+    padding: 12px 0;
+  }
+
+  .proposal-conversation-page--messages-only .thread-page-header h1 {
+    justify-self: start;
+    font-size: 23px;
+    letter-spacing: -0.04em;
+    line-height: 1.05;
+    text-align: left;
+  }
+
+  .proposal-conversation-page--messages-only .thread-page-header__back,
+  .proposal-conversation-page--messages-only .thread-page-header__menu {
+    width: 40px;
+    height: 40px;
+    border: 1px solid color-mix(in srgb, var(--app-border) 76%, transparent);
+    background: color-mix(in srgb, var(--app-surface) 84%, transparent);
+    box-shadow: var(--app-control-shadow);
+  }
+
+  .proposal-conversation-page--messages-only .thread-message-page {
+    overflow: visible;
+    border-radius: 30px;
+    background: var(--app-surface);
+    box-shadow: var(--app-card-shadow);
+  }
+
+  .private-thread-summary-strip {
+    grid-template-columns: minmax(0, 1fr) auto;
+    align-items: center;
+    margin: 18px 18px 0;
+    padding: 14px;
+  }
+
+  .private-thread-summary-strip__items {
+    grid-column: 1 / -1;
+  }
+
+  .private-thread-summary-strip__actions {
+    justify-content: flex-end;
+  }
+
+  .proposal-conversation-page--messages-only .proposal-thread-message-list {
+    min-height: min(520px, calc(100dvh - 380px));
+    background: color-mix(in srgb, var(--app-surface-soft) 24%, transparent);
+    padding: 16px 18px 14px;
+  }
+
+  .proposal-conversation-page--messages-only .thread-bottom-composer {
+    margin: 14px 18px 18px;
+  }
+}
+
+@media (max-width: 759px) {
+  .private-thread-menu__popover {
+    display: none;
+  }
+
+  .private-thread-summary-strip {
+    margin: 10px 12px 0;
+    border-radius: 20px;
+    padding: 11px;
+  }
+
+  .proposal-conversation-page--messages-only .proposal-conversation-list .message-bubble {
+    max-width: 86%;
+  }
+
+  .proposal-conversation-page--messages-only .thread-bottom-composer {
+    grid-template-columns: minmax(0, 1fr);
+    gap: 8px;
+    margin: 10px 12px max(10px, env(safe-area-inset-bottom));
+    border-radius: 22px;
+  }
+
+  .proposal-conversation-page--messages-only .thread-bottom-composer textarea {
+    min-height: 48px;
+    border-radius: 16px;
+  }
+
+  .proposal-conversation-page--messages-only .thread-bottom-composer button {
+    width: 100%;
+    min-height: 46px;
+    border-radius: 16px;
+  }
+}
