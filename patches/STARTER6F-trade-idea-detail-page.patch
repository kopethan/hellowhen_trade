+.trade-idea-detail-page {
+  gap: 14px;
+  max-width: 760px;
+}
+
+.trade-idea-detail-page .trade-detail-toolbar {
+  margin-bottom: 0;
+}
+
+.trade-idea-detail-hero {
+  display: grid;
+  gap: 12px;
+}
+
+.trade-idea-detail-hero h1 {
+  margin: 0;
+  font-size: clamp(30px, 6vw, 50px);
+  line-height: .96;
+  letter-spacing: -0.065em;
+}
+
+.trade-idea-detail-hero p,
+.trade-idea-detail-side p,
+.trade-idea-detail-expiry p {
+  margin: 0;
+}
+
+.trade-idea-detail-side .trade-section-heading h2 {
+  line-height: 1.08;
+}
+
+.trade-idea-detail-side > p:not(.meta) {
+  color: var(--app-text);
+  font-size: 16px;
+  font-weight: 840;
+  line-height: 1.45;
+}
+
+.trade-idea-detail-exchange {
+  display: grid;
+  grid-template-columns: minmax(60px, 1fr) auto minmax(60px, 1fr);
+  align-items: center;
+  gap: 12px;
+  padding: 0 26px;
+  color: var(--app-text-muted);
+}
+
+.trade-idea-detail-exchange span {
+  height: 2px;
+  border-radius: 999px;
+  background: color-mix(in srgb, var(--app-border-strong) 62%, transparent);
+}
+
+.trade-idea-detail-expiry-grid {
+  display: grid;
+  grid-template-columns: repeat(3, minmax(0, 1fr));
+  gap: 9px;
+}
+
+.trade-idea-detail-expiry-grid button {
+  min-height: 56px;
+  border: 1px solid var(--app-border);
+  border-radius: 18px;
+  background: var(--app-surface);
+  color: var(--app-text);
+  cursor: pointer;
+  display: grid;
+  gap: 3px;
+  justify-items: start;
+  padding: 10px 12px;
+  text-align: left;
+}
+
+.trade-idea-detail-expiry-grid button.is-selected {
+  border-color: color-mix(in srgb, var(--proposal-border) 62%, var(--app-border));
+  background: color-mix(in srgb, var(--proposal-bg) 9%, var(--app-surface));
+}
+
+.trade-idea-detail-expiry-grid button span {
+  font-size: 13px;
+  font-weight: 920;
+  line-height: 1.2;
+}
+
+.trade-idea-detail-expiry-grid button small {
+  color: var(--app-text-muted);
+  font-size: 11px;
+  font-weight: 820;
+  line-height: 1.2;
+}
+
+.trade-idea-detail-actions {
+  display: grid;
+  grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
+  gap: 10px;
+  padding-bottom: 18px;
+}
+
+.trade-idea-detail-actions .button {
+  justify-content: center;
+  min-height: 48px;
+}
+
+@media (max-width: 560px) {
+  .trade-idea-detail-expiry-grid,
+  .trade-idea-detail-actions {
+    grid-template-columns: 1fr;
+  }
+}
