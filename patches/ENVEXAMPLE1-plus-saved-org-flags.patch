+# Keep false in production until the feature is ready for launch.
+SAVED_LIBRARY_ENABLED=false
+SAVED_COLLECTIONS_ENABLED=false
+INVENTORY_FOLDERS_ENABLED=false
+NEXT_PUBLIC_SAVED_LIBRARY_ENABLED=false
