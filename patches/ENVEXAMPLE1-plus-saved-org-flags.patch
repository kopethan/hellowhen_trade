+# Local/dev Plus test account seed helper. Optional: override before running
+# npm run seed:plus-test-user. Do not commit real passwords.
+TEST_PLUS_EMAIL=test@plus.com
+TEST_PLUS_PASSWORD=TestPlus123!
+ALLOW_PRODUCTION_PLUS_TEST_SEED=false
+
