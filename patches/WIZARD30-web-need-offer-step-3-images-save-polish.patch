diff --git a/apps/web/src/app/globals.css b/apps/web/src/app/globals.css
index fc7a996..ed63cca 100644
--- a/apps/web/src/app/globals.css
+++ b/apps/web/src/app/globals.css
@@ -4388,3 +4388,161 @@ html[data-theme="dark"] .onboarding-guide-primary {
     grid-column: 1 / -1;
   }
 }
+
+/* WIZARD30: web Need/Offer images + save step polish */
+.inventory-final-step {
+  display: grid;
+  gap: 12px;
+}
+
+.inventory-save-summary-card {
+  gap: 13px;
+  overflow: hidden;
+}
+
+.inventory-save-summary-card__header {
+  display: flex;
+  align-items: center;
+  justify-content: space-between;
+  gap: 10px;
+}
+
+.inventory-save-summary-card h3 {
+  margin: 0;
+  font-size: 23px;
+  line-height: 1.08;
+  letter-spacing: -0.05em;
+}
+
+.inventory-save-summary-card p {
+  display: -webkit-box;
+  overflow: hidden;
+  margin: 5px 0 0;
+  color: var(--app-text-muted);
+  font-size: 13px;
+  font-weight: 750;
+  line-height: 1.45;
+  -webkit-line-clamp: 3;
+  -webkit-box-orient: vertical;
+}
+
+.inventory-save-summary-card__details {
+  display: grid;
+  grid-template-columns: repeat(2, minmax(0, 1fr));
+  gap: 8px;
+  margin: 0;
+}
+
+.inventory-save-summary-card__details div {
+  min-width: 0;
+  border: 1px solid color-mix(in srgb, var(--app-border) 72%, transparent);
+  border-radius: 16px;
+  background: color-mix(in srgb, var(--app-bg-muted) 68%, transparent);
+  padding: 10px;
+}
+
+.inventory-save-summary-card__details dt {
+  margin: 0 0 3px;
+  color: var(--app-text-muted);
+  font-size: 10px;
+  font-weight: 950;
+  letter-spacing: 0.08em;
+  text-transform: uppercase;
+}
+
+.inventory-save-summary-card__details dd {
+  overflow: hidden;
+  margin: 0;
+  color: var(--app-text);
+  font-size: 12px;
+  font-weight: 900;
+  line-height: 1.25;
+  text-overflow: ellipsis;
+  white-space: nowrap;
+}
+
+.inventory-save-summary-card__edit-details {
+  display: flex;
+  align-items: center;
+  justify-content: space-between;
+  gap: 12px;
+  width: 100%;
+  min-height: 44px;
+  border: 1px solid color-mix(in srgb, var(--app-border) 84%, transparent);
+  border-radius: 17px;
+  background: color-mix(in srgb, var(--app-surface-soft) 82%, transparent);
+  color: var(--app-text);
+  padding: 0 12px;
+  font: inherit;
+  cursor: pointer;
+}
+
+.inventory-save-summary-card__edit-details span,
+.inventory-save-summary-card__edit-details strong {
+  font-size: 12px;
+  font-weight: 950;
+}
+
+.inventory-save-summary-card__edit-details strong {
+  color: var(--app-text-muted);
+  letter-spacing: 0.06em;
+  text-transform: uppercase;
+}
+
+.inventory-media-panel--final {
+  gap: 12px;
+}
+
+.inventory-media-panel__header {
+  display: grid;
+  gap: 10px;
+}
+
+.inventory-media-panel__header h3 {
+  margin: 0;
+  font-size: 22px;
+  line-height: 1.1;
+  letter-spacing: -0.045em;
+}
+
+.inventory-media-panel__header p {
+  margin: 5px 0 0;
+  color: var(--app-text-muted);
+  font-size: 13px;
+  font-weight: 750;
+  line-height: 1.45;
+}
+
+.inventory-media-panel__header .semantic-badge {
+  justify-self: start;
+  white-space: normal;
+}
+
+.image-upload-button--full {
+  width: 100%;
+}
+
+.inventory-media-panel__empty {
+  margin: 0;
+  border: 1px dashed color-mix(in srgb, var(--app-border) 86%, transparent);
+  border-radius: 18px;
+  background: color-mix(in srgb, var(--app-bg-muted) 66%, transparent);
+  padding: 14px;
+  color: var(--app-text-muted);
+  font-size: 13px;
+  font-weight: 800;
+  text-align: center;
+}
+
+@media (min-width: 620px) {
+  .inventory-media-panel__header {
+    grid-template-columns: minmax(0, 1fr) auto;
+    align-items: start;
+  }
+}
+
+@media (max-width: 420px) {
+  .inventory-save-summary-card__details {
+    grid-template-columns: 1fr;
+  }
+}
