diff --git a/apps/web/src/app/globals.css b/apps/web/src/app/globals.css
index 2f221bf..46a8070 100644
--- a/apps/web/src/app/globals.css
+++ b/apps/web/src/app/globals.css
@@ -5273,3 +5273,170 @@ html[data-theme="dark"] .onboarding-guide-primary {
     padding-left: 20px;
   }
 }
+
+/* WEB-THREAD7: constrained web thread shell */
+.web-app-viewport--thread {
+  display: grid;
+  min-height: 100dvh;
+  place-items: center;
+  padding: 0;
+  background:
+    radial-gradient(circle at top left, color-mix(in srgb, var(--app-surface) 62%, transparent), transparent 32rem),
+    var(--app-bg-muted);
+}
+
+.web-app-shell--thread {
+  width: min(100vw, 640px);
+  height: 100dvh;
+  min-height: 100dvh;
+  overflow: hidden;
+  border-right: 1px solid color-mix(in srgb, var(--app-border) 72%, transparent);
+  border-left: 1px solid color-mix(in srgb, var(--app-border) 72%, transparent);
+  background: var(--app-bg);
+  box-shadow: 0 24px 80px rgba(15, 23, 42, 0.14);
+}
+
+.web-scroll-area--thread {
+  height: 100%;
+  max-width: none;
+  margin: 0;
+  overflow: hidden;
+  padding: 0;
+  scrollbar-width: none;
+}
+
+.public-discussion-page--messages-only,
+.private-proposals-page--messages-only,
+.proposal-conversation-page--messages-only {
+  display: flex;
+  width: 100%;
+  max-width: 640px;
+  height: 100dvh;
+  min-height: 0;
+  flex-direction: column;
+  margin: 0 auto;
+  overflow: hidden;
+  background: var(--app-bg);
+}
+
+.public-discussion-page--messages-only .web-thread-header,
+.private-proposals-page--messages-only .web-thread-header,
+.proposal-conversation-page--messages-only .thread-page-header {
+  position: relative;
+  top: auto;
+  z-index: 20;
+  flex: 0 0 auto;
+  min-height: 58px;
+  margin: 0;
+  border-bottom: 1px solid var(--app-divider-strong);
+  background: color-mix(in srgb, var(--app-bg) 96%, transparent);
+  padding: 8px 16px;
+  backdrop-filter: blur(18px);
+}
+
+.public-discussion-page--messages-only .web-thread-header,
+.private-proposals-page--messages-only .web-thread-header {
+  grid-template-columns: 42px minmax(0, 1fr) 42px;
+}
+
+.public-discussion-page--messages-only .web-thread-header--loading,
+.private-proposals-page--messages-only .web-thread-header--loading {
+  grid-template-columns: minmax(0, 1fr);
+}
+
+.public-discussion-page--messages-only .web-thread-header h2,
+.private-proposals-page--messages-only .web-thread-header h2 {
+  overflow: hidden;
+  font-size: 17px;
+  letter-spacing: -0.02em;
+  line-height: 1.15;
+  text-overflow: ellipsis;
+  white-space: nowrap;
+}
+
+.public-discussion-page--messages-only .web-thread-loading-list,
+.private-proposals-page--messages-only .web-thread-loading-list,
+.proposal-conversation-page--messages-only .web-thread-loading-list,
+.public-discussion-page--messages-only .web-thread-options-list,
+.private-proposals-page--messages-only .web-thread-options-list,
+.public-discussion-page--messages-only .web-thread-info-page,
+.private-proposals-page--messages-only .web-thread-info-page,
+.proposal-conversation-page--messages-only .thread-full-page {
+  flex: 1 1 auto;
+  min-height: 0;
+  overflow-y: auto;
+}
+
+.public-discussion-section--messages-only {
+  display: flex;
+  min-height: 0;
+  flex: 1 1 auto;
+  flex-direction: column;
+  overflow-y: auto;
+  padding: 0 16px;
+  scrollbar-width: none;
+}
+
+.public-discussion-section--messages-only::-webkit-scrollbar,
+.private-proposals-section--clean::-webkit-scrollbar,
+.proposal-thread-message-list::-webkit-scrollbar,
+.proposal-conversation-page--messages-only .thread-full-page::-webkit-scrollbar {
+  display: none;
+}
+
+.public-discussion-composer--messages-only {
+  bottom: 0;
+  flex: 0 0 auto;
+  margin: auto -16px 0;
+  padding: 10px 16px max(10px, env(safe-area-inset-bottom));
+}
+
+.private-proposals-page--messages-only .private-proposals-section--clean {
+  flex: 1 1 auto;
+  min-height: 0;
+  overflow-y: auto;
+  padding: 0 16px 24px;
+}
+
+.proposal-conversation-page--messages-only .proposal-thread-notice {
+  flex: 0 0 auto;
+  margin: 10px 16px 0;
+}
+
+.proposal-conversation-page--messages-only .thread-message-page {
+  display: flex;
+  min-height: 0;
+  flex: 1 1 auto;
+  flex-direction: column;
+  gap: 0;
+  overflow: hidden;
+  padding: 0;
+}
+
+.proposal-conversation-page--messages-only .proposal-thread-message-list {
+  flex: 1 1 auto;
+  min-height: 0;
+  overflow-y: auto;
+  padding: 18px 16px 12px;
+}
+
+.proposal-conversation-page--messages-only .thread-bottom-composer,
+.proposal-conversation-page--messages-only .thread-closed-copy {
+  position: static;
+  flex: 0 0 auto;
+  margin: 0;
+  padding-right: 16px;
+  padding-left: 16px;
+}
+
+@media (max-width: 640px) {
+  .web-app-shell--thread,
+  .public-discussion-page--messages-only,
+  .private-proposals-page--messages-only,
+  .proposal-conversation-page--messages-only {
+    max-width: none;
+    border-right: 0;
+    border-left: 0;
+    box-shadow: none;
+  }
+}
