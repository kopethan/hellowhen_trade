diff --git a/apps/web/src/app/globals.css b/apps/web/src/app/globals.css
index 9d2814e..8bd48f5 100644
--- a/apps/web/src/app/globals.css
+++ b/apps/web/src/app/globals.css
@@ -7593,3 +7593,119 @@ html[data-theme="dark"] .onboarding-guide-primary {
     margin-left: 0;
   }
 }
+
+/* WEB-THREAD21: private thread header and summary strip polish */
+.proposal-conversation-page--messages-only .thread-page-header__back,
+.proposal-conversation-page--messages-only .thread-page-header__menu {
+  padding: 0;
+}
+
+.proposal-conversation-page--messages-only .thread-page-header__back .web-icon,
+.proposal-conversation-page--messages-only .thread-page-header__menu .web-icon {
+  opacity: 0.92;
+}
+
+.proposal-conversation-page--messages-only .thread-page-header__menu {
+  padding-bottom: 0;
+}
+
+.proposal-conversation-page--messages-only .private-thread-summary-strip {
+  gap: 8px;
+  border-color: color-mix(in srgb, var(--app-border) 68%, transparent);
+  background: color-mix(in srgb, var(--app-surface) 82%, transparent);
+  padding: 13px 14px;
+  box-shadow: none;
+}
+
+.private-thread-summary-strip__topline {
+  display: flex;
+  align-items: center;
+  justify-content: space-between;
+  gap: 10px;
+  min-width: 0;
+}
+
+.private-thread-summary-strip__kind {
+  overflow: hidden;
+  color: var(--app-text-muted);
+  font-size: 11px;
+  font-weight: 950;
+  letter-spacing: 0.05em;
+  line-height: 1.2;
+  text-overflow: ellipsis;
+  text-transform: uppercase;
+  white-space: nowrap;
+}
+
+.proposal-conversation-page--messages-only .private-thread-summary-strip__main strong {
+  font-size: 17px;
+  line-height: 1.16;
+  white-space: normal;
+}
+
+.proposal-conversation-page--messages-only .private-thread-summary-strip__main p {
+  color: var(--app-text-muted);
+  font-size: 12px;
+  font-weight: 850;
+}
+
+.proposal-conversation-page--messages-only .private-thread-summary-strip__actions {
+  justify-content: flex-start;
+}
+
+.proposal-conversation-page--messages-only .private-thread-summary-strip__actions button {
+  border-color: color-mix(in srgb, var(--app-border) 70%, transparent);
+  background: color-mix(in srgb, var(--app-surface-soft) 72%, transparent);
+}
+
+@media (min-width: 760px) {
+  .proposal-conversation-page--messages-only .thread-page-header {
+    grid-template-columns: 44px minmax(0, 1fr) 44px;
+    align-items: center;
+    min-height: 62px;
+    padding-top: 8px;
+    padding-bottom: 8px;
+  }
+
+  .proposal-conversation-page--messages-only .thread-page-header h1 {
+    font-size: 22px;
+  }
+
+  .proposal-conversation-page--messages-only .private-thread-summary-strip {
+    display: grid;
+    grid-template-columns: minmax(0, 1fr) auto;
+    align-items: end;
+    gap: 8px 16px;
+    margin-top: 0;
+    margin-bottom: 6px;
+    border-radius: 26px;
+    padding: 16px;
+  }
+
+  .proposal-conversation-page--messages-only .private-thread-summary-strip__topline,
+  .proposal-conversation-page--messages-only .private-thread-summary-strip__main,
+  .proposal-conversation-page--messages-only .private-thread-summary-strip__items {
+    grid-column: 1;
+  }
+
+  .proposal-conversation-page--messages-only .private-thread-summary-strip__actions {
+    grid-column: 2;
+    grid-row: 1 / span 3;
+    align-self: end;
+    justify-content: flex-end;
+  }
+}
+
+@media (max-width: 759px) {
+  .proposal-conversation-page--messages-only .private-thread-summary-strip {
+    margin-top: 8px;
+    border: 1px solid color-mix(in srgb, var(--app-border) 64%, transparent);
+    border-radius: 22px;
+    background: color-mix(in srgb, var(--app-surface) 84%, transparent);
+    padding: 13px;
+  }
+
+  .proposal-conversation-page--messages-only .private-thread-summary-strip__actions button {
+    min-height: 38px;
+  }
+}
