 }
 
+/* Shared normal-app feed headers */
+.feed-world-header { display: flex; align-items: center; justify-content: space-between; gap: 12px; min-width: 0; }
+.feed-world-header__copy { min-width: 0; }
+.feed-world-header h1 { margin: 0; font-size: 32px; line-height: 1; letter-spacing: -0.06em; }
+.feed-world-header__actions { flex: 0 0 auto; display: flex; align-items: center; justify-content: flex-end; gap: 8px; }
+.feed-world-action { position: relative; flex: 0 0 auto; }
+.feed-world-header .trade-feed-controls { display: grid; grid-template-columns: repeat(3, 42px); align-items: center; justify-content: end; width: auto; margin: 0; padding: 0; gap: 8px; background: transparent; }
+.feed-world-header .trade-filter-pill,
+.feed-world-header .trade-activity-pill,
+.feed-world-header .trade-create-pill { width: 42px; height: 42px; min-height: 42px; padding: 0; }
+.feed-world-header .trade-filter-pill .trade-action-label,
+.feed-world-header .trade-activity-pill .trade-action-label,
+.feed-world-header .trade-create-pill .trade-action-label { display: none; }
+.feed-world-header .trade-create-pill { min-width: 42px; border: 1px solid transparent; background: var(--trade-bg); color: var(--trade-text); }
+.feed-world-header .trade-filter-pill:hover,
+.feed-world-header .trade-activity-pill:hover,
+.feed-world-header .trade-create-pill:hover,
+.feed-world-header .plans-feed-icon-button:hover { border-color: var(--app-border-strong); transform: translateY(-1px); }
+.feed-world-header .trade-filter-pill:focus-visible,
+.feed-world-header .trade-activity-pill:focus-visible,
+.feed-world-header .trade-create-pill:focus-visible,
+.feed-world-header .plans-feed-icon-button:focus-visible { outline: 3px solid color-mix(in srgb, var(--proposal-border) 42%, transparent); outline-offset: 3px; }
+@media (max-width: 540px) {
+  .feed-world-header h1 { font-size: 30px; }
+  .feed-world-header__actions, .feed-world-header .trade-feed-controls { gap: 7px; }
+  .feed-world-header .trade-feed-controls { grid-template-columns: repeat(3, 40px); }
+  .feed-world-header .trade-filter-pill,
+  .feed-world-header .trade-activity-pill,
+  .feed-world-header .trade-create-pill,
+  .feed-world-header .plans-feed-icon-button { width: 40px; height: 40px; min-height: 40px; }
+}
+
 /* Hidden Plans production shell */
 .plans-page .page-intro h2 { margin-bottom: 6px; }
 .plans-feed-page { gap: 14px; }
