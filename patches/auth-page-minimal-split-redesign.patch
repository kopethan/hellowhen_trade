+  letter-spacing: -0.075em;
+}
+.auth-info-brand p,
+.auth-account-help p {
+  margin: 0;
+}
+.auth-trust-list {
+  display: grid;
+  gap: 10px;
+  margin: 0;
+  padding: 0;
+  list-style: none;
+}
+.auth-trust-list li {
+  position: relative;
+  padding-left: 24px;
+  color: var(--app-text);
+  font-size: 14px;
+  font-weight: 850;
+  line-height: 1.4;
+}
+.auth-trust-list li::before {
+  content: '✓';
+  position: absolute;
+  left: 0;
+  top: 0;
+  color: var(--success-text);
+  font-weight: 1000;
+}
+.auth-account-help {
