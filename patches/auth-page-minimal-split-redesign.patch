+  padding-top: 14px;
+}
+.auth-policy-links a {
+  color: var(--app-text-muted);
+  font-size: 12px;
+  font-weight: 900;
+  text-decoration: none;
+}
+.auth-policy-links a:hover,
+.auth-policy-links a:focus-visible {
+  color: var(--app-text);
+  text-decoration: underline;
+}
+.auth-recovery-links { display: grid; gap: 10px; }
