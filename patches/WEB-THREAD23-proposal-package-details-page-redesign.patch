diff --git a/apps/web/src/app/globals.css b/apps/web/src/app/globals.css
index 8bd48f5..27ef593 100644
--- a/apps/web/src/app/globals.css
+++ b/apps/web/src/app/globals.css
@@ -7709,3 +7709,197 @@ html[data-theme="dark"] .onboarding-guide-primary {
     min-height: 38px;
   }
 }
+
+/* WEB-THREAD23: proposal package details page redesign */
+.proposal-package-page {
+  gap: 14px;
+  padding-bottom: 28px;
+}
+
+.proposal-package-hero,
+.proposal-package-card {
+  display: grid;
+  gap: 11px;
+  border: 1px solid color-mix(in srgb, var(--app-border) 82%, transparent);
+  border-radius: 24px;
+  background: color-mix(in srgb, var(--app-surface) 84%, transparent);
+  padding: 14px;
+}
+
+.proposal-package-hero {
+  gap: 9px;
+  background:
+    linear-gradient(135deg, color-mix(in srgb, var(--proposal-bg) 30%, transparent), transparent 60%),
+    color-mix(in srgb, var(--app-surface) 88%, transparent);
+}
+
+.proposal-package-hero__badges {
+  display: flex;
+  flex-wrap: wrap;
+  gap: 8px;
+  align-items: center;
+}
+
+.proposal-package-card__heading span {
+  margin: 0;
+  color: var(--app-text);
+  font-weight: 950;
+  letter-spacing: -0.035em;
+  line-height: 1.12;
+}
+
+
+.proposal-package-hero p,
+.proposal-package-card__heading p,
+.proposal-package-empty,
+.proposal-package-card__eyebrow {
+  margin: 0;
+  color: var(--app-text-muted);
+  font-size: 13px;
+  font-weight: 800;
+  line-height: 1.45;
+}
+
+.proposal-package-card__heading {
+  display: grid;
+  gap: 4px;
+}
+
+.proposal-package-card__heading span {
+  font-size: 16px;
+}
+
+.proposal-package-card__eyebrow,
+.proposal-package-section__label {
+  font-size: 10px;
+  font-weight: 950;
+  letter-spacing: .1em;
+  text-transform: uppercase;
+}
+
+.proposal-package-identity.user-identity-link,
+.proposal-package-card--sender .user-identity-link {
+  width: fit-content;
+  border-radius: 999px;
+  background: color-mix(in srgb, var(--app-surface-soft) 62%, transparent);
+  padding: 7px 10px 7px 7px;
+}
+
+.proposal-package-message {
+  margin: 0;
+  border-left: 3px solid color-mix(in srgb, var(--proposal-border) 76%, transparent);
+  color: var(--app-text);
+  padding-left: 11px;
+  font-size: 15px;
+  font-weight: 850;
+  line-height: 1.5;
+  overflow-wrap: anywhere;
+}
+
+.proposal-package-message--muted,
+.proposal-package-empty {
+  border-left-color: color-mix(in srgb, var(--app-border) 82%, transparent);
+  color: var(--app-text-muted);
+}
+
+.proposal-package-item-stack {
+  display: grid;
+  gap: 12px;
+}
+
+.proposal-package-item-card {
+  display: grid;
+  gap: 10px;
+  border: 1px solid color-mix(in srgb, var(--app-border) 72%, transparent);
+  border-radius: 22px;
+  background: color-mix(in srgb, var(--app-bg-muted) 52%, var(--app-surface));
+  padding: 11px;
+}
+
+.proposal-package-item-card .proposal-side-preview {
+  border: 0;
+  background: transparent;
+  padding: 0;
+  box-shadow: none;
+}
+
+.proposal-package-item-card .proposal-side-details {
+  border-color: color-mix(in srgb, var(--app-border) 62%, transparent);
+  background: color-mix(in srgb, var(--app-surface) 76%, transparent);
+}
+
+.proposal-package-card--actions {
+  gap: 12px;
+}
+
+.proposal-package-actions__group {
+  margin: 0;
+}
+
+.proposal-package-card--actions .proposal-detail-actions,
+.proposal-package-card--actions .message-actions {
+  gap: 8px;
+}
+
+.proposal-edit-form--package {
+  gap: 12px;
+}
+
+.proposal-edit-form--package textarea {
+  min-height: 110px;
+  border-radius: 18px;
+}
+
+@media (min-width: 760px) {
+  .proposal-package-page {
+    max-width: 760px;
+    margin: 0 auto;
+    padding-top: 2px;
+  }
+
+  .proposal-package-hero,
+  .proposal-package-card {
+    border-radius: 26px;
+    padding: 16px;
+  }
+
+  .proposal-package-card--sender {
+    grid-template-columns: auto minmax(0, 1fr);
+    align-items: center;
+    gap: 14px;
+  }
+
+  .proposal-package-card--sender .proposal-package-card__eyebrow {
+    min-width: 74px;
+  }
+
+  .proposal-package-item-card {
+    padding: 13px;
+  }
+}
+
+@media (max-width: 759px) {
+  .proposal-package-page {
+    padding: 12px 0 24px;
+  }
+
+  .proposal-package-hero,
+  .proposal-package-card {
+    border-radius: 22px;
+    padding: 13px;
+  }
+
+
+  .proposal-package-card--actions .proposal-detail-actions,
+  .proposal-package-card--actions .message-actions,
+  .proposal-edit-form--package .proposal-edit-form__actions {
+    display: grid;
+    grid-template-columns: 1fr;
+  }
+
+  .proposal-package-card--actions .proposal-detail-actions button,
+  .proposal-package-card--actions .message-actions button,
+  .proposal-edit-form--package .proposal-edit-form__actions button {
+    width: 100%;
+  }
+}
