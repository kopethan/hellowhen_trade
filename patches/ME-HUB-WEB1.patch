diff --git a/apps/web/src/app/globals.css b/apps/web/src/app/globals.css
index 88b6175..b5941ee 100644
--- a/apps/web/src/app/globals.css
+++ b/apps/web/src/app/globals.css
@@ -10009,3 +10009,271 @@ html[data-theme="dark"] .onboarding-guide-primary {
 @media (max-width: 560px) {
   .app-filter-options { grid-template-columns: minmax(0, 1fr); }
 }
+
+/* ME-HUB-WEB1: make Account behave like the normal Me hub in the Plans · Me · Trade shell. */
+.web-app-page--me {
+  --web-app-page-max: min(1120px, 100%);
+  display: grid;
+  gap: 18px;
+}
+
+.me-hub-page {
+  display: grid;
+  gap: 18px;
+}
+
+.me-hub-hero {
+  display: grid;
+  gap: 16px;
+  border: 1px solid color-mix(in srgb, var(--instruction-border) 42%, var(--app-border));
+  border-radius: 34px;
+  background:
+    radial-gradient(circle at 0 0, color-mix(in srgb, var(--instruction-bg) 72%, transparent), transparent 34%),
+    linear-gradient(135deg, color-mix(in srgb, var(--app-surface) 88%, var(--instruction-bg)), var(--app-surface));
+  padding: 18px;
+  box-shadow: var(--app-card-shadow-strong);
+}
+
+.me-hub-hero--signed-in {
+  border-color: color-mix(in srgb, var(--success-border) 28%, var(--app-border));
+  background:
+    radial-gradient(circle at 0 0, color-mix(in srgb, var(--success-bg) 48%, transparent), transparent 34%),
+    linear-gradient(135deg, color-mix(in srgb, var(--app-surface) 90%, var(--success-bg)), var(--app-surface));
+}
+
+.me-hub-hero__identity {
+  display: grid;
+  grid-template-columns: auto minmax(0, 1fr);
+  gap: 14px;
+  align-items: center;
+}
+
+.me-hub-hero__copy {
+  min-width: 0;
+}
+
+.me-hub-hero__copy h1 {
+  margin: 8px 0 6px;
+  overflow-wrap: anywhere;
+}
+
+.me-hub-hero__copy p,
+.me-hub-hero__loading {
+  margin: 0;
+  color: var(--app-text-muted);
+  font-size: 13px;
+  font-weight: 800;
+  line-height: 1.4;
+}
+
+.me-hub-hero__actions {
+  display: flex;
+  flex-wrap: wrap;
+  gap: 10px;
+}
+
+.me-hub-hero__actions .button,
+.me-hub-hero__actions button {
+  flex: 1 1 150px;
+  min-height: 42px;
+}
+
+.me-hub-stat-grid {
+  display: grid;
+  grid-template-columns: repeat(2, minmax(0, 1fr));
+  gap: 10px;
+}
+
+.me-hub-stat-card {
+  display: grid;
+  grid-template-columns: auto minmax(0, 1fr);
+  gap: 10px;
+  align-items: center;
+  min-height: 82px;
+  border: 1px solid var(--app-border);
+  border-radius: 24px;
+  background: var(--app-surface);
+  padding: 13px;
+  box-shadow: var(--app-control-shadow);
+  transition: border-color 160ms ease, box-shadow 160ms ease, transform 160ms ease;
+}
+
+.me-hub-stat-card:hover {
+  border-color: var(--app-border-strong);
+  text-decoration: none;
+  transform: translateY(-1px);
+}
+
+.me-hub-stat-card__icon {
+  display: grid;
+  place-items: center;
+  width: 38px;
+  height: 38px;
+  border: 1px solid var(--app-border);
+  border-radius: 15px;
+  background: var(--app-surface-soft);
+  color: var(--app-text);
+}
+
+.me-hub-stat-card span:not(.web-icon) {
+  display: grid;
+  gap: 2px;
+  min-width: 0;
+}
+
+.me-hub-stat-card strong {
+  color: var(--app-text);
+  font-size: 24px;
+  font-weight: 950;
+  letter-spacing: -0.05em;
+  line-height: 1;
+}
+
+.me-hub-stat-card small {
+  overflow: hidden;
+  color: var(--app-text-muted);
+  font-size: 11px;
+  font-weight: 900;
+  line-height: 1.25;
+  text-overflow: ellipsis;
+  white-space: nowrap;
+}
+
+.me-hub-stat-card--trade .me-hub-stat-card__icon,
+.me-hub-link-card--trade .mobile-link-card__icon { border-color: color-mix(in srgb, var(--trade-border) 54%, var(--app-border)); background: var(--trade-bg); color: var(--trade-text); }
+.me-hub-stat-card--need .me-hub-stat-card__icon,
+.me-hub-link-card--need .mobile-link-card__icon { border-color: color-mix(in srgb, var(--need-border) 54%, var(--app-border)); background: var(--need-bg); color: var(--need-text); }
+.me-hub-stat-card--offer .me-hub-stat-card__icon,
+.me-hub-link-card--offer .mobile-link-card__icon { border-color: color-mix(in srgb, var(--offer-border) 54%, var(--app-border)); background: var(--offer-bg); color: var(--offer-text); }
+.me-hub-stat-card--plan .me-hub-stat-card__icon,
+.me-hub-link-card--plan .mobile-link-card__icon { border-color: color-mix(in srgb, var(--plan-border) 54%, var(--app-border)); background: var(--plan-bg); color: var(--plan-text); }
+.me-hub-stat-card--proposal .me-hub-stat-card__icon,
+.me-hub-link-card--proposal .mobile-link-card__icon { border-color: color-mix(in srgb, var(--proposal-border) 54%, var(--app-border)); background: var(--proposal-bg); color: var(--proposal-text); }
+.me-hub-stat-card--danger .me-hub-stat-card__icon,
+.me-hub-link-card--danger .mobile-link-card__icon { border-color: color-mix(in srgb, var(--danger-border) 54%, var(--app-border)); background: var(--danger-bg); color: var(--danger-text); }
+
+.me-hub-section {
+  gap: 12px;
+  border: 1px solid color-mix(in srgb, var(--app-border) 76%, transparent);
+  border-radius: 30px;
+  background: color-mix(in srgb, var(--app-surface) 96%, transparent);
+  padding: 14px;
+  box-shadow: var(--app-card-shadow);
+}
+
+.me-hub-section--quick {
+  border-color: color-mix(in srgb, var(--trade-border) 26%, var(--app-border));
+}
+
+.me-hub-section__header {
+  align-items: flex-start;
+}
+
+.me-hub-section__header h2 {
+  margin: 4px 0 0;
+  font-size: 17px;
+  letter-spacing: -0.03em;
+}
+
+.me-hub-section__header p {
+  max-width: 320px;
+  text-align: right;
+}
+
+.me-hub-list {
+  gap: 8px;
+}
+
+.me-hub-link-card {
+  align-items: center;
+  border-radius: 22px;
+  background: color-mix(in srgb, var(--app-surface-soft) 60%, var(--app-surface));
+}
+
+.me-hub-link-card:hover {
+  transform: translateY(-1px);
+}
+
+.me-hub-link-card__body-text {
+  display: block;
+  margin-top: 4px;
+  color: var(--app-text-muted);
+  font-size: 12px;
+  font-weight: 800;
+  line-height: 1.35;
+}
+
+.me-hub-layout {
+  display: grid;
+  gap: 16px;
+}
+
+.me-hub-layout__main,
+.me-hub-layout__side {
+  display: grid;
+  align-content: start;
+  gap: 16px;
+}
+
+@media (min-width: 760px) {
+  .web-app-page--me {
+    padding-bottom: 16px;
+  }
+
+  .me-hub-page {
+    gap: 20px;
+  }
+
+  .me-hub-hero {
+    grid-template-columns: minmax(0, 1fr) auto;
+    align-items: center;
+    padding: 22px;
+  }
+
+  .me-hub-hero__actions {
+    justify-content: flex-end;
+    min-width: 250px;
+  }
+
+  .me-hub-hero__actions .button,
+  .me-hub-hero__actions button {
+    flex: 0 0 auto;
+  }
+
+  .me-hub-stat-grid {
+    grid-template-columns: repeat(4, minmax(0, 1fr));
+  }
+
+  .me-hub-layout {
+    grid-template-columns: minmax(0, 1.18fr) minmax(320px, 0.82fr);
+    align-items: start;
+  }
+
+  .me-hub-quick-grid {
+    grid-template-columns: repeat(3, minmax(0, 1fr));
+  }
+}
+
+@media (max-width: 560px) {
+  .me-hub-hero__identity {
+    grid-template-columns: 1fr;
+  }
+
+  .me-hub-hero__actions {
+    display: grid;
+    grid-template-columns: 1fr;
+  }
+
+  .me-hub-stat-grid {
+    grid-template-columns: 1fr;
+  }
+
+  .me-hub-section__header {
+    display: grid;
+  }
+
+  .me-hub-section__header p {
+    max-width: none;
+    text-align: left;
+  }
+}
