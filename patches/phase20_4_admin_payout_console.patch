 }
+
+/* Phase 20.4: admin payout console */
+.admin-console { display: grid; gap: 18px; width: min(100%, 1440px); margin: 0 auto; }
+.admin-console__hero { display: grid; gap: 16px; }
+.admin-console__login-grid { display: grid; grid-template-columns: minmax(0, 1fr) minmax(0, 1fr); gap: 10px; }
+.admin-metric-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(190px, 1fr)); gap: 12px; }
+.admin-metric-card { display: grid; align-content: start; gap: 8px; min-height: 132px; border: 1px solid var(--app-border); border-radius: 24px; background: var(--app-surface); padding: 14px; }
+.admin-metric-card strong { font-size: 30px; letter-spacing: -0.05em; }
+.admin-metric-card p { margin: 0; color: var(--app-text-muted); font-size: 12px; font-weight: 800; }
+.admin-payout-layout { display: grid; grid-template-columns: minmax(320px, 0.75fr) minmax(0, 1.7fr); gap: 16px; align-items: start; }
+.admin-payout-list { position: sticky; top: 16px; display: grid; gap: 10px; max-height: calc(100dvh - 32px); overflow: auto; }
+.admin-payout-row { display: grid; grid-template-columns: minmax(0, 1fr) auto; align-items: center; gap: 12px; width: 100%; border: 1px solid var(--app-border); border-radius: 18px; background: var(--app-surface-soft); color: var(--app-text); padding: 12px; text-align: left; }
+.admin-payout-row.is-active { border-color: var(--proposal-border); background: color-mix(in srgb, var(--proposal-bg) 42%, var(--app-surface)); }
+.admin-payout-row span { display: grid; gap: 5px; min-width: 0; }
+.admin-payout-row strong { font-size: 17px; }
+.admin-payout-row small { overflow: hidden; color: var(--app-text-muted); font-size: 12px; font-weight: 800; text-overflow: ellipsis; white-space: nowrap; }
+.admin-payout-row em { font-style: normal; justify-self: end; }
+.admin-payout-detail { display: grid; gap: 16px; min-width: 0; }
+.admin-money-strip { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 10px; margin: 12px 0; }
+.admin-money-strip span { display: grid; gap: 5px; border: 1px solid var(--app-border); border-radius: 18px; background: var(--app-surface-soft); padding: 12px; }
+.admin-money-strip small { color: var(--app-text-muted); font-weight: 900; text-transform: uppercase; letter-spacing: .06em; }
+.admin-money-strip strong { font-size: 22px; letter-spacing: -0.04em; }
+.admin-action-card { display: grid; gap: 12px; }
+.admin-action-grid { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 10px; }
+.admin-detail-grid { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 16px; align-items: start; }
+.admin-table-card { overflow-x: auto; }
+.admin-table-card table { width: 100%; border-collapse: collapse; font-size: 13px; }
+.admin-table-card td, .admin-table-card th { border-bottom: 1px solid var(--app-border); padding: 9px 8px; vertical-align: top; }
+.admin-table-card tr:last-child td { border-bottom: 0; }
+
+@media (max-width: 900px) {
+  .admin-payout-layout, .admin-detail-grid, .admin-money-strip { grid-template-columns: 1fr; }
+  .admin-payout-list { position: static; max-height: none; }
+  .admin-action-grid, .admin-console__login-grid { grid-template-columns: 1fr; }
+}
+.admin-trust-controls { display: grid; grid-template-columns: minmax(0, .8fr) minmax(0, 1.4fr) auto; gap: 8px; margin-top: 12px; }
+@media (max-width: 900px) { .admin-trust-controls { grid-template-columns: 1fr; } }
