diff --git a/apps/web/src/app/globals.css b/apps/web/src/app/globals.css
index d600b30..8b2f1db 100644
--- a/apps/web/src/app/globals.css
+++ b/apps/web/src/app/globals.css
@@ -4186,3 +4186,116 @@ html[data-theme="dark"] .onboarding-guide-primary {
     min-width: min(220px, calc(100vw - 32px));
   }
 }
+
+/* WIZARD21: web source picker modal / mobile sheet */
+.trade-side-choice-card--button {
+  appearance: none;
+  width: 100%;
+  border: 0;
+  background: transparent;
+  color: inherit;
+  padding: 0;
+  text-align: left;
+  cursor: pointer;
+}
+.trade-side-source-trigger {
+  appearance: none;
+  display: grid;
+  grid-template-columns: 46px minmax(0, 1fr);
+  gap: 10px;
+  align-items: center;
+  width: 100%;
+  border: 1px solid var(--app-border);
+  border-radius: 22px;
+  background: var(--app-surface-soft);
+  color: var(--app-text);
+  padding: 12px;
+  text-align: left;
+  cursor: pointer;
+}
+.trade-side-source-trigger > span {
+  grid-row: span 2;
+  display: grid;
+  place-items: center;
+  width: 46px;
+  height: 46px;
+  border-radius: 16px;
+  background: var(--app-bg-muted);
+  color: var(--app-text-soft);
+}
+.trade-side-source-trigger strong { align-self: end; }
+.trade-side-source-trigger small { align-self: start; color: var(--app-text-muted); font-size: 12px; font-weight: 800; line-height: 1.35; }
+.trade-source-modal {
+  position: fixed;
+  inset: 0;
+  z-index: 80;
+  display: grid;
+  place-items: center;
+  padding: 18px;
+  background: color-mix(in srgb, #000 42%, transparent);
+  backdrop-filter: blur(10px);
+}
+.trade-source-modal__sheet {
+  display: grid;
+  gap: 14px;
+  width: min(100%, 430px);
+  max-height: min(720px, calc(100dvh - 36px));
+  overflow: auto;
+  border: 1px solid var(--app-border);
+  border-radius: 28px;
+  background: var(--app-surface);
+  box-shadow: 0 28px 80px color-mix(in srgb, #000 28%, transparent);
+  padding: 16px;
+}
+.trade-source-modal__handle { display: none; }
+.trade-source-modal__header {
+  display: grid;
+  grid-template-columns: minmax(0, 1fr) 36px;
+  align-items: start;
+  gap: 12px;
+}
+.trade-source-modal__header h3,
+.trade-source-modal__header p { margin: 0; }
+.trade-source-modal__header p:not(.eyebrow) { color: var(--app-text-muted); font-size: 13px; font-weight: 760; line-height: 1.45; }
+.trade-source-modal__close {
+  appearance: none;
+  display: grid;
+  place-items: center;
+  width: 36px;
+  height: 36px;
+  border: 1px solid var(--app-border);
+  border-radius: 999px;
+  background: var(--app-surface-soft);
+  color: var(--app-text);
+  font: inherit;
+  font-size: 22px;
+  line-height: 1;
+  cursor: pointer;
+}
+.trade-side-source-grid--modal { gap: 10px; }
+.trade-side-choice-card--button:focus-visible,
+.trade-side-source-trigger:focus-visible,
+.trade-source-modal__close:focus-visible { outline: 3px solid color-mix(in srgb, var(--proposal-border) 72%, transparent); outline-offset: 3px; }
+@media (max-width: 640px) {
+  .trade-source-modal {
+    place-items: end stretch;
+    padding: 0;
+  }
+  .trade-source-modal__sheet {
+    width: 100%;
+    max-height: min(78dvh, 620px);
+    border-right: 0;
+    border-bottom: 0;
+    border-left: 0;
+    border-radius: 28px 28px 0 0;
+    padding: 10px 14px calc(14px + env(safe-area-inset-bottom));
+  }
+  .trade-source-modal__handle {
+    display: block;
+    justify-self: center;
+    width: 44px;
+    height: 5px;
+    border-radius: 999px;
+    background: var(--app-border-strong);
+  }
+}
