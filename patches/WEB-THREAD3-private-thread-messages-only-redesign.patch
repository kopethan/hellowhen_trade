diff --git a/apps/web/src/app/globals.css b/apps/web/src/app/globals.css
index c2e40eb..78ee92c 100644
--- a/apps/web/src/app/globals.css
+++ b/apps/web/src/app/globals.css
@@ -5016,3 +5016,231 @@ html[data-theme="dark"] .onboarding-guide-primary {
 @media (max-width: 420px) {
   .public-discussion-composer--messages-only { grid-template-columns: minmax(0, 1fr) auto; }
 }
+
+/* Web thread messages-only layout */
+.proposal-conversation-page--messages-only {
+  min-height: 100dvh;
+  padding-top: 0;
+}
+.thread-page-header {
+  position: sticky;
+  top: 0;
+  z-index: 12;
+  display: grid;
+  grid-template-columns: 44px minmax(0, 1fr) 44px;
+  align-items: center;
+  min-height: 58px;
+  margin: -10px -16px 0;
+  border-bottom: 1px solid var(--app-border);
+  background: color-mix(in srgb, var(--app-bg) 94%, transparent);
+  padding: 8px 16px;
+  backdrop-filter: blur(18px);
+}
+.thread-page-header h1 {
+  margin: 0;
+  overflow: hidden;
+  color: var(--app-text);
+  font-size: 17px;
+  font-weight: 950;
+  letter-spacing: -0.02em;
+  text-align: center;
+  text-overflow: ellipsis;
+  white-space: nowrap;
+}
+.thread-page-header__back,
+.thread-page-header__menu {
+  display: grid;
+  place-items: center;
+  width: 40px;
+  height: 40px;
+  border: 0;
+  border-radius: 999px;
+  background: transparent;
+  color: var(--app-text);
+  font-size: 24px;
+  font-weight: 900;
+  line-height: 1;
+  text-decoration: none;
+}
+.thread-page-header__menu {
+  justify-self: end;
+  font-size: 28px;
+  padding-bottom: 6px;
+}
+.thread-page-header__back:hover,
+.thread-page-header__back:focus-visible,
+.thread-page-header__menu:hover,
+.thread-page-header__menu:focus-visible {
+  background: var(--app-surface-soft);
+  outline: none;
+}
+.proposal-thread-notice {
+  margin: 12px 0 0;
+}
+.thread-full-page,
+.thread-message-page {
+  display: grid;
+  gap: 16px;
+  padding: 18px 0 0;
+}
+.thread-full-page h2 {
+  margin: 0;
+  color: var(--app-text);
+  font-size: 22px;
+  font-weight: 950;
+  letter-spacing: -0.04em;
+  line-height: 1.1;
+}
+.thread-option-list {
+  display: grid;
+  margin-right: -16px;
+  margin-left: -16px;
+  border-top: 1px solid var(--app-border);
+}
+.thread-option-row {
+  display: grid;
+  grid-template-columns: 42px minmax(0, 1fr) auto;
+  align-items: center;
+  gap: 12px;
+  width: 100%;
+  min-height: 70px;
+  border: 0;
+  border-bottom: 1px solid var(--app-border);
+  background: transparent;
+  color: var(--app-text);
+  padding: 13px 16px;
+  text-align: left;
+  text-decoration: none;
+}
+.thread-option-row:hover,
+.thread-option-row:focus-visible {
+  background: var(--app-surface-soft);
+  outline: none;
+}
+.thread-option-row--danger .thread-option-row__icon,
+.thread-option-row--danger .thread-option-row__body strong {
+  color: var(--danger-text);
+}
+.thread-option-row__icon {
+  display: grid;
+  place-items: center;
+  width: 42px;
+  height: 42px;
+  border-radius: 999px;
+  background: var(--app-surface-soft);
+  color: var(--proposal-text);
+}
+.thread-option-row__body {
+  display: grid;
+  gap: 3px;
+  min-width: 0;
+}
+.thread-option-row__body strong {
+  overflow: hidden;
+  color: var(--app-text);
+  font-size: 15px;
+  font-weight: 950;
+  text-overflow: ellipsis;
+  white-space: nowrap;
+}
+.thread-option-row__body small {
+  color: var(--app-text-muted);
+  font-size: 12px;
+  font-weight: 750;
+  line-height: 1.35;
+}
+.thread-option-row__chevron {
+  color: var(--app-text-muted);
+  font-size: 24px;
+  font-weight: 650;
+}
+.thread-guide-copy {
+  display: grid;
+  gap: 0;
+  margin-right: -16px;
+  margin-left: -16px;
+  border-top: 1px solid var(--app-border);
+}
+.thread-guide-copy p {
+  margin: 0;
+  border-bottom: 1px solid var(--app-border);
+  color: var(--app-text);
+  font-size: 15px;
+  font-weight: 750;
+  line-height: 1.5;
+  padding: 16px;
+}
+.thread-detail-section {
+  display: grid;
+  gap: 10px;
+}
+.proposal-detail-message {
+  margin: 0;
+  border-left: 3px solid var(--proposal-border);
+  color: var(--app-text);
+  font-size: 15px;
+  font-weight: 750;
+  line-height: 1.5;
+  padding-left: 12px;
+  overflow-wrap: anywhere;
+}
+.proposal-thread-message-list {
+  gap: 12px;
+  min-height: min(54dvh, 560px);
+}
+.thread-system-event {
+  justify-self: center;
+  width: fit-content;
+  max-width: 88%;
+  margin: 2px 0 8px;
+  border-radius: 999px;
+  background: var(--app-surface-soft);
+  color: var(--app-text-muted);
+  padding: 7px 11px;
+  font-size: 12px;
+  font-weight: 900;
+  line-height: 1.2;
+  text-align: center;
+}
+.thread-bottom-composer {
+  position: sticky;
+  bottom: 0;
+  margin: 0 -16px;
+  border-top: 1px solid var(--app-border);
+  background: color-mix(in srgb, var(--app-bg) 96%, transparent);
+  padding: 10px 16px max(10px, env(safe-area-inset-bottom));
+  backdrop-filter: blur(18px);
+}
+.thread-bottom-composer textarea {
+  min-height: 44px;
+  max-height: 144px;
+  border-radius: 18px;
+  resize: vertical;
+}
+.thread-closed-copy {
+  margin: 0 -16px;
+  border-top: 1px solid var(--app-border);
+  padding: 14px 16px;
+}
+.proposal-conversation-page--messages-only .proposal-conversation-list .message-bubble--proposal-package,
+.proposal-conversation-page--messages-only .accepted-deal-workspace {
+  display: none;
+}
+@media (min-width: 720px) {
+  .thread-page-header,
+  .thread-option-list,
+  .thread-guide-copy,
+  .thread-bottom-composer,
+  .thread-closed-copy {
+    margin-right: -20px;
+    margin-left: -20px;
+  }
+  .thread-page-header,
+  .thread-option-row,
+  .thread-guide-copy p,
+  .thread-bottom-composer,
+  .thread-closed-copy {
+    padding-right: 20px;
+    padding-left: 20px;
+  }
+}
