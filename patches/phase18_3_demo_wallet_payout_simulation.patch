+  const normalized = value.replace(',', '.').replace(/[^0-9.]/g, '');
+  if (!normalized) return 0;
+  const [whole, fraction = ''] = normalized.split('.');
+  return (Number.parseInt(whole || '0', 10) * 100) + Number.parseInt(fraction.padEnd(2, '0').slice(0, 2) || '0', 10);
+}
