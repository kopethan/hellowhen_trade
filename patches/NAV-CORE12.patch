diff --git a/apps/web/src/app/globals.css b/apps/web/src/app/globals.css
index c2ff5ae..947dc9b 100644
--- a/apps/web/src/app/globals.css
+++ b/apps/web/src/app/globals.css
@@ -9790,3 +9790,54 @@ html[data-theme="dark"] .onboarding-guide-primary {
 .trade-active-filter-card a { color: var(--trade-text); }
 .trade-filter-pill { position: relative; text-decoration: none; }
 .trade-filter-pill .plans-feed-icon-button__badge { top: -5px; right: -5px; }
+
+.app-filter-page {
+  --app-filter-accent-bg: var(--plan-bg);
+  --app-filter-accent-border: var(--plan-border);
+  --app-filter-accent-text: var(--plan-text);
+  gap: 14px;
+  padding-bottom: 96px;
+}
+.app-filter-page--trade {
+  --app-filter-accent-bg: var(--trade-bg);
+  --app-filter-accent-border: var(--trade-border);
+  --app-filter-accent-text: var(--trade-text);
+}
+.app-filter-header { display: flex; align-items: center; gap: 12px; min-width: 0; }
+.app-filter-header > div { min-width: 0; }
+.app-filter-header h1 { margin: 0; color: var(--app-text); font-size: 30px; line-height: 1.05; letter-spacing: -0.055em; }
+.app-filter-header p { margin: 3px 0 0; color: var(--app-text-muted); font-size: 13px; font-weight: 800; line-height: 1.35; }
+.app-filter-back { flex: 0 0 auto; }
+.app-filter-hero { display: flex; align-items: flex-start; gap: 12px; border: 1px solid var(--app-filter-accent-border); border-radius: 24px; background: var(--app-filter-accent-bg); padding: 14px; }
+.app-filter-hero__icon { display: inline-flex; align-items: center; justify-content: center; flex: 0 0 auto; width: 38px; height: 38px; border-radius: 19px; border: 1px solid var(--app-filter-accent-border); background: var(--app-surface); color: var(--app-filter-accent-text); font-size: 18px; font-weight: 950; }
+.app-filter-hero div { display: grid; gap: 4px; min-width: 0; }
+.app-filter-hero strong { color: var(--app-text); font-size: 18px; line-height: 23px; font-weight: 950; letter-spacing: -0.02em; }
+.app-filter-hero span { color: var(--app-text-muted); font-size: 13px; line-height: 18px; font-weight: 800; }
+.app-filter-search { display: grid; gap: 8px; border: 1px solid var(--app-border); border-radius: 22px; background: var(--app-surface); padding: 14px; box-shadow: var(--app-control-shadow); }
+.app-filter-search label { color: var(--app-text); font-size: 13px; line-height: 18px; font-weight: 950; text-transform: uppercase; letter-spacing: 0.05em; }
+.app-filter-search__input-wrap { display: flex; align-items: center; gap: 8px; border: 1px solid var(--app-border); border-radius: 18px; background: var(--app-bg); padding: 8px 10px; }
+.app-filter-search__input-wrap:focus-within { border-color: var(--app-filter-accent-border); box-shadow: 0 0 0 3px color-mix(in srgb, var(--app-filter-accent-border) 22%, transparent); }
+.app-filter-search__input-wrap input { flex: 1; min-width: 0; border: 0; outline: 0; background: transparent; color: var(--app-text); font: inherit; font-size: 15px; font-weight: 850; }
+.app-filter-search__input-wrap input::placeholder { color: var(--app-text-muted); }
+.app-filter-search__input-wrap button { flex: 0 0 auto; border: 0; border-radius: 999px; background: var(--app-filter-accent-bg); color: var(--app-filter-accent-text); padding: 7px 10px; font: inherit; font-size: 12px; font-weight: 950; cursor: pointer; }
+.app-filter-search p { margin: 0; color: var(--app-text-muted); font-size: 12px; line-height: 16px; font-weight: 800; }
+.app-filter-groups { display: grid; gap: 12px; }
+.app-filter-group { display: grid; gap: 12px; border-top: 1px solid var(--app-border); padding-top: 14px; }
+.app-filter-group__header { display: grid; gap: 4px; }
+.app-filter-group__header h2 { margin: 0; color: var(--app-text); font-size: 22px; line-height: 26px; letter-spacing: -0.03em; }
+.app-filter-group__header p { margin: 0; color: var(--app-text-muted); font-size: 13px; line-height: 18px; font-weight: 800; }
+.app-filter-options { display: grid; gap: 8px; grid-template-columns: repeat(auto-fit, minmax(160px, 1fr)); }
+.app-filter-option { display: flex; align-items: flex-start; gap: 10px; min-height: 58px; border: 1px solid var(--app-border); border-radius: 18px; background: var(--app-surface); color: var(--app-text); padding: 11px; text-align: left; font: inherit; cursor: pointer; }
+.app-filter-option:hover:not(:disabled) { border-color: var(--app-filter-accent-border); transform: translateY(-1px); }
+.app-filter-option.is-selected { border-color: var(--app-filter-accent-border); background: var(--app-filter-accent-bg); color: var(--app-filter-accent-text); }
+.app-filter-option__check { display: inline-flex; align-items: center; justify-content: center; flex: 0 0 auto; width: 22px; height: 22px; border: 1px solid var(--app-border); border-radius: 999px; color: var(--app-surface); font-size: 14px; font-weight: 950; }
+.app-filter-option.is-selected .app-filter-option__check { border-color: var(--app-filter-accent-border); background: var(--app-filter-accent-text); }
+.app-filter-option span:last-child { display: grid; gap: 2px; min-width: 0; }
+.app-filter-option strong { color: var(--app-text); font-size: 14px; line-height: 18px; font-weight: 950; }
+.app-filter-option small { color: var(--app-text-muted); font-size: 12px; line-height: 16px; font-weight: 800; }
+.app-filter-option:disabled { cursor: not-allowed; opacity: 0.48; transform: none; }
+.app-filter-footer { position: sticky; bottom: 0; z-index: 30; display: grid; grid-template-columns: minmax(0, 0.8fr) minmax(0, 1.2fr); gap: 8px; border-top: 1px solid var(--app-border); background: color-mix(in srgb, var(--app-bg) 92%, transparent); padding: 12px 0 max(12px, env(safe-area-inset-bottom)); backdrop-filter: blur(16px); }
+.app-filter-footer .button { justify-content: center; }
+@media (max-width: 560px) {
+  .app-filter-options { grid-template-columns: minmax(0, 1fr); }
+}
