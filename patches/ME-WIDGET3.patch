+  background:
+    radial-gradient(circle at 4% 0, color-mix(in srgb, var(--app-surface-soft) 42%, transparent), transparent 34%),
+    linear-gradient(145deg, var(--me-widget-surface-strong), var(--me-widget-surface));
+  padding: 18px;
+  box-shadow: var(--me-widget-shadow-soft);
+  text-decoration: none;
+  transition: border-color 160ms ease, box-shadow 160ms ease, transform 160ms ease;
+}
+
+.me-hub-widget-card:hover,
+.me-hub-widget-card:focus-visible {
+  border-color: var(--me-widget-border-strong);
+  box-shadow: var(--me-widget-shadow);
+  text-decoration: none;
+  transform: translateY(-1px);
+}
+
+.me-hub-widget-card--trade {
+  border-color: color-mix(in srgb, var(--trade-border) 34%, var(--me-widget-border));
+  background:
+    radial-gradient(circle at 8% 0, color-mix(in srgb, var(--trade-bg) 48%, transparent), transparent 34%),
+    linear-gradient(145deg, var(--me-widget-surface-strong), var(--me-widget-surface));
+}
+
+.me-hub-widget-card--proposal {
+  border-color: color-mix(in srgb, var(--proposal-border) 34%, var(--me-widget-border));
+  background:
+    radial-gradient(circle at 8% 0, color-mix(in srgb, var(--proposal-bg) 48%, transparent), transparent 34%),
+    linear-gradient(145deg, var(--me-widget-surface-strong), var(--me-widget-surface));
+}
+
+.me-hub-widget-card__topline {
+  display: flex;
+  align-items: center;
+  justify-content: space-between;
+  gap: 10px;
+}
+
+.me-hub-widget-card__metric {
+  display: inline-grid;
+  place-items: center;
+  min-width: 34px;
+  height: 34px;
+  border: 1px solid color-mix(in srgb, var(--proposal-border) 46%, var(--me-widget-border));
+  border-radius: 999px;
+  background: color-mix(in srgb, var(--proposal-bg) 48%, var(--me-widget-surface));
+  color: var(--proposal-text);
+  font-size: 14px;
+  font-weight: 950;
+}
+
+.me-hub-widget-card__body {
+  display: grid;
+  grid-template-columns: auto minmax(0, 1fr);
+  gap: 13px;
+  align-items: start;
+}
+
+.me-hub-widget-card__icon {
+  display: grid;
+  place-items: center;
+  width: 48px;
+  height: 48px;
+  border: 1px solid var(--me-widget-border);
+  border-radius: 19px;
+  background: color-mix(in srgb, var(--me-widget-surface-soft) 86%, var(--me-widget-surface));
+  color: var(--app-text);
+}
+
+.me-hub-widget-card__body strong {
+  display: block;
+  color: var(--app-text);
+  font-size: 19px;
+  font-weight: 950;
+  letter-spacing: -0.04em;
+  line-height: 1.12;
+}
+
+.me-hub-widget-card__body small {
+  display: block;
+  margin-top: 7px;
+  color: var(--app-text-muted);
+  font-size: 13px;
+  font-weight: 790;
+  line-height: 1.42;
+}
+
+.me-hub-widget-card__action {
+  display: inline-flex;
+  align-items: center;
+  gap: 6px;
+  width: fit-content;
+  min-height: 34px;
+  margin-top: auto;
+  border-radius: 999px;
+  background: color-mix(in srgb, var(--me-widget-surface-soft) 78%, var(--me-widget-surface));
+  color: var(--app-text);
+  padding: 0 12px;
+  font-size: 12px;
+  font-weight: 950;
+}
+
 .me-hub-section {
   gap: 16px;
   border: 1px solid var(--me-widget-border);
