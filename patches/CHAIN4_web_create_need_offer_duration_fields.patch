+
+.inventory-preset-field__option--selected {
+  border-color: color-mix(in srgb, var(--proposal-border) 66%, var(--app-border));
+  background: color-mix(in srgb, var(--proposal-bg) 24%, var(--app-surface));
+  color: var(--proposal-text);
+}
+
+@media (min-width: 620px) {
+  .inventory-chain-field-grid {
+    grid-template-columns: repeat(2, minmax(0, 1fr));
+  }
+}
