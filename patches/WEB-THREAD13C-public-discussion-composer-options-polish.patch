diff --git a/apps/web/src/app/globals.css b/apps/web/src/app/globals.css
index cfdc607..b01234c 100644
--- a/apps/web/src/app/globals.css
+++ b/apps/web/src/app/globals.css
@@ -6398,3 +6398,180 @@ html[data-theme="dark"] .onboarding-guide-primary {
     padding: 14px 0 0;
   }
 }
+
+/* WEB-THREAD13C: public discussion composer and options polish */
+.public-thread-menu {
+  position: relative;
+  justify-self: end;
+  pointer-events: auto;
+}
+
+.public-thread-menu__popover {
+  position: absolute;
+  z-index: 80;
+  top: calc(100% + 10px);
+  right: 0;
+  display: grid;
+  width: min(290px, calc(100vw - 32px));
+  gap: 6px;
+  border: 1px solid color-mix(in srgb, var(--app-border) 86%, transparent);
+  border-radius: 20px;
+  background: color-mix(in srgb, var(--app-surface) 96%, transparent);
+  padding: 8px;
+  box-shadow: var(--app-card-shadow);
+  backdrop-filter: blur(18px);
+}
+
+.public-thread-menu__popover a,
+.public-thread-menu__popover button {
+  display: grid;
+  grid-template-columns: 20px minmax(0, 1fr);
+  align-items: center;
+  gap: 10px;
+  width: 100%;
+  border: 0;
+  border-radius: 15px;
+  background: transparent;
+  color: var(--app-text);
+  padding: 11px 12px;
+  text-align: left;
+  text-decoration: none;
+}
+
+.public-thread-menu__popover a:hover,
+.public-thread-menu__popover a:focus-visible,
+.public-thread-menu__popover button:hover,
+.public-thread-menu__popover button:focus-visible {
+  background: var(--app-surface-soft);
+  outline: none;
+}
+
+.public-thread-menu__popover .danger-text {
+  color: var(--danger-text);
+}
+
+.public-thread-menu__popover span {
+  display: grid;
+  min-width: 0;
+  gap: 2px;
+}
+
+.public-thread-menu__popover strong {
+  overflow: hidden;
+  color: currentColor;
+  font-size: 13px;
+  font-weight: 950;
+  line-height: 1.2;
+  text-overflow: ellipsis;
+  white-space: nowrap;
+}
+
+.public-thread-menu__popover small {
+  overflow: hidden;
+  color: var(--app-text-muted);
+  font-size: 11px;
+  font-weight: 760;
+  line-height: 1.28;
+  text-overflow: ellipsis;
+  white-space: nowrap;
+}
+
+.public-discussion-page--menu .web-thread-options-list {
+  display: grid;
+  gap: 12px;
+  padding: 14px 16px 24px;
+}
+
+.public-discussion-page--menu .web-thread-option-row {
+  margin-inline: 0;
+  border: 1px solid color-mix(in srgb, var(--app-border) 82%, transparent);
+  border-radius: 18px;
+  background: color-mix(in srgb, var(--app-surface) 86%, transparent);
+  padding: 15px 16px;
+  box-shadow: 0 10px 26px rgba(15, 23, 42, 0.045);
+}
+
+.public-discussion-page--menu .web-thread-option-row:hover,
+.public-discussion-page--menu .web-thread-option-row:focus-visible {
+  border-color: var(--app-border-strong);
+  background: var(--app-surface);
+}
+
+.public-discussion-page--menu .web-thread-option-row.danger-text {
+  border-color: color-mix(in srgb, var(--danger-text) 34%, var(--app-border));
+  background: color-mix(in srgb, var(--warning-bg) 52%, var(--app-surface));
+  color: var(--danger-text);
+}
+
+.public-discussion-page--menu .web-thread-option-row.danger-text small {
+  color: color-mix(in srgb, var(--danger-text) 68%, var(--app-text-muted));
+}
+
+.public-discussion-page--flat .public-discussion-composer--messages-only {
+  border: 0;
+  border-radius: 24px;
+  background: color-mix(in srgb, var(--app-surface) 82%, transparent);
+  padding: 8px;
+  box-shadow: 0 16px 42px rgba(15, 23, 42, 0.08);
+}
+
+.public-discussion-page--flat .public-discussion-composer--messages-only textarea {
+  min-height: 46px;
+  border: 0;
+  border-radius: 18px;
+  background: color-mix(in srgb, var(--app-bg) 72%, var(--app-surface));
+  padding: 13px 14px;
+  box-shadow: inset 0 0 0 1px color-mix(in srgb, var(--app-border) 78%, transparent);
+  resize: none;
+}
+
+.public-discussion-page--flat .public-discussion-composer--messages-only textarea:focus {
+  box-shadow: inset 0 0 0 2px color-mix(in srgb, var(--proposal-border) 34%, var(--app-border-strong));
+}
+
+.public-discussion-page--flat .public-discussion-composer--messages-only button {
+  min-height: 46px;
+  border-radius: 16px;
+  padding-right: 18px;
+  padding-left: 18px;
+}
+
+@media (max-width: 759px) {
+  .public-thread-menu__popover {
+    display: none;
+  }
+
+  .public-discussion-page--flat .public-discussion-composer--messages-only {
+    bottom: calc(var(--app-tab-height) + env(safe-area-inset-bottom) + 8px);
+    grid-template-columns: minmax(0, 1fr);
+    gap: 8px;
+    margin: auto 0 0;
+    border-radius: 0;
+    background: color-mix(in srgb, var(--app-bg) 94%, transparent);
+    padding: 10px 0 max(10px, env(safe-area-inset-bottom));
+    box-shadow: none;
+  }
+
+  .public-discussion-page--flat .public-discussion-composer--messages-only textarea {
+    min-height: 48px;
+    border-radius: 18px;
+    background: var(--app-surface);
+    box-shadow: inset 0 0 0 1px color-mix(in srgb, var(--app-border) 86%, transparent);
+  }
+
+  .public-discussion-page--flat .public-discussion-composer--messages-only button {
+    width: 100%;
+    min-height: 46px;
+    border-radius: 16px;
+  }
+}
+
+@media (min-width: 760px) {
+  .public-discussion-page--flat .public-discussion-composer--messages-only {
+    bottom: 14px;
+    grid-template-columns: minmax(0, 1fr) auto;
+    align-items: end;
+    gap: 10px;
+    margin-top: 18px;
+  }
+}
