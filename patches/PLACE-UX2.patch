-.place-clean-form { border-color: var(--place-border); }
-.place-clean-form .plan-form__section-title { border-bottom: 1px solid var(--app-border); padding-bottom: 14px; }
-.place-clean-form textarea { min-height: 118px; }
+.place-create-intro { padding-bottom: 2px; }
+.place-create-intro p { max-width: 34rem; font-size: 13px; line-height: 1.35; }
+.place-clean-form { border: 0; border-top: 1px solid var(--place-border); border-radius: 0; background: transparent; box-shadow: none; padding: 14px 0 0; }
+.place-clean-form .plan-form__section-title { border-bottom: 1px solid var(--app-divider); padding-bottom: 12px; }
+.place-clean-form .plan-form__section-title h3 { font-size: 22px; letter-spacing: -0.03em; }
+.place-clean-form > label, .place-clean-form > .plan-form__row, .place-clean-form > .place-form__divider { border-bottom: 1px solid var(--app-divider); padding-bottom: 13px; }
+.place-clean-form .plan-form__row label { min-width: 0; }
+.place-clean-form textarea { min-height: 92px; }
+.place-clean-form .place-description-field textarea { min-height: 84px; }
+.place-description-field small { color: var(--app-text-soft); font-size: 11px; font-weight: 950; }
+.place-form__divider { display: grid; gap: 8px; }
+.place-save-row { position: sticky; bottom: 10px; z-index: 2; border-top: 1px solid var(--app-divider); background: color-mix(in srgb, var(--app-bg) 88%, transparent); -webkit-backdrop-filter: blur(14px); backdrop-filter: blur(14px); padding: 12px 0 2px; }
 .place-translation-compact { border-top: 1px solid var(--app-border); padding-top: 14px; }
-.place-translation-compact .inventory-translation-toggle { border-color: var(--place-border); background: color-mix(in srgb, var(--place-bg) 42%, var(--app-surface)); }
+.place-translation-compact .inventory-translation-toggle { border-color: var(--place-border); background: color-mix(in srgb, var(--place-bg) 28%, var(--app-surface)); }
 .place-translation-panel { border-color: var(--place-border); }
 .plan-mode-segment { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 6px; border: 1px solid var(--app-border); border-radius: 999px; background: var(--app-surface); padding: 5px; }
 .plan-mode-segment button { min-height: 38px; border: 0; border-radius: 999px; background: transparent; color: var(--app-text-muted); font: inherit; font-size: 12px; font-weight: 950; letter-spacing: 0.05em; text-transform: uppercase; cursor: pointer; }
 .plan-mode-segment button.is-active { background: var(--place-bg); color: #fff; box-shadow: var(--app-control-shadow); }
+.place-mode-segment { border-color: var(--place-border); background: transparent; }
+.place-mode-segment button { min-height: 36px; }
 .plan-deck-link { display: grid; gap: 8px; color: inherit; text-decoration: none; }
 .plan-deck-link__meta { margin: 0 4px 16px; color: var(--app-text-muted); font-size: 12px; font-weight: 850; text-decoration: none; }
 .plan-deck-link__meta:hover { color: var(--app-text); }
