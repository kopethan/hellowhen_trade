diff --git a/apps/web/src/app/globals.css b/apps/web/src/app/globals.css
index b1359e0..f3746fb 100644
--- a/apps/web/src/app/globals.css
+++ b/apps/web/src/app/globals.css
@@ -490,3 +490,52 @@ button.warning { background: var(--warning-bg); color: var(--warning-text); bord
   .trade-stack-card--summary { padding: 18px; }
   .trade-stack-card__body h2 { font-size: 22px; }
 }
+
+/* Phase 19.8: trade creation and detail polish */
+.trade-create-page { gap: 18px; }
+.trade-create-form { display: grid; gap: 16px; }
+.trade-create-status-row { display: flex; align-items: center; justify-content: space-between; gap: 10px; }
+.trade-create-side-grid { display: grid; gap: 14px; align-items: start; }
+.trade-side-picker { display: grid; gap: 14px; }
+.trade-side-picker__header { display: flex; align-items: flex-start; justify-content: space-between; gap: 12px; }
+.trade-side-picker__header h3 { margin: 2px 0 0; }
+.trade-side-mode-toggle { display: grid; grid-template-columns: 1fr 1fr; gap: 6px; border-radius: 999px; background: var(--app-surface-soft); padding: 5px; }
+.trade-side-mode-toggle button { min-height: 38px; border-radius: 999px; background: transparent; color: var(--app-text-muted); padding: 0 10px; font-size: 12px; }
+.trade-side-mode-toggle button.is-active { background: var(--app-surface); color: var(--app-text); box-shadow: 0 8px 22px rgba(15, 23, 42, 0.08); }
+.trade-side-option-list { display: grid; gap: 8px; max-height: 420px; overflow: auto; padding-right: 2px; }
+.trade-side-option { display: grid; grid-template-columns: 58px minmax(0, 1fr); gap: 10px; width: 100%; border: 1px solid var(--app-border); border-radius: 20px; background: var(--app-surface-soft); color: var(--app-text); padding: 8px; text-align: left; }
+.trade-side-option.is-active { border-color: var(--proposal-border); background: color-mix(in srgb, var(--proposal-bg) 28%, var(--app-surface)); box-shadow: 0 12px 30px rgba(15, 23, 42, 0.08); }
+.trade-side-option__media { display: grid; place-items: center; overflow: hidden; width: 58px; height: 58px; border-radius: 16px; background: var(--app-bg-muted); color: var(--app-text-soft); font-size: 24px; font-weight: 950; }
+.trade-side-option__media img { width: 100%; height: 100%; object-fit: cover; display: block; }
+.trade-side-option__body { display: grid; gap: 4px; min-width: 0; align-content: center; }
+.trade-side-option__body > span:last-child { overflow: hidden; color: var(--app-text-muted); font-size: 12px; font-weight: 750; text-overflow: ellipsis; white-space: nowrap; }
+.trade-side-option__top { display: flex; align-items: center; justify-content: space-between; gap: 8px; min-width: 0; }
+.trade-side-option__top strong { overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
+.trade-side-option__top em { flex: 0 0 auto; color: var(--app-text-soft); font-size: 10px; font-style: normal; font-weight: 950; letter-spacing: .08em; text-transform: uppercase; }
+.trade-side-money-state, .trade-side-empty-state { display: grid; gap: 8px; border: 1px dashed var(--app-border-strong); border-radius: 22px; background: var(--app-surface-soft); padding: 16px; }
+.trade-side-money-state span, .trade-side-empty-state span { color: var(--app-text-muted); font-weight: 750; }
+.trade-side-empty-state .button { justify-self: start; margin-top: 2px; }
+.trade-money-panel, .trade-create-preview, .trade-create-details { display: grid; gap: 14px; }
+.trade-money-panel__grid { display: grid; grid-template-columns: minmax(0, 1fr) 120px; gap: 10px; }
+.trade-create-preview__sides { display: grid; gap: 10px; }
+.trade-create-preview__sides div { display: grid; gap: 6px; border: 1px solid var(--app-border); border-radius: 20px; background: var(--app-surface-soft); padding: 12px; }
+.trade-create-preview__sides strong { font-size: 15px; }
+.trade-create-preview__sides small { color: var(--app-text-muted); font-size: 12px; font-weight: 800; }
+.trade-reference-deck-section { display: grid; gap: 14px; }
+.trade-detail-reference-deck { max-width: 430px; margin: 0 auto; }
+.trade-detail-reference-card figcaption { top: 14px; left: 14px; }
+.trade-image-grid__item { position: relative; }
+.trade-image-grid__badge { position: absolute; top: 10px; left: 10px; box-shadow: 0 10px 26px rgba(15, 23, 42, 0.2); }
+.trade-image-empty-state { display: grid; gap: 4px; border: 1px dashed var(--app-border-strong); border-radius: 22px; background: var(--app-surface-soft); padding: 16px; }
+.trade-image-empty-state span { color: var(--app-text-muted); font-weight: 750; }
+
+@media (min-width: 900px) {
+  .trade-create-side-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
+  .trade-create-preview__sides { grid-template-columns: repeat(2, minmax(0, 1fr)); }
+}
+
+@media (max-width: 420px) {
+  .trade-money-panel__grid { grid-template-columns: 1fr; }
+  .trade-side-option { grid-template-columns: 50px minmax(0, 1fr); }
+  .trade-side-option__media { width: 50px; height: 50px; }
+}
