+  if (normalized === 'SUBMITTED') return 'pending';
+  if (normalized === 'ACTIVE') return 'active';
+  if (normalized === 'ACTION_REQUIRED') return 'restricted';
+  if (normalized === 'SUSPENDED') return 'restricted';
+  if (normalized === 'REJECTED') return 'rejected';
+  return 'onboarding';
