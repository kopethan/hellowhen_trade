@@ -0,0 +1,127 @@
+import React from 'react';
+import { Image, StyleSheet, View } from 'react-native';
+
+type LowerImageAtmospherePreset = 'trade' | 'plan';
+
+type BlurBand = {
+  top: number;
+  height: number;
+  blur: number;
+  opacity: number;
+  tintOpacity: number;
+};
+
+type LowerImageAtmosphereProfile = {
+  bands: readonly BlurBand[];
+  tint: { dark: string; light: string };
+  lowerFeather: { dark: string; light: string; opacity: number };
+  middleWash: { dark: string; light: string; opacity: number };
+  bottomWash: { dark: string; light: string; opacity: number };
+};
+
+type LowerImageAtmosphereProps = {
+  imageUrl?: string | null;
+  isDark: boolean;
+  preset?: LowerImageAtmospherePreset;
+};
+
+const PROFILES: Record<LowerImageAtmospherePreset, LowerImageAtmosphereProfile> = {
+  trade: {
+    bands: [
+      { top: 50, height: 38, blur: 8, opacity: 0.03, tintOpacity: 0.012 },
+      { top: 60, height: 34, blur: 14, opacity: 0.065, tintOpacity: 0.025 },
+      { top: 70, height: 30, blur: 24, opacity: 0.11, tintOpacity: 0.05 },
+      { top: 80, height: 22, blur: 34, opacity: 0.16, tintOpacity: 0.085 },
+    ],
+    tint: { dark: 'rgba(3,6,10,0.28)', light: 'rgba(255,255,255,0.78)' },
+    lowerFeather: { dark: 'rgba(3,6,10,0.16)', light: 'rgba(255,255,255,0.38)', opacity: 0.16 },
+    middleWash: { dark: 'rgba(3,6,10,0.24)', light: 'rgba(255,255,255,0.52)', opacity: 0.2 },
+    bottomWash: { dark: 'rgba(3,6,10,0.38)', light: 'rgba(255,255,255,0.72)', opacity: 0.24 },
+  },
+  plan: {
+    bands: [
+      { top: 50, height: 38, blur: 8, opacity: 0.035, tintOpacity: 0.035 },
+      { top: 60, height: 34, blur: 14, opacity: 0.07, tintOpacity: 0.07 },
+      { top: 70, height: 30, blur: 24, opacity: 0.12, tintOpacity: 0.12 },
+      { top: 80, height: 22, blur: 34, opacity: 0.17, tintOpacity: 0.18 },
+    ],
+    tint: { dark: 'rgba(4,8,14,0.34)', light: 'rgba(255,255,255,0.84)' },
+    lowerFeather: { dark: 'rgba(4,8,14,0.18)', light: 'rgba(255,255,255,0.44)', opacity: 0.18 },
+    middleWash: { dark: 'rgba(4,8,14,0.26)', light: 'rgba(255,255,255,0.56)', opacity: 0.2 },
+    bottomWash: { dark: 'rgba(4,8,14,0.42)', light: 'rgba(255,255,255,0.72)', opacity: 0.24 },
+  },
+};
+
+function tone(value: { dark: string; light: string }, isDark: boolean) {
+  return isDark ? value.dark : value.light;
+}
+
+export function LowerImageAtmosphere({ imageUrl, isDark, preset = 'trade' }: LowerImageAtmosphereProps) {
+  const profile = PROFILES[preset];
+  const imageTint = tone(profile.tint, isDark);
+
+  return (
+    <View pointerEvents="none" style={StyleSheet.absoluteFillObject}>
+      {imageUrl ? profile.bands.map((band, index) => (
+        <React.Fragment key={`${preset}-lower-image-atmosphere-band-${index}`}>
+          <View
+            style={[
+              styles.blurBand,
+              {
+                top: `${band.top}%`,
+                height: `${band.height}%`,
+                opacity: band.opacity,
+              },
+            ]}
+          >
+            <Image source={{ uri: imageUrl }} resizeMode="cover" blurRadius={band.blur} style={StyleSheet.absoluteFillObject} />
+          </View>
+          <View
+            style={[
+              styles.blurBand,
+              {
+                top: `${band.top}%`,
+                height: `${band.height}%`,
+                backgroundColor: imageTint,
+                opacity: band.tintOpacity,
+              },
+            ]}
+          />
+        </React.Fragment>
+      )) : null}
+      <View style={[styles.lowerFeather, { backgroundColor: tone(profile.lowerFeather, isDark), opacity: profile.lowerFeather.opacity }]} />
+      <View style={[styles.middleWash, { backgroundColor: tone(profile.middleWash, isDark), opacity: profile.middleWash.opacity }]} />
+      <View style={[styles.bottomWash, { backgroundColor: tone(profile.bottomWash, isDark), opacity: profile.bottomWash.opacity }]} />
+    </View>
+  );
+}
+
+const styles = StyleSheet.create({
+  blurBand: {
+    position: 'absolute',
+    left: 0,
+    right: 0,
+    overflow: 'hidden',
+  },
+  lowerFeather: {
+    position: 'absolute',
+    left: 0,
+    right: 0,
+    top: '50%',
+    height: '32%',
+  },
+  middleWash: {
+    position: 'absolute',
+    left: 0,
+    right: 0,
+    top: '62%',
+    height: '30%',
+  },
+  bottomWash: {
+    position: 'absolute',
+    left: 0,
+    right: 0,
+    bottom: 0,
+    height: '34%',
+  },
+});
