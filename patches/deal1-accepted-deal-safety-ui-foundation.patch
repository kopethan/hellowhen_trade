+  const statusIndex = tradeStatus === "completed" ? 3 : tradeStatus === "submitted" ? 2 : tradeStatus === "in_progress" ? 1 : 0;
+  if (stepIndex < statusIndex) return "done";
+  if (stepIndex === statusIndex) return "current";
+  return "pending";
