+function uniqueInventoryItems(items: Array<ProposalSideItem | null | undefined>) {
+  const seen = new Set<string>();
+  return items.filter((item): item is ProposalSideItem => {
+    if (!item?.id || seen.has(item.id)) return false;
+    seen.add(item.id);
+    return true;
+  });
+}
