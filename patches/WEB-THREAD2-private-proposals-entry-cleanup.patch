 .public-discussion-composer textarea { min-height: 48px; max-height: 140px; }
 .private-proposals-section { padding-top: 16px; }
+.private-proposals-page--messages-only { padding-bottom: calc(24px + env(safe-area-inset-bottom)); }
+.private-proposals-section--clean { gap: 0; padding: 0 16px 24px; }
+.private-proposals-section--clean .notice-box { margin: 12px 0; }
+.private-proposals-section--clean .proposal-composer { gap: 10px; margin-inline: -16px; border-bottom: 1px solid var(--app-border-strong); padding: 14px 16px 16px; }
+.private-proposals-section--clean .proposal-message-field--minimal { gap: 7px; }
+.private-proposals-section--clean .proposal-message-field--minimal textarea { min-height: 92px; border-radius: 18px; background: transparent; }
+.proposal-attachment-lines { display: grid; gap: 8px; }
+.proposal-attachment-line { display: grid; grid-template-columns: auto minmax(0, 1fr) auto; align-items: center; gap: 10px; border-bottom: 1px solid var(--app-border-strong); color: var(--app-text); margin-inline: -16px; padding: 12px 16px; text-decoration: none; }
+.proposal-attachment-line:hover, .proposal-attachment-line:focus-visible { background: var(--app-surface-soft); }
+.proposal-attachment-line span { display: grid; min-width: 0; gap: 2px; }
+.proposal-attachment-line strong { color: var(--app-text-muted); font-size: 10px; font-weight: 950; letter-spacing: .09em; text-transform: uppercase; }
+.proposal-attachment-line small { display: block; overflow: hidden; color: var(--app-text); font-size: 13px; font-weight: 880; line-height: 1.28; text-overflow: ellipsis; white-space: nowrap; }
+.proposal-attachment-hint { margin: 0; color: var(--app-text-muted); font-size: 12px; font-weight: 800; line-height: 1.42; }
+.private-proposal-row-list { display: grid; gap: 0; margin-inline: -16px; }
+.private-proposal-row { display: grid; grid-template-columns: minmax(0, 1fr) auto auto; align-items: center; gap: 10px; border-bottom: 1px solid var(--app-border-strong); color: var(--app-text); padding: 13px 16px; text-decoration: none; }
+.private-proposal-row:hover, .private-proposal-row:focus-visible { background: var(--app-surface-soft); }
+.private-proposal-row--active { background: color-mix(in srgb, var(--proposal-bg) 24%, transparent); }
+.private-proposal-row__person { min-width: 0; }
+.private-proposal-row__status { display: inline-flex; align-items: center; justify-content: flex-end; gap: 5px; color: var(--app-text-muted); font-size: 11px; font-weight: 950; letter-spacing: .06em; text-transform: uppercase; white-space: nowrap; }
+.private-proposal-empty-text { margin: 16px 0 0; color: var(--app-text-muted); font-size: 14px; font-weight: 800; line-height: 1.45; }
+@media (max-width: 560px) {
+  .private-proposal-row { grid-template-columns: minmax(0, 1fr) auto; }
+  .private-proposal-row__status { grid-column: 1; justify-content: flex-start; padding-left: 42px; }
+  .private-proposal-row > .web-icon:last-child { grid-column: 2; grid-row: 1 / span 2; }
+}
 @media (max-width: 420px) {
