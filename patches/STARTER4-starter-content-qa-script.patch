+#!/usr/bin/env node
+import fs from 'node:fs';
+import path from 'node:path';
+import process from 'node:process';
+
+const repoRoot = process.cwd();
+const seedPath = path.join(repoRoot, 'apps/api/prisma/seed.ts');
+
+const allowedKinds = new Set(['need', 'offer']);
+const allowedSourceTypes = new Set(['hellowhen', 'business', 'brand', 'partner']);
+const allowedItemTypes = new Set(['service', 'goods', 'other']);
+const allowedModes = new Set(['remote', 'local', 'hybrid']);
+const allowedStatuses = new Set(['draft', 'pending_review', 'active', 'rejected', 'archived']);
+const supportedLocales = ['en', 'fr', 'es'];
+const strictLocales = process.env.STARTER_QA_STRICT_LOCALES === 'true';
+
+const unsafePatterns = [
+  /\bwallet\b/i,
+  /\bescrow\b/i,
+  /\bstripe\b/i,
+  /\bairwallex\b/i,
+  /\bpayouts?\b/i,
+  /\brefund protection\b/i,
+  /\bpayment protection\b/i,
+  /\bprotected payment\b/i,
+  /\bguaranteed payment\b/i,
+  /\bguaranteed cash\b/i,
+  /\bin-app payment\b/i,
+  /\bcheckout\b/i,
+];
+
+function fail(message) {
+  return { level: 'error', message };
+}
+
+function warn(message) {
+  return { level: 'warning', message };
+}
+
+function findMatchingBracket(source, openIndex, openChar, closeChar) {
+  let depth = 0;
+  let quote = null;
+  let escaped = false;
+
+  for (let index = openIndex; index < source.length; index += 1) {
+    const char = source[index];
+
+    if (quote) {
+      if (escaped) {
+        escaped = false;
+        continue;
+      }
+      if (char === '\\') {
+        escaped = true;
+        continue;
+      }
+      if (char === quote) quote = null;
+      continue;
+    }
+
+    if (char === '\'' || char === '"' || char === '`') {
+      quote = char;
+      continue;
+    }
+
+    if (char === openChar) depth += 1;
+    if (char === closeChar) depth -= 1;
+    if (depth === 0) return index;
+  }
+
+  return -1;
+}
+
+function splitTopLevelObjects(arrayBody) {
+  const objects = [];
+  let index = 0;
+
+  while (index < arrayBody.length) {
+    const start = arrayBody.indexOf('{', index);
+    if (start === -1) break;
+    const end = findMatchingBracket(arrayBody, start, '{', '}');
+    if (end === -1) break;
+    objects.push(arrayBody.slice(start, end + 1));
+    index = end + 1;
+  }
+
+  return objects;
+}
+
+function extractStarterArrays(source) {
+  const arrays = [];
+  const declarationPattern = /const\s+([A-Za-z0-9_]*[Ss]tarterInventoryTemplates)\s*:\s*SeedInventoryTemplateData\[\]\s*=\s*\[/g;
+  let match;
+
+  while ((match = declarationPattern.exec(source))) {
+    const name = match[1];
+    const openIndex = source.indexOf('[', declarationPattern.lastIndex - 1);
+    const closeIndex = findMatchingBracket(source, openIndex, '[', ']');
+    if (closeIndex === -1) {
+      arrays.push({ name, body: '', malformed: true });
+      continue;
+    }
+    arrays.push({ name, body: source.slice(openIndex + 1, closeIndex), malformed: false });
+    declarationPattern.lastIndex = closeIndex + 1;
+  }
+
+  return arrays;
+}
+
+function getStringProperty(objectText, propertyName) {
+  const pattern = new RegExp(`\\b${propertyName}\\s*:\\s*'((?:\\\\'|[^'])*)'`);
+  const match = objectText.match(pattern);
+  return match ? match[1].replace(/\\'/g, '\'') : null;
+}
+
+function getNumberProperty(objectText, propertyName) {
+  const pattern = new RegExp(`\\b${propertyName}\\s*:\\s*(-?\\d+)`);
+  const match = objectText.match(pattern);
+  return match ? Number(match[1]) : null;
+}
+
+function getStringArrayProperty(objectText, propertyName) {
+  const pattern = new RegExp(`\\b${propertyName}\\s*:\\s*\\[([^\\]]*)\\]`, 's');
+  const match = objectText.match(pattern);
+  if (!match) return [];
+  return Array.from(match[1].matchAll(/'((?:\\\\'|[^'])*)'/g)).map((item) => item[1].replace(/\\'/g, '\''));
+}
+
+function getPropertyNames(objectText) {
+  return Array.from(objectText.matchAll(/^\s*([A-Za-z0-9_]+)\s*:/gm)).map((match) => match[1]);
+}
+
+function canonicalStarterKey(key) {
+  return key.replace(/^starter-(fr|es)-/, 'starter-');
+}
+
+function localeFromTemplate(template) {
+  if (template.languageCode) return template.languageCode;
+  if (template.key.startsWith('starter-fr-')) return 'fr';
+  if (template.key.startsWith('starter-es-')) return 'es';
+  return 'en';
+}
+
+if (!fs.existsSync(seedPath)) {
+  console.error(`Starter QA failed: missing seed file at ${path.relative(repoRoot, seedPath)}`);
+  process.exit(1);
+}
+
+const source = fs.readFileSync(seedPath, 'utf8');
+const arrays = extractStarterArrays(source);
+const issues = [];
+const templates = [];
+
+if (!arrays.length) {
+  issues.push(fail('No starter inventory template arrays were found in apps/api/prisma/seed.ts.'));
+}
+
+for (const array of arrays) {
+  if (array.malformed) {
+    issues.push(fail(`Could not parse ${array.name}; array brackets look malformed.`));
+    continue;
+  }
+
+  const objectTexts = splitTopLevelObjects(array.body);
+  if (!objectTexts.length) {
+    issues.push(warn(`${array.name} contains no starter templates.`));
+  }
+
+  for (const objectText of objectTexts) {
+    const template = {
+      arrayName: array.name,
+      key: getStringProperty(objectText, 'key'),
+      kind: getStringProperty(objectText, 'kind'),
+      sourceType: getStringProperty(objectText, 'sourceType'),
+      languageCode: getStringProperty(objectText, 'languageCode'),
+      countryCode: getStringProperty(objectText, 'countryCode'),
+      title: getStringProperty(objectText, 'title'),
+      description: getStringProperty(objectText, 'description'),
+      itemType: getStringProperty(objectText, 'itemType'),
+      category: getStringProperty(objectText, 'category'),
+      timing: getStringProperty(objectText, 'timing'),
+      availability: getStringProperty(objectText, 'availability'),
+      mode: getStringProperty(objectText, 'mode'),
+      locationLabel: getStringProperty(objectText, 'locationLabel'),
+      status: getStringProperty(objectText, 'status'),
+      sortOrder: getNumberProperty(objectText, 'sortOrder'),
+      tags: getStringArrayProperty(objectText, 'tags'),
+      includes: getStringArrayProperty(objectText, 'includes'),
+      objectText,
+    };
+    template.locale = localeFromTemplate(template);
+    template.canonicalKey = template.key ? canonicalStarterKey(template.key) : null;
+    templates.push(template);
+  }
+}
+
+const seenKeys = new Map();
+const seenLocaleGroups = new Map();
+const seenSortOrders = new Map();
+
+for (const template of templates) {
+  const label = template.key || `${template.arrayName} template #${templates.indexOf(template) + 1}`;
+  const required = ['key', 'kind', 'sourceType', 'title', 'description', 'itemType', 'status'];
+
+  for (const property of required) {
+    if (!template[property]) issues.push(fail(`${label} is missing required property: ${property}.`));
+  }
+
+  if (template.key && !template.key.startsWith('starter-')) {
+    issues.push(fail(`${label} key must start with "starter-".`));
+  }
+  if (template.key && seenKeys.has(template.key)) {
+    issues.push(fail(`${label} duplicates key already used in ${seenKeys.get(template.key)}.`));
+  } else if (template.key) {
+    seenKeys.set(template.key, template.arrayName);
+  }
+
+  if (template.kind && !allowedKinds.has(template.kind)) issues.push(fail(`${label} has unsupported kind: ${template.kind}.`));
+  if (template.sourceType && !allowedSourceTypes.has(template.sourceType)) {
+    issues.push(fail(`${label} has unsupported sourceType: ${template.sourceType}.`));
+  }
+  if (template.itemType && !allowedItemTypes.has(template.itemType)) {
+    issues.push(fail(`${label} has unsupported itemType: ${template.itemType}.`));
+  }
+  if (template.mode && !allowedModes.has(template.mode)) issues.push(fail(`${label} has unsupported mode: ${template.mode}.`));
+  if (template.status && !allowedStatuses.has(template.status)) {
+    issues.push(fail(`${label} has unsupported status: ${template.status}.`));
+  }
+  if (!supportedLocales.includes(template.locale)) {
+    issues.push(fail(`${label} has unsupported languageCode/locale: ${template.locale}.`));
+  }
+
+  if (template.title && template.title.length > 80) {
+    issues.push(warn(`${label} title is long (${template.title.length} chars). Target 80 or less.`));
+  }
+  if (template.description && template.description.length > 320) {
+    issues.push(warn(`${label} description is long (${template.description.length} chars). Target 320 or less.`));
+  }
+  if (template.tags.length > 6) issues.push(warn(`${label} has ${template.tags.length} tags. Target 6 or less.`));
+  if (template.includes.length > 5) issues.push(warn(`${label} has ${template.includes.length} includes. Target 5 or less.`));
+  if (template.kind === 'need' && template.includes.length) {
+    issues.push(warn(`${label} is a need template but has includes; includes are usually offer-side.`));
+  }
+  if (template.kind === 'offer' && !template.availability && !template.timing) {
+    issues.push(warn(`${label} is an offer template without availability/timing copy.`));
+  }
+  if (template.kind === 'need' && !template.timing && !template.availability) {
+    issues.push(warn(`${label} is a need template without timing/availability copy.`));
+  }
+
+  const textToScan = [template.title, template.description, template.category, template.timing, template.availability, template.locationLabel, ...template.tags, ...template.includes]
+    .filter(Boolean)
+    .join(' ');
+  for (const pattern of unsafePatterns) {
+    if (pattern.test(textToScan)) issues.push(fail(`${label} contains unsafe/payment wording matched by ${pattern}.`));
+  }
+
+  const propertyCounts = new Map();
+  for (const propertyName of getPropertyNames(template.objectText)) {
+    propertyCounts.set(propertyName, (propertyCounts.get(propertyName) || 0) + 1);
+  }
+  for (const [propertyName, count] of propertyCounts) {
+    if (count > 1) issues.push(warn(`${label} repeats property "${propertyName}" ${count} times.`));
+  }
+
+  if (template.canonicalKey) {
+    const localeMap = seenLocaleGroups.get(template.canonicalKey) || new Map();
+    if (localeMap.has(template.locale)) {
+      issues.push(fail(`${label} duplicates locale ${template.locale} for ${template.canonicalKey}.`));
+    }
+    localeMap.set(template.locale, template.key);
+    seenLocaleGroups.set(template.canonicalKey, localeMap);
+  }
+
+  if (template.sortOrder !== null && template.kind) {
+    const sortKey = `${template.locale}:${template.kind}:${template.sortOrder}`;
+    if (seenSortOrders.has(sortKey)) {
+      issues.push(warn(`${label} shares sortOrder ${template.sortOrder} with ${seenSortOrders.get(sortKey)} for ${template.locale}/${template.kind}.`));
+    } else {
+      seenSortOrders.set(sortKey, label);
+    }
+  }
+}
+
+const localeCoverage = new Map();
+for (const [canonicalKey, localeMap] of seenLocaleGroups) {
+  for (const locale of supportedLocales) {
+    if (!localeMap.has(locale)) {
+      const missing = localeCoverage.get(locale) || [];
+      missing.push(canonicalKey);
+      localeCoverage.set(locale, missing);
+    }
+  }
+}
+
+for (const locale of supportedLocales) {
+  const missing = localeCoverage.get(locale) || [];
+  if (!missing.length) continue;
+  const message = `${locale} is missing ${missing.length} starter localization group(s). Example: ${missing.slice(0, 5).join(', ')}${missing.length > 5 ? ', ...' : ''}`;
+  issues.push(strictLocales ? fail(message) : warn(`${message}. Set STARTER_QA_STRICT_LOCALES=true to fail on this.`));
+}
+
+const errors = issues.filter((issue) => issue.level === 'error');
+const warnings = issues.filter((issue) => issue.level === 'warning');
+const countsByLocale = templates.reduce((counts, template) => {
+  counts[template.locale] = (counts[template.locale] || 0) + 1;
+  return counts;
+}, {});
+const countsByKind = templates.reduce((counts, template) => {
+  counts[template.kind] = (counts[template.kind] || 0) + 1;
+  return counts;
+}, {});
+
+console.log(`Starter library QA checked ${templates.length} template(s) across ${arrays.length} seed array(s).`);
+console.log(`By locale: ${JSON.stringify(countsByLocale)}`);
+console.log(`By kind: ${JSON.stringify(countsByKind)}`);
+
+if (warnings.length) {
+  console.warn(`\nWarnings (${warnings.length}):`);
+  for (const issue of warnings.slice(0, 30)) console.warn(`- ${issue.message}`);
+  if (warnings.length > 30) console.warn(`- ... ${warnings.length - 30} more warning(s)`);
+}
+
+if (errors.length) {
+  console.error(`\nErrors (${errors.length}):`);
+  for (const issue of errors) console.error(`- ${issue.message}`);
+  process.exit(1);
+}
+
+console.log('\nStarter library QA passed.');
