diff --git a/apps/web/src/app/globals.css b/apps/web/src/app/globals.css
index b01234c..f9ef9f1 100644
--- a/apps/web/src/app/globals.css
+++ b/apps/web/src/app/globals.css
@@ -6575,3 +6575,81 @@ html[data-theme="dark"] .onboarding-guide-primary {
     margin-top: 18px;
   }
 }
+
+/* WEB-THREAD13D: public discussion autosizing composer with one clean border */
+.public-discussion-page--flat .public-discussion-composer--messages-only {
+  border: 1px solid color-mix(in srgb, var(--app-border) 82%, transparent);
+  border-radius: 24px;
+  background: color-mix(in srgb, var(--app-surface) 92%, transparent);
+  padding: 8px;
+  box-shadow: 0 14px 34px rgba(15, 23, 42, 0.065);
+}
+
+.public-discussion-page--flat .public-discussion-composer--messages-only:focus-within {
+  border-color: color-mix(in srgb, var(--proposal-border) 42%, var(--app-border-strong));
+  box-shadow: 0 16px 38px rgba(15, 23, 42, 0.085);
+}
+
+.public-discussion-page--flat .public-discussion-composer--messages-only textarea {
+  min-height: 46px;
+  max-height: 144px;
+  border: 0;
+  border-radius: 17px;
+  background: transparent;
+  padding: 13px 14px;
+  box-shadow: none;
+  line-height: 1.45;
+  overflow-y: hidden;
+  resize: none;
+}
+
+.public-discussion-page--flat .public-discussion-composer--messages-only textarea:focus {
+  box-shadow: none;
+}
+
+.public-discussion-page--flat .public-discussion-composer--messages-only button {
+  align-self: end;
+  min-height: 46px;
+  border-radius: 17px;
+}
+
+@media (max-width: 759px) {
+  .public-discussion-page--flat .public-discussion-composer--messages-only {
+    bottom: calc(var(--app-tab-height) + env(safe-area-inset-bottom) + 8px);
+    grid-template-columns: minmax(0, 1fr);
+    gap: 8px;
+    margin: auto 0 0;
+    border-radius: 22px;
+    background: color-mix(in srgb, var(--app-surface) 94%, transparent);
+    padding: 8px;
+    box-shadow: 0 12px 30px rgba(15, 23, 42, 0.07);
+  }
+
+  .public-discussion-page--flat .public-discussion-composer--messages-only textarea {
+    min-height: 48px;
+    max-height: 144px;
+    border-radius: 16px;
+    background: transparent;
+    box-shadow: none;
+  }
+
+  .public-discussion-page--flat .public-discussion-composer--messages-only textarea:focus {
+    box-shadow: none;
+  }
+
+  .public-discussion-page--flat .public-discussion-composer--messages-only button {
+    width: 100%;
+    min-height: 46px;
+    border-radius: 16px;
+  }
+}
+
+@media (min-width: 760px) {
+  .public-discussion-page--flat .public-discussion-composer--messages-only {
+    bottom: 14px;
+    grid-template-columns: minmax(0, 1fr) auto;
+    align-items: end;
+    gap: 8px;
+    margin-top: 18px;
+  }
+}
