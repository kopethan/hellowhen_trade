diff --git a/apps/web/src/app/globals.css b/apps/web/src/app/globals.css
index 752a77f..e9a69cc 100644
--- a/apps/web/src/app/globals.css
+++ b/apps/web/src/app/globals.css
@@ -4041,3 +4041,32 @@ html[data-theme="dark"] .onboarding-guide-primary {
 }
 .trade-side-source-back:is(button) { border: 0; background: transparent; padding: 0; cursor: pointer; }
 .trade-side-source-card--button { color: var(--app-text); }
+
+/* WIZARD23: compact final Create Trade preview step */
+.trade-create-wizard__step-stack--preview { gap: 12px; }
+.trade-create-preview--final { gap: 12px; }
+.trade-create-preview__intro--final {
+  grid-template-columns: minmax(0, 1fr);
+  gap: 6px;
+}
+.trade-create-preview__intro--final h3 { margin: 0; font-size: 18px; }
+.trade-create-preview__summary {
+  display: inline-flex;
+  flex-wrap: wrap;
+  gap: 5px;
+  margin: 0;
+  color: var(--app-text-muted);
+  font-size: 12px;
+  font-weight: 880;
+  line-height: 1.35;
+}
+.trade-create-preview--final .trade-create-preview__deck { padding-top: 0; }
+.trade-create-preview--final .trade-create-preview__empty { margin-top: 2px; }
+
+@media (min-width: 680px) {
+  .trade-create-preview__intro--final {
+    grid-template-columns: minmax(0, 1fr) auto;
+    align-items: end;
+  }
+  .trade-create-preview__summary { justify-content: flex-end; text-align: right; }
+}
