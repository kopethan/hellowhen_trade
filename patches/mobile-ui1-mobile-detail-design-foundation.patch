+import React from 'react';
+import {
+  Image,
+  Pressable,
+  ScrollView,
+  StyleSheet,
+  TextInput,
+  type ImageStyle,
+  type StyleProp,
+  type ViewStyle,
+  View,
+} from 'react-native';
+import type { SemanticColorName } from '@hellowhen/theme';
+import { AppText } from '../AppText';
+import { MobileIcon, type MobileIconName } from '../MobileIcon';
+import { useThemeTokens } from '../../providers/ThemeProvider';
+
+type DetailTone = SemanticColorName | 'neutral';
+
+type DetailHeroProps = {
+  eyebrow?: string;
+  title: string;
+  subtitle?: string;
+  meta?: string;
+  children?: React.ReactNode;
+  rightSlot?: React.ReactNode;
+  style?: StyleProp<ViewStyle>;
+};
+
+type DetailSectionProps = {
+  eyebrow?: string;
+  title?: string;
+  description?: string | null;
+  children?: React.ReactNode;
+  rightSlot?: React.ReactNode;
+  compact?: boolean;
+  withTopBorder?: boolean;
+  style?: StyleProp<ViewStyle>;
+};
+
+type DetailMetadataChip = {
+  key?: string;
+  label: string;
+  tone?: DetailTone;
+  icon?: MobileIconName;
+};
+
+type DetailMetadataChipsProps = {
+  chips: Array<DetailMetadataChip | string | null | undefined | false>;
+  compact?: boolean;
+  style?: StyleProp<ViewStyle>;
+};
+
+type DetailImageItem = {
+  id: string;
+  uri: string;
+  accessibilityLabel?: string;
+};
+
+type DetailImageGridProps = {
+  images: DetailImageItem[];
+  maxVisible?: number;
+  onPressImage?: (image: DetailImageItem, index: number) => void;
+  style?: StyleProp<ViewStyle>;
+  imageStyle?: StyleProp<ImageStyle>;
+};
+
+type DetailInfoRow = {
+  label: string;
+  value: string | number | null | undefined;
+  tone?: DetailTone;
+};
+
+type DetailInfoListProps = {
+  rows: DetailInfoRow[];
+  style?: StyleProp<ViewStyle>;
+};
+
+type DetailPrimaryAction = {
+  label: string;
+  onPress: () => void;
+  disabled?: boolean;
+  loading?: boolean;
+  tone?: 'primary' | 'danger' | 'muted';
+  icon?: MobileIconName;
+};
+
+type DetailSecondaryAction = {
+  label: string;
+  onPress: () => void;
+  disabled?: boolean;
+  icon?: MobileIconName;
+};
+
+type DetailBottomActionBarProps = {
+  primary?: DetailPrimaryAction;
+  secondary?: DetailSecondaryAction[];
+  helper?: string;
+  style?: StyleProp<ViewStyle>;
+};
+
+type DetailEmptyStateProps = {
+  icon?: MobileIconName;
+  title: string;
+  body?: string;
+  actionLabel?: string;
+  onAction?: () => void;
+  style?: StyleProp<ViewStyle>;
+};
+
+type ConversationBubbleProps = {
+  body: string;
+  mine?: boolean;
+  authorLabel?: string;
+  meta?: string;
+  deleted?: boolean;
+  rightSlot?: React.ReactNode;
+  style?: StyleProp<ViewStyle>;
+};
+
+type ConversationComposerBarProps = {
+  value: string;
+  placeholder: string;
+  onChangeText: (value: string) => void;
+  onSend: () => void;
+  disabled?: boolean;
+  sending?: boolean;
+  sendLabel?: string;
+  style?: StyleProp<ViewStyle>;
+};
+
+function normalizeChip(chip: DetailMetadataChip | string): DetailMetadataChip {
+  return typeof chip === 'string' ? { label: chip } : chip;
+}
+
+function toneColors(tone: DetailTone | undefined, theme: ReturnType<typeof useThemeTokens>) {
+  if (!tone || tone === 'neutral') {
+    return {
+      backgroundColor: theme.color.subtleSurface,
+      borderColor: theme.color.border,
+      color: theme.color.muted,
+    };
+  }
+  const color = theme.semantic[tone];
+  return { backgroundColor: color.softBg, borderColor: color.border, color: color.text };
+}
+
+export function DetailHero({ eyebrow, title, subtitle, meta, children, rightSlot, style }: DetailHeroProps) {
+  const theme = useThemeTokens();
+
+  return (
+    <View style={[styles.hero, style]}>
+      <View style={styles.heroTopRow}>
+        <View style={styles.heroCopy}>
+          {eyebrow ? <AppText style={[styles.eyebrow, { color: theme.color.muted }]}>{eyebrow}</AppText> : null}
+          <AppText style={styles.heroTitle}>{title}</AppText>
+        </View>
+        {rightSlot ? <View style={styles.heroRightSlot}>{rightSlot}</View> : null}
+      </View>
+      {subtitle ? <AppText style={[styles.heroSubtitle, { color: theme.color.text }]}>{subtitle}</AppText> : null}
+      {meta ? <AppText style={[styles.heroMeta, { color: theme.color.muted }]}>{meta}</AppText> : null}
+      {children ? <View style={styles.heroChildren}>{children}</View> : null}
+    </View>
+  );
+}
+
+export function DetailSection({ eyebrow, title, description, children, rightSlot, compact, withTopBorder = true, style }: DetailSectionProps) {
+  const theme = useThemeTokens();
+  const hasHeader = Boolean(eyebrow || title || rightSlot);
+
+  return (
+    <View style={[styles.section, compact && styles.sectionCompact, withTopBorder && { borderTopColor: theme.color.border, borderTopWidth: StyleSheet.hairlineWidth }, style]}>
+      {hasHeader ? (
+        <View style={styles.sectionHeader}>
+          <View style={styles.sectionTitleArea}>
+            {eyebrow ? <AppText style={[styles.eyebrow, { color: theme.color.muted }]}>{eyebrow}</AppText> : null}
+            {title ? <AppText style={styles.sectionTitle}>{title}</AppText> : null}
+          </View>
+          {rightSlot ? <View style={styles.sectionRightSlot}>{rightSlot}</View> : null}
+        </View>
+      ) : null}
+      {description ? <AppText style={[styles.sectionDescription, { color: theme.color.text }]}>{description}</AppText> : null}
+      {children ? <View style={styles.sectionChildren}>{children}</View> : null}
+    </View>
+  );
+}
+
+export function DetailMetadataChips({ chips, compact, style }: DetailMetadataChipsProps) {
+  const theme = useThemeTokens();
+  const normalized = chips.filter(Boolean).map((chip) => normalizeChip(chip as DetailMetadataChip | string)).filter((chip) => chip.label.trim().length > 0);
+  if (normalized.length === 0) return null;
+
+  return (
+    <View style={[styles.chips, style]}>
+      {normalized.map((chip, index) => {
+        const colors = toneColors(chip.tone, theme);
+        const key = chip.key ?? `${chip.label}-${index}`;
+        return (
+          <View key={key} style={[styles.chip, compact && styles.chipCompact, { backgroundColor: colors.backgroundColor, borderColor: colors.borderColor }]}>
+            {chip.icon ? <MobileIcon name={chip.icon} color={colors.color} size={compact ? 13 : 15} decorative /> : null}
+            <AppText style={[styles.chipText, compact && styles.chipTextCompact, { color: colors.color }]}>{chip.label}</AppText>
+          </View>
+        );
+      })}
+    </View>
+  );
+}
+
+export function DetailInfoList({ rows, style }: DetailInfoListProps) {
+  const theme = useThemeTokens();
+  const visibleRows = rows.filter((row) => row.value !== null && row.value !== undefined && String(row.value).trim().length > 0);
+  if (visibleRows.length === 0) return null;
+
+  return (
+    <View style={[styles.infoList, { borderColor: theme.color.border }, style]}>
+      {visibleRows.map((row, index) => {
+        const colors = toneColors(row.tone, theme);
+        return (
+          <View key={`${row.label}-${index}`} style={[styles.infoRow, index > 0 && { borderTopColor: theme.color.border, borderTopWidth: StyleSheet.hairlineWidth }]}>
+            <AppText style={[styles.infoLabel, { color: theme.color.muted }]}>{row.label}</AppText>
+            <AppText style={[styles.infoValue, { color: colors.color }]}>{row.value}</AppText>
+          </View>
+        );
+      })}
+    </View>
+  );
+}
+
+export function DetailImageGrid({ images, maxVisible = 4, onPressImage, style, imageStyle }: DetailImageGridProps) {
+  const theme = useThemeTokens();
+  const visibleImages = images.filter((image) => image.uri).slice(0, maxVisible);
+  if (visibleImages.length === 0) return null;
+  const extraCount = Math.max(0, images.length - visibleImages.length);
+  const count = visibleImages.length;
+
+  return (
+    <View style={[styles.imageGrid, count === 1 && styles.imageGridSingle, style]}>
+      {visibleImages.map((image, index) => {
+        const showExtra = extraCount > 0 && index === visibleImages.length - 1;
+        const tileStyle = [
+          styles.imageTile,
+          count === 1 && styles.imageTileSingle,
+          count === 2 && styles.imageTileHalf,
+          count >= 3 && styles.imageTileGrid,
+          { backgroundColor: theme.color.subtleSurface, borderColor: theme.color.border },
+        ];
+        const content = (
+          <>
+            <Image accessibilityLabel={image.accessibilityLabel} source={{ uri: image.uri }} style={[styles.image, imageStyle]} />
+            {showExtra ? (
+              <View style={styles.imageOverlay}>
+                <AppText style={styles.imageOverlayText}>+{extraCount}</AppText>
+              </View>
+            ) : null}
+          </>
+        );
+        if (!onPressImage) return <View key={image.id} style={tileStyle}>{content}</View>;
+        return (
+          <Pressable key={image.id} accessibilityRole="imagebutton" onPress={() => onPressImage(image, index)} style={({ pressed }) => [tileStyle, pressed && styles.pressed]}>
+            {content}
+          </Pressable>
+        );
+      })}
+    </View>
+  );
+}
+
+export function DetailBottomActionBar({ primary, secondary = [], helper, style }: DetailBottomActionBarProps) {
+  const theme = useThemeTokens();
+  const primaryTone = primary?.tone ?? 'primary';
+  const primaryBackground = primaryTone === 'danger' ? theme.semantic.danger.bg : primaryTone === 'muted' ? theme.color.subtleSurface : theme.color.text;
+  const primaryText = primaryTone === 'muted' ? theme.color.text : theme.color.inverseText;
+
+  if (!primary && secondary.length === 0 && !helper) return null;
+
+  return (
+    <View style={[styles.bottomBar, { backgroundColor: theme.color.background, borderTopColor: theme.color.border }, style]}>
+      {helper ? <AppText style={[styles.bottomHelper, { color: theme.color.muted }]}>{helper}</AppText> : null}
+      <View style={styles.bottomActions}>
+        {secondary.map((action) => (
+          <Pressable
+            key={action.label}
+            accessibilityRole="button"
+            disabled={action.disabled}
+            onPress={action.onPress}
+            style={({ pressed }) => [styles.secondaryAction, { backgroundColor: theme.color.surface, borderColor: theme.color.border }, pressed && styles.pressed, action.disabled && styles.disabled]}
+          >
+            {action.icon ? <MobileIcon name={action.icon} color={theme.color.text} size={17} decorative /> : null}
+            <AppText style={styles.secondaryActionText}>{action.label}</AppText>
+          </Pressable>
+        ))}
+        {primary ? (
+          <Pressable
+            accessibilityRole="button"
+            disabled={primary.disabled || primary.loading}
+            onPress={primary.onPress}
+            style={({ pressed }) => [styles.primaryAction, { backgroundColor: primaryBackground }, pressed && styles.pressed, (primary.disabled || primary.loading) && styles.disabled]}
+          >
+            {primary.icon ? <MobileIcon name={primary.icon} color={primaryText} size={18} decorative /> : null}
+            <AppText style={[styles.primaryActionText, { color: primaryText }]}>{primary.loading ? '…' : primary.label}</AppText>
+          </Pressable>
+        ) : null}
+      </View>
+    </View>
+  );
+}
+
+export function DetailEmptyState({ icon = 'trade', title, body, actionLabel, onAction, style }: DetailEmptyStateProps) {
+  const theme = useThemeTokens();
+  return (
+    <View style={[styles.emptyState, { backgroundColor: theme.color.subtleSurface, borderColor: theme.color.border }, style]}>
+      <View style={[styles.emptyIcon, { backgroundColor: theme.color.surface, borderColor: theme.color.border }]}>
+        <MobileIcon name={icon} color={theme.color.muted} size={22} decorative />
+      </View>
+      <AppText style={styles.emptyTitle}>{title}</AppText>
+      {body ? <AppText style={[styles.emptyBody, { color: theme.color.muted }]}>{body}</AppText> : null}
+      {actionLabel && onAction ? (
+        <Pressable accessibilityRole="button" onPress={onAction} style={({ pressed }) => [styles.emptyAction, { backgroundColor: theme.color.text }, pressed && styles.pressed]}>
+          <AppText style={[styles.emptyActionText, { color: theme.color.inverseText }]}>{actionLabel}</AppText>
+        </Pressable>
+      ) : null}
+    </View>
+  );
+}
+
+export function ConversationBubble({ body, mine, authorLabel, meta, deleted, rightSlot, style }: ConversationBubbleProps) {
+  const theme = useThemeTokens();
+  const bubbleBg = mine ? theme.color.text : theme.color.surface;
+  const bubbleBorder = mine ? theme.color.text : theme.color.border;
+  const bubbleText = mine ? theme.color.inverseText : theme.color.text;
+  const metaColor = mine ? theme.color.inverseText : theme.color.muted;
+
+  return (
+    <View style={[styles.bubbleWrap, mine && styles.bubbleWrapMine, style]}>
+      {authorLabel ? <AppText style={[styles.bubbleAuthor, { color: theme.color.muted }, mine && styles.bubbleAuthorMine]}>{authorLabel}</AppText> : null}
+      <View style={[styles.bubble, mine && styles.bubbleMine, { backgroundColor: bubbleBg, borderColor: bubbleBorder }]}>
+        <View style={styles.bubbleTopRow}>
+          <AppText style={[styles.bubbleBody, deleted && styles.bubbleDeleted, { color: bubbleText }]}>{body}</AppText>
+          {rightSlot ? <View style={styles.bubbleRightSlot}>{rightSlot}</View> : null}
+        </View>
+        {meta ? <AppText style={[styles.bubbleMeta, { color: metaColor }]}>{meta}</AppText> : null}
+      </View>
+    </View>
+  );
+}
+
+export function ConversationComposerBar({ value, placeholder, onChangeText, onSend, disabled, sending, sendLabel, style }: ConversationComposerBarProps) {
+  const theme = useThemeTokens();
+  const canSend = value.trim().length > 0 && !disabled && !sending;
+  return (
+    <View style={[styles.composerWrap, { backgroundColor: theme.color.background, borderTopColor: theme.color.border }, style]}>
+      <TextInput
+        editable={!disabled && !sending}
+        multiline
+        onChangeText={onChangeText}
+        placeholder={placeholder}
+        placeholderTextColor={theme.color.muted}
+        style={[styles.composerInput, { backgroundColor: theme.color.surface, borderColor: theme.color.border, color: theme.color.text }]}
+        value={value}
+      />
+      <Pressable
+        accessibilityRole="button"
+        accessibilityLabel={sendLabel}
+        disabled={!canSend}
+        onPress={onSend}
+        style={({ pressed }) => [styles.composerSend, { backgroundColor: canSend ? theme.color.text : theme.color.subtleSurface, borderColor: theme.color.border }, pressed && styles.pressed, !canSend && styles.disabled]}
+      >
+        <MobileIcon name="send" color={canSend ? theme.color.inverseText : theme.color.muted} size={18} decorative />
+      </Pressable>
+    </View>
+  );
+}
+
+export function HorizontalDetailScroller({ children, style }: { children: React.ReactNode; style?: StyleProp<ViewStyle> }) {
+  return (
+    <ScrollView horizontal showsHorizontalScrollIndicator={false} style={style} contentContainerStyle={styles.horizontalScrollerContent}>
+      {children}
+    </ScrollView>
+  );
+}
