+    forwardProgress,
+    [0, SQUARE_STACK_COMMIT_THRESHOLD, 1],
+    [0, SQUARE_STACK_BACKGROUND_THRESHOLD_PROMOTION, SQUARE_STACK_BACKGROUND_DRAG_PROMOTION],
+    Extrapolation.CLAMP,
