+      forwardProgress,
+      [0, SQUARE_STACK_COMMIT_THRESHOLD, SQUARE_STACK_NEXT_RELEASE_TARGET],
+      [0, SQUARE_STACK_BACKGROUND_THRESHOLD_PROMOTION, 1],
+      Extrapolation.CLAMP,
+    );
+  }
+
