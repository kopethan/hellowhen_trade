+
+function formatSubscriptionDate(value: string | null | undefined, language: SupportedLanguage) {
+  return formatWebDate(value, '—', language);
+}
+
+function formatPeriodSummary(snapshot: MembershipSnapshot, language: SupportedLanguage) {
+  const state = snapshot?.subscriptionState;
+  if (!state) return 'No billing period is attached.';
+  if (state.trialEndsAt) return `Trial ends ${formatSubscriptionDate(state.trialEndsAt, language)}`;
+  if (state.currentPeriodEndsAt) return `Current period ends ${formatSubscriptionDate(state.currentPeriodEndsAt, language)}`;
+  if (state.expiresAt) return `Access expires ${formatSubscriptionDate(state.expiresAt, language)}`;
+  if (state.canceledAt) return `Canceled ${formatSubscriptionDate(state.canceledAt, language)}`;
+  return 'No renewal or expiry date is attached.';
+}
+
+function formatUpdatedAt(value: string | null | undefined, language: SupportedLanguage) {
+  if (!value) return 'No status update date';
+  return `Updated ${formatSubscriptionDate(value, language)}`;
+}
