+    orderBy: { createdAt: 'desc' },
+    take: 20,
+    include: { admin: { select: { id: true, email: true, profile: true } } },
+  }) ?? [];
+  res.json({ summary, recentAuditLogs, placements: await hydrateAdminBusinessSponsoredPlacements(placements) });
+}));
