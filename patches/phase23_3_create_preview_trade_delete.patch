+
+    return tx.trade.update({
+      where: { id: trade.id },
+      data: { status: 'closed', isPublic: false, closedAt: trade.closedAt ?? new Date() },
+      include: tradeInclude
+    });
+  });
+
+  res.json({ trade: await withOneTradeDeckMedia(deleted, 'owner'), deleted: true });
