diff --git a/apps/web/src/app/globals.css b/apps/web/src/app/globals.css
index 24aa0aa..6806268 100644
--- a/apps/web/src/app/globals.css
+++ b/apps/web/src/app/globals.css
@@ -10668,3 +10668,299 @@ html[data-theme="dark"] .web-app-page--me {
     grid-template-columns: minmax(0, 1fr);
   }
 }
+
+/* ME-WIDGET4: mobile web responsive polish for the Me hub. */
+@media (max-width: 759px) {
+  .web-app-page--me {
+    --me-widget-radius: 26px;
+    --me-widget-radius-large: 32px;
+    gap: 20px;
+    padding-bottom: calc(var(--app-tab-height) + 82px + env(safe-area-inset-bottom));
+  }
+
+  .web-app-shell--normal-dock .web-app-page--me {
+    padding-bottom: calc(var(--app-dock-height) + 96px + env(safe-area-inset-bottom));
+  }
+
+  .web-app-page--me .mobile-link-card,
+  .web-app-page--me .me-hub-stat-card,
+  .web-app-page--me .me-hub-widget-card {
+    -webkit-tap-highlight-color: transparent;
+  }
+
+  .me-hub-page {
+    gap: 20px;
+  }
+
+  .me-hub-hero {
+    min-height: 0;
+    border-radius: var(--me-widget-radius-large);
+    padding: 20px;
+  }
+
+  .me-hub-hero::after {
+    right: -98px;
+    bottom: -104px;
+    opacity: 0.72;
+  }
+
+  .me-hub-hero__identity {
+    grid-template-columns: auto minmax(0, 1fr);
+    gap: 14px;
+  }
+
+  .me-hub-hero .account-avatar--large {
+    width: 70px;
+    height: 70px;
+    font-size: 28px;
+  }
+
+  .me-hub-hero__copy h1 {
+    margin-top: 6px;
+    font-size: clamp(26px, 8vw, 34px);
+    line-height: 1.04;
+  }
+
+  .me-hub-hero__copy p,
+  .me-hub-hero__loading {
+    font-size: 15px;
+    line-height: 1.45;
+  }
+
+  .me-hub-hero__actions {
+    display: grid;
+    grid-template-columns: minmax(0, 1fr);
+  }
+
+  .me-hub-hero__actions .button,
+  .me-hub-hero__actions button {
+    width: 100%;
+    min-height: 50px;
+    justify-content: center;
+  }
+
+  .me-hub-overview {
+    border-radius: 30px;
+    padding: 6px;
+  }
+
+  .me-hub-stat-grid {
+    grid-template-columns: repeat(2, minmax(0, 1fr));
+    gap: 10px;
+  }
+
+  .me-hub-stat-card {
+    grid-template-columns: minmax(0, 1fr);
+    align-items: start;
+    min-height: 118px;
+    border-radius: 24px;
+    padding: 14px;
+  }
+
+  .me-hub-stat-card__icon {
+    width: 42px;
+    height: 42px;
+    border-radius: 16px;
+  }
+
+  .me-hub-stat-card strong {
+    font-size: 30px;
+  }
+
+  .me-hub-stat-card small {
+    white-space: normal;
+  }
+
+  .me-hub-stat-card__hint {
+    display: none;
+  }
+
+  .me-hub-widget-strip {
+    grid-template-columns: minmax(0, 1fr);
+    gap: 12px;
+  }
+
+  .me-hub-widget-card {
+    min-height: 0;
+    border-radius: 28px;
+    gap: 14px;
+    padding: 18px;
+  }
+
+  .me-hub-widget-card__body {
+    align-items: center;
+  }
+
+  .me-hub-widget-card__icon {
+    width: 46px;
+    height: 46px;
+    border-radius: 18px;
+  }
+
+  .me-hub-widget-card__body strong {
+    font-size: 18px;
+  }
+
+  .me-hub-widget-card__body small {
+    font-size: 13px;
+  }
+
+  .me-hub-widget-card__action {
+    min-height: 38px;
+    padding: 0 13px;
+  }
+
+  .me-hub-section {
+    border-radius: 28px;
+    gap: 14px;
+    padding: 16px;
+  }
+
+  .me-hub-section__header {
+    display: grid;
+    gap: 8px;
+  }
+
+  .me-hub-section__header h2 {
+    font-size: 20px;
+  }
+
+  .me-hub-section__header p {
+    max-width: none;
+    font-size: 13px;
+    text-align: left;
+  }
+
+  .me-hub-list {
+    gap: 9px;
+  }
+
+  .me-hub-link-card {
+    min-height: 74px;
+    border-radius: 22px;
+    gap: 10px;
+    padding: 14px;
+  }
+
+  .me-hub-link-card .mobile-link-card__icon {
+    width: 42px;
+    height: 42px;
+    border-radius: 16px;
+  }
+
+  .me-hub-link-card .mobile-link-card__title-row strong {
+    font-size: 15px;
+  }
+
+  .me-hub-link-card__body-text {
+    display: -webkit-box;
+    overflow: hidden;
+    font-size: 12.5px;
+    line-height: 1.35;
+    -webkit-box-orient: vertical;
+    -webkit-line-clamp: 2;
+  }
+
+  .me-hub-quick-actions {
+    gap: 10px;
+  }
+
+  .me-hub-quick-grid {
+    grid-template-columns: repeat(2, minmax(0, 1fr));
+    gap: 10px;
+  }
+
+  .account-quick-action-card.me-hub-link-card {
+    min-height: 104px;
+    padding: 14px;
+  }
+
+  .account-quick-action-card--primary.me-hub-link-card {
+    grid-template-columns: auto minmax(0, 1fr) auto;
+    align-items: center;
+    min-height: 88px;
+    border-radius: 26px;
+    padding: 16px;
+  }
+
+  .account-quick-action-card--primary.me-hub-link-card .mobile-link-card__icon {
+    width: 48px;
+    height: 48px;
+    border-radius: 18px;
+  }
+
+  .account-quick-action-card--compact.me-hub-link-card .mobile-link-card__arrow {
+    display: none;
+  }
+
+  .account-quick-action-card.me-hub-link-card .mobile-link-card__title-row {
+    margin-top: 8px;
+  }
+
+  .account-quick-action-card--primary.me-hub-link-card .mobile-link-card__title-row {
+    margin-top: 0;
+  }
+
+  .me-hub-layout,
+  .me-hub-layout__primary,
+  .me-hub-layout__secondary,
+  .me-hub-layout__quiet {
+    gap: 14px;
+  }
+
+  .me-hub-layout__quiet .me-hub-list {
+    grid-template-columns: minmax(0, 1fr);
+  }
+
+  .me-hub-layout__quiet .me-hub-link-card {
+    min-height: 66px;
+  }
+}
+
+@media (max-width: 430px) {
+  .web-app-page--me {
+    padding-bottom: calc(var(--app-tab-height) + 96px + env(safe-area-inset-bottom));
+  }
+
+  .me-hub-hero {
+    padding: 18px;
+  }
+
+  .me-hub-hero__identity {
+    grid-template-columns: minmax(0, 1fr);
+  }
+
+  .me-hub-hero .account-avatar--large {
+    width: 64px;
+    height: 64px;
+    font-size: 26px;
+  }
+
+  .me-hub-stat-grid,
+  .me-hub-quick-grid {
+    grid-template-columns: minmax(0, 1fr);
+  }
+
+  .me-hub-stat-card {
+    grid-template-columns: auto minmax(0, 1fr);
+    min-height: 86px;
+  }
+
+  .me-hub-stat-card__hint {
+    display: block;
+  }
+
+  .account-quick-action-card.me-hub-link-card,
+  .account-quick-action-card--primary.me-hub-link-card {
+    grid-template-columns: auto minmax(0, 1fr) auto;
+    min-height: 78px;
+  }
+
+  .account-quick-action-card--compact.me-hub-link-card .mobile-link-card__arrow {
+    display: inline-flex;
+  }
+
+  .account-quick-action-card.me-hub-link-card .mobile-link-card__title-row {
+    margin-top: 0;
+  }
+}
