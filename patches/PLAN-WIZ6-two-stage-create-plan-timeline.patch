+.plan-form--timeline { gap: 16px; }
+.plan-build-timeline { display: grid; gap: 0; }
+.plan-timeline-row { display: grid; grid-template-columns: minmax(0, 1fr) auto; gap: 12px; align-items: center; border-top: 1px solid var(--app-border); padding: 16px 0; }
+.plan-timeline-row:first-child { border-top: 0; padding-top: 0; }
+.plan-timeline-row__main { display: grid; gap: 6px; min-width: 0; }
+.plan-timeline-row__main h3 { margin: 0; font-size: 18px; letter-spacing: -0.02em; }
+.plan-timeline-row__heading { display: flex; align-items: center; gap: 7px; flex-wrap: wrap; }
+.plan-timeline-row__actions { display: flex; align-items: center; justify-content: flex-end; gap: 8px; flex-wrap: wrap; }
+.plan-timeline-row__fields { display: grid; grid-template-columns: repeat(2, minmax(130px, 1fr)); gap: 10px; align-items: end; }
+.plan-timeline-row__fields label, .plan-timeline-row__details label, .plan-stop-note label { display: grid; gap: 7px; color: var(--app-text-muted); font-size: 12px; font-weight: 950; letter-spacing: 0.04em; text-transform: uppercase; }
+.plan-timeline-row__fields input, .plan-timeline-row__details input, .plan-stop-note textarea { width: 100%; border: 1px solid var(--app-border-strong); border-radius: 18px; background: var(--app-surface-soft); color: var(--app-text); padding: 12px 13px; font: inherit; font-weight: 750; outline: none; }
+.plan-timeline-row__fields--optional { grid-column: 1 / -1; max-width: 360px; }
+.plan-timeline-row__details { grid-column: 1 / -1; display: grid; gap: 10px; padding-top: 4px; }
+.plan-stop-note { grid-column: 1 / -1; display: grid; gap: 10px; }
+.plan-stop-note summary { width: fit-content; cursor: pointer; color: var(--app-text-muted); font-size: 12px; font-weight: 950; letter-spacing: 0.04em; text-transform: uppercase; }
+.plan-stop-note[open] { gap: 10px; }
+.plan-preview-stage { border-top: 1px solid var(--app-border); padding-top: 14px; }
+.plan-preview-confirmation, .plan-preview-actions { display: flex; align-items: center; gap: 8px; flex-wrap: wrap; }
+.plan-preview-actions { justify-content: flex-end; border-top: 1px solid var(--app-border); padding-top: 14px; }
+@media (max-width: 760px) {
+  .plan-timeline-row { grid-template-columns: 1fr; align-items: stretch; }
+  .plan-timeline-row__actions { justify-content: flex-start; }
+  .plan-timeline-row__fields { grid-template-columns: 1fr; }
+  .plan-timeline-row__fields--optional { max-width: none; }
+  .plan-preview-actions .button { width: 100%; }
+}
