+/* WIZARD31: web Need/Offer wizard menu and collapsed help */
+.inventory-create-menu {
+  position: relative;
+  display: inline-flex;
+  align-items: center;
+  justify-content: center;
+}
+
+.inventory-create-menu__trigger {
+  display: inline-grid;
+  place-items: center;
+  width: 40px;
+  height: 40px;
+  border: 1px solid var(--app-border);
+  border-radius: 999px;
+  background: var(--app-surface-soft);
+  color: var(--app-text);
+  cursor: pointer;
+  box-shadow: var(--app-control-shadow);
+}
+
+.inventory-create-menu__trigger:hover,
+.inventory-create-menu__trigger[aria-expanded="true"] {
+  border-color: color-mix(in srgb, var(--proposal-border) 60%, var(--app-border));
+  background: color-mix(in srgb, var(--proposal-bg) 22%, var(--app-surface));
+}
+
+.inventory-create-menu__trigger:focus-visible,
+.inventory-create-menu__panel a:focus-visible,
+.inventory-create-menu__panel button:focus-visible {
+  outline: 3px solid color-mix(in srgb, var(--proposal-border) 72%, transparent);
+  outline-offset: 3px;
+}
+
+.inventory-create-menu__trigger-dot {
+  display: block;
+  width: 4px;
+  height: 4px;
+  border-radius: 999px;
+  background: currentColor;
+  box-shadow: -7px 0 0 currentColor, 7px 0 0 currentColor;
+}
+
+.inventory-create-menu__panel {
+  position: absolute;
+  z-index: 40;
+  top: calc(100% + 8px);
+  right: 0;
+  display: grid;
+  min-width: 190px;
+  overflow: hidden;
+  border: 1px solid color-mix(in srgb, var(--app-border) 88%, transparent);
+  border-radius: 18px;
+  background: color-mix(in srgb, var(--app-surface) 96%, transparent);
+  padding: 6px;
+  box-shadow: var(--app-card-shadow-strong);
+  backdrop-filter: blur(16px);
+}
+
+.inventory-create-menu__panel a,
+.inventory-create-menu__panel button {
+  display: flex;
+  align-items: center;
+  justify-content: flex-start;
+  width: 100%;
+  min-height: 42px;
+  border: 0;
+  border-radius: 13px;
+  background: transparent;
+  color: var(--app-text);
+  padding: 0 12px;
+  font: inherit;
+  font-size: 13px;
+  font-weight: 920;
+  text-align: left;
+  text-decoration: none;
+  cursor: pointer;
+}
+
+.inventory-create-menu__panel a:hover,
+.inventory-create-menu__panel button:hover {
+  background: var(--app-surface-soft);
+}
+
+.inventory-create-help-panel {
+  align-items: start;
+  gap: 12px;
+}
+
+.inventory-create-help-panel h3,
+.inventory-create-help-panel p {
+  margin: 0;
+}
+
+.inventory-create-help-panel > div {
+  display: grid;
+  gap: 8px;
+}
+
+.inventory-create-help-panel p {
+  color: var(--app-text-muted);
+  font-size: 13px;
+  font-weight: 760;
+  line-height: 1.45;
+}
+
+.inventory-create-help-panel .button {
+  justify-self: start;
+}
+
+@media (max-width: 520px) {
+  .inventory-create-menu__trigger {
+    width: 38px;
+    height: 38px;
+  }
+
+  .inventory-create-menu__panel {
+    right: -2px;
+    min-width: min(220px, calc(100vw - 32px));
+  }
+}
