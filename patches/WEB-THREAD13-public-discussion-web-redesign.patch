diff --git a/apps/web/src/app/globals.css b/apps/web/src/app/globals.css
index 2216ffd..60f90ff 100644
--- a/apps/web/src/app/globals.css
+++ b/apps/web/src/app/globals.css
@@ -5756,3 +5756,173 @@ html[data-theme="dark"] .onboarding-guide-primary {
     background: color-mix(in srgb, var(--app-surface) 96%, transparent);
   }
 }
+
+/* WEB-THREAD13: public discussion web comment redesign */
+.public-discussion-page--messages-only {
+  background: transparent;
+}
+
+.public-discussion-page--messages-only .public-message-list--thread {
+  display: grid;
+  gap: 10px;
+}
+
+.public-discussion-section--messages-only .notice-box {
+  margin: 12px 0;
+}
+
+.public-discussion-section--messages-only .public-message__header .user-identity-link {
+  min-width: 0;
+}
+
+@media (min-width: 760px) {
+  .public-discussion-page--messages-only {
+    display: grid;
+    grid-template-rows: auto minmax(0, auto) auto;
+    max-width: 760px;
+    min-height: auto;
+    overflow: visible;
+    border-radius: 30px;
+    background: var(--app-surface);
+  }
+
+  .public-discussion-page--messages-only .web-thread-header {
+    grid-template-columns: 44px minmax(0, 1fr) 44px;
+    min-height: 74px;
+    padding: 14px 18px;
+  }
+
+  .public-discussion-page--messages-only .web-thread-header h2 {
+    justify-self: start;
+    font-size: 23px;
+    letter-spacing: -0.04em;
+    line-height: 1.05;
+    text-align: left;
+  }
+
+  .public-discussion-page--messages-only .web-thread-header__back,
+  .public-discussion-page--messages-only .web-thread-header__menu {
+    width: 40px;
+    height: 40px;
+    border-color: color-mix(in srgb, var(--app-border) 76%, transparent);
+    background: color-mix(in srgb, var(--app-bg) 72%, transparent);
+    box-shadow: var(--app-control-shadow);
+  }
+
+  .public-discussion-page--messages-only .web-thread-header__back:hover,
+  .public-discussion-page--messages-only .web-thread-header__back:focus-visible,
+  .public-discussion-page--messages-only .web-thread-header__menu:hover,
+  .public-discussion-page--messages-only .web-thread-header__menu:focus-visible {
+    border-color: var(--app-border-strong);
+    background: var(--app-bg);
+  }
+
+  .public-discussion-section--messages-only {
+    display: grid;
+    min-height: 0;
+    overflow: visible;
+    gap: 12px;
+    padding: 18px;
+    background: color-mix(in srgb, var(--app-surface-soft) 35%, transparent);
+  }
+
+  .public-discussion-section--messages-only .public-message-list--thread {
+    margin: 0;
+  }
+
+  .public-discussion-section--messages-only .public-message-group {
+    gap: 10px;
+  }
+
+  .public-discussion-section--messages-only .public-message-date {
+    margin: 4px 0;
+    border-color: color-mix(in srgb, var(--app-border) 78%, transparent);
+    background: color-mix(in srgb, var(--app-surface) 88%, transparent);
+    box-shadow: var(--app-control-shadow);
+  }
+
+  .public-discussion-section--messages-only .public-message {
+    margin: 0;
+    border: 1px solid color-mix(in srgb, var(--app-border) 82%, transparent);
+    border-radius: 24px;
+    background: color-mix(in srgb, var(--app-surface) 96%, transparent);
+    padding: 15px 16px;
+    box-shadow: 0 10px 28px rgba(15, 23, 42, 0.055);
+  }
+
+  .public-discussion-section--messages-only .public-message:hover {
+    border-color: color-mix(in srgb, var(--app-border-strong) 82%, transparent);
+  }
+
+  .public-discussion-section--messages-only .public-message__header {
+    align-items: flex-start;
+    gap: 16px;
+  }
+
+  .public-discussion-section--messages-only .public-message__meta {
+    gap: 7px;
+    padding-top: 2px;
+    white-space: nowrap;
+  }
+
+  .public-discussion-section--messages-only .public-message__body,
+  .public-discussion-section--messages-only .public-message__edited,
+  .public-discussion-section--messages-only .public-message-edit-form,
+  .public-discussion-section--messages-only .public-message__menu {
+    margin-left: 44px;
+  }
+
+  .public-discussion-section--messages-only .public-message__body {
+    max-width: 62ch;
+    font-size: 15px;
+    font-weight: 760;
+    line-height: 1.56;
+  }
+
+  .public-discussion-section--messages-only .public-message__edited {
+    margin-top: -3px;
+  }
+
+  .public-discussion-empty-text {
+    margin: 18px 0;
+    border: 1px dashed var(--app-border-strong);
+    border-radius: 22px;
+    background: color-mix(in srgb, var(--app-surface) 78%, transparent);
+    padding: 18px;
+  }
+
+  .public-discussion-composer--messages-only {
+    position: sticky;
+    bottom: 18px;
+    display: grid;
+    grid-template-columns: minmax(0, 1fr) auto;
+    margin: 0;
+    border: 0;
+    border-top: 1px solid color-mix(in srgb, var(--app-border) 80%, transparent);
+    border-radius: 0 0 30px 30px;
+    background: color-mix(in srgb, var(--app-surface) 96%, transparent);
+    padding: 14px 18px;
+    box-shadow: none;
+  }
+
+  .public-discussion-composer--messages-only textarea {
+    min-height: 48px;
+    border-radius: 18px;
+    background: color-mix(in srgb, var(--app-bg) 78%, var(--app-surface));
+    padding-top: 13px;
+  }
+
+  .public-discussion-composer--messages-only button {
+    min-height: 48px;
+    border-radius: 16px;
+    padding-right: 18px;
+    padding-left: 18px;
+  }
+
+  .public-discussion-bottom-notice {
+    margin: 0;
+    border-width: 1px 0 0;
+    border-radius: 0 0 30px 30px;
+    padding: 14px 18px;
+  }
+}
