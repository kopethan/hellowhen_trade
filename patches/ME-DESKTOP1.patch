diff --git a/apps/web/src/app/globals.css b/apps/web/src/app/globals.css
index 62a3499..126cbf1 100644
--- a/apps/web/src/app/globals.css
+++ b/apps/web/src/app/globals.css
@@ -11215,3 +11215,109 @@ html[data-theme="dark"] .web-app-page--me {
     min-height: 44px;
   }
 }
+
+/* ME-DESKTOP1: let the Me hub breathe on desktop like a personal control room. */
+@media (min-width: 1024px) {
+  .mobile-page.web-app-page--me,
+  .web-app-page--me {
+    --web-app-page-max: min(1180px, calc(100vw - 48px));
+    --web-app-page-toolbar-max: min(1180px, calc(100vw - 48px));
+    width: min(100%, var(--web-app-page-max));
+    max-width: var(--web-app-page-max);
+  }
+
+  .web-app-page--me {
+    padding-bottom: calc(var(--app-dock-height) + 76px + env(safe-area-inset-bottom));
+  }
+
+  .me-hub-page {
+    gap: 26px;
+  }
+
+  .me-hub-hero {
+    min-height: 168px;
+    padding: 32px;
+  }
+
+  .me-hub-overview {
+    padding: 12px;
+  }
+
+  .me-hub-stat-grid {
+    gap: 16px;
+  }
+
+  .me-hub-stat-card {
+    min-height: 108px;
+    padding: 17px;
+  }
+
+  .me-hub-action-zone {
+    display: grid;
+    grid-template-columns: minmax(0, 1.24fr) minmax(320px, 0.76fr);
+    grid-template-areas: "quick widgets";
+    align-items: stretch;
+    gap: 22px;
+  }
+
+  .me-hub-action-zone--single {
+    grid-template-columns: minmax(0, 1fr);
+    grid-template-areas: "quick";
+  }
+
+  .me-hub-action-zone .me-hub-section--quick {
+    grid-area: quick;
+    min-height: 100%;
+  }
+
+  .me-hub-action-zone .me-hub-widget-strip {
+    grid-area: widgets;
+    grid-template-columns: minmax(0, 1fr);
+    align-content: start;
+    gap: 12px;
+  }
+
+  .me-hub-action-zone .me-hub-widget-card {
+    min-height: 142px;
+    border-radius: 28px;
+    padding: 17px;
+  }
+
+  .me-hub-action-zone .me-hub-widget-card__body strong {
+    font-size: 18px;
+  }
+
+  .me-hub-action-zone .me-hub-widget-card__body small {
+    font-size: 12.5px;
+  }
+
+  .me-hub-section--quick .me-hub-quick-actions {
+    grid-template-columns: minmax(250px, 0.82fr) minmax(0, 1.18fr);
+    gap: 14px;
+  }
+
+  .me-hub-section--quick .me-hub-quick-grid {
+    grid-template-columns: repeat(2, minmax(185px, 1fr));
+  }
+
+  .me-hub-layout {
+    grid-template-columns: minmax(0, 1.04fr) minmax(360px, 0.96fr);
+    gap: 22px;
+  }
+}
+
+@media (min-width: 1280px) {
+  .mobile-page.web-app-page--me,
+  .web-app-page--me {
+    --web-app-page-max: min(1240px, calc(100vw - 64px));
+    --web-app-page-toolbar-max: min(1240px, calc(100vw - 64px));
+  }
+
+  .me-hub-action-zone {
+    grid-template-columns: minmax(0, 1.32fr) minmax(340px, 0.68fr);
+  }
+
+  .me-hub-layout {
+    grid-template-columns: minmax(0, 1.08fr) minmax(380px, 0.92fr);
+  }
+}
