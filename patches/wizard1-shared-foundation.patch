@@ -0,0 +1,65 @@
+import React from 'react';
+import { StyleSheet, View, type StyleProp, type ViewStyle } from 'react-native';
+import { getWizardProgressLabel, getWizardProgressPercent, getWizardStepStates, type WizardStepDefinition } from '@hellowhen/shared';
+import { AppText } from '../../../components/AppText';
+import { useThemeTokens } from '../../../providers/ThemeProvider';
+
+type WizardProgressProps<TStepId extends string> = {
+  steps: readonly WizardStepDefinition<TStepId>[];
+  activeStepId: TStepId;
+  label?: string;
+  stepLabel?: string;
+  ofLabel?: string;
+  style?: StyleProp<ViewStyle>;
+};
+
+export function WizardProgress<TStepId extends string>({ steps, activeStepId, label, stepLabel, ofLabel, style }: WizardProgressProps<TStepId>) {
+  const theme = useThemeTokens();
+  const states = getWizardStepStates(steps, activeStepId);
+  const progressPercent = getWizardProgressPercent(steps, activeStepId);
+  const progressLabel = label ?? getWizardProgressLabel(steps, activeStepId, { step: stepLabel, of: ofLabel });
+
+  return (
+    <View style={[styles.wrap, style]}>
+      <View style={styles.labelRow}>
+        <AppText style={[styles.progressLabel, { color: theme.color.muted }]}>{progressLabel}</AppText>
+        <AppText style={[styles.progressLabel, { color: theme.color.muted }]}>{progressPercent}%</AppText>
+      </View>
+      <View style={[styles.track, { backgroundColor: theme.color.subtleSurface }]}>
+        <View style={[styles.fill, { width: `${progressPercent}%`, backgroundColor: theme.semantic.proposal.bg }]} />
+      </View>
+      <View style={styles.stepsRow}>
+        {states.map((step) => {
+          const isCurrent = step.status === 'current';
+          const isComplete = step.status === 'complete';
+          const isBlocked = step.status === 'blocked';
+          const borderColor = isCurrent || isComplete ? theme.semantic.proposal.border : theme.color.border;
+          const backgroundColor = isCurrent ? theme.semantic.proposal.softBg : isComplete ? theme.semantic.success.softBg : theme.color.surface;
+          const textColor = isCurrent ? theme.semantic.proposal.text : isComplete ? theme.semantic.success.text : isBlocked ? theme.color.muted : theme.color.muted;
+
+          return (
+            <View key={step.id} style={styles.stepItem}>
+              <View style={[styles.stepDot, { backgroundColor, borderColor }]}>
+                <AppText style={[styles.stepNumber, { color: textColor }]}>{step.number}</AppText>
+              </View>
+              <AppText style={[styles.stepTitle, { color: textColor }]} numberOfLines={1}>{step.title}</AppText>
+            </View>
+          );
+        })}
+      </View>
+    </View>
+  );
+}
+
+const styles = StyleSheet.create({
+  wrap: { gap: 10 },
+  labelRow: { flexDirection: 'row', alignItems: 'center', justifyContent: 'space-between', gap: 10 },
+  progressLabel: { fontSize: 12, fontWeight: '900', letterSpacing: 0.45, textTransform: 'uppercase' },
+  track: { height: 7, overflow: 'hidden', borderRadius: 999 },
+  fill: { height: '100%', borderRadius: 999 },
+  stepsRow: { flexDirection: 'row', gap: 8 },
+  stepItem: { flex: 1, minWidth: 0, alignItems: 'center', gap: 5 },
+  stepDot: { alignItems: 'center', justifyContent: 'center', width: 28, height: 28, borderRadius: 14, borderWidth: 1 },
+  stepNumber: { fontSize: 12, fontWeight: '900' },
+  stepTitle: { maxWidth: '100%', fontSize: 10, fontWeight: '900', letterSpacing: 0.2 },
+});
