+
+/* PLAN-DETAIL2 — web Plan detail social parity */
+.plan-detail-page--web {
+  width: min(100%, 760px);
+  margin: 0 auto;
+  padding: clamp(18px, 3vw, 34px) clamp(14px, 3vw, 22px) 42px;
+  display: grid;
+  gap: 0;
+}
+.plan-detail-page--web .semantic-badge.trade,
+.plan-detail-page--web .semantic-badge.instruction {
+  background: color-mix(in srgb, var(--place-text) 12%, var(--app-surface));
+  border-color: color-mix(in srgb, var(--place-text) 26%, var(--app-border));
+  color: var(--place-text);
+}
+.plan-detail-toolbar {
+  display: flex;
+  align-items: center;
+  justify-content: space-between;
+  gap: 12px;
+  padding: 2px 0 14px;
+  border-bottom: 1px solid var(--app-divider);
+}
+.plan-detail-back-link {
+  display: inline-flex;
+  align-items: center;
+  gap: 8px;
+  color: var(--app-text);
+  font-weight: 950;
+  text-decoration: none;
+  letter-spacing: -0.02em;
+}
+.plan-detail-toolbar__actions {
+  display: flex;
+  align-items: center;
+  justify-content: flex-end;
+  gap: 8px;
+  min-width: 0;
+}
+.plan-detail-icon-button {
+  display: inline-flex;
+  align-items: center;
+  gap: 7px;
+  border: 1px solid var(--app-border);
+  border-radius: 999px;
+  background: var(--app-surface);
+  color: var(--app-text);
+  min-height: 36px;
+  padding: 0 12px;
+  font-size: 12px;
+  font-weight: 950;
+  box-shadow: var(--app-control-shadow);
+}
+.plan-detail-icon-button:disabled { opacity: 0.68; cursor: wait; }
+.plan-detail-hero-social,
+.plan-social-section {
+  display: grid;
+  gap: 14px;
+  padding: 22px 0;
+  border-bottom: 1px solid var(--app-divider);
+}
+.plan-social-section--soft {
+  color: var(--app-text-muted);
+}
+.plan-detail-hero-social {
+  padding-top: 26px;
+}
+.plan-detail-status-row,
+.plan-detail-chip-row,
+.plan-route-stop__topline {
+  display: flex;
+  align-items: center;
+  flex-wrap: wrap;
+  gap: 7px;
+}
+.plan-detail-hero-social h1 {
+  margin: 0;
+  max-width: 11ch;
+  font-size: clamp(42px, 8vw, 76px);
+  line-height: 0.9;
+  letter-spacing: -0.08em;
+}
+.plan-detail-hero-description {
+  margin: 0;
+  max-width: 62ch;
+  color: var(--app-text-muted);
+  font-size: 15px;
+  line-height: 1.6;
+}
+.plan-detail-owner-row {
+  display: flex;
+  align-items: center;
+  flex-wrap: wrap;
+  gap: 8px;
+}
+.plan-share-notice {
+  margin: 0;
+  color: var(--app-text-muted);
+  font-size: 13px;
+  font-weight: 850;
+}
+.plan-section-heading {
+  display: grid;
+  gap: 3px;
+}
+.plan-section-heading h2,
+.plan-section-heading p {
+  margin: 0;
+}
+.plan-route-list,
+.plan-participant-list {
+  display: grid;
+  gap: 0;
+}
+.plan-route-stop {
+  display: grid;
+  grid-template-columns: 34px minmax(0, 1fr);
+  gap: 11px;
+  padding: 15px 0;
+  border-top: 1px solid var(--app-divider);
+}
+.plan-route-stop:first-child { border-top: 0; padding-top: 0; }
+.plan-route-stop:last-child { padding-bottom: 0; }
+.plan-route-stop__index {
+  display: grid;
+  place-items: center;
+  width: 30px;
+  height: 30px;
+  border-radius: 999px;
+  background: color-mix(in srgb, var(--place-text) 12%, var(--app-surface));
+  border: 1px solid color-mix(in srgb, var(--place-text) 26%, var(--app-border));
+  color: var(--place-text);
+  font-size: 12px;
+  font-weight: 950;
+}
+.plan-route-stop__body,
+.plan-route-stop__copy {
+  min-width: 0;
+}
+.plan-route-stop__topline {
+  color: var(--time-text);
+  font-size: 12px;
+  font-weight: 950;
+  letter-spacing: 0.02em;
+  text-transform: uppercase;
+}
+.plan-route-stop__topline span:not(:last-child)::after {
+  content: "·";
+  margin-left: 7px;
+  color: var(--app-text-muted);
+}
+.plan-route-stop__content {
+  display: grid;
+  grid-template-columns: minmax(0, 1fr) 86px;
+  align-items: start;
+  gap: 14px;
+  margin-top: 6px;
+}
+.plan-route-stop__copy h4 {
+  margin: 0 0 4px;
+  color: var(--app-text);
+  font-size: 20px;
+  line-height: 1.1;
+  letter-spacing: -0.04em;
+}
+.plan-route-stop__copy p {
+  margin: 0 0 6px;
+}
+.plan-route-stop__media {
+  overflow: hidden;
+  width: 86px;
+  height: 86px;
+  border-radius: 24px;
+  border: 1px solid var(--app-border);
+  background: var(--app-surface-soft);
+  color: var(--place-text);
+}
+.plan-route-stop__media img {
+  width: 100%;
+  height: 100%;
+  object-fit: cover;
+}
+.plan-detail-list {
+  display: grid;
+  gap: 0;
+  margin: 0;
+}
+.plan-detail-list-item {
+  display: flex;
+  align-items: baseline;
+  justify-content: space-between;
+  gap: 18px;
+  padding: 12px 0;
+  border-top: 1px solid var(--app-divider);
+}
+.plan-detail-list-item:first-child { border-top: 0; }
+.plan-detail-list-item dt {
+  color: var(--app-text-muted);
+  font-size: 12px;
+  font-weight: 950;
+  letter-spacing: 0.08em;
+  text-transform: uppercase;
+}
+.plan-detail-list-item dd {
+  margin: 0;
+  color: var(--app-text);
+  font-weight: 900;
+  text-align: right;
+}
+.plan-owner-row {
+  display: flex;
+  align-items: center;
+  justify-content: space-between;
+  gap: 14px;
+}
+.plan-detail-actions--social {
+  display: flex;
+  flex-wrap: wrap;
+  gap: 8px;
+}
+.plan-detail-actions--social .button,
+.plan-detail-actions--social button {
+  flex: 1 1 150px;
+}
+.plan-participant-row--social {
+  display: grid;
+  grid-template-columns: auto minmax(0, 1fr) auto;
+  align-items: center;
+  gap: 10px;
+  padding: 13px 0;
+  border: 0;
+  border-top: 1px solid var(--app-divider);
+  border-radius: 0;
+  background: transparent;
+}
+.plan-participant-row--social:first-child { border-top: 0; }
+@media (max-width: 640px) {
+  .plan-detail-page--web { padding-right: 16px; padding-left: 16px; }
+  .plan-detail-toolbar { position: sticky; top: 0; z-index: 20; background: color-mix(in srgb, var(--app-bg) 88%, transparent); backdrop-filter: blur(18px); }
+  .plan-detail-toolbar__actions .plans-internal-badge { display: none; }
+  .plan-detail-hero-social h1 { max-width: 12ch; font-size: clamp(38px, 14vw, 58px); }
+  .plan-route-stop__content { grid-template-columns: 1fr; }
+  .plan-route-stop__media { width: 100%; height: auto; aspect-ratio: 16 / 9; border-radius: 22px; }
+  .plan-owner-row { display: grid; }
+  .plan-participant-row--social { grid-template-columns: auto minmax(0, 1fr); }
+  .plan-participant-row--social .button { grid-column: 1 / -1; }
+  .plan-detail-list-item { display: grid; gap: 5px; }
+  .plan-detail-list-item dd { text-align: left; }
+}
