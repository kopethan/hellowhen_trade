index e9a69cc..d600b30 100644
--- a/apps/web/src/app/globals.css
+++ b/apps/web/src/app/globals.css
@@ -4070,3 +4070,119 @@ html[data-theme="dark"] .onboarding-guide-primary {
   }
   .trade-create-preview__summary { justify-content: flex-end; text-align: right; }
 }
+
+/* WIZARD24: compact Create Trade menu and collapsed help */
+.trade-create-menu {
+  position: relative;
+  display: inline-flex;
+  align-items: center;
+  justify-content: center;
+}
+
+.trade-create-menu__trigger {
+  display: inline-grid;
+  place-items: center;
+  width: 40px;
+  height: 40px;
+  border: 1px solid var(--app-border);
+  border-radius: 999px;
+  background: var(--app-surface-soft);
+  color: var(--app-text);
+  font-size: 24px;
+  font-weight: 950;
+  line-height: 1;
+  cursor: pointer;
+  box-shadow: var(--app-control-shadow);
+}
+
+.trade-create-menu__trigger:hover,
+.trade-create-menu__trigger[aria-expanded="true"] {
+  border-color: color-mix(in srgb, var(--proposal-border) 60%, var(--app-border));
+  background: color-mix(in srgb, var(--proposal-bg) 22%, var(--app-surface));
+}
+
+.trade-create-menu__trigger:focus-visible,
+.trade-create-menu__panel a:focus-visible,
+.trade-create-menu__panel button:focus-visible {
+  outline: 3px solid color-mix(in srgb, var(--proposal-border) 72%, transparent);
+  outline-offset: 3px;
+}
+
+.trade-create-menu__panel {
+  position: absolute;
+  z-index: 40;
+  top: calc(100% + 8px);
+  right: 0;
+  display: grid;
+  min-width: 190px;
+  overflow: hidden;
+  border: 1px solid color-mix(in srgb, var(--app-border) 88%, transparent);
+  border-radius: 18px;
+  background: color-mix(in srgb, var(--app-surface) 96%, transparent);
+  padding: 6px;
+  box-shadow: var(--app-card-shadow-strong);
+  backdrop-filter: blur(16px);
+}
+
+.trade-create-menu__panel a,
+.trade-create-menu__panel button {
+  display: flex;
+  align-items: center;
+  justify-content: flex-start;
+  width: 100%;
+  min-height: 42px;
+  border: 0;
+  border-radius: 13px;
+  background: transparent;
+  color: var(--app-text);
+  padding: 0 12px;
+  font: inherit;
+  font-size: 13px;
+  font-weight: 920;
+  text-align: left;
+  text-decoration: none;
+  cursor: pointer;
+}
+
+.trade-create-menu__panel a:hover,
+.trade-create-menu__panel button:hover {
+  background: var(--app-surface-soft);
+}
+
+.trade-create-help-panel {
+  align-items: start;
+  gap: 12px;
+}
+
+.trade-create-help-panel h3,
+.trade-create-help-panel p {
+  margin: 0;
+}
+
+.trade-create-help-panel > div {
+  display: grid;
+  gap: 8px;
+}
+
+.trade-create-help-panel p {
+  color: var(--app-text-muted);
+  font-size: 13px;
+  font-weight: 760;
+  line-height: 1.45;
+}
+
+.trade-create-help-panel .button {
+  justify-self: start;
+}
+
+@media (max-width: 520px) {
+  .trade-create-menu__trigger {
+    width: 38px;
+    height: 38px;
+  }
+
+  .trade-create-menu__panel {
+    right: -2px;
+    min-width: min(220px, calc(100vw - 32px));
+  }
+}
