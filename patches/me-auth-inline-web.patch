+    grid-template-columns: minmax(260px, 0.72fr) minmax(360px, 1fr);
+    gap: clamp(22px, 3vw, 38px);
+  }
+
+  .me-hub-auth-card .auth-panel {
+    padding-left: clamp(22px, 3vw, 38px);
+  }
+}
+
+@media (max-width: 560px) {
+  .me-hub-auth-card {
+    border-radius: 30px;
+    padding: 18px;
+  }
+}
+
 .me-hub-overview {
   border: 1px solid color-mix(in srgb, var(--me-widget-border) 80%, transparent);
   border-radius: 32px;
