diff --git a/apps/web/src/app/globals.css b/apps/web/src/app/globals.css
index f3746fb..3420b6e 100644
--- a/apps/web/src/app/globals.css
+++ b/apps/web/src/app/globals.css
@@ -539,3 +539,53 @@ button.warning { background: var(--warning-bg); color: var(--warning-text); bord
   .trade-side-option { grid-template-columns: 50px minmax(0, 1fr); }
   .trade-side-option__media { width: 50px; height: 50px; }
 }
+
+/* Phase 19.9: refresh-safe loading states and mobile deck card parity */
+.trade-deck-grid--skeleton { pointer-events: none; }
+.trade-stack-deck--skeleton .square-stack-deck__surface { cursor: default; }
+.trade-stack-card--skeleton { display: grid; align-content: center; gap: 14px; padding: 24px; background: var(--app-surface); }
+.trade-stack-card--skeleton span,
+.inventory-card--skeleton span,
+.inventory-card--skeleton .inventory-card__media,
+.inventory-card--skeleton .inventory-card__body > span { display: block; overflow: hidden; border-radius: 999px; background: linear-gradient(90deg, var(--app-surface-soft), color-mix(in srgb, var(--app-border) 65%, var(--app-surface)), var(--app-surface-soft)); background-size: 220% 100%; animation: web-skeleton-shimmer 1.3s ease-in-out infinite; }
+.trade-stack-card--skeleton span:nth-child(1) { width: 42%; height: 15px; }
+.trade-stack-card--skeleton span:nth-child(2) { width: 74%; height: 28px; justify-self: center; margin-top: 24px; }
+.trade-stack-card--skeleton span:nth-child(3) { width: 58%; height: 14px; justify-self: center; }
+.trade-stack-card--skeleton span:nth-child(4) { width: 74%; height: 28px; justify-self: center; margin-top: 20px; }
+.trade-stack-card--skeleton span:nth-child(5) { width: 58%; height: 14px; justify-self: center; }
+.inventory-list--skeleton { pointer-events: none; }
+.inventory-card--skeleton { cursor: default; }
+.inventory-card--skeleton .inventory-card__media { min-height: 100%; }
+.inventory-card--skeleton .inventory-card__body { align-content: center; }
+.inventory-card--skeleton .inventory-card__body > span:nth-child(1) { width: 26%; height: 14px; }
+.inventory-card--skeleton .inventory-card__body > span:nth-child(2) { width: 54%; height: 20px; }
+.inventory-card--skeleton .inventory-card__body > span:nth-child(3) { width: 84%; height: 13px; }
+.inventory-card--skeleton .inventory-card__body > span:nth-child(4) { width: 44%; height: 13px; }
+
+.trade-stack-card--mobile-parity { grid-template-rows: auto 1fr auto 1fr auto; gap: 0; padding: clamp(22px, 7vw, 32px); text-align: center; }
+.trade-stack-card__mobile-top { display: flex; align-items: center; justify-content: space-between; gap: 12px; color: var(--app-text-muted); font-size: 12px; font-weight: 950; letter-spacing: .12em; text-transform: uppercase; }
+.trade-stack-card__mobile-top strong { color: var(--app-text); font-size: 12px; font-weight: 950; }
+.trade-stack-card__mobile-section { display: grid; align-content: center; justify-items: center; gap: 8px; min-height: 0; }
+.trade-stack-card__mobile-section p { margin: 0; color: var(--app-text-muted); font-size: 15px; font-weight: 950; }
+.trade-stack-card__mobile-section h2 { width: 100%; margin: 0; overflow-wrap: anywhere; font-size: clamp(28px, 8vw, 36px); line-height: .98; letter-spacing: -0.06em; }
+.trade-stack-card__mobile-section span { display: -webkit-box; max-width: 92%; overflow: hidden; color: var(--app-text-muted); font-size: 14px; font-weight: 850; line-height: 1.35; -webkit-box-orient: vertical; -webkit-line-clamp: 2; }
+.trade-stack-card__mobile-divider { position: relative; display: grid; place-items: center; min-height: 38px; color: var(--app-text-muted); }
+.trade-stack-card__mobile-divider::before { content: ''; position: absolute; right: 0; left: 0; top: 50%; height: 1px; background: color-mix(in srgb, var(--app-border) 72%, transparent); }
+.trade-stack-card__mobile-divider span { position: relative; z-index: 1; display: grid; place-items: center; width: 28px; height: 28px; border: 1px solid var(--app-border); border-radius: 999px; background: var(--app-surface); color: var(--app-text); font-size: 16px; font-weight: 900; box-shadow: 0 8px 20px rgba(15, 23, 42, 0.08); }
+.trade-stack-card__mobile-money { justify-self: center; align-self: end; display: inline-flex; align-items: center; min-height: 30px; border: 1px solid var(--money-border); border-radius: 999px; background: var(--money-bg); color: var(--money-text); padding: 0 12px; font-size: 12px; font-weight: 950; }
+
+@keyframes web-skeleton-shimmer {
+  0% { background-position: 110% 0; }
+  100% { background-position: -110% 0; }
+}
+
+@media (min-width: 760px) {
+  .trade-stack-card--mobile-parity { padding: 30px; }
+  .trade-stack-card__mobile-section h2 { font-size: clamp(30px, 2.25vw, 38px); }
+  .trade-stack-card__mobile-section span { font-size: 15px; }
+}
+
+@media (max-width: 420px) {
+  .trade-stack-card--mobile-parity { padding: 22px; }
+  .trade-stack-card__mobile-section h2 { font-size: 28px; }
+}
