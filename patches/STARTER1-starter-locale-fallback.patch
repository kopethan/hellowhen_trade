+function templateFallbackKey(template: { key: string }) {
+  return template.key.replace(/^starter-(fr|es)-/, 'starter-');
+}
+
+function mergePreferredTemplatesWithFallback<T extends { key: string }>(preferred: T[], fallback: T[], take: number) {
+  const seenKeys = new Set(preferred.map(templateFallbackKey));
+  const merged = [...preferred];
+
+  for (const template of fallback) {
+    const fallbackKey = templateFallbackKey(template);
+    if (seenKeys.has(fallbackKey)) continue;
+    seenKeys.add(fallbackKey);
+    merged.push(template);
+    if (merged.length >= take) break;
+  }
+
+  return merged.slice(0, take);
+}
