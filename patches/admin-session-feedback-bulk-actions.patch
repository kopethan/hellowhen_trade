+  background: color-mix(in srgb, var(--proposal-bg) 38%, var(--app-surface));
+}
+.admin-row-check {
+  display: grid;
+  place-items: center;
+  min-width: 44px;
+  border: 1px solid var(--app-border);
+  border-radius: 18px;
+  background: var(--app-surface-soft);
+  cursor: pointer;
+}
+.admin-row-check input {
+  width: 18px;
+  height: 18px;
+  margin: 0;
+  accent-color: var(--proposal-text);
+}
+.notice-box ul {
+  margin: 8px 0 0 18px;
+  padding: 0;
+}
+.notice-box li {
+  margin-top: 4px;
+}
+@media (max-width: 720px) {
+  .admin-bulk-bar { grid-template-columns: 1fr; }
