+  gap: 8px;
+  align-items: center;
+  margin-top: 10px;
+}
+.admin-selectable-row {
+  display: grid;
+  grid-template-columns: auto minmax(0, 1fr);
+  gap: 8px;
+  align-items: stretch;
+}
+.admin-selectable-row.is-active .admin-user-row {
