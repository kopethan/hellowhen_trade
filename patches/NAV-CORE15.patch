+  gap: 12px;
+  border: 1px solid color-mix(in srgb, var(--app-create-accent-border) 64%, var(--app-border));
+  border-radius: 28px;
+  background: color-mix(in srgb, var(--app-surface) 91%, var(--app-create-accent-bg));
+  padding: 14px;
+  box-shadow: var(--app-card-shadow);
+}
+.app-create-header__title-row,
+.app-create-shell .wizard-shell__title-row {
+  display: flex;
+  align-items: center;
+  gap: 12px;
+  min-width: 0;
+}
+.app-create-header__copy,
+.app-create-shell .wizard-shell__title-copy {
+  min-width: 0;
+  flex: 1 1 auto;
+}
+.app-create-header__eyebrow {
+  display: flex;
+  align-items: center;
+  gap: 7px;
+  flex-wrap: wrap;
+  margin-bottom: 5px;
+}
+.app-create-header h1,
+.app-create-shell .wizard-shell__title-copy h1 {
+  margin: 0;
+  color: var(--app-text);
+  font-size: 24px;
+  line-height: 1.08;
+  letter-spacing: -0.05em;
+}
+.app-create-header p,
+.app-create-shell .wizard-shell__title-copy p {
+  margin: 5px 0 0;
+  color: var(--app-text-muted);
+  font-size: 13px;
+  font-weight: 760;
+  line-height: 1.45;
+}
+.app-create-back,
+.app-create-shell .web-back-button {
+  border-color: color-mix(in srgb, var(--app-create-accent-border) 44%, var(--app-border));
+}
+.app-create-progress,
+.app-create-shell .wizard-progress {
+  display: grid;
+  gap: 7px;
+}
+.app-create-progress__label-row,
+.app-create-shell .wizard-progress__label-row {
+  display: flex;
+  align-items: center;
+  justify-content: flex-start;
+  gap: 10px;
+  color: var(--app-text-muted);
+  font-size: 11px;
+  font-weight: 950;
+  letter-spacing: 0.12em;
+  line-height: 1;
+  text-transform: uppercase;
+}
+.app-create-progress__track,
+.app-create-shell .wizard-progress__track {
+  position: relative;
+  height: 5px;
+  overflow: hidden;
+  border-radius: 999px;
+  background: color-mix(in srgb, var(--app-create-accent-bg) 42%, var(--app-bg-muted));
+}
+.app-create-progress__fill,
+.app-create-shell .wizard-progress__fill {
+  position: absolute;
+  inset: 0 auto 0 0;
+  border-radius: inherit;
+  background: var(--app-create-accent-text);
+}
+.app-create-shell .wizard-shell__body { gap: 14px; }
+.app-create-shell .wizard-shell__step-intro { gap: 4px; }
+.app-create-shell .wizard-shell__step-intro h2 { font-size: 24px; }
+.app-create-shell .wizard-shell__step-intro p { font-size: 13px; line-height: 1.45; }
+.app-create-shell .wizard-shell__footer-wrap { margin-bottom: 0; }
+.app-create-shell--plan .plan-form--timeline { display: grid; gap: 14px; }
+.app-create-shell--plan .plan-stage-tabs { border-color: color-mix(in srgb, var(--app-create-accent-border) 46%, var(--app-divider)); background: color-mix(in srgb, var(--app-create-accent-bg) 32%, transparent); }
+.app-create-shell--plan .plan-stage-tabs button.is-active { background: var(--app-surface); color: var(--app-create-accent-text); box-shadow: var(--app-control-shadow); }
 .page-intro { display: flex; align-items: flex-start; justify-content: space-between; gap: 12px; }
 .page-intro p { margin-bottom: 0; }
 .page-intro__action { flex: 0 0 auto; }
