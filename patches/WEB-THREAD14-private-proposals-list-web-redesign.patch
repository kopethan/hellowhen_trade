diff --git a/apps/web/src/app/globals.css b/apps/web/src/app/globals.css
index 60f90ff..6f02960 100644
--- a/apps/web/src/app/globals.css
+++ b/apps/web/src/app/globals.css
@@ -5926,3 +5926,194 @@ html[data-theme="dark"] .onboarding-guide-primary {
     padding: 14px 18px;
   }
 }
+
+/* WEB-THREAD14: private proposals list web redesign */
+.private-proposal-row__main {
+  display: grid;
+  min-width: 0;
+  gap: 6px;
+}
+
+.private-proposal-row__message {
+  display: -webkit-box;
+  -webkit-box-orient: vertical;
+  -webkit-line-clamp: 2;
+  overflow: hidden;
+  margin: 0 0 0 42px;
+  color: var(--app-text-muted);
+  font-size: 12px;
+  font-weight: 760;
+  line-height: 1.38;
+}
+
+.private-proposal-row__open {
+  display: none;
+}
+
+.private-proposals-section--clean .proposal-composer button[type="submit"] {
+  justify-self: stretch;
+}
+
+@media (min-width: 760px) {
+  .private-proposals-page--messages-only {
+    display: grid;
+    grid-template-rows: auto minmax(0, auto);
+    max-width: 760px;
+    min-height: auto;
+    overflow: visible;
+    border-radius: 30px;
+    background: var(--app-surface);
+  }
+
+  .private-proposals-page--messages-only .web-thread-header {
+    grid-template-columns: 44px minmax(0, 1fr) 44px;
+    min-height: 74px;
+    padding: 14px 18px;
+  }
+
+  .private-proposals-page--messages-only .web-thread-header h2 {
+    justify-self: start;
+    font-size: 23px;
+    letter-spacing: -0.04em;
+    line-height: 1.05;
+    text-align: left;
+  }
+
+  .private-proposals-page--messages-only .web-thread-header__back,
+  .private-proposals-page--messages-only .web-thread-header__menu {
+    width: 40px;
+    height: 40px;
+    border-color: color-mix(in srgb, var(--app-border) 76%, transparent);
+    background: color-mix(in srgb, var(--app-bg) 72%, transparent);
+    box-shadow: var(--app-control-shadow);
+  }
+
+  .private-proposals-page--messages-only .web-thread-header__back:hover,
+  .private-proposals-page--messages-only .web-thread-header__back:focus-visible,
+  .private-proposals-page--messages-only .web-thread-header__menu:hover,
+  .private-proposals-page--messages-only .web-thread-header__menu:focus-visible {
+    border-color: var(--app-border-strong);
+    background: var(--app-bg);
+  }
+
+  .private-proposals-page--messages-only .private-proposals-section--clean {
+    display: grid;
+    min-height: 0;
+    overflow: visible;
+    gap: 14px;
+    padding: 18px;
+    background: color-mix(in srgb, var(--app-surface-soft) 35%, transparent);
+  }
+
+  .private-proposals-page--messages-only .private-proposals-section--clean .notice-box {
+    margin: 0;
+  }
+
+  .private-proposals-page--messages-only .private-proposals-section--clean .proposal-composer {
+    margin: 0;
+    border: 1px solid color-mix(in srgb, var(--app-border) 82%, transparent);
+    border-radius: 24px;
+    background: color-mix(in srgb, var(--app-surface) 96%, transparent);
+    padding: 15px;
+    box-shadow: 0 10px 28px rgba(15, 23, 42, 0.055);
+  }
+
+  .private-proposals-page--messages-only .proposal-attachment-lines {
+    margin: 0;
+    overflow: hidden;
+    border: 1px solid color-mix(in srgb, var(--app-border) 80%, transparent);
+    border-radius: 18px;
+    background: color-mix(in srgb, var(--app-bg) 66%, var(--app-surface));
+  }
+
+  .private-proposals-page--messages-only .proposal-attachment-line {
+    margin: 0;
+    padding: 11px 12px;
+  }
+
+  .private-proposals-page--messages-only .proposal-attachment-hint {
+    margin: 0;
+    border-radius: 18px;
+    background: color-mix(in srgb, var(--app-bg) 70%, var(--app-surface));
+    padding: 12px 13px;
+  }
+
+  .private-proposals-page--messages-only .proposal-message-field--minimal textarea {
+    min-height: 96px;
+    border: 1px solid color-mix(in srgb, var(--app-border) 86%, transparent);
+    background: color-mix(in srgb, var(--app-bg) 78%, var(--app-surface));
+  }
+
+  .private-proposals-page--messages-only .private-proposal-row-list {
+    display: grid;
+    gap: 12px;
+    margin: 0;
+  }
+
+  .private-proposals-page--messages-only .private-proposal-row {
+    grid-template-columns: minmax(0, 1fr) auto auto auto;
+    min-height: 0;
+    gap: 12px;
+    border: 1px solid color-mix(in srgb, var(--app-border) 82%, transparent);
+    border-radius: 24px;
+    background: color-mix(in srgb, var(--app-surface) 96%, transparent);
+    padding: 15px 16px;
+    box-shadow: 0 10px 28px rgba(15, 23, 42, 0.055);
+  }
+
+  .private-proposals-page--messages-only .private-proposal-row:hover,
+  .private-proposals-page--messages-only .private-proposal-row:focus-visible {
+    border-color: color-mix(in srgb, var(--app-border-strong) 84%, transparent);
+    background: var(--app-surface);
+    transform: translateY(-1px);
+  }
+
+  .private-proposals-page--messages-only .private-proposal-row--active {
+    border-color: color-mix(in srgb, var(--proposal-border) 64%, var(--app-border));
+    background: color-mix(in srgb, var(--proposal-bg) 24%, var(--app-surface));
+  }
+
+  .private-proposals-page--messages-only .private-proposal-row__message {
+    max-width: 52ch;
+    margin-left: 44px;
+    font-size: 13px;
+    line-height: 1.42;
+  }
+
+  .private-proposals-page--messages-only .private-proposal-row__status {
+    min-height: 30px;
+    border: 1px solid color-mix(in srgb, var(--proposal-border) 44%, var(--app-border));
+    border-radius: 999px;
+    background: color-mix(in srgb, var(--proposal-bg) 22%, var(--app-surface));
+    color: var(--proposal-text);
+    padding: 0 10px;
+  }
+
+  .private-proposals-page--messages-only .private-proposal-row__open {
+    display: inline-flex;
+    align-items: center;
+    justify-content: center;
+    min-height: 30px;
+    border-radius: 999px;
+    background: color-mix(in srgb, var(--app-bg) 75%, var(--app-surface));
+    color: var(--app-text-muted);
+    padding: 0 10px;
+    font-size: 11px;
+    font-weight: 950;
+    letter-spacing: .08em;
+    text-transform: uppercase;
+    white-space: nowrap;
+  }
+
+  .private-proposals-page--messages-only .private-proposal-row > .web-icon:last-child {
+    color: var(--app-text-muted);
+  }
+
+  .private-proposals-page--messages-only .private-proposal-empty-text {
+    margin: 0;
+    border: 1px dashed var(--app-border-strong);
+    border-radius: 22px;
+    background: color-mix(in srgb, var(--app-surface) 78%, transparent);
+    padding: 20px;
+  }
+}
