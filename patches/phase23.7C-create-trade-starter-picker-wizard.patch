diff --git a/apps/web/src/app/globals.css b/apps/web/src/app/globals.css
index bcc0099..661aa76 100644
--- a/apps/web/src/app/globals.css
+++ b/apps/web/src/app/globals.css
@@ -1024,3 +1024,33 @@ html[data-theme="dark"] .inventory-empty-state__plus {
 .trade-create-pair-status--warning { border-color: var(--warning-border); background: color-mix(in srgb, var(--warning-bg) 42%, var(--app-surface)); }
 .trade-create-pair-status--success { border-color: var(--success-border); background: color-mix(in srgb, var(--success-bg) 36%, var(--app-surface)); }
 .trade-create-pair-status--info { border-color: var(--info-border); background: color-mix(in srgb, var(--info-bg) 36%, var(--app-surface)); }
+
+/* Phase 23.7C: create-trade starter picker wizard */
+.trade-side-source-step { gap: 16px; }
+.trade-side-source-grid { display: grid; gap: 10px; }
+.trade-side-source-card { display: grid; grid-template-columns: 48px minmax(0, 1fr); gap: 10px; align-items: center; border: 1px solid var(--app-border); border-radius: 22px; background: var(--app-surface-soft); color: var(--app-text); padding: 12px; text-decoration: none; }
+.trade-side-source-card > span { grid-row: span 2; display: grid; place-items: center; width: 48px; height: 48px; border-radius: 16px; background: var(--app-bg-muted); color: var(--app-text-soft); }
+.trade-side-source-card strong { align-self: end; }
+.trade-side-source-card small { align-self: start; color: var(--app-text-muted); font-size: 12px; font-weight: 800; }
+.trade-side-source-card:focus-visible,
+.trade-side-source-back:focus-visible,
+.trade-side-template-option:focus-within { outline: 3px solid color-mix(in srgb, var(--proposal-border) 72%, transparent); outline-offset: 3px; }
+.trade-side-source-back { justify-self: start; color: var(--app-text-muted); font-size: 12px; font-weight: 950; letter-spacing: .02em; text-decoration: none; }
+.trade-side-source-back::before { content: '‹ '; }
+.trade-side-template-filters { margin-top: -2px; }
+.trade-side-template-library { display: grid; gap: 16px; }
+.trade-side-template-section { display: grid; gap: 8px; }
+.trade-side-template-option { display: grid; grid-template-columns: 58px minmax(0, 1fr); gap: 10px; border: 1px solid var(--app-border); border-radius: 20px; background: var(--app-surface-soft); color: var(--app-text); padding: 8px; }
+.trade-side-template-option__body { display: grid; gap: 6px; min-width: 0; }
+.trade-side-template-option__body p { margin: 0; color: var(--app-text-muted); font-size: 12px; font-weight: 750; line-height: 1.35; }
+.trade-side-template-option__body > span { color: var(--app-text-muted); font-size: 12px; font-weight: 750; }
+.trade-side-template-option__body .trade-side-option__top em { max-width: 45%; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
+.trade-side-template-option__tags { margin-top: 0; }
+.trade-side-template-option__button { justify-self: start; min-height: 34px; margin-top: 2px; padding-inline: 12px; }
+.trade-side-empty-actions { display: flex; flex-wrap: wrap; gap: 8px; margin-top: 2px; }
+@media (max-width: 420px) {
+  .trade-side-source-card,
+  .trade-side-template-option { grid-template-columns: 50px minmax(0, 1fr); }
+  .trade-side-source-card > span,
+  .trade-side-template-option .trade-side-option__media { width: 50px; height: 50px; }
+}
