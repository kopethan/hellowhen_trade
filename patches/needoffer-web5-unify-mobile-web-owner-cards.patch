diff --git a/apps/web/src/app/globals.css b/apps/web/src/app/globals.css
index d83c5ab..5b09f77 100644
--- a/apps/web/src/app/globals.css
+++ b/apps/web/src/app/globals.css
@@ -3826,3 +3826,103 @@ html[data-theme="dark"] .onboarding-guide-primary {
     right: 9px;
   }
 }
+
+/* NEEDOFFER-WEB5: make mobile web owner cards use the same compact shell as starter cards. */
+.inventory-card__chevron { display: none; }
+
+@media (max-width: 719px) {
+  .inventory-card--owner {
+    grid-template-columns: minmax(92px, 33.333%) minmax(0, 1fr);
+    min-height: 118px;
+    cursor: pointer;
+  }
+
+  .inventory-card--owner::after { content: none; }
+
+  .inventory-card--owner .inventory-card__media {
+    align-self: stretch;
+    height: 100%;
+    min-height: 100%;
+    aspect-ratio: auto;
+  }
+
+  .inventory-card--owner .inventory-card__body {
+    display: grid;
+    align-content: center;
+    gap: 5px;
+    min-width: 0;
+    overflow: hidden;
+    padding: 10px 36px 10px 12px;
+  }
+
+  .inventory-card--owner .inventory-card__body .status-row {
+    flex-wrap: nowrap;
+    gap: 5px;
+    min-width: 0;
+    overflow: hidden;
+  }
+
+  .inventory-card--owner .inventory-card__body .status-row .semantic-badge {
+    flex: 0 1 auto;
+    max-width: 100%;
+    min-width: 0;
+    overflow: hidden;
+    text-overflow: ellipsis;
+    white-space: nowrap;
+  }
+
+  .inventory-card--owner .inventory-card__body h3 {
+    display: -webkit-box;
+    overflow: hidden;
+    margin: 0;
+    -webkit-line-clamp: 2;
+    -webkit-box-orient: vertical;
+    font-size: 15px;
+    line-height: 1.12;
+  }
+
+  .inventory-card--owner .inventory-card__body .meta {
+    display: block;
+    overflow: hidden;
+    margin: 0;
+    text-overflow: ellipsis;
+    white-space: nowrap;
+  }
+
+  .inventory-card--owner .inventory-card__body > p:not(.meta),
+  .inventory-card--owner .inventory-card__footer,
+  .inventory-card--owner .inventory-card__tags {
+    display: none;
+  }
+
+  .inventory-card--owner .inventory-card__chevron {
+    position: absolute;
+    top: 50%;
+    right: 12px;
+    display: grid;
+    place-items: center;
+    width: 20px;
+    height: 20px;
+    color: var(--app-text-muted);
+    font-size: 26px;
+    font-weight: 650;
+    line-height: 1;
+    transform: translateY(-50%);
+  }
+}
+
+@media (max-width: 380px) {
+  .inventory-card--owner {
+    grid-template-columns: minmax(86px, 33.333%) minmax(0, 1fr);
+    min-height: 108px;
+  }
+
+  .inventory-card--owner .inventory-card__body {
+    gap: 4px;
+    padding: 8px 30px 8px 10px;
+  }
+
+  .inventory-card--owner .inventory-card__chevron {
+    right: 9px;
+  }
+}
