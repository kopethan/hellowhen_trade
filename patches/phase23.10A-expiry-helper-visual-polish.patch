+  font-weight: 760;
+  line-height: 1.45;
+}
+.trade-expiry-callout__icon {
+  display: inline-grid;
+  place-items: center;
+  width: 20px;
+  height: 20px;
+  border-radius: 999px;
+  background: var(--danger-text);
+  color: var(--danger-bg);
+  font-size: 12px;
+  font-weight: 950;
+  line-height: 1;
+}
 .password-field { position: relative; display: grid; }
 .password-field input { padding-right: 72px; }
 .inline-button { position: absolute; top: 50%; right: 7px; min-height: 34px; transform: translateY(-50%); border: 1px solid var(--app-border); border-radius: 999px; background: var(--app-surface-soft); color: var(--app-text); padding: 0 11px; font-size: 12px; }
