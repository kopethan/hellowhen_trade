 .trade-stack-card__mobile-divider::before { content: ''; position: absolute; right: 0; left: 0; top: 50%; height: 1px; background: color-mix(in srgb, var(--app-border) 72%, transparent); }
-.trade-stack-card__mobile-divider span { position: relative; z-index: 1; display: grid; place-items: center; width: 28px; height: 28px; border: 1px solid var(--app-border); border-radius: 999px; background: var(--app-surface); color: var(--app-text); box-shadow: 0 8px 20px rgba(15, 23, 42, 0.08); }
+.trade-stack-card__mobile-divider > span { position: relative; z-index: 1; display: grid; place-items: center; width: 28px; height: 28px; border: 1px solid var(--app-border); border-radius: 999px; background: var(--app-surface); color: var(--app-text); box-shadow: 0 8px 20px rgba(15, 23, 42, 0.08); }
 .trade-stack-card__mobile-money { justify-self: center; align-self: end; display: inline-flex; align-items: center; min-height: 30px; border: 1px solid var(--money-border); border-radius: 999px; background: var(--money-bg); color: var(--money-text); padding: 0 12px; font-size: 12px; font-weight: 950; }
 
