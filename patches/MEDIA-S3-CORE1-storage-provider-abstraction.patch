diff --git a/apps/api/src/modules/media/storage/localMediaStorage.ts b/apps/api/src/modules/media/storage/localMediaStorage.ts
new file mode 100644
index 0000000..0fe8c1d
--- /dev/null
+++ b/apps/api/src/modules/media/storage/localMediaStorage.ts
@@ -0,0 +1,47 @@
+import fs from 'node:fs';
+import { promises as fsp } from 'node:fs';
+import path from 'node:path';
+import type { MediaStorageProvider, StoreMediaImageInput, StoredMediaImage } from './mediaStorage.types.js';
+
+const localUploadNamePattern = /^[A-Za-z0-9][A-Za-z0-9._-]*\.(?:jpg|jpeg|png|webp)$/i;
+
+function normalizeFilenameBase(value: string) {
+  const safeBase = path.basename(value, path.extname(value)).replace(/[^A-Za-z0-9._-]/g, '-');
+  return safeBase || `${Date.now()}-upload`;
+}
+
+export class LocalMediaStorageProvider implements MediaStorageProvider {
+  readonly driver = 'local' as const;
+
+  constructor(private readonly uploadDir: string) {
+    fs.mkdirSync(this.uploadDir, { recursive: true });
+  }
+
+  async storeImage(input: StoreMediaImageInput): Promise<StoredMediaImage> {
+    const storageKey = `${normalizeFilenameBase(input.filenameBase)}${input.extension}`;
+    const filePath = this.resolveLocalPath(storageKey);
+    if (!filePath) {
+      throw Object.assign(new Error('Invalid local media storage key.'), {
+        statusCode: 400,
+        code: 'invalid_media_storage_key',
+        publicMessage: 'Image upload failed. Try uploading the image again.'
+      });
+    }
+
+    await fsp.writeFile(filePath, input.buffer);
+    return {
+      storageKey,
+      url: `/uploads/${storageKey}`,
+      sizeBytes: input.buffer.length
+    };
+  }
+
+  resolveLocalPath(storageKey: string) {
+    if (!storageKey || !localUploadNamePattern.test(storageKey)) return null;
+    const uploadRoot = path.resolve(this.uploadDir);
+    const filePath = path.resolve(uploadRoot, storageKey);
+    if (filePath !== path.join(uploadRoot, path.basename(storageKey))) return null;
+    if (!filePath.startsWith(`${uploadRoot}${path.sep}`)) return null;
+    return filePath;
+  }
+}
diff --git a/apps/api/src/modules/media/storage/mediaStorage.types.ts b/apps/api/src/modules/media/storage/mediaStorage.types.ts
new file mode 100644
index 0000000..6131517
--- /dev/null
+++ b/apps/api/src/modules/media/storage/mediaStorage.types.ts
@@ -0,0 +1,21 @@
+export type MediaStorageDriver = 'local' | 's3';
+
+export type MediaStorageImageExtension = '.jpg' | '.png' | '.webp';
+
+export type StoreMediaImageInput = {
+  buffer: Buffer;
+  filenameBase: string;
+  extension: MediaStorageImageExtension;
+  mimeType: string;
+};
+
+export type StoredMediaImage = {
+  storageKey: string;
+  url: string;
+  sizeBytes: number;
+};
+
+export interface MediaStorageProvider {
+  readonly driver: MediaStorageDriver;
+  storeImage(input: StoreMediaImageInput): Promise<StoredMediaImage>;
+}
diff --git a/apps/api/src/modules/media/storage/mediaStorageProvider.ts b/apps/api/src/modules/media/storage/mediaStorageProvider.ts
new file mode 100644
index 0000000..5873534
--- /dev/null
+++ b/apps/api/src/modules/media/storage/mediaStorageProvider.ts
@@ -0,0 +1,29 @@
+import { env } from '../../../config/env.js';
+import { LocalMediaStorageProvider } from './localMediaStorage.js';
+import { S3MediaStorageProvider } from './s3MediaStorage.js';
+import type { MediaStorageProvider } from './mediaStorage.types.js';
+
+const localMediaStorageProvider = new LocalMediaStorageProvider(env.uploadDir);
+
+let writeProvider: MediaStorageProvider | null = null;
+
+export function getLocalMediaStorageProvider() {
+  return localMediaStorageProvider;
+}
+
+export function getMediaStorageProvider() {
+  if (writeProvider) return writeProvider;
+
+  if (env.mediaStorageDriver === 's3') {
+    writeProvider = new S3MediaStorageProvider({
+      region: env.awsRegion,
+      bucket: env.mediaS3Bucket,
+      prefix: env.mediaS3Prefix,
+      publicBaseUrl: env.mediaPublicBaseUrl
+    });
+    return writeProvider;
+  }
+
+  writeProvider = localMediaStorageProvider;
+  return writeProvider;
+}
