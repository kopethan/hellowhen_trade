@@ -0,0 +1,22 @@
+import type { MediaStorageProvider, StoreMediaImageInput, StoredMediaImage } from './mediaStorage.types.js';
+
+export type S3MediaStorageConfig = {
+  region: string;
+  bucket: string;
+  prefix: string;
+  publicBaseUrl: string;
+};
+
+export class S3MediaStorageProvider implements MediaStorageProvider {
+  readonly driver = 's3' as const;
+
+  constructor(readonly config: S3MediaStorageConfig) {}
+
+  async storeImage(_input: StoreMediaImageInput): Promise<StoredMediaImage> {
+    throw Object.assign(new Error('S3 media storage is configured, but upload support has not been enabled yet.'), {
+      statusCode: 503,
+      code: 'media_s3_not_enabled',
+      publicMessage: 'S3 media storage is configured, but uploads are not enabled yet. Switch MEDIA_STORAGE_DRIVER=local or apply the S3 upload patch.'
+    });
+  }
+}
