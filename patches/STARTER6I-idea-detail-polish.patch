+
+/* STARTER6I: idea detail polish, related ideas, and honest next-step guidance. */
+.button.ghost {
+  background: transparent;
+  border-color: var(--app-border);
+  color: var(--app-text-muted);
+}
+
+.trade-idea-detail-next ol {
+  counter-reset: starter-step;
+  display: grid;
+  gap: 10px;
+  list-style: none;
+  margin: 0;
+  padding: 0;
+}
+
+.trade-idea-detail-next li {
+  align-items: flex-start;
+  counter-increment: starter-step;
+  color: var(--app-text);
+  display: grid;
+  font-size: 14px;
+  font-weight: 820;
+  gap: 10px;
+  grid-template-columns: 24px minmax(0, 1fr);
+  line-height: 1.45;
+}
+
+.trade-idea-detail-next li::before {
+  align-items: center;
+  background: var(--app-surface-soft);
+  border: 1px solid var(--app-border);
+  border-radius: 999px;
+  color: var(--app-text-muted);
+  content: counter(starter-step);
+  display: inline-flex;
+  font-size: 11px;
+  font-weight: 950;
+  height: 24px;
+  justify-content: center;
+  line-height: 1;
+  margin-top: 1px;
+  width: 24px;
+}
+
+.trade-idea-detail-more {
+  display: grid;
+  gap: 12px;
+}
+
+.trade-idea-detail-more-grid {
+  display: grid;
+  gap: 10px;
+  grid-template-columns: repeat(3, minmax(0, 1fr));
+}
+
+.trade-idea-detail-more-card {
+  border: 1px solid var(--app-border);
+  border-radius: 18px;
+  background: var(--app-surface);
+  color: inherit;
+  display: grid;
+  gap: 6px;
+  min-height: 124px;
+  padding: 13px;
+  text-decoration: none;
+  transition: transform .18s ease, border-color .18s ease, background .18s ease;
+}
+
+.trade-idea-detail-more-card:hover,
+.trade-idea-detail-more-card:focus-visible {
+  background: var(--app-surface-soft);
+  border-color: var(--app-border-strong);
+  transform: translateY(-1px);
+}
+
+.trade-idea-detail-more-card span,
+.trade-idea-detail-more-card small {
+  color: var(--app-text-muted);
+  font-size: 11px;
+  font-weight: 900;
+  letter-spacing: .48px;
+  line-height: 1.25;
+  text-transform: uppercase;
+}
+
+.trade-idea-detail-more-card strong {
+  color: var(--app-text);
+  font-size: 13px;
+  font-weight: 880;
+  line-height: 1.32;
+}
+
+.trade-idea-detail-more-card small {
+  align-self: end;
+  text-transform: none;
+}
+
+.trade-idea-detail-not-found {
+  align-items: start;
+}
+
+.trade-idea-detail-not-found-actions {
+  display: flex;
+  flex-wrap: wrap;
+  gap: 10px;
+}
+
+@media (max-width: 720px) {
+  .trade-idea-detail-more-grid {
+    grid-template-columns: 1fr;
+  }
+
+  .trade-idea-detail-more-card {
+    min-height: 0;
+  }
+
+  .trade-idea-detail-actions {
+    grid-template-columns: 1fr;
+  }
+}
