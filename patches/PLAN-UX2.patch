 .plan-place-source-overlay { position: fixed; inset: 0; z-index: 80; display: grid; align-items: end; justify-items: stretch; padding: 16px; }
 .plan-place-source-backdrop { position: absolute; inset: 0; border: 0; background: rgba(9, 9, 11, 0.48); cursor: pointer; }
 .plan-place-source-sheet { position: relative; z-index: 1; display: grid; gap: 10px; width: min(100%, 560px); max-height: min(86vh, 720px); overflow: auto; border: 1px solid var(--app-border); border-radius: 26px 26px 22px 22px; background: var(--app-surface); box-shadow: 0 24px 80px rgba(15, 23, 42, 0.28); padding: 14px; }
+.plan-place-source-sheet--compact { gap: 6px; width: min(100%, 500px); max-height: min(76vh, 620px); border-radius: 22px 22px 20px 20px; box-shadow: 0 24px 80px rgba(15, 23, 42, 0.24); padding: 12px 14px 16px; }
 .plan-place-source-grid { display: grid; gap: 0; border-top: 1px solid var(--app-divider); }
-.plan-place-source-option { display: grid; grid-template-columns: 36px minmax(0, 1fr); align-items: center; gap: 12px; width: 100%; min-height: 62px; border: 0; border-bottom: 1px solid var(--app-divider); border-radius: 0; background: transparent; color: inherit; padding: 10px 0; text-align: left; cursor: pointer; }
+.plan-place-source-option { display: grid; grid-template-columns: 32px minmax(0, 1fr); align-items: center; gap: 11px; width: 100%; min-height: 54px; border: 0; border-bottom: 1px solid var(--app-divider); border-radius: 0; background: transparent; color: inherit; padding: 9px 0; text-align: left; cursor: pointer; }
 .plan-place-source-option:hover { background: color-mix(in srgb, var(--place-bg) 18%, transparent); }
 .plan-place-source-option--primary { background: transparent; }
-.plan-place-source-option__icon { display: grid; place-items: center; width: 36px; height: 36px; border: 1px solid var(--place-border); border-radius: 999px; background: var(--place-bg); color: var(--place-text); font-size: 16px; font-weight: 950; }
-.plan-place-source-option span:last-child { display: grid; gap: 3px; min-width: 0; }
-.plan-place-source-option strong { color: var(--app-text); font-size: 15px; font-weight: 950; }
+.plan-place-source-option__icon { display: grid; place-items: center; width: 32px; height: 32px; border: 1px solid var(--place-border); border-radius: 999px; background: var(--place-bg); color: var(--place-text); font-size: 15px; font-weight: 950; }
+.plan-place-source-option span:last-child { display: grid; gap: 1px; min-width: 0; }
+.plan-place-source-option strong { color: var(--app-text); font-size: 15px; line-height: 1.25; font-weight: 950; }
 .plan-place-source-option small { color: var(--app-text-muted); font-size: 12px; font-weight: 800; line-height: 1.28; }
 .plan-place-picker-actions { display: flex; gap: 8px; flex-wrap: wrap; justify-content: flex-end; }
 @media (min-width: 721px) {
   .plan-place-source-overlay { align-items: center; justify-items: center; }
   .plan-place-source-sheet { border-radius: 28px; }
