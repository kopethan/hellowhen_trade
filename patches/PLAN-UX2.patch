 }
 .plan-create-place-box { display: grid; gap: 11px; border: 1px solid var(--app-border); border-radius: 22px; background: var(--app-surface-soft); padding: 12px; }
 .plan-create-place-box h4 { margin: 0; letter-spacing: -0.02em; }
