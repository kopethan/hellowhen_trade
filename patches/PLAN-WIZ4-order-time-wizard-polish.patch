 }
+
+/* PLAN-WIZ4 — Order/time Create Plan wizard polish */
+.plan-wizard-steps { display: grid; grid-template-columns: repeat(4, minmax(0, 1fr)); gap: 7px; }
+.plan-wizard-steps span { border: 1px solid var(--app-border); border-radius: 999px; background: var(--app-surface-soft); color: var(--app-text-muted); padding: 8px 10px; font-size: 11px; font-weight: 950; text-align: center; text-transform: uppercase; letter-spacing: 0.04em; }
+.plan-wizard-steps span.is-active { border-color: var(--app-border-strong); background: var(--app-surface); color: var(--app-text); }
+.plan-form__section-title--divider { border-top: 1px solid var(--app-border); padding-top: 14px; }
+.plan-time-section { display: grid; gap: 12px; border-top: 1px solid var(--app-border); padding-top: 14px; }
+.plan-time-list { display: grid; gap: 9px; }
+.plan-time-row { display: grid; grid-template-columns: minmax(0, 1.4fr) minmax(140px, 0.8fr) minmax(120px, 0.7fr); align-items: end; gap: 10px; border: 1px solid var(--app-border); border-radius: 20px; background: var(--app-surface-soft); padding: 10px; }
+.plan-time-row > div { display: grid; gap: 4px; min-width: 0; }
+.plan-time-row strong, .plan-time-row small { overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
+.plan-time-row strong { color: var(--app-text); font-size: 14px; font-weight: 950; }
+.plan-time-row small { color: var(--app-text-muted); font-size: 12px; font-weight: 800; }
+.plan-time-row label { display: grid; gap: 7px; color: var(--app-text-muted); font-size: 12px; font-weight: 950; letter-spacing: 0.04em; text-transform: uppercase; }
+.plan-time-row input { width: 100%; border: 1px solid var(--app-border-strong); border-radius: 18px; background: var(--app-surface); color: var(--app-text); padding: 12px 13px; font: inherit; font-weight: 750; outline: none; }
+@media (max-width: 720px) {
+  .plan-wizard-steps { grid-template-columns: repeat(2, minmax(0, 1fr)); }
+  .plan-time-row { grid-template-columns: 1fr; align-items: stretch; }
+}
