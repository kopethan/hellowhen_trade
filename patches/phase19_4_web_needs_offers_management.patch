+
+/* Phase 19.4: web Needs/Offers management */
+.inventory-controls { position: sticky; z-index: 10; top: 0; display: grid; grid-template-columns: minmax(0, 1fr) auto; gap: 8px; margin: -2px 0 2px; padding: 2px 0 10px; background: var(--app-bg); }
+.inventory-list { display: grid; gap: 14px; }
+.inventory-card { display: grid; grid-template-columns: 104px minmax(0, 1fr); gap: 12px; border: 0; border-radius: 28px; background: var(--app-surface); padding: 10px; box-shadow: 0 14px 38px rgba(15, 23, 42, 0.09); }
+.inventory-card__media { display: grid; place-items: center; overflow: hidden; min-height: 104px; border-radius: 22px; background: var(--app-surface-soft); color: var(--app-text-soft); font-size: 34px; font-weight: 900; }
+.inventory-card__media img { width: 100%; height: 100%; object-fit: cover; display: block; }
+.inventory-card__body { display: grid; align-content: start; gap: 7px; min-width: 0; padding: 5px 4px 5px 0; }
+.inventory-card__body h3 { margin: 0; }
+.inventory-card__body p { display: -webkit-box; overflow: hidden; margin: 0; -webkit-line-clamp: 2; -webkit-box-orient: vertical; font-size: 13px; }
+.inventory-card__body .meta { -webkit-line-clamp: 1; font-size: 12px; }
+.inventory-card__footer { display: flex; align-items: center; justify-content: space-between; gap: 10px; color: var(--app-text-muted); font-size: 12px; font-weight: 850; }
+.inventory-card__footer strong { color: var(--app-text); }
+.inventory-card__tags { margin-top: 2px; }
+.inventory-card__tags span { min-height: 24px; padding: 0 8px; font-size: 11px; }
+.inventory-form { display: grid; gap: 16px; }
+.inventory-form__hero { display: grid; gap: 14px; }
+.inventory-form__grid { display: grid; gap: 13px; }
+.inventory-form__wide { grid-column: 1 / -1; }
+.inventory-media-panel { display: grid; gap: 14px; }
+.inventory-media-panel h3 { margin-bottom: 4px; }
+.inventory-media-panel p { margin-bottom: 0; }
+.image-upload-button { display: inline-flex; align-items: center; justify-content: center; min-height: 44px; border: 1px solid var(--app-border-strong); border-radius: 999px; background: var(--app-text); color: var(--app-bg); padding: 0 15px; font-size: 14px; font-weight: 900; cursor: pointer; }
+.image-upload-button input { position: absolute; width: 1px; height: 1px; overflow: hidden; opacity: 0; pointer-events: none; }
+.inventory-media-grid { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 8px; }
+.inventory-media-grid figure { position: relative; overflow: hidden; margin: 0; border-radius: 22px; background: var(--app-border); aspect-ratio: 1 / 1; }
+.inventory-media-grid img { width: 100%; height: 100%; object-fit: cover; display: block; }
+.inventory-media-grid figcaption { position: absolute; inset: auto 8px 8px 8px; display: flex; align-items: center; justify-content: space-between; gap: 6px; }
+.inventory-media-grid figcaption .semantic-badge { box-shadow: 0 10px 24px rgba(15, 23, 42, 0.18); }
+.inventory-media-grid figcaption button { min-height: 30px; border-radius: 999px; padding: 0 9px; font-size: 11px; box-shadow: 0 10px 24px rgba(15, 23, 42, 0.18); }
+.inventory-media-grid--detail { grid-template-columns: 1fr; }
+.inventory-media-grid--detail figure { aspect-ratio: 16 / 11; }
+.inventory-detail-actions { display: flex; flex-wrap: wrap; gap: 10px; }
+.sticky-form-actions { position: sticky; bottom: calc(var(--app-tab-height) + 12px); z-index: 12; display: grid; grid-template-columns: 1fr 1fr; gap: 10px; border: 1px solid color-mix(in srgb, var(--app-border) 80%, transparent); border-radius: 24px; background: color-mix(in srgb, var(--app-bg) 92%, transparent); padding: 10px; backdrop-filter: blur(16px); box-shadow: 0 14px 38px rgba(15, 23, 42, 0.12); }
+.danger-button { color: var(--danger-text) !important; border-color: var(--danger-border) !important; background: var(--danger-bg) !important; }
+.form-message { margin: 0; border-radius: 18px; padding: 12px; font-size: 13px; font-weight: 800; }
+.form-message--success { background: var(--success-bg); color: var(--success-text); border: 1px solid var(--success-border); }
+.form-message--error { background: var(--danger-bg); color: var(--danger-text); border: 1px solid var(--danger-border); }
+
+@media (min-width: 430px) {
+  .inventory-form__grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
+}
+
+@media (max-width: 380px) {
+  .inventory-card { grid-template-columns: 86px minmax(0, 1fr); }
+  .inventory-card__media { min-height: 86px; border-radius: 19px; }
+  .sticky-form-actions { grid-template-columns: 1fr; }
+}
