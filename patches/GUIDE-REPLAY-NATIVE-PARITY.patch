+export function useFeatureGuidePrompt(type: FeatureGuidePromptType): FeatureGuidePromptValue {
+  const [visible, setVisible] = useState(false);
+  const [hydrated, setHydrated] = useState(false);
+
+  const refresh = useCallback(async () => {
+    setHydrated(false);
+    try {
+      const [dismissed, completed] = await Promise.all([
+        hasDismissedFeatureGuidePrompt(type),
+        hasCompletedOnboardingGuide(type),
+      ]);
