# API
NODE_ENV=development
PORT=4000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/zizilia?schema=public
JWT_SECRET=dev-change-me
WEB_ORIGIN=http://localhost:3000
MOBILE_ORIGIN=exp://127.0.0.1:8081

# Mobile app
# Copy apps/mobile/.env.example to apps/mobile/.env and set this to the API URL
# reachable from your simulator or phone. Physical devices need your computer LAN IP.
EXPO_PUBLIC_API_URL=http://127.0.0.1:4000

# Payments are intentionally disabled in Patch 1.
CREDITS_MODE=fake
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
