GOOGLE_PLACES_DEFAULT_LANGUAGE=en
# Optional comma-separated ISO country codes, e.g. FR or FR,BE,CH.
GOOGLE_PLACES_COUNTRY_CODES=FR
GOOGLE_PLACES_REQUEST_TIMEOUT_MS=4500

# Optional Place card static map previews. These render Google Static Maps as direct image URLs; do not download/re-host them.
GOOGLE_STATIC_MAPS_ENABLED=false
GOOGLE_STATIC_MAPS_API_KEY=
# Keep anonymous static maps off until you are comfortable with public traffic. Logged-in users can still receive map URLs.
GOOGLE_STATIC_MAPS_ANONYMOUS_ENABLED=false
# Soft API-side exposure caps. These estimate Static Maps image loads and stop issuing URLs before the free-tier target.
GOOGLE_STATIC_MAPS_DAILY_SOFT_LIMIT=250
GOOGLE_STATIC_MAPS_MONTHLY_SOFT_LIMIT=9000
# Default template family when a Place has no assigned template yet.
GOOGLE_STATIC_MAPS_DEFAULT_TEMPLATE=clean_local
# Optional Cloud Styling map IDs. Keep blank to fall back to simple URL styles.
GOOGLE_STATIC_MAPS_DEFAULT_MAP_ID=
GOOGLE_STATIC_MAPS_LIGHT_MAP_ID=
GOOGLE_STATIC_MAPS_DARK_MAP_ID=

# Offline place presence verification. Keep disabled until mobile UI and privacy copy are ready.
PLACE_PRESENCE_VERIFICATION_ENABLED=false
PLACE_PRESENCE_MAX_DISTANCE_METERS=100
PLACE_PRESENCE_MAX_ACCURACY_METERS=75
PLACE_PRESENCE_VERIFICATION_COOLDOWN_HOURS=24
PLACE_PRESENCE_MIN_SECONDS_BETWEEN_ATTEMPTS=20
PLACE_PRESENCE_MAX_DAILY_ATTEMPTS=30
PLACE_PRESENCE_MAX_DAILY_REJECTED_ATTEMPTS=8
PLACE_PRESENCE_REJECT_MOCKED_LOCATION=true
PLACE_PRESENCE_MAX_LOCATION_AGE_SECONDS=120
PLACE_PRESENCE_MAX_FUTURE_LOCATION_SECONDS=30
PLACE_PRESENCE_MAX_TRAVEL_SPEED_KPH=900
