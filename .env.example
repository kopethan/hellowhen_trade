# API
NODE_ENV=development
# Keep true for the first public launch. Set false only in a later scoped money/plans/business launch.
FIRST_LAUNCH_GUARDS_ENABLED=true
PORT=4000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/hellowhen?schema=public
JWT_SECRET=dev-change-me
WEB_ORIGIN=http://localhost:3000
MOBILE_ORIGIN=exp://127.0.0.1:8081
UPLOAD_DIR=./uploads
# Media uploads stay local by default. Set MEDIA_STORAGE_DRIVER=s3 after configuring backend-only AWS envs.
# MEDIA_PUBLIC_BASE_URL should be your public CDN/CloudFront base URL, not an S3 secret URL.
MEDIA_STORAGE_DRIVER=local
AWS_REGION=eu-west-3
MEDIA_S3_BUCKET=
MEDIA_S3_PREFIX=uploads
MEDIA_PUBLIC_BASE_URL=
# Backend-only AWS credentials. Never expose these through NEXT_PUBLIC_* or EXPO_PUBLIC_*.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_FIRST_LAUNCH_GUARDS_ENABLED=true
EXPO_PUBLIC_FIRST_LAUNCH_GUARDS_ENABLED=true
# Production origin safety:
# - WEB_ORIGIN and WEB_APP_URL must be public https:// origins with no path.
# - NEXT_PUBLIC_API_URL must be a public https:// API URL for deployed web.
# - MOBILE_ORIGIN must not be an Expo, localhost, or private LAN origin in production; leave empty if native requests send no Origin header.

# Money provider architecture. Keep MONEY_PROVIDER=none for the first public launch.
# FIRST_LAUNCH_GUARDS_ENABLED=true rejects Stripe/Airwallex credentials and provider runtime flags in production.
# none = money-off beta; stripe = existing Stripe test fallback/reference; airwallex = future sandbox provider.
MONEY_PROVIDER=none
MONEY_PROVIDER_SANDBOX_ONLY=true
MONEY_PROVIDER_ACCOUNT_CREATION_ENABLED=false
MONEY_PROVIDER_WALLET_SYNC_ENABLED=false
MONEY_PROVIDER_PAYINS_ENABLED=false
MONEY_PROVIDER_TRADE_MONEY_ENABLED=false
MONEY_PROVIDER_PAYOUTS_ENABLED=false
MONEY_PROVIDER_WEBHOOKS_ENABLED=false

# Stripe test-mode credit purchase simulation. Leave blank to keep Stripe disabled locally.
CREDITS_MODE=fake
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CURRENCY=eur
# Web Membership checkout + webhook foundation. Test mode only until a complete billing launch review.
STRIPE_MEMBERSHIP_CHECKOUT_ENABLED=false
STRIPE_MEMBERSHIP_WEBHOOK_ENABLED=false
STRIPE_MEMBERSHIP_WEBHOOK_SECRET=
STRIPE_MEMBERSHIP_PORTAL_ENABLED=false
STRIPE_MEMBERSHIP_PORTAL_RETURN_PATH=/account/membership?membership_portal=return
STRIPE_MEMBERSHIP_SUCCESS_PATH=/account/membership?membership_checkout=success&session_id={CHECKOUT_SESSION_ID}
STRIPE_MEMBERSHIP_CANCEL_PATH=/account/membership?membership_checkout=cancelled
STRIPE_PLUS_MONTHLY_PRICE_ID=
STRIPE_PLUS_YEARLY_PRICE_ID=
STRIPE_PRO_MONTHLY_PRICE_ID=
STRIPE_PRO_YEARLY_PRICE_ID=
NEXT_PUBLIC_STRIPE_MEMBERSHIP_CHECKOUT_ENABLED=false
NEXT_PUBLIC_STRIPE_MEMBERSHIP_PORTAL_ENABLED=false

# iOS App Store / StoreKit Membership sync. Requires App Store Server API credentials before production.
APPLE_MEMBERSHIP_PURCHASE_SYNC_ENABLED=false
APPLE_MEMBERSHIP_SERVER_VALIDATION_ENABLED=false
APPLE_MEMBERSHIP_SERVER_ENVIRONMENT=sandbox
APPLE_MEMBERSHIP_BUNDLE_ID=com.hellowhen.app
APPLE_MEMBERSHIP_ISSUER_ID=
APPLE_MEMBERSHIP_KEY_ID=
APPLE_MEMBERSHIP_PRIVATE_KEY=

# Android Google Play Billing Membership sync. Requires Google Play Developer API service account before production.
GOOGLE_PLAY_MEMBERSHIP_PURCHASE_SYNC_ENABLED=false
GOOGLE_PLAY_MEMBERSHIP_SERVER_VALIDATION_ENABLED=false
GOOGLE_PLAY_MEMBERSHIP_PACKAGE_NAME=com.hellowhen.app
GOOGLE_PLAY_MEMBERSHIP_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PLAY_MEMBERSHIP_SERVICE_ACCOUNT_PRIVATE_KEY=

STRIPE_CONNECT_ENABLED=false
STRIPE_CONNECT_COUNTRY=US
STRIPE_CONNECT_REFRESH_PATH=/account/payouts?stripe_connect=refresh
STRIPE_CONNECT_RETURN_PATH=/account/payouts?stripe_connect=return
STRIPE_CONNECT_TRANSFER_MODE=false

# Airwallex sandbox placeholders for Phase 21.2+. Do not set production values for first beta.
AIRWALLEX_ENABLED=false
AIRWALLEX_ENV=demo
AIRWALLEX_BASE_URL=https://api-demo.airwallex.com
AIRWALLEX_CLIENT_ID=
AIRWALLEX_API_KEY=
AIRWALLEX_WEBHOOK_SECRET=
AIRWALLEX_HOSTED_FLOW_TEMPLATE_ID=
AIRWALLEX_BUSINESS_HOSTED_FLOW_TEMPLATE_ID=
AIRWALLEX_ONBOARDING_RETURN_PATH=/account/payouts?airwallex=return
AIRWALLEX_ONBOARDING_ERROR_PATH=/account/payouts?airwallex=error
AIRWALLEX_BUSINESS_ONBOARDING_RETURN_PATH=/account/business?airwallex=return
AIRWALLEX_BUSINESS_ONBOARDING_ERROR_PATH=/account/business?airwallex=error
AIRWALLEX_PLATFORM_ACCOUNT_ID=
AIRWALLEX_DEFAULT_CURRENCY=eur
AIRWALLEX_CONNECTED_ACCOUNTS_ENABLED=false
AIRWALLEX_KYC_ONBOARDING_MODE=hosted
AIRWALLEX_DEFAULT_ACCOUNT_TYPE=individual
AIRWALLEX_SANDBOX_PAYOUT_BENEFICIARY_ID=
AIRWALLEX_SANDBOX_PAYOUT_TRANSFER_METHOD=LOCAL
AIRWALLEX_SANDBOX_PAYOUT_REASON=services

WEB_APP_URL=http://localhost:3000
# Production email links must use your public HTTPS web app URL, for example:
# WEB_ORIGIN=https://hellowhen.com
# WEB_APP_URL=https://hellowhen.com
MOBILE_APP_URL=hellowhen://

# Auth / password reset. Google sign-in is disabled for the first launch.
# Keep these empty until a dedicated Google sign-in implementation scope re-enables OAuth.
GOOGLE_SIGN_IN_ENABLED=false
NEXT_PUBLIC_GOOGLE_SIGN_IN_ENABLED=false
EXPO_PUBLIC_GOOGLE_SIGN_IN_ENABLED=false
GOOGLE_WEB_CLIENT_ID=
GOOGLE_IOS_CLIENT_ID=
GOOGLE_ANDROID_CLIENT_ID=
# Resend is used for password reset and email verification.
# EMAIL_FROM must be a verified Resend sender. If the verified domain is
# mail.hellowhen.com, use an address on that exact domain.
RESEND_API_KEY=
EMAIL_FROM=Hellowhen <support@mail.hellowhen.com>
PASSWORD_RESET_TTL_MINUTES=45

# Marketplace payout fee. 1000 bps = 10% of payout-eligible earnings.
PAYOUT_PLATFORM_FEE_RATE_BPS=1000


# Seed/admin setup. Override before running npm run prisma:seed outside local demos.
SEED_DEMO_PASSWORD=password123
SEED_ADMIN_EMAIL=admin@hellowhen.app
SEED_ADMIN_PASSWORD=change-me-admin-password
SEED_ADMIN_DISPLAY_NAME=Admin Reviewer
SEED_ADMIN_HANDLE=admin

# Auth hardening
REFRESH_TOKEN_TTL_DAYS=30
EMAIL_VERIFICATION_TTL_MINUTES=60
TWO_FACTOR_ENCRYPTION_SECRET=dev-change-me-with-32-random-bytes
TWO_FACTOR_CHALLENGE_TTL_MINUTES=10
SENSITIVE_ACTION_TTL_MINUTES=10
ADMIN_REQUIRE_TWO_FACTOR=true
NEXT_PUBLIC_ADMIN_REQUIRE_TWO_FACTOR=true

# Launch money safety limits (cents). Keep low for first launch/beta.
LIMIT_NEW_ACTIVE_SERVICE_TRADES=3
LIMIT_NEW_ACTIVE_MONEY_TRADES=0
LIMIT_NEW_PER_TRADE_MONEY_CENTS=0
LIMIT_NEW_WALLET_BALANCE_CENTS=0
LIMIT_NEW_WEEKLY_PAYOUT_CENTS=0
LIMIT_EMAIL_ACTIVE_SERVICE_TRADES=5
LIMIT_EMAIL_ACTIVE_MONEY_TRADES=0
LIMIT_EMAIL_PER_TRADE_MONEY_CENTS=0
LIMIT_EMAIL_WALLET_BALANCE_CENTS=0
LIMIT_EMAIL_WEEKLY_PAYOUT_CENTS=0
LIMIT_STRIPE_ACTIVE_SERVICE_TRADES=10
LIMIT_STRIPE_ACTIVE_MONEY_TRADES=0
LIMIT_STRIPE_PER_TRADE_MONEY_CENTS=0
LIMIT_STRIPE_WALLET_BALANCE_CENTS=0
LIMIT_STRIPE_WEEKLY_PAYOUT_CENTS=0
LIMIT_TRUSTED_ACTIVE_SERVICE_TRADES=25
LIMIT_TRUSTED_ACTIVE_MONEY_TRADES=0
LIMIT_TRUSTED_PER_TRADE_MONEY_CENTS=0
LIMIT_TRUSTED_WALLET_BALANCE_CENTS=0
LIMIT_TRUSTED_WEEKLY_PAYOUT_CENTS=0
LIMIT_MINIMUM_PAYOUT_CENTS=0

# Money launch safety. Keep production money disabled until legal/payment review is complete.
# disabled = all money features blocked; demo = product simulation only; private_beta = allow listed beta; production = live launch gate.
MONEY_LAUNCH_MODE=disabled
MONEY_PRODUCTION_ENABLED=false
MONEY_PRIVATE_BETA_USER_IDS=
MONEY_POLICY_ACK_REQUIRED=true
MONEY_POLICY_VERSION=2026-05-09
MONEY_WALLET_TERMS_VERSION=2026-05-09
MONEY_PAYOUT_TERMS_VERSION=2026-05-09
MONEY_REFUND_POLICY_VERSION=2026-05-09
MONEY_DISPUTE_POLICY_VERSION=2026-05-09
MONEY_REQUIRE_MANUAL_PAYOUT_REVIEW=true

# Beta launch UI flags. Keep money hidden for the international service/goods beta.
# Production web/native builds also force these off while FIRST_LAUNCH_GUARDS_ENABLED=true.
MONEY_FEATURES_VISIBLE=false
WALLET_VISIBLE=false
PAYOUTS_VISIBLE=false
MONEY_TRADES_ENABLED=false
CASH_TRADES_ENABLED=false
# Cash Promise is a future written outside-app promise only. It is not wallet money, escrow, checkout, payout, or payment protection.
CASH_PROMISE_ENABLED=false
CASH_PROMISE_VISIBLE=false
CASH_PROMISE_MAX_AMOUNT_CENTS=100000
NEXT_PUBLIC_MONEY_PROVIDER=none
NEXT_PUBLIC_MONEY_FEATURES_VISIBLE=false
NEXT_PUBLIC_WALLET_VISIBLE=false
NEXT_PUBLIC_PAYOUTS_VISIBLE=false
NEXT_PUBLIC_MONEY_TRADES_ENABLED=false
NEXT_PUBLIC_CASH_TRADES_ENABLED=false
NEXT_PUBLIC_CASH_PROMISE_ENABLED=false
NEXT_PUBLIC_CASH_PROMISE_VISIBLE=false
EXPO_PUBLIC_MONEY_PROVIDER=none
EXPO_PUBLIC_MONEY_FEATURES_VISIBLE=false
EXPO_PUBLIC_WALLET_VISIBLE=false
EXPO_PUBLIC_PAYOUTS_VISIBLE=false
EXPO_PUBLIC_MONEY_TRADES_ENABLED=false
EXPO_PUBLIC_CASH_TRADES_ENABLED=false
EXPO_PUBLIC_CASH_PROMISE_ENABLED=false
EXPO_PUBLIC_CASH_PROMISE_VISIBLE=false


# Provider-neutral moderation foundation. Keep external providers and scans disabled for the first public launch.
# SAFETY1 only stores shared types, schema, and a no-provider adapter; no external API is connected.
MODERATION_ENABLED=false
MODERATION_PROVIDER=none
MODERATION_TEXT_ENABLED=false
MODERATION_IMAGE_ENABLED=false
# Optional no-provider/manual queue: when true, public images attached to trades, needs, offers, or profiles stay pending until admin approval.
PUBLIC_IMAGE_REVIEW_ENABLED=false
# Optional public exposure protection: when true, logged-out public API responses omit image URLs and return hidden media counts.
PUBLIC_MEDIA_REQUIRES_AUTH=false
NEXT_PUBLIC_PUBLIC_MEDIA_REQUIRES_AUTH=false
EXPO_PUBLIC_PUBLIC_MEDIA_REQUIRES_AUTH=false
MODERATION_PRIVATE_MESSAGE_SCAN_ENABLED=false
MODERATION_STORE_RAW_PROVIDER_RESULT=false
# For MODERATION_PROVIDER=openai, set MODERATION_PROVIDER_API_KEY to your OpenAI API key.
# MODERATION_PROVIDER_ENDPOINT is optional; leave empty to use https://api.openai.com/v1/moderations.
MODERATION_PROVIDER_API_KEY=
MODERATION_PROVIDER_ENDPOINT=
OPENAI_MODERATION_MODEL=omni-moderation-latest
MODERATION_PROVIDER_TIMEOUT_MS=10000
MODERATION_PROVIDER_MAX_RETRIES=0
# SAFETY7 text-review pipeline. Keep disabled until a mock or real moderation provider is intentionally enabled.
AI_TEXT_REVIEW_ON_CREATE_ENABLED=false
AI_TEXT_REVIEW_ON_EDIT_ENABLED=false
AI_TEXT_REVIEW_PUBLIC_MESSAGES_ENABLED=false
AI_TEXT_REVIEW_PROFILE_ENABLED=false
AI_TEXT_REVIEW_PRIVATE_MESSAGES_ENABLED=false
# SAFETY8 route enforcement. When true, hold/reject decisions can keep public content pending, hidden, or unpublished.
AI_TEXT_REVIEW_ENFORCEMENT_ENABLED=false
# allow_with_case | hold_pending | reject. With SAFETY8 enforcement enabled, provider failures follow this mode.
MODERATION_TEXT_FAIL_MODE=allow_with_case

# Hidden AI foundation. Keep disabled for the first public launch.
# No SDKs, external calls, tracking, or private-message AI are wired in this foundation.
AI_ENABLED=false
AI_PROVIDER=none
AI_MODERATION_ENABLED=false
AI_SUGGESTIONS_ENABLED=false
AI_ADMIN_ASSIST_ENABLED=false
AI_SAFETY_CLASSIFIER_ENABLED=false
AI_PRIVATE_CONTENT_ENABLED=false
AI_DEBUG_PLACEHOLDERS=false
# Optional later-launch provider keys/models for admin-only Content Intelligence suggestions.
# Leave all provider keys empty for the first public launch.
AI_API_KEY=
OPENAI_API_KEY=
OPENAI_CONTENT_SUGGESTION_MODEL=gpt-4o-mini
GEMINI_API_KEY=
GEMINI_CONTENT_SUGGESTION_MODEL=gemini-1.5-flash
GROQ_API_KEY=
GROQ_CONTENT_SUGGESTION_MODEL=llama-3.1-8b-instant
AI_CONTENT_SUGGESTION_TIMEOUT_MS=12000
NEXT_PUBLIC_AI_ENABLED=false
NEXT_PUBLIC_AI_PROVIDER=none
NEXT_PUBLIC_AI_MODERATION_ENABLED=false
NEXT_PUBLIC_AI_SUGGESTIONS_ENABLED=false
NEXT_PUBLIC_AI_ADMIN_ASSIST_ENABLED=false
NEXT_PUBLIC_AI_SAFETY_CLASSIFIER_ENABLED=false
NEXT_PUBLIC_AI_DEBUG_PLACEHOLDERS=false
EXPO_PUBLIC_AI_ENABLED=false
EXPO_PUBLIC_AI_PROVIDER=none
EXPO_PUBLIC_AI_MODERATION_ENABLED=false
EXPO_PUBLIC_AI_SUGGESTIONS_ENABLED=false
EXPO_PUBLIC_AI_ADMIN_ASSIST_ENABLED=false
EXPO_PUBLIC_AI_SAFETY_CLASSIFIER_ENABLED=false
EXPO_PUBLIC_AI_DEBUG_PLACEHOLDERS=false

# Hidden Content Intelligence foundation. Rule-based storage only; no public labels, no AI calls, and no automatic actions.
CONTENT_INTELLIGENCE_ENABLED=false
CONTENT_CLASSIFICATION_ENABLED=false
# Hidden future matching signals. Keep disabled for first launch: no ads, no tracking, no public targeting.
CONTENT_PLACEMENT_SIGNALS_ENABLED=false
BUSINESS_CONTEXTUAL_SIGNALS_ENABLED=false
CONTEXTUAL_AD_SIGNALS_ENABLED=false
AI_MODERATION_SUGGESTIONS_ENABLED=false
AUTO_MODERATION_ACTIONS_ENABLED=false
CONTENT_REVIEW_GATE_ENABLED=false
CONTENT_REVIEW_GATE_HIGH_RISK_ENABLED=false
CONTENT_REVIEW_GATE_CATEGORY_MISMATCH_ENABLED=false
CONTENT_REVIEW_GATE_SUGGESTED_HIDE_ENABLED=false
CONTENT_REVIEW_GATE_CLASSIFIER_FAILURE_ENABLED=false

# Ads foundation. Keep disabled for the first public launch.
# These flags only enable future ad slots/placeholders; no real ad SDKs are wired yet.
ADS_ENABLED=false
WEB_ADS_ENABLED=false
MOBILE_ADS_ENABLED=false
ADS_PROVIDER=none
ADS_DEBUG_PLACEHOLDERS=false
NEXT_PUBLIC_ADS_ENABLED=false
NEXT_PUBLIC_WEB_ADS_ENABLED=false
NEXT_PUBLIC_ADS_PROVIDER=none
NEXT_PUBLIC_ADS_DEBUG_PLACEHOLDERS=false
EXPO_PUBLIC_ADS_ENABLED=false
EXPO_PUBLIC_MOBILE_ADS_ENABLED=false
EXPO_PUBLIC_ADS_PROVIDER=none
EXPO_PUBLIC_ADS_DEBUG_PLACEHOLDERS=false


# Hidden Plus foundation. Keep disabled for the first public launch.
# Plus is the first planned paid tier: AI helpers + controlled customization. Billing is not connected.
PLUS_ENABLED=false
PLUS_PUBLIC=false
AI_ASSIST_ENABLED=false
PLUS_CUSTOMIZATION_ENABLED=false
PLUS_ADMIN_GRANTS_ENABLED=false
PLUS_MONTHLY_PRICE_CENTS=499
PLUS_MONTHLY_PRICE_CURRENCY=eur
PLUS_YEARLY_PRICE_CENTS=3999
PLUS_YEARLY_PRICE_CURRENCY=eur
FREE_MONTHLY_AI_ASSIST_QUOTA=3
PLUS_MONTHLY_AI_ASSIST_QUOTA=75
NEXT_PUBLIC_PLUS_ENABLED=false
NEXT_PUBLIC_PLUS_PUBLIC=false
NEXT_PUBLIC_AI_ASSIST_ENABLED=false
NEXT_PUBLIC_PLUS_CUSTOMIZATION_ENABLED=false
NEXT_PUBLIC_PLUS_MONTHLY_PRICE_CENTS=499
NEXT_PUBLIC_PLUS_MONTHLY_PRICE_CURRENCY=eur
NEXT_PUBLIC_PLUS_YEARLY_PRICE_CENTS=3999
NEXT_PUBLIC_PLUS_YEARLY_PRICE_CURRENCY=eur
NEXT_PUBLIC_FREE_MONTHLY_AI_ASSIST_QUOTA=3
NEXT_PUBLIC_PLUS_MONTHLY_AI_ASSIST_QUOTA=75
EXPO_PUBLIC_PLUS_ENABLED=false
EXPO_PUBLIC_PLUS_PUBLIC=false
EXPO_PUBLIC_AI_ASSIST_ENABLED=false
EXPO_PUBLIC_PLUS_CUSTOMIZATION_ENABLED=false
EXPO_PUBLIC_PLUS_MONTHLY_PRICE_CENTS=499
EXPO_PUBLIC_PLUS_MONTHLY_PRICE_CURRENCY=eur
EXPO_PUBLIC_PLUS_YEARLY_PRICE_CENTS=3999
EXPO_PUBLIC_PLUS_YEARLY_PRICE_CURRENCY=eur
EXPO_PUBLIC_FREE_MONTHLY_AI_ASSIST_QUOTA=3
EXPO_PUBLIC_PLUS_MONTHLY_AI_ASSIST_QUOTA=75

# Mobile Membership preview and native store product metadata.
# iOS StoreKit purchase UI remains hidden unless EXPO_PUBLIC_IOS_STOREKIT_MEMBERSHIP_ENABLED=true.
# Android Google Play purchase UI remains hidden unless EXPO_PUBLIC_ANDROID_GOOGLE_PLAY_MEMBERSHIP_ENABLED=true.
