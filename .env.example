# API
NODE_ENV=development
# Keep true for the first public launch. Set false only in a later scoped money/plans/business launch.
FIRST_LAUNCH_GUARDS_ENABLED=true
PORT=4000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/hellowhen?schema=public
JWT_SECRET=dev-change-me
WEB_ORIGIN=http://localhost:3000
MOBILE_ORIGIN=exp://127.0.0.1:8081
UPLOAD_DIR=./uploads
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_FIRST_LAUNCH_GUARDS_ENABLED=true
EXPO_PUBLIC_FIRST_LAUNCH_GUARDS_ENABLED=true
# Production origin safety:
# - WEB_ORIGIN and WEB_APP_URL must be public https:// origins with no path.
# - NEXT_PUBLIC_API_URL must be a public https:// API URL for deployed web.
# - MOBILE_ORIGIN must not be an Expo, localhost, or private LAN origin in production; leave empty if native requests send no Origin header.

# Money provider architecture. Keep MONEY_PROVIDER=none for the first public launch.
# FIRST_LAUNCH_GUARDS_ENABLED=true rejects Stripe/Airwallex credentials and provider runtime flags in production.
# none = money-off beta; stripe = existing Stripe test fallback/reference; airwallex = future sandbox provider.
MONEY_PROVIDER=none
MONEY_PROVIDER_SANDBOX_ONLY=true
MONEY_PROVIDER_ACCOUNT_CREATION_ENABLED=false
MONEY_PROVIDER_WALLET_SYNC_ENABLED=false
MONEY_PROVIDER_PAYINS_ENABLED=false
MONEY_PROVIDER_TRADE_MONEY_ENABLED=false
MONEY_PROVIDER_PAYOUTS_ENABLED=false
MONEY_PROVIDER_WEBHOOKS_ENABLED=false

# Stripe test-mode credit purchase simulation. Leave blank to keep Stripe disabled locally.
CREDITS_MODE=fake
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CURRENCY=eur
STRIPE_CONNECT_ENABLED=false
STRIPE_CONNECT_COUNTRY=US
STRIPE_CONNECT_REFRESH_PATH=/account/payouts?stripe_connect=refresh
STRIPE_CONNECT_RETURN_PATH=/account/payouts?stripe_connect=return
STRIPE_CONNECT_TRANSFER_MODE=false

# Airwallex sandbox placeholders for Phase 21.2+. Do not set production values for first beta.
AIRWALLEX_ENABLED=false
AIRWALLEX_ENV=demo
AIRWALLEX_BASE_URL=https://api-demo.airwallex.com
AIRWALLEX_CLIENT_ID=
AIRWALLEX_API_KEY=
AIRWALLEX_WEBHOOK_SECRET=
AIRWALLEX_HOSTED_FLOW_TEMPLATE_ID=
AIRWALLEX_BUSINESS_HOSTED_FLOW_TEMPLATE_ID=
AIRWALLEX_ONBOARDING_RETURN_PATH=/account/payouts?airwallex=return
AIRWALLEX_ONBOARDING_ERROR_PATH=/account/payouts?airwallex=error
AIRWALLEX_BUSINESS_ONBOARDING_RETURN_PATH=/account/business?airwallex=return
AIRWALLEX_BUSINESS_ONBOARDING_ERROR_PATH=/account/business?airwallex=error
AIRWALLEX_PLATFORM_ACCOUNT_ID=
AIRWALLEX_DEFAULT_CURRENCY=eur
AIRWALLEX_CONNECTED_ACCOUNTS_ENABLED=false
AIRWALLEX_KYC_ONBOARDING_MODE=hosted
AIRWALLEX_DEFAULT_ACCOUNT_TYPE=individual
AIRWALLEX_SANDBOX_PAYOUT_BENEFICIARY_ID=
AIRWALLEX_SANDBOX_PAYOUT_TRANSFER_METHOD=LOCAL
AIRWALLEX_SANDBOX_PAYOUT_REASON=services

WEB_APP_URL=http://localhost:3000
# Production email links must use your public HTTPS web app URL, for example:
# WEB_ORIGIN=https://hellowhen.com
# WEB_APP_URL=https://hellowhen.com
MOBILE_APP_URL=hellowhen://

# Auth / password reset. Google sign-in is disabled for the first launch.
# Keep these empty until a dedicated Google sign-in implementation scope re-enables OAuth.
GOOGLE_SIGN_IN_ENABLED=false
NEXT_PUBLIC_GOOGLE_SIGN_IN_ENABLED=false
EXPO_PUBLIC_GOOGLE_SIGN_IN_ENABLED=false
GOOGLE_WEB_CLIENT_ID=
GOOGLE_IOS_CLIENT_ID=
GOOGLE_ANDROID_CLIENT_ID=
# Resend is used for password reset and email verification.
# EMAIL_FROM must be a verified Resend sender. If the verified domain is
# mail.hellowhen.com, use an address on that exact domain.
RESEND_API_KEY=
EMAIL_FROM=Hellowhen <support@mail.hellowhen.com>
PASSWORD_RESET_TTL_MINUTES=45

# Marketplace payout fee. 1000 bps = 10% of payout-eligible earnings.
PAYOUT_PLATFORM_FEE_RATE_BPS=1000


# Seed/admin setup. Override before running npm run prisma:seed outside local demos.
SEED_DEMO_PASSWORD=password123
SEED_ADMIN_EMAIL=admin@hellowhen.app
SEED_ADMIN_PASSWORD=change-me-admin-password
SEED_ADMIN_DISPLAY_NAME=Admin Reviewer
SEED_ADMIN_HANDLE=admin

# Auth hardening
REFRESH_TOKEN_TTL_DAYS=30
EMAIL_VERIFICATION_TTL_MINUTES=60
TWO_FACTOR_ENCRYPTION_SECRET=dev-change-me-with-32-random-bytes
TWO_FACTOR_CHALLENGE_TTL_MINUTES=10
SENSITIVE_ACTION_TTL_MINUTES=10
ADMIN_REQUIRE_TWO_FACTOR=true

# Launch money safety limits (cents). Keep low for first launch/beta.
LIMIT_NEW_ACTIVE_SERVICE_TRADES=3
LIMIT_NEW_ACTIVE_MONEY_TRADES=0
LIMIT_NEW_PER_TRADE_MONEY_CENTS=0
LIMIT_NEW_WALLET_BALANCE_CENTS=0
LIMIT_NEW_WEEKLY_PAYOUT_CENTS=0
LIMIT_EMAIL_ACTIVE_SERVICE_TRADES=5
LIMIT_EMAIL_ACTIVE_MONEY_TRADES=0
LIMIT_EMAIL_PER_TRADE_MONEY_CENTS=0
LIMIT_EMAIL_WALLET_BALANCE_CENTS=0
LIMIT_EMAIL_WEEKLY_PAYOUT_CENTS=0
LIMIT_STRIPE_ACTIVE_SERVICE_TRADES=10
LIMIT_STRIPE_ACTIVE_MONEY_TRADES=0
LIMIT_STRIPE_PER_TRADE_MONEY_CENTS=0
LIMIT_STRIPE_WALLET_BALANCE_CENTS=0
LIMIT_STRIPE_WEEKLY_PAYOUT_CENTS=0
LIMIT_TRUSTED_ACTIVE_SERVICE_TRADES=25
LIMIT_TRUSTED_ACTIVE_MONEY_TRADES=0
LIMIT_TRUSTED_PER_TRADE_MONEY_CENTS=0
LIMIT_TRUSTED_WALLET_BALANCE_CENTS=0
LIMIT_TRUSTED_WEEKLY_PAYOUT_CENTS=0
LIMIT_MINIMUM_PAYOUT_CENTS=0

# Money launch safety. Keep production money disabled until legal/payment review is complete.
# disabled = all money features blocked; demo = product simulation only; private_beta = allow listed beta; production = live launch gate.
MONEY_LAUNCH_MODE=disabled
MONEY_PRODUCTION_ENABLED=false
MONEY_PRIVATE_BETA_USER_IDS=
MONEY_POLICY_ACK_REQUIRED=true
MONEY_POLICY_VERSION=2026-05-09
MONEY_WALLET_TERMS_VERSION=2026-05-09
MONEY_PAYOUT_TERMS_VERSION=2026-05-09
MONEY_REFUND_POLICY_VERSION=2026-05-09
MONEY_DISPUTE_POLICY_VERSION=2026-05-09
MONEY_REQUIRE_MANUAL_PAYOUT_REVIEW=true

# Beta launch UI flags. Keep money hidden for the international service/goods beta.
# Production web/native builds also force these off while FIRST_LAUNCH_GUARDS_ENABLED=true.
MONEY_FEATURES_VISIBLE=false
WALLET_VISIBLE=false
PAYOUTS_VISIBLE=false
MONEY_TRADES_ENABLED=false
CASH_TRADES_ENABLED=false
NEXT_PUBLIC_MONEY_PROVIDER=none
NEXT_PUBLIC_MONEY_FEATURES_VISIBLE=false
NEXT_PUBLIC_WALLET_VISIBLE=false
NEXT_PUBLIC_PAYOUTS_VISIBLE=false
NEXT_PUBLIC_MONEY_TRADES_ENABLED=false
NEXT_PUBLIC_CASH_TRADES_ENABLED=false
EXPO_PUBLIC_MONEY_PROVIDER=none
EXPO_PUBLIC_MONEY_FEATURES_VISIBLE=false
EXPO_PUBLIC_WALLET_VISIBLE=false
EXPO_PUBLIC_PAYOUTS_VISIBLE=false
EXPO_PUBLIC_MONEY_TRADES_ENABLED=false
EXPO_PUBLIC_CASH_TRADES_ENABLED=false


# Hidden AI foundation. Keep disabled for the first public launch.
# No SDKs, external calls, tracking, or private-message AI are wired in this foundation.
AI_ENABLED=false
AI_PROVIDER=none
AI_MODERATION_ENABLED=false
AI_SUGGESTIONS_ENABLED=false
AI_ADMIN_ASSIST_ENABLED=false
AI_SAFETY_CLASSIFIER_ENABLED=false
AI_PRIVATE_CONTENT_ENABLED=false
AI_DEBUG_PLACEHOLDERS=false
NEXT_PUBLIC_AI_ENABLED=false
NEXT_PUBLIC_AI_PROVIDER=none
NEXT_PUBLIC_AI_MODERATION_ENABLED=false
NEXT_PUBLIC_AI_SUGGESTIONS_ENABLED=false
NEXT_PUBLIC_AI_ADMIN_ASSIST_ENABLED=false
NEXT_PUBLIC_AI_SAFETY_CLASSIFIER_ENABLED=false
NEXT_PUBLIC_AI_DEBUG_PLACEHOLDERS=false
EXPO_PUBLIC_AI_ENABLED=false
EXPO_PUBLIC_AI_PROVIDER=none
EXPO_PUBLIC_AI_MODERATION_ENABLED=false
EXPO_PUBLIC_AI_SUGGESTIONS_ENABLED=false
EXPO_PUBLIC_AI_ADMIN_ASSIST_ENABLED=false
EXPO_PUBLIC_AI_SAFETY_CLASSIFIER_ENABLED=false
EXPO_PUBLIC_AI_DEBUG_PLACEHOLDERS=false

# Ads foundation. Keep disabled for the first public launch.
# These flags only enable future ad slots/placeholders; no real ad SDKs are wired yet.
ADS_ENABLED=false
WEB_ADS_ENABLED=false
MOBILE_ADS_ENABLED=false
ADS_PROVIDER=none
ADS_DEBUG_PLACEHOLDERS=false
NEXT_PUBLIC_ADS_ENABLED=false
NEXT_PUBLIC_WEB_ADS_ENABLED=false
NEXT_PUBLIC_ADS_PROVIDER=none
NEXT_PUBLIC_ADS_DEBUG_PLACEHOLDERS=false
EXPO_PUBLIC_ADS_ENABLED=false
EXPO_PUBLIC_MOBILE_ADS_ENABLED=false
EXPO_PUBLIC_ADS_PROVIDER=none
EXPO_PUBLIC_ADS_DEBUG_PLACEHOLDERS=false

# Business/brand account scaffolding. Keep hidden for the first public beta unless explicitly testing Phase 21.6.
BUSINESS_ACCOUNTS_VISIBLE=false
NEXT_PUBLIC_BUSINESS_ACCOUNTS_VISIBLE=false
EXPO_PUBLIC_BUSINESS_ACCOUNTS_VISIBLE=false

# Hidden Plans foundation. Keep disabled/hidden for the first public launch.
PLANS_ENABLED=false
PLANS_VISIBLE=false
NEXT_PUBLIC_PLANS_ENABLED=false
NEXT_PUBLIC_PLANS_VISIBLE=false
EXPO_PUBLIC_PLANS_ENABLED=false
EXPO_PUBLIC_PLANS_VISIBLE=false
