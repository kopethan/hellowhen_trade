EXPO_PUBLIC_GOOGLE_PRO_YEARLY_PRODUCT_ID=hellowhen_pro_yearly

# Plus-gated Saved Library, Agenda, and inventory organization tools.
# These are separate master feature flags. A Plus-active test account still cannot use
# the features while these flags are false. For local testing, set PLUS_ENABLED=true,
# SUBSCRIPTIONS_ENABLED=true, and set the matching API/web/native flags below to true.
# Agenda is private and personal: it is not booking, shared availability, or external calendar sync.
