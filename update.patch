+export const needStatusSchema = z.enum(['draft', 'active', 'fulfilled', 'closed', 'expired']);
+export const offerStatusSchema = z.enum(['draft', 'active', 'accepted', 'closed', 'expired']);
+export const tradeStatusSchema = z.enum([
