+  'active',
+  'funded',
+  'in_progress',
+  'submitted',
+  'completed',
+  'disputed',
+  'expired',
+  'closed',
+  'cancelled'
+]);
+
+export const createNeedRequestSchema = z.object({
+  title: z.string().min(3).max(120),
+  description: z.string().min(10).max(2000),
+  status: needStatusSchema.optional(),
+  expiresAt: z.string().datetime().optional()
+});
