{
  "cli": {
    "version": ">= 20.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_CASH_PROMISE_ENABLED": "false",
        "EXPO_PUBLIC_CASH_PROMISE_VISIBLE": "false"
      }
    },
    "production": {
      "autoIncrement": true,
      "android": {
        "buildType": "app-bundle"
      },
      "env": {
        "EXPO_PUBLIC_CASH_PROMISE_ENABLED": "false",
        "EXPO_PUBLIC_CASH_PROMISE_VISIBLE": "false"
      }
    }
  },
  "submit": {
    "production": {}
  }
}