EXPO_PUBLIC_API_URL=http://YOUR_COMPUTER_IP:4000
# Used when sharing public trade links from the native app. For local testing, use http://YOUR_COMPUTER_IP:3000.
EXPO_PUBLIC_WEB_URL=https://www.hellowhen.com

# Google sign-in is disabled for the first launch. Reintroduce OAuth client IDs
# only when the app has a dedicated Google sign-in implementation scope.

# First beta stays money-off. Provider can become airwallex only in future sandbox phases.
EXPO_PUBLIC_MONEY_PROVIDER=none
EXPO_PUBLIC_MONEY_FEATURES_VISIBLE=false
EXPO_PUBLIC_WALLET_VISIBLE=false
EXPO_PUBLIC_PAYOUTS_VISIBLE=false
EXPO_PUBLIC_MONEY_TRADES_ENABLED=false
EXPO_PUBLIC_CASH_TRADES_ENABLED=false
EXPO_PUBLIC_CASH_PROMISE_ENABLED=false
EXPO_PUBLIC_CASH_PROMISE_VISIBLE=false


# Hidden AI foundation. Keep disabled for the first public launch.
EXPO_PUBLIC_AI_ENABLED=false
EXPO_PUBLIC_AI_PROVIDER=none
EXPO_PUBLIC_AI_MODERATION_ENABLED=false
EXPO_PUBLIC_AI_SUGGESTIONS_ENABLED=false
EXPO_PUBLIC_AI_ADMIN_ASSIST_ENABLED=false
EXPO_PUBLIC_AI_SAFETY_CLASSIFIER_ENABLED=false
EXPO_PUBLIC_AI_DEBUG_PLACEHOLDERS=false

# Ads foundation. Keep disabled for the first public launch; no AdMob SDK is wired yet.
EXPO_PUBLIC_ADS_ENABLED=false
EXPO_PUBLIC_MOBILE_ADS_ENABLED=false
EXPO_PUBLIC_ADS_PROVIDER=none
EXPO_PUBLIC_ADS_DEBUG_PLACEHOLDERS=false


# Hidden Pro/subscription foundation. Keep disabled for the first public launch.
# Pro is a future paid professional upgrade: verified identity + active/trialing Pro subscription.
EXPO_PUBLIC_SUBSCRIPTIONS_ENABLED=false
EXPO_PUBLIC_PRO_ACCOUNTS_ENABLED=false
EXPO_PUBLIC_PRO_ACCOUNTS_VISIBLE=false
EXPO_PUBLIC_PRO_TRIALS_ENABLED=false
EXPO_PUBLIC_IDENTITY_VERIFICATION_ENABLED=false
EXPO_PUBLIC_PRO_MONTHLY_PRICE_CENTS=1499
EXPO_PUBLIC_PRO_MONTHLY_PRICE_CURRENCY=eur
EXPO_PUBLIC_PRO_TRIAL_DAYS=14
EXPO_PUBLIC_PRO_TRADE_PACKAGES_ENABLED=false
EXPO_PUBLIC_PRO_TRADE_PACKAGES_VISIBLE=false
EXPO_PUBLIC_PRO_TRADE_PACKAGE_MAX_SUPPORTING_NEEDS=3
EXPO_PUBLIC_PRO_TRADE_PACKAGE_MAX_SUPPORTING_OFFERS=3

# Hidden Plans foundation. Keep disabled/hidden for the first public launch.
EXPO_PUBLIC_PLANS_ENABLED=false
EXPO_PUBLIC_PLANS_VISIBLE=false
