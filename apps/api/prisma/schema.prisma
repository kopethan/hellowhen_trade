generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  user
  admin
}

enum AuthIdentityProvider {
  email
  google
}

enum NeedStatus {
  draft
  active
  fulfilled
  closed
  expired
}

enum OfferStatus {
  draft
  active
  accepted
  closed
  expired
}

enum TradeExchangeMode {
  remote
  local
  hybrid
}

enum TradeStatus {
  draft
  active
  funded
  in_progress
  submitted
  completed
  disputed
  expired
  closed
  cancelled
}

enum ProposalStatus {
  pending
  accepted
  declined
  withdrawn
}

enum MediaEntityType {
  need
  offer
  trade
  profile
  support_ticket
  support_message
}

enum MediaAssetStatus {
  active
  flagged
  removed
  pending_review
}

enum CreditPurchaseStatus {
  pending
  paid
  failed
  expired
}

enum SupportTicketCategory {
  general_feedback
  trade_issue
  credits_issue
  media_issue
  bug_report
  account_issue
  safety_concern
}

enum SupportTicketStatus {
  open
  in_review
  waiting_for_user
  resolved
  closed
}

enum SupportTicketPriority {
  low
  normal
  high
  urgent
}

enum SupportMessageSenderRole {
  user
  admin
  system
}

enum LedgerEntryType {
  starting_demo_credits
  test_credit_grant
  credit_purchase
  trade_hold
  trade_release
  trade_refund
  earned_pending
  platform_fee
  platform_fee_placeholder
  payout_requested
  payout_paid
  adjustment
}

enum LedgerBalanceType {
  purchased
  earned_pending
  earned_available
  held
}

enum TradePaymentStatus {
  draft
  authorized
  held
  released
  refunded
  failed
  cancelled
}

enum PayoutRequestStatus {
  draft
  requested
  approved
  paid
  rejected
  cancelled
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash    String?
  role            UserRole  @default(user)
  emailVerifiedAt DateTime?
  lastLoginAt     DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  profile      Profile?
  settings     UserSettings?
  sessions     Session[]
  identities    UserIdentity[]
  passwordResetTokens PasswordResetToken[]
  needs        Need[]
  offers       Offer[]
  trades       Trade[] @relation("OwnedTrades")
  providerTrades Trade[] @relation("ProvidedTrades")
  tradeProposals TradeProposal[] @relation("ApplicantProposals")
  proposalMessages ProposalMessage[] @relation("SentProposalMessages")
  mediaAssets  MediaAsset[] @relation("OwnedMediaAssets")
  reviewedMediaAssets MediaAsset[] @relation("ReviewedMediaAssets")
  creditPurchases CreditPurchase[]
  supportTickets SupportTicket[] @relation("OwnedSupportTickets")
  assignedSupportTickets SupportTicket[] @relation("AssignedSupportTickets")
  supportMessages SupportTicketMessage[] @relation("SentSupportMessages")
  wallet       Wallet?
  ledger       CreditLedgerEntry[]
  payoutRequests PayoutRequest[]
}


model UserIdentity {
  id             String               @id @default(cuid())
  userId         String
  provider       AuthIdentityProvider
  providerUserId String
  email          String?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerUserId])
  @@index([userId, provider])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
  @@index([expiresAt])
}

model Session {
  id           String   @id @default(cuid())
  userId       String
  refreshToken String   @unique
  createdAt    DateTime @default(now())
  expiresAt    DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Profile {
  id          String   @id @default(cuid())
  userId      String   @unique
  displayName String?
  handle      String?  @unique
  bio         String?
  avatarUrl   String?
  avatarMediaId String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([avatarMediaId])
}

model UserSettings {
  id                   String   @id @default(cuid())
  userId               String   @unique
  appearance            String   @default("system")
  accent                String   @default("teal")
  language              String   @default("en")
  notificationsEnabled  Boolean  @default(true)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Need {
  id            String             @id @default(cuid())
  ownerId       String
  title         String
  description   String
  category      String?
  timing        String?
  mode          TradeExchangeMode?
  locationLabel String?
  tags          String[]           @default([])
  status        NeedStatus         @default(draft)
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  expiresAt     DateTime?

  owner  User    @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  trades Trade[]

  @@index([ownerId, status])
  @@index([category])
  @@index([mode])
}

model Offer {
  id            String             @id @default(cuid())
  ownerId       String
  title         String
  description   String
  category      String?
  availability  String?
  mode          TradeExchangeMode?
  locationLabel String?
  includes      String[]           @default([])
  tags          String[]           @default([])
  status        OfferStatus        @default(draft)
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  expiresAt     DateTime?

  owner  User    @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  trades Trade[]

  @@index([ownerId, status])
  @@index([category])
  @@index([mode])
}

model Trade {
  id           String      @id @default(cuid())
  ownerId      String
  providerId   String?
  needId       String?
  offerId      String?
  title        String
  description  String
  creditAmount Int         @default(0)
  amountCents  Int         @default(0)
  currency     String      @default("eur")
  status       TradeStatus @default(draft)
  isPublic     Boolean     @default(false)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  expiresAt    DateTime?
  closedAt     DateTime?

  owner    User      @relation("OwnedTrades", fields: [ownerId], references: [id], onDelete: Cascade)
  provider User?     @relation("ProvidedTrades", fields: [providerId], references: [id], onDelete: SetNull)
  need     Need?     @relation(fields: [needId], references: [id], onDelete: SetNull)
  offer    Offer?    @relation(fields: [offerId], references: [id], onDelete: SetNull)
  payment  TradePayment?
  escrow   TradeEscrow?
  proposals TradeProposal[]
  ledgerEntries CreditLedgerEntry[]

  @@index([status, isPublic, createdAt])
  @@index([ownerId, status])
  @@index([providerId, status])
  @@index([needId])
  @@index([offerId])
}

model TradeProposal {
  id          String         @id @default(cuid())
  tradeId     String
  applicantId String
  message     String
  status      ProposalStatus @default(pending)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  respondedAt DateTime?

  trade     Trade             @relation(fields: [tradeId], references: [id], onDelete: Cascade)
  applicant User              @relation("ApplicantProposals", fields: [applicantId], references: [id], onDelete: Cascade)
  messages  ProposalMessage[]

  @@unique([tradeId, applicantId])
  @@index([tradeId, status])
  @@index([applicantId, status])
}

model ProposalMessage {
  id         String   @id @default(cuid())
  proposalId String
  senderId   String
  body       String
  createdAt  DateTime @default(now())

  proposal TradeProposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)
  sender   User          @relation("SentProposalMessages", fields: [senderId], references: [id], onDelete: Cascade)

  @@index([proposalId, createdAt])
  @@index([senderId, createdAt])
}

model MediaAsset {
  id          String           @id @default(cuid())
  ownerId     String
  entityType  MediaEntityType?
  entityId    String?
  url         String
  storageKey  String
  filename    String
  mimeType    String
  sizeBytes   Int
  status      MediaAssetStatus @default(pending_review)
  reviewNote  String?
  reviewedAt  DateTime?
  reviewerId  String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  owner    User  @relation("OwnedMediaAssets", fields: [ownerId], references: [id], onDelete: Cascade)
  reviewer User? @relation("ReviewedMediaAssets", fields: [reviewerId], references: [id], onDelete: SetNull)

  @@index([ownerId, createdAt])
  @@index([entityType, entityId])
  @@index([status, createdAt])
}

model CreditPurchase {
  id                      String               @id @default(cuid())
  userId                  String
  stripeCheckoutSessionId String?              @unique
  stripePaymentIntentId   String?
  creditAmount            Int
  amountCents             Int
  currency                String               @default("eur")
  status                  CreditPurchaseStatus @default(pending)
  checkoutUrl             String?
  createdAt               DateTime             @default(now())
  updatedAt               DateTime             @updatedAt
  paidAt                  DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([status, createdAt])
}

model SupportTicket {
  id                String                @id @default(cuid())
  userId            String
  category          SupportTicketCategory
  subject           String
  message           String
  status            SupportTicketStatus   @default(open)
  priority          SupportTicketPriority @default(normal)
  relatedTradeId    String?
  relatedProposalId String?
  relatedMediaId    String?
  assignedAdminId   String?
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt
  resolvedAt        DateTime?

  user          User                   @relation("OwnedSupportTickets", fields: [userId], references: [id], onDelete: Cascade)
  assignedAdmin User?                  @relation("AssignedSupportTickets", fields: [assignedAdminId], references: [id], onDelete: SetNull)
  messages      SupportTicketMessage[]

  @@index([userId, status, createdAt])
  @@index([status, priority, createdAt])
  @@index([category, status])
  @@index([assignedAdminId, status])
}

model SupportTicketMessage {
  id         String                   @id @default(cuid())
  ticketId   String
  senderId   String
  senderRole SupportMessageSenderRole @default(user)
  body       String
  internal   Boolean                  @default(false)
  createdAt  DateTime                 @default(now())

  ticket SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  sender User          @relation("SentSupportMessages", fields: [senderId], references: [id], onDelete: Cascade)

  @@index([ticketId, createdAt])
  @@index([senderId, createdAt])
}

model Wallet {
  id                         String   @id @default(cuid())
  userId                     String   @unique
  purchasedAvailableCredits  Int      @default(0)
  earnedPendingCredits       Int      @default(0)
  earnedAvailableCredits     Int      @default(0)
  heldCredits                Int      @default(0)
  availableBalanceCents      Int      @default(0)
  heldBalanceCents           Int      @default(0)
  pendingPayoutCents         Int      @default(0)
  currency                   String   @default("eur")
  createdAt                  DateTime @default(now())
  updatedAt                  DateTime @updatedAt

  user    User @relation(fields: [userId], references: [id], onDelete: Cascade)
  entries CreditLedgerEntry[]
}

model CreditLedgerEntry {
  id          String            @id @default(cuid())
  userId      String
  walletId    String
  tradeId     String?
  type        LedgerEntryType
  balanceType LedgerBalanceType
  amount      Int
  amountCents Int               @default(0)
  currency    String            @default("eur")
  description String?
  metadata    Json?
  createdAt   DateTime          @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  wallet Wallet @relation(fields: [walletId], references: [id], onDelete: Cascade)
  trade  Trade? @relation(fields: [tradeId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([walletId, createdAt])
  @@index([tradeId])
}

model TradePayment {
  id             String             @id @default(cuid())
  tradeId        String             @unique
  buyerId        String
  sellerId       String?
  creditAmount   Int                @default(0)
  amountCents    Int                @default(0)
  currency       String             @default("eur")
  platformFee    Int                @default(0)
  platformFeeCents Int              @default(0)
  status         TradePaymentStatus @default(draft)
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  trade Trade @relation(fields: [tradeId], references: [id], onDelete: Cascade)
}

model TradeEscrow {
  id              String   @id @default(cuid())
  tradeId         String   @unique
  heldCredits     Int      @default(0)
  heldAmountCents Int      @default(0)
  currency        String   @default("eur")
  holdReleasedAt  DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  trade Trade @relation(fields: [tradeId], references: [id], onDelete: Cascade)
}

model PayoutRequest {
  id          String              @id @default(cuid())
  userId      String
  amount      Int
  amountCents Int                 @default(0)
  currency    String              @default("eur")
  status      PayoutRequestStatus @default(draft)
  requestedAt DateTime            @default(now())
  reviewedAt  DateTime?
  paidAt      DateTime?
  notes       String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
}
