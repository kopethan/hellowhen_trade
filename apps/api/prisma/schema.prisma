generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  user
  admin
}

enum UserTrustTier {
  new
  email_verified
  stripe_verified
  trusted
  restricted
}

enum AuthIdentityProvider {
  email
  google
}

enum NeedStatus {
  draft
  active
  fulfilled
  closed
  expired
}

enum OfferStatus {
  draft
  active
  accepted
  closed
  expired
}

enum TradeExchangeMode {
  remote
  local
  hybrid
}

enum InventoryItemType {
  service
  goods
  other
}

enum InventoryTemplateKind {
  need
  offer
}

enum InventoryTemplateSourceType {
  hellowhen
  business
  brand
  partner
}

enum InventoryTemplateStatus {
  draft
  active
  archived
}

enum TradePostType {
  need_offer
  open_need
  open_offer
}

enum TradeStatus {
  draft
  active
  funded
  in_progress
  submitted
  completed
  disputed
  expired
  closed
  cancelled
}

enum ProposalStatus {
  pending
  accepted
  declined
  withdrawn
}

enum MediaEntityType {
  need
  offer
  trade
  inventory_template
  profile
  support_ticket
  support_message
  plan
  plan_place
}

enum MediaAssetStatus {
  active
  flagged
  removed
  pending_review
}

enum CreditPurchaseStatus {
  pending
  paid
  failed
  expired
}

enum SupportTicketCategory {
  general_feedback
  trade_issue
  credits_issue
  media_issue
  bug_report
  account_issue
  account_recovery
  safety_concern
}

enum SupportTicketStatus {
  open
  in_review
  waiting_for_user
  resolved
  closed
}

enum SupportTicketPriority {
  low
  normal
  high
  urgent
}

enum SupportMessageSenderRole {
  user
  admin
  system
}

enum LedgerEntryType {
  starting_demo_credits
  test_credit_grant
  credit_purchase
  trade_hold
  trade_release
  trade_refund
  earned_pending
  platform_fee
  platform_fee_placeholder
  payout_requested
  payout_paid
  adjustment
}

enum LedgerBalanceType {
  purchased
  earned_pending
  earned_available
  held
}

enum TradePaymentStatus {
  draft
  authorized
  held
  released
  refunded
  failed
  cancelled
}

enum PayoutRequestStatus {
  draft
  requested
  approved
  paid
  rejected
  cancelled
}

enum StripeConnectAccountStatus {
  not_started
  onboarding
  restricted
  pending
  enabled
  disabled
}

enum StripeEventProcessingStatus {
  received
  processed
  failed
}

enum MoneyProviderName {
  none
  stripe
  airwallex
}

enum MoneyProviderAccountType {
  individual
  business
  brand
}

enum MoneyProviderAccountStatus {
  not_started
  onboarding
  pending
  active
  restricted
  disabled
  rejected
}

enum BusinessProfileType {
  business
  agency
  brand
  enterprise
}

enum BusinessProfileStatus {
  draft
  active
  pending_review
  verified
  restricted
  disabled
  rejected
}

enum BusinessProfileMemberRole {
  owner
  admin
  finance
  member
}

enum MoneyProviderTransactionType {
  payin
  internal_transfer
  trade_hold
  trade_release
  platform_fee
  payout
  refund
  reversal
  dispute_hold
}

enum MoneyProviderTransactionStatus {
  pending
  succeeded
  failed
  canceled
  reversed
}

enum MoneyProviderEventProcessingStatus {
  received
  processed
  ignored
  failed
}

enum ReportTargetType {
  user
  profile
  trade
  need
  offer
  proposal
  message
  media
  plan
  plan_place
}

enum ReportReason {
  spam
  scam
  harassment
  illegal_unsafe
  fake_profile
  inappropriate_image
  other
}

enum ReportStatus {
  pending
  reviewing
  resolved
  dismissed
}

enum AccountDeletionRequestStatus {
  requested
  in_review
  completed
  cancelled
  rejected
}

enum PlanStatus {
  draft
  open
  full
  started
  completed
  cancelled
  expired
  hidden
}

enum PlanJoinApprovalMode {
  owner_approval
  automatic
}

enum PlanParticipantStatus {
  pending
  accepted
  declined
  cancelled
  left
  removed
}

enum PlanPlaceMode {
  local
  remote
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash    String?
  role            UserRole  @default(user)
  trustTier       UserTrustTier @default(new)
  trustTierUpdatedAt DateTime?
  trustTierNote   String?
  emailVerifiedAt DateTime?
  emailVerificationRequestedAt DateTime?
  twoFactorEnabled Boolean @default(false)
  twoFactorSecretEncrypted String?
  twoFactorConfirmedAt DateTime?
  twoFactorRecoveryCodes Json?
  twoFactorLastUsedStep Int?
  forceTwoFactor Boolean @default(false)
  sensitiveActionVerifiedAt DateTime?
  sessionRevokedAt DateTime?
  lastLoginAt     DateTime?
  termsAcceptedAt DateTime?
  termsVersion    String?
  privacyVersion  String?
  ageConfirmedAt  DateTime?
  declaredAgeBucket String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  profile      Profile?
  settings     UserSettings?
  sessions     Session[]
  identities    UserIdentity[]
  passwordResetTokens PasswordResetToken[]
  emailVerificationTokens EmailVerificationToken[]
  twoFactorChallenges TwoFactorChallenge[]
  needs        Need[]
  offers       Offer[]
  trades       Trade[] @relation("OwnedTrades")
  providerTrades Trade[] @relation("ProvidedTrades")
  tradeProposals TradeProposal[] @relation("ApplicantProposals")
  proposalMessages ProposalMessage[] @relation("SentProposalMessages")
  mediaAssets  MediaAsset[] @relation("OwnedMediaAssets")
  reviewedMediaAssets MediaAsset[] @relation("ReviewedMediaAssets")
  creditPurchases CreditPurchase[]
  supportTickets SupportTicket[] @relation("OwnedSupportTickets")
  assignedSupportTickets SupportTicket[] @relation("AssignedSupportTickets")
  supportMessages SupportTicketMessage[] @relation("SentSupportMessages")
  wallet       Wallet?
  ledger       CreditLedgerEntry[]
  payoutRequests PayoutRequest[]
  reviewedPayoutEvents AdminPayoutEvent[] @relation("ReviewedPayoutEvents")
  stripeConnectAccount StripeConnectAccount?
  moneyProviderAccounts MoneyProviderAccount[]
  ownedBusinessProfiles BusinessProfile[] @relation("OwnedBusinessProfiles")
  businessProfileMemberships BusinessProfileMember[] @relation("BusinessProfileMemberships")
  reviewedBusinessProfiles BusinessProfile[] @relation("ReviewedBusinessProfiles")
  moneyProviderTransactions MoneyProviderTransaction[]
  moneyPolicyAcknowledgements MoneyPolicyAcknowledgement[]
  adminAuditLogs AdminAuditLog[] @relation("AdminAuditLogs")
  reportsMade Report[] @relation("UserReportsMade")
  reviewedReports Report[] @relation("ReviewedReports")
  accountDeletionRequests AccountDeletionRequest[]
  blocksCreated UserBlock[] @relation("UserBlocksCreated")
  blocksReceived UserBlock[] @relation("UserBlocksReceived")
  plans       Plan[] @relation("OwnedPlans")
  planParticipants PlanParticipant[] @relation("PlanParticipants")
  decidedPlanParticipants PlanParticipant[] @relation("PlanParticipantDecisions")
  usageHeartbeats UsageHeartbeat[]
  apiRequestMetrics ApiRequestMetric[]
}




model UsageHeartbeat {
  id           String   @id @default(cuid())
  userId       String?
  sessionId    String?
  clientId     String?  @unique
  appArea      String
  routePattern String
  lastSeenAt   DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([lastSeenAt])
  @@index([appArea, lastSeenAt])
  @@index([userId, lastSeenAt])
  @@index([sessionId, lastSeenAt])
}


model ApiRequestMetric {
  id           String   @id @default(cuid())
  userId       String?
  sessionId    String?
  method       String
  routePattern String
  appArea      String
  statusCode   Int
  statusGroup  String
  durationMs   Int
  createdAt    DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([appArea, createdAt])
  @@index([routePattern, createdAt])
  @@index([statusGroup, createdAt])
  @@index([userId, createdAt])
  @@index([sessionId, createdAt])
}

model UserIdentity {
  id             String               @id @default(cuid())
  userId         String
  provider       AuthIdentityProvider
  providerUserId String
  email          String?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerUserId])
  @@index([userId, provider])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
  @@index([expiresAt])
}

model EmailVerificationToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
  @@index([expiresAt])
}

model TwoFactorChallenge {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
  @@index([expiresAt])
}

model Session {
  id           String   @id @default(cuid())
  userId       String
  refreshToken String   @unique
  userAgent    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  expiresAt    DateTime
  revokedAt    DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@index([revokedAt])
}

model Profile {
  id          String   @id @default(cuid())
  userId      String   @unique
  displayName String?
  handle      String?  @unique
  bio         String?
  avatarUrl   String?
  avatarMediaId String?
  countryCode String?
  preferredCurrency String? @default("eur")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([avatarMediaId])
}

model UserSettings {
  id                   String   @id @default(cuid())
  userId               String   @unique
  appearance            String   @default("system")
  accent                String   @default("teal")
  language              String   @default("system")
  notificationsEnabled  Boolean  @default(true)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Need {
  id            String             @id @default(cuid())
  ownerId       String
  businessProfileId String?
  sourceTemplateId String?
  title         String
  description   String
  itemType      InventoryItemType @default(service)
  category      String?
  timing        String?
  mode          TradeExchangeMode?
  locationLabel String?
  tags          String[]           @default([])
  status        NeedStatus         @default(draft)
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  expiresAt     DateTime?

  owner  User    @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  businessProfile BusinessProfile? @relation(fields: [businessProfileId], references: [id], onDelete: SetNull)
  sourceTemplate InventoryTemplate? @relation("NeedSourceTemplate", fields: [sourceTemplateId], references: [id], onDelete: SetNull)
  trades Trade[]
  proposedInTradeProposals TradeProposal[] @relation("ProposalNeed")

  @@index([ownerId, status])
  @@index([businessProfileId, status])
  @@index([sourceTemplateId])
  @@index([category])
  @@index([itemType])
  @@index([mode])
}

model Offer {
  id            String             @id @default(cuid())
  ownerId       String
  businessProfileId String?
  sourceTemplateId String?
  title         String
  description   String
  itemType      InventoryItemType @default(service)
  category      String?
  availability  String?
  mode          TradeExchangeMode?
  locationLabel String?
  includes      String[]           @default([])
  tags          String[]           @default([])
  status        OfferStatus        @default(draft)
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  expiresAt     DateTime?

  owner  User    @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  businessProfile BusinessProfile? @relation(fields: [businessProfileId], references: [id], onDelete: SetNull)
  sourceTemplate InventoryTemplate? @relation("OfferSourceTemplate", fields: [sourceTemplateId], references: [id], onDelete: SetNull)
  trades Trade[]
  proposedInTradeProposals TradeProposal[] @relation("ProposalOffer")

  @@index([ownerId, status])
  @@index([businessProfileId, status])
  @@index([sourceTemplateId])
  @@index([category])
  @@index([itemType])
  @@index([mode])
}

model InventoryTemplate {
  id                String                      @id @default(cuid())
  key               String                      @unique
  kind              InventoryTemplateKind
  sourceType        InventoryTemplateSourceType @default(hellowhen)
  businessProfileId String?
  languageCode      String                      @default("en")
  countryCode       String?
  title             String
  description       String
  itemType          InventoryItemType           @default(service)
  category          String?
  timing            String?
  availability      String?
  mode              TradeExchangeMode?
  locationLabel     String?
  tags              String[]                    @default([])
  includes          String[]                    @default([])
  status            InventoryTemplateStatus     @default(active)
  sortOrder         Int                         @default(0)
  createdAt         DateTime                    @default(now())
  updatedAt         DateTime                    @updatedAt

  businessProfile   BusinessProfile?            @relation(fields: [businessProfileId], references: [id], onDelete: SetNull)
  createdNeeds      Need[]                      @relation("NeedSourceTemplate")
  createdOffers     Offer[]                     @relation("OfferSourceTemplate")

  @@index([kind, status, itemType, sortOrder])
  @@index([sourceType, status])
  @@index([businessProfileId, status])
  @@index([languageCode, status, sortOrder])
  @@index([countryCode, status])
  @@index([category])
}

model Trade {
  id           String      @id @default(cuid())
  ownerId      String
  businessProfileId String?
  providerId   String?
  needId       String?
  offerId      String?
  title        String
  description  String
  creditAmount Int         @default(0)
  amountCents  Int         @default(0)
  currency     String      @default("eur")
  postType     TradePostType @default(need_offer)
  status       TradeStatus @default(draft)
  isPublic     Boolean     @default(false)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  expiresAt    DateTime?
  closedAt     DateTime?
  cancelledByUserId    String?
  cancelledAt          DateTime?
  cancelReason         String?
  deliverySubmittedById String?
  deliverySubmittedAt   DateTime?
  confirmedById         String?
  confirmedAt           DateTime?
  disputedById          String?
  disputedAt            DateTime?
  disputeTicketId       String?

  owner    User      @relation("OwnedTrades", fields: [ownerId], references: [id], onDelete: Cascade)
  businessProfile BusinessProfile? @relation(fields: [businessProfileId], references: [id], onDelete: SetNull)
  provider User?     @relation("ProvidedTrades", fields: [providerId], references: [id], onDelete: SetNull)
  need     Need?     @relation(fields: [needId], references: [id], onDelete: SetNull)
  offer    Offer?    @relation(fields: [offerId], references: [id], onDelete: SetNull)
  payment  TradePayment?
  escrow   TradeEscrow?
  proposals TradeProposal[]
  ledgerEntries CreditLedgerEntry[]

  @@index([status, isPublic, createdAt])
  @@index([postType, status, isPublic, createdAt])
  @@index([ownerId, status])
  @@index([businessProfileId, status])
  @@index([providerId, status])
  @@index([needId])
  @@index([offerId])
  @@index([disputedAt])
  @@index([cancelledAt])
  @@index([disputeTicketId])
}

model TradeProposal {
  id              String         @id @default(cuid())
  tradeId         String
  applicantId     String
  proposedNeedId  String?
  proposedOfferId String?
  message         String
  messageEditedAt DateTime?
  messageEditCount Int           @default(0)
  messageDeletedAt DateTime?
  status          ProposalStatus @default(pending)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  respondedAt     DateTime?

  trade         Trade             @relation(fields: [tradeId], references: [id], onDelete: Cascade)
  applicant     User              @relation("ApplicantProposals", fields: [applicantId], references: [id], onDelete: Cascade)
  proposedNeed  Need?             @relation("ProposalNeed", fields: [proposedNeedId], references: [id], onDelete: SetNull)
  proposedOffer Offer?            @relation("ProposalOffer", fields: [proposedOfferId], references: [id], onDelete: SetNull)
  messages      ProposalMessage[]

  @@index([tradeId, applicantId, status])
  @@index([tradeId, status])
  @@index([applicantId, status])
  @@index([proposedNeedId])
  @@index([proposedOfferId])
}

model ProposalMessage {
  id         String   @id @default(cuid())
  proposalId String
  senderId   String
  body       String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  editedAt   DateTime?
  editCount  Int      @default(0)
  deletedAt  DateTime?

  proposal TradeProposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)
  sender   User          @relation("SentProposalMessages", fields: [senderId], references: [id], onDelete: Cascade)

  @@index([proposalId, createdAt])
  @@index([senderId, createdAt])
}

model MediaAsset {
  id          String           @id @default(cuid())
  ownerId     String
  entityType  MediaEntityType?
  entityId    String?
  url         String
  storageKey  String
  filename    String
  mimeType    String
  sizeBytes   Int
  status      MediaAssetStatus @default(active)
  reviewNote  String?
  reviewedAt  DateTime?
  reviewerId  String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  owner    User  @relation("OwnedMediaAssets", fields: [ownerId], references: [id], onDelete: Cascade)
  reviewer User? @relation("ReviewedMediaAssets", fields: [reviewerId], references: [id], onDelete: SetNull)

  @@index([ownerId, createdAt])
  @@index([entityType, entityId])
  @@index([status, createdAt])
}

model CreditPurchase {
  id                      String               @id @default(cuid())
  userId                  String
  stripeCheckoutSessionId String?              @unique
  stripePaymentIntentId   String?
  creditAmount            Int
  amountCents             Int
  currency                String               @default("eur")
  status                  CreditPurchaseStatus @default(pending)
  checkoutUrl             String?
  createdAt               DateTime             @default(now())
  updatedAt               DateTime             @updatedAt
  paidAt                  DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([status, createdAt])
}

model SupportTicket {
  id                String                @id @default(cuid())
  userId            String?
  category          SupportTicketCategory
  subject           String
  message           String
  status            SupportTicketStatus   @default(open)
  priority          SupportTicketPriority @default(normal)
  relatedTradeId    String?
  relatedProposalId String?
  relatedMediaId    String?
  assignedAdminId   String?
  guestEmail        String?
  guestAccountEmail String?
  guestName         String?
  guestUserAgent    String?
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt
  resolvedAt        DateTime?

  user          User?                  @relation("OwnedSupportTickets", fields: [userId], references: [id], onDelete: Cascade)
  assignedAdmin User?                  @relation("AssignedSupportTickets", fields: [assignedAdminId], references: [id], onDelete: SetNull)
  messages      SupportTicketMessage[]

  @@index([userId, status, createdAt])
  @@index([status, priority, createdAt])
  @@index([category, status])
  @@index([assignedAdminId, status])
  @@index([guestEmail, status, createdAt])
  @@index([guestAccountEmail, status, createdAt])
}

model SupportTicketMessage {
  id         String                   @id @default(cuid())
  ticketId   String
  senderId   String?
  senderRole SupportMessageSenderRole @default(user)
  body       String
  internal   Boolean                  @default(false)
  createdAt  DateTime                 @default(now())

  ticket SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  sender User?         @relation("SentSupportMessages", fields: [senderId], references: [id], onDelete: Cascade)

  @@index([ticketId, createdAt])
  @@index([senderId, createdAt])
}

model Wallet {
  id                         String   @id @default(cuid())
  userId                     String   @unique
  purchasedAvailableCredits  Int      @default(0)
  earnedPendingCredits       Int      @default(0)
  earnedAvailableCredits     Int      @default(0)
  heldCredits                Int      @default(0)
  availableBalanceCents      Int      @default(0)
  heldBalanceCents           Int      @default(0)
  pendingPayoutCents         Int      @default(0)
  currency                   String   @default("eur")
  createdAt                  DateTime @default(now())
  updatedAt                  DateTime @updatedAt

  user    User @relation(fields: [userId], references: [id], onDelete: Cascade)
  entries CreditLedgerEntry[]
}

model CreditLedgerEntry {
  id          String            @id @default(cuid())
  userId      String
  walletId    String
  tradeId     String?
  type        LedgerEntryType
  balanceType LedgerBalanceType
  amount      Int
  amountCents Int               @default(0)
  currency    String            @default("eur")
  description String?
  metadata    Json?
  createdAt   DateTime          @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  wallet Wallet @relation(fields: [walletId], references: [id], onDelete: Cascade)
  trade  Trade? @relation(fields: [tradeId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([walletId, createdAt])
  @@index([tradeId])
}

model TradePayment {
  id             String             @id @default(cuid())
  tradeId        String             @unique
  buyerId        String
  sellerId       String?
  creditAmount   Int                @default(0)
  amountCents    Int                @default(0)
  currency       String             @default("eur")
  platformFee    Int                @default(0)
  platformFeeCents Int              @default(0)
  status         TradePaymentStatus @default(draft)
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  trade Trade @relation(fields: [tradeId], references: [id], onDelete: Cascade)
}

model TradeEscrow {
  id              String   @id @default(cuid())
  tradeId         String   @unique
  heldCredits     Int      @default(0)
  heldAmountCents Int      @default(0)
  currency        String   @default("eur")
  holdReleasedAt  DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  trade Trade @relation(fields: [tradeId], references: [id], onDelete: Cascade)
}

model PayoutRequest {
  id                 String              @id @default(cuid())
  userId             String
  amount             Int
  amountCents        Int                 @default(0)
  grossAmountCents   Int                 @default(0)
  platformFeeCents   Int                 @default(0)
  netAmountCents     Int                 @default(0)
  platformFeeRateBps Int                 @default(1000)
  currency           String              @default("eur")
  status             PayoutRequestStatus @default(draft)
  requestedAt DateTime            @default(now())
  reviewedAt  DateTime?
  paidAt      DateTime?
  notes       String?
  stripeConnectAccountId String?
  stripeTransferId String?
  stripePayoutId String?
  stripeEventId String?
  stripeFailureCode String?
  stripeFailureMessage String?
  stripeExternalStatus String?
  provider              MoneyProviderName?
  providerAccountId     String?
  providerTransferId    String?
  providerPayoutId      String?
  providerEventId       String?
  providerFailureCode   String?
  providerFailureMessage String?
  providerExternalStatus String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  stripeConnectAccount StripeConnectAccount? @relation(fields: [stripeConnectAccountId], references: [id], onDelete: SetNull)
  providerAccount MoneyProviderAccount? @relation(fields: [providerAccountId], references: [id], onDelete: SetNull)
  providerTransactions MoneyProviderTransaction[]
  adminEvents AdminPayoutEvent[]

  @@index([userId, status])
  @@index([stripeConnectAccountId, status])
  @@index([provider, status])
  @@index([providerAccountId, status])
  @@index([providerTransferId])
  @@index([providerPayoutId])
  @@index([stripeTransferId])
  @@index([stripePayoutId])
}

model AdminPayoutEvent {
  id              String              @id @default(cuid())
  payoutRequestId String
  adminId         String
  action          String
  note            String?
  previousStatus  PayoutRequestStatus?
  nextStatus      PayoutRequestStatus?
  metadata        Json?
  createdAt       DateTime            @default(now())

  payoutRequest PayoutRequest @relation(fields: [payoutRequestId], references: [id], onDelete: Cascade)
  admin         User          @relation("ReviewedPayoutEvents", fields: [adminId], references: [id], onDelete: Cascade)

  @@index([payoutRequestId, createdAt])
  @@index([adminId, createdAt])
  @@index([action, createdAt])
}


model BusinessProfile {
  id                    String                @id @default(cuid())
  ownerId               String
  type                  BusinessProfileType   @default(business)
  status                BusinessProfileStatus @default(active)
  displayName           String
  legalName             String?
  handle                String?               @unique
  description           String?
  websiteUrl            String?
  countryCode           String?
  preferredCurrency     String                @default("eur")
  verificationProvider  MoneyProviderName?
  verificationProviderStatus MoneyProviderAccountStatus?
  verifiedAt            DateTime?
  reviewedAt            DateTime?
  reviewerId            String?
  reviewNote            String?
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt

  owner                 User                  @relation("OwnedBusinessProfiles", fields: [ownerId], references: [id], onDelete: Cascade)
  reviewer              User?                 @relation("ReviewedBusinessProfiles", fields: [reviewerId], references: [id], onDelete: SetNull)
  members               BusinessProfileMember[]
  moneyProviderAccounts MoneyProviderAccount[]
  needs                 Need[]
  offers                Offer[]
  trades                Trade[]
  inventoryTemplates    InventoryTemplate[]

  @@index([ownerId, status])
  @@index([type, status])
  @@index([countryCode])
  @@index([verificationProvider, verificationProviderStatus])
}

model BusinessProfileMember {
  id                String                    @id @default(cuid())
  businessProfileId String
  userId            String
  role              BusinessProfileMemberRole @default(member)
  createdAt         DateTime                  @default(now())
  updatedAt         DateTime                  @updatedAt

  businessProfile   BusinessProfile           @relation(fields: [businessProfileId], references: [id], onDelete: Cascade)
  user              User                      @relation("BusinessProfileMemberships", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([businessProfileId, userId])
  @@index([userId, role])
  @@index([businessProfileId, role])
}

model MoneyPolicyAcknowledgement {
  id                   String   @id @default(cuid())
  userId               String
  policyVersion        String
  walletTermsVersion   String
  payoutTermsVersion   String
  refundPolicyVersion  String
  disputePolicyVersion String
  launchMode           String
  ipAddress            String?
  userAgent            String?
  acknowledgedAt       DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, policyVersion])
  @@index([userId, acknowledgedAt])
  @@index([policyVersion, acknowledgedAt])
}

model StripeConnectAccount {
  id                       String                     @id @default(cuid())
  userId                   String                     @unique
  stripeAccountId           String                     @unique
  status                   StripeConnectAccountStatus @default(onboarding)
  chargesEnabled            Boolean                    @default(false)
  payoutsEnabled            Boolean                    @default(false)
  detailsSubmitted          Boolean                    @default(false)
  currentlyDue              String[]                   @default([])
  eventuallyDue             String[]                   @default([])
  pastDue                   String[]                   @default([])
  disabledReason            String?
  defaultCurrency           String?
  country                   String?
  onboardingStartedAt       DateTime?
  onboardingCompletedAt     DateTime?
  lastSyncedAt              DateTime?
  lastWebhookEventAt        DateTime?
  createdAt                 DateTime                   @default(now())
  updatedAt                 DateTime                   @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  payoutRequests PayoutRequest[]

  @@index([status, updatedAt])
  @@index([payoutsEnabled, status])
}

model StripeEvent {
  id                     String                      @id @default(cuid())
  stripeEventId          String                      @unique
  type                   String
  livemode               Boolean                     @default(false)
  stripeAccountId        String?
  stripeConnectAccountId String?
  objectId               String?
  processingStatus       StripeEventProcessingStatus @default(received)
  payload                Json?
  error                  String?
  processedAt            DateTime?
  createdAt              DateTime                    @default(now())

  @@index([type, createdAt])
  @@index([stripeAccountId, createdAt])
  @@index([stripeConnectAccountId, createdAt])
}


model MoneyProviderAccount {
  id                    String                     @id @default(cuid())
  userId                String
  businessProfileId     String?
  provider              MoneyProviderName
  providerAccountId     String
  accountType           MoneyProviderAccountType   @default(individual)
  status                MoneyProviderAccountStatus @default(onboarding)
  country               String?
  defaultCurrency       String?
  capabilities          Json?
  requirements          Json?
  rawProviderStatus     Json?
  lastSyncedAt          DateTime?
  createdAt             DateTime                   @default(now())
  updatedAt             DateTime                   @updatedAt

  user                  User                       @relation(fields: [userId], references: [id], onDelete: Cascade)
  businessProfile       BusinessProfile?           @relation(fields: [businessProfileId], references: [id], onDelete: SetNull)
  balances              MoneyProviderWalletBalance[]
  transactions          MoneyProviderTransaction[] @relation("ProviderAccountTransactions")
  counterpartyTransactions MoneyProviderTransaction[] @relation("ProviderCounterpartyTransactions")
  payoutRequests        PayoutRequest[]

  @@unique([provider, providerAccountId])
  @@index([userId, provider])
  @@index([businessProfileId, provider])
  @@index([provider, status, updatedAt])
}

model MoneyProviderWalletBalance {
  id                    String              @id @default(cuid())
  moneyProviderAccountId String
  provider              MoneyProviderName
  currency              String
  availableCents        Int                 @default(0)
  reservedCents         Int                 @default(0)
  pendingCents          Int                 @default(0)
  externalUpdatedAt     DateTime?
  lastSyncedAt          DateTime?
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt

  account               MoneyProviderAccount @relation(fields: [moneyProviderAccountId], references: [id], onDelete: Cascade)

  @@unique([moneyProviderAccountId, currency])
  @@index([provider, currency])
  @@index([lastSyncedAt])
}

model MoneyProviderTransaction {
  id                         String                         @id @default(cuid())
  userId                     String?
  tradeId                    String?
  payoutRequestId            String?
  provider                   MoneyProviderName
  providerTransactionId      String
  type                       MoneyProviderTransactionType
  status                     MoneyProviderTransactionStatus @default(pending)
  amountCents                Int
  currency                   String                         @default("eur")
  moneyProviderAccountId     String?
  counterpartyProviderAccountId String?
  rawProviderStatus          Json?
  createdAt                  DateTime                       @default(now())
  updatedAt                  DateTime                       @updatedAt

  user                       User?                          @relation(fields: [userId], references: [id], onDelete: SetNull)
  payoutRequest              PayoutRequest?                 @relation(fields: [payoutRequestId], references: [id], onDelete: SetNull)
  account                    MoneyProviderAccount?          @relation("ProviderAccountTransactions", fields: [moneyProviderAccountId], references: [id], onDelete: SetNull)
  counterpartyAccount        MoneyProviderAccount?          @relation("ProviderCounterpartyTransactions", fields: [counterpartyProviderAccountId], references: [id], onDelete: SetNull)

  @@unique([provider, providerTransactionId])
  @@index([userId, createdAt])
  @@index([tradeId, createdAt])
  @@index([payoutRequestId, createdAt])
  @@index([provider, type, status, createdAt])
}

model MoneyProviderEvent {
  id                    String                            @id @default(cuid())
  provider              MoneyProviderName
  providerEventId       String
  eventType             String
  providerAccountId     String?
  status                MoneyProviderEventProcessingStatus @default(received)
  payload               Json?
  error                 String?
  processedAt           DateTime?
  createdAt             DateTime                          @default(now())

  @@unique([provider, providerEventId])
  @@index([provider, eventType, createdAt])
  @@index([providerAccountId, createdAt])
  @@index([status, createdAt])
}


model AccountDeletionRequest {
  id              String                       @id @default(cuid())
  userId          String
  status          AccountDeletionRequestStatus @default(requested)
  reason          String?
  details         String?
  supportTicketId String?
  requestedAt     DateTime                     @default(now())
  reviewedAt      DateTime?
  completedAt     DateTime?
  cancelledAt     DateTime?
  createdAt       DateTime                     @default(now())
  updatedAt       DateTime                     @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status, createdAt])
  @@index([status, createdAt])
  @@index([supportTicketId])
}

model UserBlock {
  id        String   @id @default(cuid())
  blockerId String
  blockedId String
  reason    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  blocker User @relation("UserBlocksCreated", fields: [blockerId], references: [id], onDelete: Cascade)
  blocked User @relation("UserBlocksReceived", fields: [blockedId], references: [id], onDelete: Cascade)

  @@unique([blockerId, blockedId])
  @@index([blockerId, createdAt])
  @@index([blockedId, createdAt])
}


model Plan {
  id               String               @id @default(cuid())
  ownerId          String
  title            String
  description      String
  category         String?
  tags             String[]             @default([])
  mode             TradeExchangeMode?
  locationLabel    String?
  startsAt         DateTime
  endsAt           DateTime?
  maxParticipants  Int?
  joinApprovalMode PlanJoinApprovalMode @default(owner_approval)
  status           PlanStatus           @default(draft)
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  cancelledAt      DateTime?

  owner        User              @relation("OwnedPlans", fields: [ownerId], references: [id], onDelete: Cascade)
  places       PlanPlace[]
  participants PlanParticipant[]

  @@index([status, startsAt])
  @@index([ownerId, status, startsAt])
  @@index([category])
  @@index([mode])
}

model PlanPlace {
  id                 String   @id @default(cuid())
  planId             String
  order              Int      @default(0)
  mode               PlanPlaceMode @default(local)
  title              String
  note               String?
  addressPublicText  String?
  addressPrivateText String?
  startsAt           DateTime?
  endsAt             DateTime?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  plan Plan @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@index([planId, order])
  @@index([mode])
  @@index([startsAt])
}

model PlanParticipant {
  id          String                @id @default(cuid())
  planId      String
  userId      String
  message     String?
  status      PlanParticipantStatus @default(pending)
  decidedAt   DateTime?
  decidedById String?
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt

  plan      Plan  @relation(fields: [planId], references: [id], onDelete: Cascade)
  user      User  @relation("PlanParticipants", fields: [userId], references: [id], onDelete: Cascade)
  decidedBy User? @relation("PlanParticipantDecisions", fields: [decidedById], references: [id], onDelete: SetNull)

  @@unique([planId, userId])
  @@index([userId, status, createdAt])
  @@index([planId, status, createdAt])
  @@index([decidedById, decidedAt])
}

model Report {
  id            String           @id @default(cuid())
  reporterId    String
  targetType    ReportTargetType
  targetId      String
  targetOwnerId String?
  reason        ReportReason
  details       String?
  status        ReportStatus     @default(pending)
  reviewedById  String?
  reviewedAt    DateTime?
  resolutionNote String?
  escalatedSupportTicketId String?
  escalatedAt   DateTime?
  escalatedById String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  reporter User @relation("UserReportsMade", fields: [reporterId], references: [id], onDelete: Cascade)
  reviewer User? @relation("ReviewedReports", fields: [reviewedById], references: [id], onDelete: SetNull)

  @@index([status, createdAt])
  @@index([targetType, targetId])
  @@index([targetOwnerId, status])
  @@index([reporterId, createdAt])
  @@index([reviewedById, reviewedAt])
  @@index([escalatedSupportTicketId])
  @@index([escalatedById, escalatedAt])
}

model AdminAuditLog {
  id            String   @id @default(cuid())
  adminId       String
  action        String
  targetType    String
  targetId      String?
  reason        String?
  previousValue Json?
  nextValue     Json?
  metadata      Json?
  createdAt     DateTime @default(now())

  admin User @relation("AdminAuditLogs", fields: [adminId], references: [id], onDelete: Cascade)

  @@index([adminId, createdAt])
  @@index([action, createdAt])
  @@index([targetType, targetId])
  @@index([createdAt])
}
