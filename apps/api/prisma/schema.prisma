model UsernameHistory {
  id            String   @id @default(cuid())
  profileId     String
  userId        String
  oldHandle     String?
  newHandle     String
  changedById   String?
  changedByRole String   @default("user")
  reason        String?
  releasedAt    DateTime?
  createdAt     DateTime @default(now())

  profile   Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  user      User    @relation("UsernameHistoryUser", fields: [userId], references: [id], onDelete: Cascade)
