model User {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash    String?
  role            UserRole  @default(user)
  trustTier       UserTrustTier @default(new)
  accountKind     AccountKind @default(individual)
  professionalStatus ProfessionalStatus @default(none)
  professionalStatusUpdatedAt DateTime?
  subscriptionTier SubscriptionTier @default(free)
  subscriptionStatus SubscriptionStatus @default(none)
  subscriptionStatusUpdatedAt DateTime?
  trustTierUpdatedAt DateTime?
  trustTierNote   String?
  emailVerifiedAt DateTime?
  emailVerificationRequestedAt DateTime?
  twoFactorEnabled Boolean @default(false)
  twoFactorSecretEncrypted String?
  twoFactorConfirmedAt DateTime?
  twoFactorRecoveryCodes Json?
  twoFactorLastUsedStep Int?
  forceTwoFactor Boolean @default(false)
  sensitiveActionVerifiedAt DateTime?
  sessionRevokedAt DateTime?
  lastLoginAt     DateTime?
  termsAcceptedAt DateTime?
  termsVersion    String?
  privacyVersion  String?
  ageConfirmedAt  DateTime?
  declaredAgeBucket String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  profile      Profile?
  settings     UserSettings?
  professionalProfile ProfessionalProfile?
  subscriptionState SubscriptionState?
  identityVerificationState IdentityVerificationState?
  sessions     Session[]
  identities    UserIdentity[]
  passwordResetTokens PasswordResetToken[]
  emailVerificationTokens EmailVerificationToken[]
  twoFactorChallenges TwoFactorChallenge[]
  needs        Need[]
  offers       Offer[]
  inventoryTranslations InventoryTranslation[]
  trades       Trade[] @relation("OwnedTrades")
  providerTrades Trade[] @relation("ProvidedTrades")
  tradeProposals TradeProposal[] @relation("ApplicantProposals")
  proposalMessages ProposalMessage[] @relation("SentProposalMessages")
  tradePublicMessages TradePublicMessage[] @relation("AuthoredTradePublicMessages")
  hiddenTradePublicMessages TradePublicMessage[] @relation("HiddenTradePublicMessages")
  mediaAssets  MediaAsset[] @relation("OwnedMediaAssets")
  reviewedMediaAssets MediaAsset[] @relation("ReviewedMediaAssets")
  creditPurchases CreditPurchase[]
  supportTickets SupportTicket[] @relation("OwnedSupportTickets")
  assignedSupportTickets SupportTicket[] @relation("AssignedSupportTickets")
  supportMessages SupportTicketMessage[] @relation("SentSupportMessages")
  wallet       Wallet?
  ledger       CreditLedgerEntry[]
  payoutRequests PayoutRequest[]
  reviewedPayoutEvents AdminPayoutEvent[] @relation("ReviewedPayoutEvents")
  stripeConnectAccount StripeConnectAccount?
  moneyProviderAccounts MoneyProviderAccount[]
  ownedBusinessProfiles BusinessProfile[] @relation("OwnedBusinessProfiles")
  businessProfileMemberships BusinessProfileMember[] @relation("BusinessProfileMemberships")
  businessProfileInvitationsSent BusinessProfileInvitation[] @relation("BusinessProfileInvitationsSent")
  businessProfileInvitationsAccepted BusinessProfileInvitation[] @relation("BusinessProfileInvitationsAccepted")
  businessProfileTeamAuditLogs BusinessProfileTeamAuditLog[] @relation("BusinessProfileTeamAuditLogs")
  businessProfileTeamAuditTargets BusinessProfileTeamAuditLog[] @relation("BusinessProfileTeamAuditTargets")
  reviewedBusinessProfiles BusinessProfile[] @relation("ReviewedBusinessProfiles")
  createdBusinessSponsoredPlacements BusinessSponsoredPlacement[] @relation("CreatedBusinessSponsoredPlacements")
  reviewedBusinessSponsoredPlacements BusinessSponsoredPlacement[] @relation("ReviewedBusinessSponsoredPlacements")
  createdBusinessCampaigns BusinessCampaign[] @relation("CreatedBusinessCampaigns")
  reviewedBusinessCampaigns BusinessCampaign[] @relation("ReviewedBusinessCampaigns")
  createdBusinessBudgets BusinessBudget[] @relation("CreatedBusinessBudgets")
  reviewedBusinessBudgets BusinessBudget[] @relation("ReviewedBusinessBudgets")
  createdBusinessBudgetLedgerEntries BusinessBudgetLedgerEntry[] @relation("CreatedBusinessBudgetLedgerEntries")
  businessCampaignApplications BusinessCampaignApplication[] @relation("BusinessCampaignApplications")
  reviewedBusinessCampaignApplications BusinessCampaignApplication[] @relation("ReviewedBusinessCampaignApplications")
  moneyProviderTransactions MoneyProviderTransaction[]
  moneyPolicyAcknowledgements MoneyPolicyAcknowledgement[]
  adminAuditLogs AdminAuditLog[] @relation("AdminAuditLogs")
  reviewedProfessionalProfiles ProfessionalProfile[] @relation("ReviewedProfessionalProfiles")
  reviewedIdentityVerificationStates IdentityVerificationState[] @relation("ReviewedIdentityVerificationStates")
  reportsMade Report[] @relation("UserReportsMade")
  reviewedReports Report[] @relation("ReviewedReports")
  accountDeletionRequests AccountDeletionRequest[]
  blocksCreated UserBlock[] @relation("UserBlocksCreated")
  blocksReceived UserBlock[] @relation("UserBlocksReceived")
  plans       Plan[] @relation("OwnedPlans")
  planParticipants PlanParticipant[] @relation("PlanParticipants")
  decidedPlanParticipants PlanParticipant[] @relation("PlanParticipantDecisions")
  usageHeartbeats UsageHeartbeat[]
  apiRequestMetrics ApiRequestMetric[]
  inAppNotifications InAppNotification[]
  acceptedDealSnapshotsAsOwner AcceptedDealSnapshot[] @relation("AcceptedDealSnapshotOwner")
  acceptedDealSnapshotsAsApplicant AcceptedDealSnapshot[] @relation("AcceptedDealSnapshotApplicant")
  acknowledgedCashPromises CashPromise[] @relation("CashPromiseAcknowledgedBy")
  usernameHistory UsernameHistory[] @relation("UsernameHistoryUser")
  usernameChangesApproved UsernameHistory[] @relation("UsernameHistoryChangedBy")
  reviewedContentClassifications ContentClassification[] @relation("ReviewedContentClassifications")
  approvedContentPlacementSignals ContentPlacementSignal[] @relation("ApprovedContentPlacementSignals")
  aiAssistUsage AiAssistUsage[]
}

model AiAssistUsage {
  id              String                @id @default(cuid())
  userId          String
  periodKey       String
  taskType        AiAssistUsageTaskType
  status          AiAssistUsageStatus   @default(completed)
  planTierAtUse   SubscriptionTier      @default(free)
  quotaLimitAtUse Int
  inputHash       String?
  metadata        Json?
  errorCode       String?
  requestedAt     DateTime              @default(now())
  completedAt     DateTime?
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, periodKey, status])
  @@index([userId, taskType, requestedAt])
  @@index([periodKey, status, requestedAt])
  @@index([createdAt])
}





model InAppNotification {
  id              String                @id @default(cuid())
  userId          String
  type            InAppNotificationType
  title           String
  body            String
  targetPath      String?
  tradeId         String?
  proposalId      String?
  supportTicketId String?
  metadata        Json?
  readAt          DateTime?
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt, createdAt])
  @@index([userId, createdAt])
  @@index([type, createdAt])
  @@index([tradeId])
  @@index([proposalId])
  @@index([supportTicketId])
}

model UsageHeartbeat {
  id           String   @id @default(cuid())
  userId       String?
  sessionId    String?
  clientId     String?  @unique
  appArea      String
  routePattern String
  lastSeenAt   DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([lastSeenAt])
  @@index([appArea, lastSeenAt])
  @@index([userId, lastSeenAt])
  @@index([sessionId, lastSeenAt])
}


model ApiRequestMetric {
  id           String   @id @default(cuid())
  userId       String?
  sessionId    String?
  method       String
  routePattern String
  appArea      String
  statusCode   Int
  statusGroup  String
  durationMs   Int
  createdAt    DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([appArea, createdAt])
  @@index([routePattern, createdAt])
  @@index([statusGroup, createdAt])
  @@index([userId, createdAt])
  @@index([sessionId, createdAt])
}




model ContentClassification {
  id                 String                          @id @default(cuid())
  targetType         ContentClassificationTargetType
  targetId           String
  source             ContentClassificationSource     @default(rules)
  status             ContentClassificationStatus     @default(pending)
  userCategory       String?
  systemCategory     ContentDomainCategory?
  categoryConfidence Float?
  categoryMismatch   Boolean                         @default(false)
  suggestedTags      String[]                        @default([])
  suggestedNewTags   String[]                        @default([])
  safetyCategory     ContentSafetyCategory           @default(unknown)
  safetySeverity     ContentSafetySeverity           @default(none)
  adultRelated       Boolean                         @default(false)
  childSafe          Boolean                         @default(true)
  spamOrScamRisk     Boolean                         @default(false)
  regulatedRisk      Boolean                         @default(false)
  suggestedAction    ContentSuggestedAction           @default(allow)
  reason             String?
  reviewedById       String?
  reviewedAt         DateTime?
  adminNote          String?
  createdAt          DateTime                        @default(now())
  updatedAt          DateTime                        @updatedAt

  reviewedBy User? @relation("ReviewedContentClassifications", fields: [reviewedById], references: [id], onDelete: SetNull)
  placementSignals ContentPlacementSignal[]

  @@unique([targetType, targetId, source])
  @@index([targetType, targetId])
  @@index([status, updatedAt])
  @@index([safetyCategory, safetySeverity])
  @@index([systemCategory, categoryMismatch])
  @@index([suggestedAction, updatedAt])
  @@index([reviewedById, reviewedAt])
}

model ContentPlacementSignal {
  id                     String                         @id @default(cuid())
  targetType             ContentClassificationTargetType
  targetId               String
  source                 ContentClassificationSource    @default(admin)
  status                 ContentPlacementSignalStatus   @default(pending)
  sourceClassificationId String?
  category               ContentDomainCategory?
  tags                   String[]                       @default([])
  suggestedNewTags       String[]                       @default([])
  safetyCategory         ContentSafetyCategory          @default(unknown)
  safetySeverity         ContentSafetySeverity          @default(none)
  adultRelated           Boolean                        @default(false)
  childSafe              Boolean                        @default(true)
  spamOrScamRisk         Boolean                        @default(false)
  regulatedRisk          Boolean                        @default(false)
  contextualEligible     Boolean                        @default(false)
  businessPlacementEligible Boolean                     @default(false)
  adsPlacementEligible   Boolean                        @default(false)
  surfaces               String[]                       @default([])
  reason                 String?
  approvedById           String?
  approvedAt             DateTime?
  createdAt              DateTime                       @default(now())
  updatedAt              DateTime                       @updatedAt

  sourceClassification ContentClassification? @relation(fields: [sourceClassificationId], references: [id], onDelete: SetNull)
  approvedBy           User?                  @relation("ApprovedContentPlacementSignals", fields: [approvedById], references: [id], onDelete: SetNull)

  @@unique([targetType, targetId])
  @@index([status, updatedAt])
  @@index([category, status])
  @@index([contextualEligible, updatedAt])
  @@index([businessPlacementEligible, updatedAt])
  @@index([adsPlacementEligible, updatedAt])
  @@index([sourceClassificationId])
  @@index([approvedById, approvedAt])
}

model ProfessionalProfile {
  id                String             @id @default(cuid())
  userId            String             @unique
  displayName       String?
  headline          String?
  professionalBio   String?
  category          String?
  specialties       String[]           @default([])
  websiteUrl        String?
  portfolioUrl      String?
  countryCode       String?
  preferredCurrency String             @default("eur")
  status            ProfessionalStatus @default(none)
  statusNote        String?
  reviewedAt        DateTime?
  reviewedById      String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  user       User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  reviewedBy User? @relation("ReviewedProfessionalProfiles", fields: [reviewedById], references: [id], onDelete: SetNull)

  @@index([status, updatedAt])
  @@index([countryCode])
  @@index([category])
  @@index([reviewedById, reviewedAt])
}

model SubscriptionState {
  id                     String             @id @default(cuid())
  userId                 String             @unique
  tier                   SubscriptionTier   @default(free)
  status                 SubscriptionStatus @default(none)
  provider               String?
  externalCustomerId     String?
  externalSubscriptionId String?
  currentPeriodStartedAt DateTime?
  currentPeriodEndsAt    DateTime?
  trialStartedAt         DateTime?
  trialEndsAt            DateTime?
  canceledAt             DateTime?
  pastDueAt              DateTime?
  expiresAt              DateTime?
  lastSyncedAt           DateTime?
  adminNote              String?
  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tier, status])
  @@index([status, currentPeriodEndsAt])
  @@index([externalCustomerId])
  @@index([externalSubscriptionId])
}

model IdentityVerificationState {
