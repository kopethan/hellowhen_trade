{
  "name": "hellowhen",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:api": "npm run dev -w @hellowhen/api",
    "dev:web": "npm run dev -w @hellowhen/web",
    "dev:mobile": "npm run start -w @hellowhen/mobile",
    "build": "npm run build --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "prisma:generate": "npm run prisma:generate -w @hellowhen/api",
    "prisma:migrate": "npm run prisma:migrate -w @hellowhen/api",
    "prisma:validate": "npm run prisma:validate -w @hellowhen/api",
    "prisma:seed": "npm run prisma:seed -w @hellowhen/api"
  },
  "devDependencies": {
    "typescript": "^5.4.5"
  },
  "engines": {
    "node": ">=20"
  }
}
