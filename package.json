{
  "name": "hellowhen",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev:api": "npm run dev -w @hellowhen/api",
    "dev:web": "npm run dev -w @hellowhen/web",
    "dev:mobile": "npm run start -w @hellowhen/mobile",
    "stop:dev": "powershell -ExecutionPolicy Bypass -File scripts/stop-dev.ps1",
    "build": "npm run build:packages && npm run build:apps",
    "typecheck": "npm run prisma:generate && npm run build:packages && npm run typecheck --workspaces --if-present",
    "lint": "npm run typecheck",
    "prisma:generate": "prisma generate --schema apps/api/prisma/schema.prisma",
    "prisma:migrate": "prisma migrate dev --schema apps/api/prisma/schema.prisma",
    "prisma:validate": "prisma validate --schema apps/api/prisma/schema.prisma",
    "prisma:seed": "prisma db seed --schema apps/api/prisma/schema.prisma",
    "seed:plus-test-user": "tsx apps/api/prisma/seed-plus-test-user.ts",
    "admin:smoke": "node scripts/admin-launch-smoke.mjs",
    "admin:rehearsal": "node scripts/admin-launch-smoke.mjs",
    "plans:smoke": "node scripts/plans-hidden-smoke.mjs",
    "business:hidden-smoke": "node scripts/business-hidden-smoke.mjs",
    "mobile:launch-smoke": "node scripts/mobile-launch-smoke.mjs",
    "build:packages": "npm run build -w @hellowhen/contracts && npm run build -w @hellowhen/api-client && npm run build -w @hellowhen/i18n && npm run build -w @hellowhen/shared && npm run build -w @hellowhen/theme && npm run build -w @hellowhen/trade-domain && npm run build -w @hellowhen/ui",
    "build:apps": "npm run build -w @hellowhen/api && npm run build -w @hellowhen/web",
    "mobile:store-readiness": "npm run mobile:launch-smoke && node scripts/mobile-store-readiness.mjs && npm run cash-promise:safety-smoke",
    "cash-promise:safety-smoke": "node scripts/cash-promise-safety-smoke.mjs",
    "starter-library:qa": "node scripts/starter-library-qa.mjs",
    "places:smoke": "node scripts/place-library-hidden-smoke.mjs",
    "media:cdn-smoke": "node scripts/media-cdn-smoke.mjs",
    "language:audit": "node scripts/language-consistency-audit.mjs",
    "media:variants-smoke": "node scripts/media-variants-smoke.mjs",
    "media:s3-cleanup-smoke": "node scripts/media-s3-cleanup-smoke.mjs",
    "media:s3-migrate": "npm run media:s3-migrate -w @hellowhen/api --",
    "places:address-audit": "npm run places:address-cleanup -w @hellowhen/api -- --dry-run",
    "places:address-cleanup": "npm run places:address-cleanup -w @hellowhen/api --",
    "places:address-provider-smoke": "node scripts/place-address-provider-smoke.mjs",
    "plans:test": "npm run test:plans -w @hellowhen/api"
  },
  "devDependencies": {
    "typescript": "^5.4.5"
  },
  "engines": {
    "node": ">=20"
  },
  "prisma": {
    "seed": "tsx apps/api/prisma/seed.ts"
  }
}
