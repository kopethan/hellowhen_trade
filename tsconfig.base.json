{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true,
    "noUncheckedIndexedAccess": true,
    "baseUrl": ".",
    "paths": {
      "@hellowhen/contracts": ["packages/contracts/src"],
      "@hellowhen/api-client": ["packages/api-client/src"],
      "@hellowhen/shared": ["packages/shared/src"],
      "@hellowhen/theme": ["packages/theme/src"],
      "@hellowhen/trade-domain": ["packages/trade-domain/src"],
      "@hellowhen/ui": ["packages/ui/src"]
    }
  }
}
